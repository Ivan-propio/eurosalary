---
import { jobSlugsByLang, countrySlugsByLang, countryFlags } from '../data/slugs';
import { countryNames, jobNames, uiLabels } from '../i18n/translations';
import { fb, useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const t = useTranslations(lang as Lang);

const allCountriesLabel = fb(uiLabels.allCountries, lang);

// Build client data
const jobList = Object.entries(jobNames).map(([key, names]) => ({
  canonical: key,
  slug: (jobSlugsByLang[lang] || jobSlugsByLang.en)[key],
  name: fb(names, lang),
}));

const countryList = Object.entries(countryNames).map(([code, names]) => ({
  code,
  slug: (countrySlugsByLang[lang] || countrySlugsByLang.en)[code],
  name: fb(names, lang),
  flag: countryFlags[code],
}));

const popularSearches = [
  { job: 'software-engineer', country: 'DE' },
  { job: 'nurse', country: 'FR' },
  { job: 'financial-analyst', country: 'LU' },
  { job: 'teacher', country: 'ES' },
].map((s) => ({
  ...s,
  label: `${fb(jobNames[s.job], lang)} ${fb(countryNames[s.country], lang)}`,
}));

const searchConfig = JSON.stringify({ lang, jobs: jobList, countries: countryList });
---

<div class="search-widget" id="search-widget">
  <div class="hero__search">
    <div class="search-input-wrap">
      <input
        type="text"
        id="job-search"
        placeholder={t('home.searchPlaceholder')}
        autocomplete="off"
        role="combobox"
        aria-expanded="false"
        aria-controls="job-dropdown"
        aria-autocomplete="list"
      />
      <ul class="search-dropdown" id="job-dropdown" role="listbox" aria-label="Job suggestions"></ul>
    </div>
    <select id="country-select" aria-label={allCountriesLabel}>
      <option value="">{allCountriesLabel}</option>
      {countryList.sort((a, b) => a.name.localeCompare(b.name)).map((c) => (
        <option value={c.slug}>{c.flag} {c.name}</option>
      ))}
    </select>
    <button type="button" id="search-btn">{t('home.searchButton')}</button>
  </div>

  <div class="popular-searches">
    {popularSearches.map((s) => {
      const jobSlug = (jobSlugsByLang[lang] || jobSlugsByLang.en)[s.job];
      const countrySlug = (countrySlugsByLang[lang] || countrySlugsByLang.en)[s.country];
      return (
        <a href={`/${lang}/salary/${countrySlug}/${jobSlug}/`} class="popular-pill">
          {s.label}
        </a>
      );
    })}
  </div>
</div>

<script id="search-config" type="application/json" set:html={searchConfig} />

<script>
  const cfg = JSON.parse(document.getElementById('search-config')?.textContent || '{}');
  const input = document.getElementById('job-search') as HTMLInputElement;
  const dropdown = document.getElementById('job-dropdown') as HTMLUListElement;
  const countrySelect = document.getElementById('country-select') as HTMLSelectElement;
  const searchBtn = document.getElementById('search-btn') as HTMLButtonElement;

  let selectedJob = '';

  function showDropdown(matches: typeof cfg.jobs) {
    dropdown.innerHTML = '';
    if (matches.length === 0) {
      dropdown.style.display = 'none';
      input.setAttribute('aria-expanded', 'false');
      return;
    }
    matches.forEach((job: any) => {
      const li = document.createElement('li');
      li.role = 'option';
      li.textContent = job.name;
      li.dataset.slug = job.slug;
      li.addEventListener('click', () => {
        input.value = job.name;
        selectedJob = job.slug;
        dropdown.style.display = 'none';
        input.setAttribute('aria-expanded', 'false');
      });
      dropdown.appendChild(li);
    });
    dropdown.style.display = 'block';
    input.setAttribute('aria-expanded', 'true');
  }

  input?.addEventListener('input', () => {
    const q = input.value.toLowerCase().trim();
    if (q.length < 1) { dropdown.style.display = 'none'; return; }
    const matches = cfg.jobs.filter((j: any) => j.name.toLowerCase().includes(q));
    showDropdown(matches);
    selectedJob = matches.length === 1 ? matches[0].slug : '';
  });

  input?.addEventListener('focus', () => {
    if (input.value.length > 0) {
      const q = input.value.toLowerCase().trim();
      showDropdown(cfg.jobs.filter((j: any) => j.name.toLowerCase().includes(q)));
    }
  });

  document.addEventListener('click', (e) => {
    if (!(e.target as Element)?.closest('.search-input-wrap')) {
      dropdown.style.display = 'none';
      input?.setAttribute('aria-expanded', 'false');
    }
  });

  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      navigate();
    }
  });

  function navigate() {
    const q = input.value.toLowerCase().trim();
    if (!selectedJob) {
      const match = cfg.jobs.find((j: any) => j.name.toLowerCase() === q);
      if (match) selectedJob = match.slug;
    }
    const country = countrySelect.value;
    if (selectedJob && country) {
      window.location.href = `/${cfg.lang}/salary/${country}/${selectedJob}/`;
    } else if (selectedJob) {
      window.location.href = `/${cfg.lang}/compare/${selectedJob}/`;
    } else {
      window.location.href = `/${cfg.lang}/compare/`;
    }
  }

  searchBtn?.addEventListener('click', navigate);
</script>

<style>
  .search-widget {
    max-width: 640px;
    margin: 0 auto;
  }

  .hero__search {
    display: flex;
    background: var(--color-white);
    border-radius: var(--radius-lg);
    overflow: visible;
    box-shadow: var(--shadow-xl);
    position: relative;
  }

  .search-input-wrap {
    flex: 1;
    position: relative;
  }

  .search-input-wrap input {
    width: 100%;
    padding: var(--space-4) var(--space-6);
    border: none;
    font-size: var(--text-base);
    font-family: var(--font-sans);
    color: var(--color-navy-800);
    outline: none;
    border-radius: var(--radius-lg) 0 0 var(--radius-lg);
  }

  .search-input-wrap input::placeholder {
    color: var(--color-gray-400);
  }

  .search-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: white;
    border: 1px solid var(--color-gray-200);
    border-top: none;
    border-radius: 0 0 var(--radius-md) var(--radius-md);
    box-shadow: var(--shadow-lg);
    list-style: none;
    max-height: 240px;
    overflow-y: auto;
    z-index: 50;
  }

  .search-dropdown li {
    padding: var(--space-3) var(--space-4);
    cursor: pointer;
    font-size: var(--text-sm);
    color: var(--color-navy-800);
    transition: background 0.1s;
  }

  .search-dropdown li:hover {
    background: var(--color-gray-50);
    color: var(--color-blue-600);
  }

  #country-select {
    padding: var(--space-3) var(--space-4);
    border: none;
    border-left: 1px solid var(--color-gray-200);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-navy-800);
    background: white;
    cursor: pointer;
    min-width: 140px;
    outline: none;
  }

  #search-btn {
    padding: var(--space-4) var(--space-8);
    background: var(--color-blue-600);
    color: var(--color-white);
    border: none;
    font-weight: var(--weight-semibold);
    font-family: var(--font-sans);
    cursor: pointer;
    transition: background var(--transition-fast);
    white-space: nowrap;
    border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
  }

  #search-btn:hover {
    background: var(--color-blue-500);
  }

  .popular-searches {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .popular-pill {
    padding: var(--space-2) var(--space-4);
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: var(--radius-full);
    color: var(--color-gray-300);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    transition: all 0.15s;
    text-decoration: none;
  }

  .popular-pill:hover {
    background: rgba(255, 255, 255, 0.25);
    color: white;
  }

  @media (max-width: 768px) {
    .hero__search {
      flex-direction: column;
      border-radius: var(--radius-md);
    }

    .search-input-wrap input {
      border-radius: var(--radius-md) var(--radius-md) 0 0;
    }

    #country-select {
      border-left: none;
      border-top: 1px solid var(--color-gray-200);
    }

    #search-btn {
      border-radius: 0 0 var(--radius-md) var(--radius-md);
    }

    .search-dropdown {
      border-radius: 0;
    }
  }
</style>
