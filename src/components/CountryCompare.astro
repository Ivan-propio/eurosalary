---
import { getLangFromUrl, useTranslations, fb } from '../i18n/utils';
import { uiLabels } from '../i18n/translations';
import type { Lang } from '../i18n/ui';

interface CompareItem {
  countryName: string;
  countrySlug: string;
  countryCode: string;
  flag: string;
  medianSalary: number;
}

interface Props {
  jobName: string;
  jobSlug: string;
  items: CompareItem[];
}

const { jobName, jobSlug, items } = Astro.props;
const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);

function formatSalary(amount: number): string {
  return new Intl.NumberFormat(lang, {
    style: 'currency',
    currency: 'EUR',
    maximumFractionDigits: 0,
  }).format(amount);
}

const maxSalary = Math.max(...items.map((i) => i.medianSalary));

const sectionTitle = `${jobName} — ${fb(uiLabels.salaryComparison, lang)} ${fb(uiLabels.acrossEurope, lang)}`;
const subTitle = fb(uiLabels.medianCompByJurisdiction, lang);
const fullCompLabel = fb(uiLabels.fullComparison, lang);
---

<section class="compare-section">
  <div class="compare-section__header">
    <div>
      <h2>{sectionTitle}</h2>
      <p class="compare-section__sub">{subTitle}</p>
    </div>
    <a href={`/${lang}/compare/${jobSlug}/`} class="btn btn--outline btn--sm">
      <span class="material-symbols-outlined" style="font-size: 14px;">compare_arrows</span>
      {fullCompLabel}
    </a>
  </div>

  <div class="compare-list">
    {items.map((item, i) => {
      const barWidth = (item.medianSalary / maxSalary) * 100;
      return (
        <a href={`/${lang}/salary/${item.countrySlug}/${jobSlug}/`} class="compare-row">
          <div class="compare-row__rank">{String(i + 1).padStart(2, '0')}</div>
          <div class="compare-row__flag">{item.flag}</div>
          <div class="compare-row__name">{item.countryName}</div>
          <div class="compare-row__bar-area">
            <div class="compare-row__bar" style={`width: ${barWidth}%`}></div>
          </div>
          <div class="compare-row__salary">{formatSalary(item.medianSalary)}</div>
          <span class="compare-row__arrow material-symbols-outlined">chevron_right</span>
        </a>
      );
    })}
  </div>
</section>

<style>
  .compare-section {
    margin: var(--space-12) 0;
  }
  .compare-section__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-surface-high);
  }
  .compare-section__sub {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-on-surface-variant);
    margin-top: var(--space-1);
  }
  .compare-list {
    border: 1px solid var(--color-surface-high);
  }
  .compare-row {
    display: grid;
    grid-template-columns: 40px 36px 1fr 2fr auto 24px;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    background: var(--color-white);
    border-bottom: 1px solid var(--color-surface-high);
    text-decoration: none;
    color: inherit;
    transition: background var(--transition-fast);
  }
  .compare-row:last-child { border-bottom: none; }
  .compare-row:hover { background: var(--color-surface-low); }
  .compare-row__rank {
    font-family: var(--font-headline);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: var(--color-on-surface-variant);
    text-align: center;
  }
  .compare-row__flag {
    font-size: var(--text-xl);
  }
  .compare-row__name {
    font-family: var(--font-headline);
    font-weight: var(--weight-bold);
    color: var(--color-primary-container);
    font-size: var(--text-sm);
  }
  .compare-row__bar-area {
    height: 8px;
    background: var(--color-surface-high);
    border-radius: 4px;
    overflow: hidden;
  }
  .compare-row__bar {
    height: 100%;
    background: linear-gradient(90deg, var(--color-secondary), var(--color-blue-400));
    border-radius: 4px;
    transition: width var(--transition-slow);
  }
  .compare-row__salary {
    font-family: var(--font-headline);
    font-size: var(--text-lg);
    font-weight: var(--weight-extrabold);
    color: var(--color-primary-container);
    white-space: nowrap;
    text-align: right;
  }
  .compare-row__arrow {
    color: var(--color-on-surface-variant);
    font-size: 18px;
    opacity: 0;
    transition: opacity var(--transition-fast);
  }
  .compare-row:hover .compare-row__arrow {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .compare-section__header {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-4);
    }
    .compare-row {
      grid-template-columns: 28px 28px 1fr auto 20px;
      gap: var(--space-3);
      padding: var(--space-4);
    }
    .compare-row__bar-area { display: none; }
    .compare-row__salary { font-size: var(--text-base); }
  }
</style>
