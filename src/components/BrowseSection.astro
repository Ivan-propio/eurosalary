---
import { countrySlugsByLang, jobSlugsByLang, countryFlags } from '../data/slugs';
import { useTranslations, fb } from '../i18n/utils';
import { countryNames, jobNames } from '../i18n/translations';

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const countrySlugs = countrySlugsByLang[lang] || countrySlugsByLang.en;
const jobSlugs = jobSlugsByLang[lang] || jobSlugsByLang.en;


const browseByCountryTitle: Record<string, string> = {
  en: 'Browse Salaries by Country',
  fr: 'Salaires par pays',
  de: 'Gehälter nach Land',
  es: 'Salarios por país',
};

const browseByJobTitle: Record<string, string> = {
  en: 'Browse Salaries by Job Title',
  fr: 'Salaires par métier',
  de: 'Gehälter nach Beruf',
  es: 'Salarios por profesión',
};

const viewAllLabel: Record<string, string> = {
  en: 'View all jobs',
  fr: 'Voir tous les métiers',
  de: 'Alle Berufe ansehen',
  es: 'Ver todas las profesiones',
};
---

<section class="section" id="browse">
  <div class="container">
    <h2 class="browse__title">{fb(browseByCountryTitle, lang)}</h2>
    <div class="browse-grid browse-grid--countries">
      {Object.entries(countrySlugs).map(([code, slug]) => (
        <a href={`/${lang}/country/${slug}/`} class="browse-chip">
          <span class="browse-chip__flag">{countryFlags[code]}</span>
          <span>{fb(countryNames[code], lang)}</span>
        </a>
      ))}
    </div>

    <h2 class="browse__title" style="margin-top: var(--space-12);">{fb(browseByJobTitle, lang)}</h2>
    <div class="browse-grid browse-grid--jobs">
      {Object.entries(jobNames).map(([key, nameRecord]) => (
        <a href={`/${lang}/salary/germany/${jobSlugs[key]}/`} class="browse-chip browse-chip--job">
          <span>{fb(nameRecord, lang)}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .browse__title {
    text-align: center;
    margin-bottom: var(--space-6);
  }

  .browse-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
  }

  .browse-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full, 999px);
    background: var(--color-gray-100, #f3f4f6);
    color: var(--color-gray-800, #1f2937);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    transition: background 0.15s, transform 0.15s;
    border: 1px solid var(--color-gray-200, #e5e7eb);
  }

  .browse-chip:hover {
    background: var(--color-blue-50, #eff6ff);
    border-color: var(--color-blue-300, #93c5fd);
    transform: translateY(-1px);
  }

  .browse-chip__flag {
    font-size: var(--text-base);
  }

  .browse-chip--job {
    background: var(--color-blue-50, #eff6ff);
    border-color: var(--color-blue-200, #bfdbfe);
    color: var(--color-blue-700, #1d4ed8);
  }

  .browse-chip--job:hover {
    background: var(--color-blue-100, #dbeafe);
    border-color: var(--color-blue-400, #60a5fa);
  }
</style>
