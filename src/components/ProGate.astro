const t = i18n[lang] || i18n.en;
const description = featureDescriptions[feature]?.[lang]
  || featureDescriptions[feature]?.['en']
  || featureDescriptions['net-salary'][lang]
  || featureDescriptions['net-salary']['en'];
---

<div class="progate" data-progate={feature}>
  <div class="progate__content">
    <slot />
  </div>

  <div class="progate__overlay" aria-hidden="true">
    <div class="progate__card">
      <span class="material-symbols-outlined progate__lock">lock</span>
      <h3 class="progate__title">{t.title}</h3>
      <p class="progate__desc">{description}</p>
      <a href={`/${lang}/pricing/`} class="progate__cta">
        {t.upgrade}
      </a>
      <a href={`/${lang}/login/`} class="progate__login">
        {t.login}
      </a>
    </div>
  </div>
</div>

<style>
  .progate {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
  }

  .progate__content {
    filter: blur(8px);
    pointer-events: none;
    user-select: none;
    transition: filter 0.4s ease;
  }

  .progate--unlocked .progate__content {
    filter: none;
    pointer-events: auto;
    user-select: auto;
  }

  .progate__overlay {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(15, 31, 61, 0.7);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  .progate--unlocked .progate__overlay {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .progate__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    max-width: 380px;
    padding: 32px 28px;
    background: rgba(15, 31, 61, 0.92);
    border: 1px solid rgba(37, 99, 235, 0.3);
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    text-align: center;
  }

  .progate__lock {
    font-size: 40px;
    color: #2563eb;
  }

  .progate__title {
    margin: 0;
    font-family: 'Public Sans', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
  }

  .progate__desc {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.75);
  }

  .progate__cta {
    display: inline-block;
    margin-top: 8px;
    padding: 12px 32px;
    background: #2563eb;
    color: #fff;
    font-weight: 600;
    font-size: 0.95rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.15s ease;
  }

  .progate__cta:hover {
    background: #1d4ed8;
    transform: translateY(-1px);
  }

  .progate__login {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }

  .progate__login:hover {
    color: rgba(255, 255, 255, 0.85);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const gates = document.querySelectorAll<HTMLDivElement>('[data-progate]');
    if (!gates.length) return;

    fetch('/api/auth/session', { credentials: 'include' })
      .then((res) => res.json())
      .then((data: { entitlements?: { is_paid?: boolean } }) => {
        if (data?.entitlements?.is_paid) {
          gates.forEach((gate) => {
            gate.classList.add('progate--unlocked');
          });
        }
      })
      .catch(() => {
        // Session check failed — keep gated (safe default)
      });
  });
</script>
