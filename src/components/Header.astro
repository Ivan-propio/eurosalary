---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getLangFromUrl, useTranslations, getAlternateLinks } from '../i18n/utils';
import { languages, type Lang } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const alternates = getAlternateLinks(Astro.url.pathname);

const langLabels: Record<string, string> = {
  en: 'English', fr: 'Français', de: 'Deutsch', es: 'Español',
  it: 'Italiano', pt: 'Português', nl: 'Nederlands', pl: 'Polski',
  ro: 'Română', cs: 'Čeština', sv: 'Svenska', da: 'Dansk',
  fi: 'Suomi', el: 'Ελληνικά', hu: 'Magyar', sk: 'Slovenčina',
  bg: 'Български', hr: 'Hrvatski', sl: 'Slovenščina', lt: 'Lietuvių',
  lv: 'Latviešu', et: 'Eesti', mt: 'Malti', ga: 'Gaeilge',
};

const langOrder = ['en','fr','de','es','it','pt','nl','pl','ro','cs','sv','da','fi','el','hu','sk','bg','hr','sl','lt','lv','et','mt','ga'];
const sortedAlternates = langOrder
  .map((code) => alternates.find((a) => a.lang === code))
  .filter(Boolean) as { lang: Lang; href: string }[];
---

<header class="header">
  <div class="header__inner">
    <a href={`/${lang}/`} class="header__logo" aria-label="EuroSalary.eu — Home">
      Euro<span>Salary</span><small>.eu</small>
    </a>

    <nav class="header__nav" id="main-nav" aria-label="Main navigation">
      <a href={`/${lang}/countries/`}>{t('nav.countries')}</a>
      <a href={`/${lang}/compare/`}>{t('nav.compare')}</a>
      <a href={`/${lang}/sectors/`}>{t('nav.sectors')}</a>
      <a href={`/${lang}/calculator/`}>{t('nav.calculator')}</a>

      <!-- Solutions dropdown -->
      <div class="nav-dropdown">
        <button class="nav-dropdown__trigger" aria-expanded="false" aria-haspopup="true">
          {t('nav.solutions')}
          <span class="material-symbols-outlined nav-dropdown__arrow">expand_more</span>
        </button>
        <div class="nav-dropdown__panel">
          <div class="nav-dropdown__grid">
            <div class="nav-dropdown__col">
              <div class="nav-dropdown__heading">{t('nav.forEmployers')}</div>
              <a href={`/${lang}/for-employers/`} class="nav-dropdown__link">
                <span class="material-symbols-outlined">business</span>
                {t('nav.forEmployers')}
              </a>
              <a href={`/${lang}/for-recruiters/`} class="nav-dropdown__link">
                <span class="material-symbols-outlined">person_search</span>
                {t('nav.forRecruiters')}
              </a>
              <a href={`/${lang}/alerts/`} class="nav-dropdown__link">
                <span class="material-symbols-outlined">notifications_active</span>
                {t('nav.alerts')}
              </a>
            </div>
            <div class="nav-dropdown__col">
              <div class="nav-dropdown__heading">Data & API</div>
              <a href={`/${lang}/salary-api/`} class="nav-dropdown__link">
                <span class="material-symbols-outlined">api</span>
                {t('nav.salaryAPI')}
              </a>
              <a href={`/${lang}/premium/`} class="nav-dropdown__link">
                <span class="material-symbols-outlined">description</span>
                {t('nav.premiumReports')}
              </a>
              <a href={`/${lang}/pricing/api/`} class="nav-dropdown__link">
                <span class="material-symbols-outlined">receipt_long</span>
                {t('nav.apiPricing')}
              </a>
            </div>
            <div class="nav-dropdown__col">
              <div class="nav-dropdown__heading">{t('nav.enterprise')}</div>
              <a href={`/${lang}/enterprise/`} class="nav-dropdown__link">
                <span class="material-symbols-outlined">corporate_fare</span>
                {t('nav.enterprise')}
              </a>
              <a href={`/${lang}/partners/`} class="nav-dropdown__link">
                <span class="material-symbols-outlined">handshake</span>
                {t('nav.partners')}
              </a>
            </div>
          </div>
          <div class="nav-dropdown__footer">
            <a href={`/${lang}/pricing/`} class="nav-dropdown__cta">
              <span class="material-symbols-outlined">payments</span>
              {t('nav.pricing')} →
            </a>
          </div>
        </div>
      </div>

      <a href={`/${lang}/blog/`}>{t('nav.blog')}</a>
      <a href={`/${lang}/pricing/`} class="header__nav-pricing">{t('nav.pricing')}</a>
    </nav>

    <div class="header__right">
      <LanguageSwitcher />
      <button class="hamburger" id="hamburger-btn" aria-label="Menu" aria-expanded="false" aria-controls="mobile-nav">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile nav overlay -->
  <div class="mobile-nav" id="mobile-nav" aria-hidden="true">
    <nav class="mobile-nav__links">
      <a href={`/${lang}/`}>{t('nav.home')}</a>
      <a href={`/${lang}/countries/`}>{t('nav.countries')}</a>
      <a href={`/${lang}/compare/`}>{t('nav.compare')}</a>
      <a href={`/${lang}/sectors/`}>{t('nav.sectors')}</a>
      <a href={`/${lang}/calculator/`}>{t('nav.calculator')}</a>
      <a href={`/${lang}/blog/`}>{t('nav.blog')}</a>

      <div class="mobile-nav__divider"></div>
      <div class="mobile-nav__section-label">{t('nav.solutions')}</div>
      <a href={`/${lang}/for-employers/`}>{t('nav.forEmployers')}</a>
      <a href={`/${lang}/for-recruiters/`}>{t('nav.forRecruiters')}</a>
      <a href={`/${lang}/salary-api/`}>{t('nav.salaryAPI')}</a>
      <a href={`/${lang}/enterprise/`}>{t('nav.enterprise')}</a>
      <a href={`/${lang}/partners/`}>{t('nav.partners')}</a>
      <a href={`/${lang}/premium/`}>{t('nav.premiumReports')}</a>
      <a href={`/${lang}/alerts/`}>{t('nav.alerts')}</a>

      <div class="mobile-nav__divider"></div>
      <a href={`/${lang}/pricing/`} class="mobile-nav__pricing">{t('nav.pricing')}</a>
    </nav>
    <div class="mobile-nav__langs">
      <select class="mobile-nav__lang-select" aria-label="Language" onchange="localStorage.setItem('eurosalary-lang',this.options[this.selectedIndex].dataset.lang);window.location.href=this.value">
        {sortedAlternates.map((alt) => (
          <option value={alt.href} selected={alt.lang === lang} data-lang={alt.lang}>
            {languages[alt.lang]} — {langLabels[alt.lang]}
          </option>
        ))}
      </select>
    </div>
  </div>
</header>

<script>
  // Hamburger
  const btn = document.getElementById('hamburger-btn');
  const nav = document.getElementById('mobile-nav');
  if (btn && nav) {
    btn.addEventListener('click', () => {
      const open = nav.classList.toggle('mobile-nav--open');
      btn.classList.toggle('hamburger--open', open);
      btn.setAttribute('aria-expanded', String(open));
      nav.setAttribute('aria-hidden', String(!open));
    });
    document.addEventListener('click', (e) => {
      if (!nav.contains(e.target as Node) && !btn.contains(e.target as Node)) {
        nav.classList.remove('mobile-nav--open');
        btn.classList.remove('hamburger--open');
        btn.setAttribute('aria-expanded', 'false');
        nav.setAttribute('aria-hidden', 'true');
      }
    });
  }

  // Desktop dropdown
  const trigger = document.querySelector('.nav-dropdown__trigger');
  const panel = document.querySelector('.nav-dropdown__panel');
  const dropdown = document.querySelector('.nav-dropdown');
  if (trigger && panel && dropdown) {
    let timeout: ReturnType<typeof setTimeout>;
    dropdown.addEventListener('mouseenter', () => {
      clearTimeout(timeout);
      panel.classList.add('nav-dropdown__panel--open');
      trigger.setAttribute('aria-expanded', 'true');
    });
    dropdown.addEventListener('mouseleave', () => {
      timeout = setTimeout(() => {
        panel.classList.remove('nav-dropdown__panel--open');
        trigger.setAttribute('aria-expanded', 'false');
      }, 150);
    });
    // Keyboard accessible
    trigger.addEventListener('click', () => {
      const isOpen = panel.classList.toggle('nav-dropdown__panel--open');
      trigger.setAttribute('aria-expanded', String(isOpen));
    });
  }
</script>

<style>
  /* ---- Hamburger ---- */
  .hamburger {
    display: none; flex-direction: column; justify-content: center;
    gap: 5px; width: 32px; height: 32px; background: none; border: none; cursor: pointer; padding: 4px;
  }
  .hamburger span { display: block; width: 100%; height: 2px; background: var(--color-gray-300); transition: all 0.2s ease; }
  .hamburger--open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  .hamburger--open span:nth-child(2) { opacity: 0; }
  .hamburger--open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

  /* ---- Solutions Dropdown ---- */
  .nav-dropdown { position: relative; }
  .nav-dropdown__trigger {
    display: inline-flex; align-items: center; gap: 2px;
    background: none; border: none; cursor: pointer;
    font-family: inherit; font-size: inherit; font-weight: inherit;
    color: rgba(203, 213, 225, 0.8); padding: 0;
    transition: color 0.15s ease;
  }
  .nav-dropdown__trigger:hover { color: var(--color-white); }
  .nav-dropdown__arrow { font-size: 18px; transition: transform 0.2s; }
  .nav-dropdown__panel--open + .nav-dropdown__trigger .nav-dropdown__arrow,
  [aria-expanded="true"] .nav-dropdown__arrow { transform: rotate(180deg); }

  .nav-dropdown__panel {
    position: absolute; top: calc(100% + 12px); left: 50%; transform: translateX(-50%) translateY(8px);
    background: rgba(15, 31, 61, 0.98); backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 12px;
    padding: 0; width: 560px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6);
    opacity: 0; pointer-events: none; transition: all 0.2s ease; z-index: 100;
  }
  .nav-dropdown__panel--open {
    opacity: 1; pointer-events: auto; transform: translateX(-50%) translateY(0);
  }

  .nav-dropdown__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; padding: 1.25rem; }
  .nav-dropdown__col { display: flex; flex-direction: column; gap: 2px; }
  .nav-dropdown__heading {
    font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em;
    color: rgba(148, 163, 184, 0.6); padding: 4px 10px; margin-bottom: 4px;
  }
  .nav-dropdown__link {
    display: flex; align-items: center; gap: 8px; padding: 8px 10px;
    color: rgba(203, 213, 225, 0.9); font-size: 13px; font-weight: 500;
    text-decoration: none; border-radius: 6px; transition: all 0.15s ease;
  }
  .nav-dropdown__link:hover { background: rgba(255, 255, 255, 0.06); color: var(--color-white); }
  .nav-dropdown__link .material-symbols-outlined { font-size: 18px; color: var(--color-secondary); }

  .nav-dropdown__footer {
    border-top: 1px solid rgba(255, 255, 255, 0.08); padding: 0.75rem 1.25rem;
    background: rgba(255, 255, 255, 0.02); border-radius: 0 0 12px 12px;
  }
  .nav-dropdown__cta {
    display: flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 600;
    color: var(--color-secondary); text-decoration: none; transition: color 0.15s;
  }
  .nav-dropdown__cta:hover { color: var(--color-white); }
  .nav-dropdown__cta .material-symbols-outlined { font-size: 16px; }

  /* ---- Pricing link highlight ---- */
  .header__nav-pricing {
    background: rgba(37, 99, 235, 0.12); padding: 4px 12px !important;
    border-radius: 6px; color: var(--color-secondary) !important;
    font-weight: 600 !important;
  }
  .header__nav-pricing:hover { background: rgba(37, 99, 235, 0.2); color: var(--color-white) !important; }

  /* ---- Mobile nav ---- */
  .mobile-nav {
    display: none; position: absolute; top: var(--header-height); left: 0; right: 0;
    background: rgba(15, 31, 61, 0.98); backdrop-filter: blur(16px);
    padding: var(--space-6) var(--space-8);
    transform: translateY(-10px); opacity: 0; pointer-events: none; transition: all 0.2s ease;
    max-height: calc(100vh - var(--header-height)); overflow-y: auto;
  }
  .mobile-nav--open { transform: translateY(0); opacity: 1; pointer-events: auto; }

  .mobile-nav__links { display: flex; flex-direction: column; gap: var(--space-1); }
  .mobile-nav__links a {
    display: block; padding: var(--space-3) var(--space-4);
    color: rgba(203, 213, 225, 0.9); font-size: var(--text-sm); font-weight: var(--weight-medium);
    transition: all 0.15s ease; text-decoration: none;
  }
  .mobile-nav__links a:hover { color: var(--color-white); background: rgba(255, 255, 255, 0.05); }

  .mobile-nav__divider {
    height: 1px; background: rgba(255, 255, 255, 0.08);
    margin: var(--space-2) var(--space-4);
  }
  .mobile-nav__section-label {
    font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;
    color: rgba(148, 163, 184, 0.5); padding: var(--space-2) var(--space-4);
  }
  .mobile-nav__pricing {
    background: rgba(37, 99, 235, 0.12) !important; border-radius: 6px;
    color: var(--color-secondary) !important; font-weight: 600 !important;
  }

  .mobile-nav__langs {
    display: flex; gap: var(--space-4); margin-top: var(--space-4);
    padding-top: var(--space-4); border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .mobile-nav__lang-select {
    appearance: none; background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.15);
    color: var(--color-white); padding: 8px 16px; font-size: var(--text-sm); font-weight: var(--weight-bold);
    width: 100%; cursor: pointer; border-radius: var(--radius-sm);
  }
  .mobile-nav__lang-select option { background: var(--color-primary-container); color: var(--color-white); }

  @media (max-width: 768px) {
    .hamburger { display: flex; }
    .mobile-nav { display: block; }
    .nav-dropdown { display: none; }
    .header__nav-pricing { display: none; }
  }
  @media (max-width: 1100px) {
    .nav-dropdown__panel { width: 480px; }
  }
</style>
