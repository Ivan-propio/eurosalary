---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TLDRBox from '../../../components/TLDRBox.astro';
import FAQSection from '../../../components/FAQSection.astro';

const lang = 'en';
const countryName = 'Germany';
const countrySlug = 'germany';
const countryCode = 'DE';

const topJobs = [
  { name: 'Software Engineer', slug: 'software-engineer', median: 65000, sector: 'Technology' },
  { name: 'Doctor (GP)', slug: 'doctor', median: 85000, sector: 'Healthcare' },
  { name: 'Product Manager', slug: 'product-manager', median: 70000, sector: 'Technology' },
  { name: 'Lawyer', slug: 'lawyer', median: 78000, sector: 'Legal' },
  { name: 'DevOps Engineer', slug: 'devops-engineer', median: 68000, sector: 'Technology' },
  { name: 'Financial Analyst', slug: 'financial-analyst', median: 60000, sector: 'Finance' },
  { name: 'Data Scientist', slug: 'data-scientist', median: 68000, sector: 'Technology' },
  { name: 'Marketing Manager', slug: 'marketing-manager', median: 55000, sector: 'Marketing' },
  { name: 'Teacher (Secondary)', slug: 'teacher', median: 58000, sector: 'Education' },
  { name: 'Nurse', slug: 'nurse', median: 40000, sector: 'Healthcare' },
];

const faqItems = [
  {
    question: 'What is the average salary in Germany in 2026?',
    answer: 'The average gross salary in Germany is approximately €52,000 per year across all professions. However, this varies significantly by sector: technology professionals earn €65,000-85,000, healthcare €40,000-115,000, and public sector employees €45,000-68,000. Germany is the 4th highest-paying EU country.',
  },
  {
    question: 'How much tax do you pay in Germany?',
    answer: 'Germany uses progressive income tax from 14% to 45%, plus a 5.5% solidarity surcharge and social contributions (~20%). The effective tax rate for a €65,000 salary is approximately 38-40%. Church tax (8-9%) applies if registered with a church.',
  },
  {
    question: 'What are the highest-paying jobs in Germany?',
    answer: 'The highest-paying jobs in Germany include: Doctors (€85,000-145,000), Lawyers at top firms (€78,000-170,000), Software Engineers at FAANG (€85,000-130,000), Product Managers (€70,000-135,000), and Investment Bankers (€80,000-200,000+).',
  },
  {
    question: 'How does Germany compare to other EU countries for salaries?',
    answer: 'Germany ranks 4th in the EU for average salaries, behind Luxembourg, Denmark, and Ireland. However, when adjusted for cost of living, Germany offers the best purchasing power among large EU economies, particularly outside of Munich and Frankfurt.',
  },
  {
    question: 'Is the minimum wage increasing in Germany in 2026?',
    answer: 'The German minimum wage was raised to €12.82 per hour in 2025 and is expected to reach €13.50 by late 2026. This equates to approximately €28,000 gross per year for full-time work. The Mindestlohnkommission reviews rates biennially.',
  },
];

const pageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: 'Average Salaries in Germany (2026) — Complete Guide',
    author: { '@type': 'Organization', name: 'EuroSalary.eu' },
    datePublished: '2026-01-15',
    dateModified: '2026-04-01',
    publisher: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
  },
];

function formatSalary(amount: number): string {
  return new Intl.NumberFormat('en', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 }).format(amount);
}
---

<BaseLayout
  title="Average Salaries in Germany (2026) — All Jobs & Sectors"
  description="Complete salary guide for Germany in 2026. Average salary €52,000/yr. Top paying jobs, tax rates, cost of living, and comparison with other EU countries."
  datePublished="2026-01-15"
  dateModified="2026-04-01"
  schema={pageSchema}
>
  <nav class="breadcrumbs container">
    <a href={`/${lang}/`}>Home</a>
    <span class="breadcrumbs__sep">/</span>
    <a href={`/${lang}/`}>Countries</a>
    <span class="breadcrumbs__sep">/</span>
    <span>{countryName}</span>
  </nav>

  <article class="country-page container">
    <h1>What Are the Average Salaries in Germany in 2026?</h1>

    <p class="country-page__answer">
      The average gross salary in Germany is <strong>€52,000 per year</strong> across all professions.
      Germany ranks 4th in the EU for salaries, with technology and finance sectors paying significantly above average.
      Progressive tax rates of 14-45% mean net take-home is roughly 55-65% of gross.
    </p>

    <TLDRBox items={[
      'Average salary: €52,000/yr gross across all professions',
      'Top-paying sectors: Technology (€65K-85K), Legal (€78K-135K), Healthcare specialists (€85K-145K)',
      'Effective tax rate: 38-40% at average income level',
    ]} />

    <!-- Economic indicators -->
    <section class="section">
      <h2>Germany Economic Overview 2026</h2>
      <div class="indicators-grid">
        <div class="indicator card">
          <div class="indicator__label">Average Salary</div>
          <div class="indicator__value">€52,000</div>
          <div class="indicator__note">gross/year</div>
        </div>
        <div class="indicator card">
          <div class="indicator__label">Minimum Wage</div>
          <div class="indicator__value">€12.82/hr</div>
          <div class="indicator__note">~€28,000/year</div>
        </div>
        <div class="indicator card">
          <div class="indicator__label">Income Tax</div>
          <div class="indicator__value">14-45%</div>
          <div class="indicator__note">progressive</div>
        </div>
        <div class="indicator card">
          <div class="indicator__label">Cost of Living Index</div>
          <div class="indicator__value">65.3</div>
          <div class="indicator__note">vs. EU avg 58.2</div>
        </div>
        <div class="indicator card">
          <div class="indicator__label">Population</div>
          <div class="indicator__value">84.5M</div>
          <div class="indicator__note">largest EU economy</div>
        </div>
        <div class="indicator card">
          <div class="indicator__label">Currency</div>
          <div class="indicator__value">EUR</div>
          <div class="indicator__note">Eurozone member</div>
        </div>
      </div>
    </section>

    <!-- Top jobs -->
    <section class="section">
      <h2>Highest-Paying Jobs in Germany</h2>
      <table class="data-table">
        <thead>
          <tr>
            <th>Job Title</th>
            <th>Sector</th>
            <th>Median Salary</th>
          </tr>
        </thead>
        <tbody>
          {topJobs.map((job) => (
            <tr>
              <td>
                <a href={`/${lang}/salary/${countrySlug}/${job.slug}/`}>
                  <strong>{job.name}</strong>
                </a>
              </td>
              <td>{job.sector}</td>
              <td class="salary-value">{formatSalary(job.median)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <!-- Top sectors -->
    <section class="section">
      <h2>Salary by Industry Sector</h2>
      <div class="sectors-grid">
        <div class="sector-card card">
          <h3>Technology</h3>
          <p class="sector-card__range">€48,000 — €130,000</p>
          <p class="sector-card__desc">Software engineering, data science, DevOps, product management. Berlin and Munich are key hubs.</p>
        </div>
        <div class="sector-card card">
          <h3>Finance & Banking</h3>
          <p class="sector-card__range">€45,000 — €120,000</p>
          <p class="sector-card__desc">Frankfurt is the financial capital. Investment banking and fintech pay the highest premiums.</p>
        </div>
        <div class="sector-card card">
          <h3>Healthcare</h3>
          <p class="sector-card__range">€33,000 — €145,000</p>
          <p class="sector-card__desc">Wide range from nursing (€40K) to specialist doctors (€145K). Public hospital salaries follow TVöD scales.</p>
        </div>
        <div class="sector-card card">
          <h3>Engineering</h3>
          <p class="sector-card__range">€45,000 — €110,000</p>
          <p class="sector-card__desc">Automotive (BMW, Mercedes, VW) and industrial engineering. Stuttgart and Munich are the centers.</p>
        </div>
      </div>
    </section>

    <!-- Tax overview -->
    <section class="section">
      <h2>Tax & Social Contributions in Germany</h2>
      <p>Germany has one of the highest tax-plus-contribution rates in Europe. Here's a breakdown for a typical employee:</p>
      <table class="data-table" style="margin-top: var(--space-4);">
        <thead>
          <tr>
            <th>Deduction</th>
            <th>Rate</th>
            <th>Notes</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Income Tax</td><td>14-45%</td><td>Progressive brackets</td></tr>
          <tr><td>Solidarity Surcharge</td><td>5.5%</td><td>On income tax amount</td></tr>
          <tr><td>Health Insurance</td><td>7.3%</td><td>Employee share</td></tr>
          <tr><td>Pension Insurance</td><td>9.3%</td><td>Employee share</td></tr>
          <tr><td>Unemployment Insurance</td><td>1.3%</td><td>Employee share</td></tr>
          <tr><td>Long-term Care</td><td>1.7%</td><td>Higher if childless</td></tr>
          <tr><td>Church Tax</td><td>8-9%</td><td>Optional (on income tax)</td></tr>
        </tbody>
      </table>
    </section>

    <FAQSection items={faqItems} />
  </article>
</BaseLayout>

<style>
  .country-page {
    padding-bottom: var(--space-16);
  }

  .country-page h1 {
    margin-top: var(--space-6);
    margin-bottom: var(--space-4);
  }

  .country-page__answer {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-gray-700);
    margin-bottom: var(--space-6);
    max-width: 720px;
  }

  .indicators-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    margin-top: var(--space-4);
  }

  .indicator {
    text-align: center;
  }

  .indicator__label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gray-500);
    margin-bottom: var(--space-2);
  }

  .indicator__value {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--color-blue-600);
  }

  .indicator__note {
    font-size: var(--text-xs);
    color: var(--color-gray-400);
    margin-top: var(--space-1);
  }

  .sectors-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    margin-top: var(--space-4);
  }

  .sector-card h3 {
    margin-bottom: var(--space-2);
  }

  .sector-card__range {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    color: var(--color-blue-600);
    margin-bottom: var(--space-2);
  }

  .sector-card__desc {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
  }

  @media (max-width: 768px) {
    .indicators-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .sectors-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
