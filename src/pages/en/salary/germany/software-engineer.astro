---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import TLDRBox from '../../../../components/TLDRBox.astro';
import SalaryTable from '../../../../components/SalaryTable.astro';
import FAQSection from '../../../../components/FAQSection.astro';
import CountryCompare from '../../../../components/CountryCompare.astro';
import JobAffiliateCTA from '../../../../components/JobAffiliateCTA.astro';
import SalaryForm from '../../../../components/SalaryForm.astro';

const lang = 'en';
const jobName = 'Software Engineer';
const jobSlug = 'software-engineer';
const countryName = 'Germany';
const countrySlug = 'germany';
const countryCode = 'DE';

const salaryRows = [
  { level: 'junior', min: 42000, median: 48000, max: 55000, netEstimate: 30000 },
  { level: 'mid', min: 55000, median: 65000, max: 78000, netEstimate: 40000 },
  { level: 'senior', min: 75000, median: 85000, max: 100000, netEstimate: 52000 },
  { level: 'lead', min: 90000, median: 105000, max: 130000, netEstimate: 62000 },
];

const compareCountries = [
  { countryName: 'France', countrySlug: 'france', countryCode: 'FR', flag: '🇫🇷', medianSalary: 52000 },
  { countryName: 'Netherlands', countrySlug: 'netherlands', countryCode: 'NL', flag: '🇳🇱', medianSalary: 62000 },
  { countryName: 'Spain', countrySlug: 'spain', countryCode: 'ES', flag: '🇪🇸', medianSalary: 40000 },
  { countryName: 'Ireland', countrySlug: 'ireland', countryCode: 'IE', flag: '🇮🇪', medianSalary: 68000 },
  { countryName: 'Luxembourg', countrySlug: 'luxembourg', countryCode: 'LU', flag: '🇱🇺', medianSalary: 75000 },
  { countryName: 'Austria', countrySlug: 'austria', countryCode: 'AT', flag: '🇦🇹', medianSalary: 58000 },
];

const faqItems = [
  {
    question: 'What is the average salary for a Software Engineer in Germany in 2026?',
    answer: 'The average (median) gross salary for a Software Engineer in Germany is €65,000 per year for a mid-level professional. Junior developers earn around €48,000, while senior engineers can expect €85,000 or more. These figures are based on Eurostat data and verified job postings.',
  },
  {
    question: 'How much does a Software Engineer earn after taxes in Germany?',
    answer: 'A mid-level Software Engineer earning €65,000 gross in Germany takes home approximately €40,000 net per year. Germany has progressive income tax (14-45%), plus solidarity surcharge (5.5%) and social contributions (~20%). The effective tax rate is roughly 38-40% at this income level.',
  },
  {
    question: 'What factors affect Software Engineer salaries in Germany?',
    answer: 'Key factors include: city (Munich and Frankfurt pay 15-20% above average), company size (large corporates and FAANG offices pay more), programming languages (Go, Rust, and Scala command premiums), industry (fintech and automotive pay above average), and years of experience.',
  },
  {
    question: 'Which German cities pay Software Engineers the most?',
    answer: 'Munich leads with median salaries 15-20% above the national average, followed by Frankfurt (+12%), Stuttgart (+10%), Hamburg (+8%), and Berlin (+5%). Remote roles are increasingly matching Munich-level salaries regardless of location.',
  },
  {
    question: 'How does the Software Engineer salary in Germany compare to other EU countries?',
    answer: 'Germany ranks in the top 5 for Software Engineer salaries in the EU. Luxembourg (€75,000) and Ireland (€68,000) pay more, while the Netherlands (€62,000) is close. France (€52,000) and Spain (€40,000) are significantly lower. When adjusted for cost of living, Germany offers strong purchasing power.',
  },
  {
    question: 'Is the Software Engineer salary in Germany increasing?',
    answer: 'Yes. Software Engineer salaries in Germany have grown 4-6% annually since 2022, driven by the EU-wide tech talent shortage. The EU Pay Transparency Directive (effective June 2026) is expected to further increase salary visibility and upward pressure on wages.',
  },
];

const pageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: `What is the Average Software Engineer Salary in Germany in 2026?`,
    author: { '@type': 'Organization', name: 'EuroSalary.eu' },
    datePublished: '2026-01-15',
    dateModified: '2026-04-01',
    publisher: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Dataset',
    name: 'Software Engineer Salary Data — Germany 2026',
    description: 'Salary ranges for Software Engineers in Germany by experience level, sourced from Eurostat and verified job postings.',
    url: 'https://eurosalary.eu/en/salary/germany/software-engineer/',
    creator: { '@type': 'Organization', name: 'EuroSalary.eu' },
    temporalCoverage: '2025/2026',
    spatialCoverage: { '@type': 'Place', name: 'Germany' },
    variableMeasured: 'Annual gross salary in EUR',
  },
];
---

<BaseLayout
  title="Average Software Engineer Salary in Germany (2026)"
  description="The average Software Engineer salary in Germany is €65,000/yr, ranging from €42,000 (junior) to €130,000 (lead). Updated April 2026. Source: Eurostat + verified job postings."
  datePublished="2026-01-15"
  dateModified="2026-04-01"
  schema={pageSchema}
>
  <!-- Breadcrumbs -->
  <nav class="breadcrumbs container">
    <a href={`/${lang}/`}>Home</a>
    <span class="breadcrumbs__sep">/</span>
    <a href={`/${lang}/salary/`}>Salaries</a>
    <span class="breadcrumbs__sep">/</span>
    <a href={`/${lang}/country/${countrySlug}/`}>{countryName}</a>
    <span class="breadcrumbs__sep">/</span>
    <span>{jobName}</span>
  </nav>

  <article class="salary-page container">
    <!-- 1. H1 as direct question (AEO rule) -->
    <h1>What is the Average Salary for a Software Engineer in Germany in 2026?</h1>

    <!-- 2. Direct answer paragraph (40-60 words) -->
    <p class="salary-page__answer">
      The average gross salary for a Software Engineer in Germany is <strong>€65,000 per year</strong> (mid-level).
      Junior developers start at €48,000, while senior engineers earn €85,000 and lead engineers reach €105,000.
      After taxes and social contributions, the net take-home is approximately €40,000 for a mid-level position.
    </p>

    <!-- 3. TL;DR box above the fold -->
    <TLDRBox items={[
      'Median salary: €65,000/yr gross (€40,000 net) for mid-level',
      'Range: €42,000 (junior) to €130,000 (lead)',
      'Germany ranks #4 in the EU for Software Engineer pay, behind Luxembourg, Ireland, and Netherlands',
    ]} />

    <!-- 4. Salary data table with gross/net toggle -->
    <section>
      <h2>Software Engineer Salary Breakdown by Experience Level</h2>
      <SalaryTable rows={salaryRows} />
    </section>

    <!-- 5. Country comparison -->
    <CountryCompare job={jobName} jobSlug={jobSlug} items={compareCountries} />

    <!-- 6. Top paying cities -->
    <section class="section">
      <h2>Top Paying Cities for Software Engineers in Germany</h2>
      <div class="cities-grid">
        <div class="city-card card">
          <h3>Munich</h3>
          <p class="city-card__premium">+18%</p>
          <p class="city-card__salary">€77,000 median</p>
        </div>
        <div class="city-card card">
          <h3>Frankfurt</h3>
          <p class="city-card__premium">+12%</p>
          <p class="city-card__salary">€73,000 median</p>
        </div>
        <div class="city-card card">
          <h3>Stuttgart</h3>
          <p class="city-card__premium">+10%</p>
          <p class="city-card__salary">€72,000 median</p>
        </div>
        <div class="city-card card">
          <h3>Hamburg</h3>
          <p class="city-card__premium">+8%</p>
          <p class="city-card__salary">€70,000 median</p>
        </div>
        <div class="city-card card">
          <h3>Berlin</h3>
          <p class="city-card__premium">+5%</p>
          <p class="city-card__salary">€68,000 median</p>
        </div>
      </div>
    </section>

    <!-- 7. What affects salary -->
    <section class="section">
      <h2>What Affects Software Engineer Salaries in Germany?</h2>
      <div class="factors-grid">
        <div class="factor-card card">
          <h3>Skills & Languages</h3>
          <p>Go, Rust, and Scala developers earn 15-25% more than the average. Cloud expertise (AWS, GCP) adds €5-10K to offers. Full-stack engineers with DevOps skills command the highest premiums.</p>
        </div>
        <div class="factor-card card">
          <h3>Education & Certifications</h3>
          <p>A Master's degree adds ~10% over a Bachelor's. AWS Solutions Architect or Kubernetes certifications are valued by employers and can add €3-8K to salary negotiations.</p>
        </div>
        <div class="factor-card card">
          <h3>Company Size & Type</h3>
          <p>FAANG offices (Google Munich, Amazon Berlin) pay 30-50% above market. German corporates (SAP, Siemens) offer stability with lower peaks. Startups compensate with equity, typically 10-15% lower base salary.</p>
        </div>
        <div class="factor-card card">
          <h3>Industry Sector</h3>
          <p>Fintech and automotive (BMW, Mercedes) pay the highest premiums (+15-20%). E-commerce and SaaS are at market rate. Public sector and NGOs pay 20-30% below market.</p>
        </div>
      </div>
    </section>

    <!-- 8. Affiliate CTA -->
    <JobAffiliateCTA jobName={jobName} countryName={countryName} countryCode={countryCode} />

    <!-- 9. Data sources -->
    <section class="section">
      <h2>Data Sources & Methodology</h2>
      <p>This salary data is compiled from multiple verified sources:</p>
      <ul class="source-list">
        <li><strong>Eurostat</strong> — nama_10_fte dataset, official EU wage statistics (quarterly updates)</li>
        <li><strong>OECD.Stat</strong> — Cross-country comparable wage data</li>
        <li><strong>Job postings</strong> — Analysis of 12,000+ verified listings from Indeed, StepStone, and LinkedIn (weekly scraping)</li>
        <li><strong>Anonymous reports</strong> — Salary submissions from verified professionals in Germany</li>
      </ul>
      <p class="source-date">Last updated: April 2026 &middot; Next update: May 2026</p>
    </section>

    <!-- 10. Submit salary CTA -->
    <SalaryForm />

    <!-- 11. FAQ section with schema -->
    <FAQSection items={faqItems} />
  </article>
</BaseLayout>

<style>
  .salary-page {
    padding-bottom: var(--space-16);
  }

  .salary-page h1 {
    margin-top: var(--space-6);
    margin-bottom: var(--space-4);
  }

  .salary-page__answer {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-gray-700);
    margin-bottom: var(--space-6);
    max-width: 720px;
  }

  .cities-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: var(--space-4);
    margin-top: var(--space-4);
  }

  .city-card {
    text-align: center;
  }

  .city-card h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-1);
  }

  .city-card__premium {
    color: var(--color-success);
    font-weight: var(--weight-bold);
    font-size: var(--text-xl);
  }

  .city-card__salary {
    color: var(--color-gray-500);
    font-size: var(--text-sm);
  }

  .factors-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    margin-top: var(--space-4);
  }

  .factor-card h3 {
    font-size: var(--text-base);
    margin-bottom: var(--space-2);
    color: var(--color-blue-600);
  }

  .factor-card p {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
  }

  .source-list {
    list-style: none;
    margin: var(--space-4) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .source-list li {
    padding-left: var(--space-5);
    position: relative;
    font-size: var(--text-sm);
    color: var(--color-gray-600);
  }

  .source-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-success);
  }

  .source-date {
    font-size: var(--text-xs);
    color: var(--color-gray-400);
  }

  @media (max-width: 768px) {
    .factors-grid {
      grid-template-columns: 1fr;
    }

    .cities-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
