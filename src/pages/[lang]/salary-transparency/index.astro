    whatIsBody: 'La directiva establece tres pilares. Primero, transparencia previa al empleo: los empleadores deben indicar rangos salariales y no pueden preguntar sobre historial salarial. Segundo, transparencia durante el empleo: los trabajadores pueden solicitar datos salariales promedio por g\u00e9nero. Empresas de 100+ empleados deben publicar informes regulares. Tercero, aplicaci\u00f3n: los Estados deben crear organismos de control.',
    timelineTitle: 'Fechas clave',
    timelineBody: 'La directiva fue adoptada el 10 de mayo de 2023. Los Estados miembros tienen hasta el 7 de junio de 2026. Informes de brecha salarial desde 2027 para empresas de 250+, 2028 para 150+ y 2031 para 100+.',
    keyRightsTitle: 'Sus derechos',
    keyRightsBody: 'Como solicitante de empleo, tiene derecho a conocer el rango salarial antes de la primera entrevista. No le pueden preguntar su historial salarial. Como empleado, puede solicitar informaci\u00f3n escrita sobre su salario y el promedio por g\u00e9nero para trabajo equivalente.',
    employerTitle: 'Obligaciones de los empleadores',
    employerBody: 'Los empleadores deben indicar rangos salariales, no preguntar historial salarial, proporcionar informaci\u00f3n a solicitud y asegurar estructuras salariales no discriminatorias. Empresas de 250+ empleados informan anualmente desde 2027.',
    countryListTitle: 'Estado de implementaci\u00f3n por pa\u00eds',
    countryListIntro: 'Haga clic en un pa\u00eds para ver reglas detalladas, brecha salarial de g\u00e9nero, obligaciones y plazos.',
    genderGapLabel: 'Brecha salarial',
    deadlineLabel: 'Plazo',
    penaltiesLabel: 'Sanciones',
    thresholdLabel: 'Umbral de reporte',
    viewDetails: 'Ver detalles',
    faq: [
      { question: '\u00bfCu\u00e1ndo entra en vigor la directiva de transparencia salarial?', answer: 'La directiva fue adoptada en mayo de 2023. Todos los Estados miembros deben transponerla antes del 7 de junio de 2026. Francia, Espa\u00f1a, Portugal, Suecia e Irlanda ya tienen leyes activas.' },
      { question: '\u00bfDeben los empleadores indicar salarios en las ofertas de empleo?', answer: 'S\u00ed. Los empleadores deben proporcionar el rango salarial en la oferta o antes de la primera entrevista. No pueden preguntar sobre el historial salarial.' },
      { question: '\u00bfQu\u00e9 sucede por incumplimiento?', answer: 'Cada Estado miembro debe establecer sanciones. En Alemania hasta 500.000 \u20ac, en Francia hasta 1% de la masa salarial, en Espa\u00f1a hasta 225.000 \u20ac.' },
      { question: '\u00bfQu\u00e9 pa\u00edses ya tienen leyes de transparencia?', answer: 'Cinco pa\u00edses tienen marcos activos: Francia (Index \u00e9galit\u00e9 desde 2019), Espa\u00f1a (auditor\u00edas salariales), Portugal (Ley 60/2018), Suecia (encuestas anuales desde 2009) e Irlanda (Gender Pay Gap Act 2021).' },
      { question: '\u00bfSe aplica la directiva a Suiza?', answer: 'No. Suiza no es miembro de la UE. Sin embargo, las empresas de 100+ empleados deben realizar an\u00e1lisis de igualdad salarial seg\u00fan la ley federal de igualdad.' },
    ],
  },
};

// --------------- getStaticPaths ---------------
export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
    props: { lang },
  }));
}

// --------------- Page data ---------------
const { lang } = Astro.props;
const t = fb(i18n, lang);
const ui = useTranslations(lang as any);
const names: Record<string, string> = Object.fromEntries(
  Object.keys(countryNames).map((code) => [code, fb(countryNames[code], lang)])
);
const slugs = countrySlugsByLang[lang] || countrySlugsByLang.en;
const countryCodes = Object.keys(transparencyData);

// Group countries by status
const implemented = countryCodes.filter((c) => transparencyData[c].status === 'implemented');
const inProgress = countryCodes.filter((c) => transparencyData[c].status === 'in-progress');
const pending = countryCodes.filter((c) => transparencyData[c].status === 'pending');

// EU average gender gap
const euAvgGap = 12.7;

const pageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: t.h1,
    author: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
    publisher: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
    datePublished: '2026-03-15',
    dateModified: '2026-04-04',
    description: t.metaDesc,
    mainEntityOfPage: `https://eurosalary.eu/${lang}/salary-transparency/`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: t.faq.map((item: any) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: { '@type': 'Answer', text: item.answer },
    })),
  },
];
---

<BaseLayout
  title={t.metaTitle}
  description={t.metaDesc}
  datePublished="2026-03-15"
  dateModified="2026-04-04"
  schema={pageSchema}
>
  <section class="page-hero">
    <div class="page-hero__dots"></div>
    <div class="container page-hero__inner">
      <nav class="page-hero__breadcrumbs" aria-label="Breadcrumb">
        <a href={`/${lang}/`}>{t.home}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <span class="page-hero__breadcrumbs-current">{t.breadcrumb}</span>
      </nav>
      <div class="page-hero__grid">
        <div class="page-hero__content">
          <h1 class="page-hero__title">{t.h1}</h1>
          <p class="page-hero__desc">{t.intro}</p>
        </div>
        <div class="page-hero__side">
          <div class="page-hero__card">
            <span class="page-hero__card-label">EU Directive 2023/970</span>
            <p class="page-hero__card-item"><strong>{t.deadlineLabel}:</strong> June 7, 2026</p>
            <p class="page-hero__card-item"><strong>{implemented.length}</strong> {fb({ en: 'countries implemented', fr: 'pays l\'ont mis en oeuvre', de: 'L\u00e4nder umgesetzt', es: 'pa\u00edses implementados' }, lang)}</p>
            <p class="page-hero__card-item"><strong>{inProgress.length}</strong> {fb({ en: 'in progress', fr: 'en cours', de: 'in Bearbeitung', es: 'en progreso' }, lang)}</p>
            <p class="page-hero__card-item"><strong>{pending.length}</strong> {fb({ en: 'pending', fr: 'en attente', de: 'ausstehend', es: 'pendiente' }, lang)}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <article class="container page-body">
    <TLDRBox items={t.tldr} />

    <!-- What Does the Directive Require -->
    <section class="section">
      <h2>{t.whatIsTitle}</h2>
      <p>{t.whatIsBody}</p>
    </section>

    <!-- Timeline -->
    <section class="section">
      <h2>{t.timelineTitle}</h2>
      <p>{t.timelineBody}</p>
    </section>

    <!-- Your Rights -->
    <section class="section">
      <h2>{t.keyRightsTitle}</h2>
      <p>{t.keyRightsBody}</p>
    </section>

    <!-- Employer Obligations -->
    <section class="section">
      <h2>{t.employerTitle}</h2>
      <p>{t.employerBody}</p>
    </section>

    <!-- Country Status Grid -->
    <section class="section">
      <h2>{t.countryListTitle}</h2>
      <p>{t.countryListIntro}</p>

      <!-- Status legend -->
      <div class="status-legend">
        <span class="status-legend__item">
          <span class="status-dot" style="background: #22c55e"></span>
          {fb(statusConfig['implemented'].label, lang)}
        </span>
        <span class="status-legend__item">
          <span class="status-dot" style="background: #eab308"></span>
          {fb(statusConfig['in-progress'].label, lang)}
        </span>
        <span class="status-legend__item">
          <span class="status-dot" style="background: #ef4444"></span>
          {fb(statusConfig['pending'].label, lang)}
        </span>
      </div>

      <div class="country-grid">
        {countryCodes.map((code) => {
          const slug = slugs[code] || countrySlugsByLang.en[code];
          const name = names[code] || countryNames[code]?.en;
          const flag = countryFlags[code];
          const data = transparencyData[code];
          const sc = statusConfig[data.status];
          const statusLabel = fb(sc.label, lang);
          return (
            <a href={`/${lang}/salary-transparency/${slug}/`} class="country-card">
              <div class="country-card__top">
                <div class="country-card__header">
                  <span class="country-card__flag">{flag}</span>
                  <span class="country-card__name">{name}</span>
                </div>
                <span class="country-card__status" style={`background: ${sc.color}15; color: ${sc.color}; border: 1px solid ${sc.color}40`}>
                  {statusLabel}
                </span>
              </div>
              <div class="country-card__meta">
                <div class="country-card__meta-item">
                  <span class="country-card__meta-label">{t.genderGapLabel}</span>
                  <span class="country-card__meta-value">{data.genderGap}%</span>
                </div>
                <div class="country-card__meta-item">
                  <span class="country-card__meta-label">{t.deadlineLabel}</span>
                  <span class="country-card__meta-value">{data.deadline}</span>
                </div>
              </div>
              <div class="country-card__gap-bar">
                <div class="country-card__gap-fill" style={`width: ${Math.min((data.genderGap / 25) * 100, 100)}%`}></div>
              </div>
              <span class="country-card__link">{t.viewDetails} &rarr;</span>
            </a>
          );
        })}
      </div>
    </section>

    <!-- Internal Links -->
    <section class="section">
      <div class="internal-links">
        <a href={`/${lang}/methodology/`} class="internal-link">
          <span class="material-symbols-outlined">science</span>
          {fb({ en: 'Our Methodology', fr: 'Notre m\u00e9thodologie', de: 'Unsere Methodik', es: 'Nuestra metodolog\u00eda' }, lang)}
        </a>
        <a href={`/${lang}/premium/`} class="internal-link internal-link--cta">
          <span class="material-symbols-outlined">workspace_premium</span>
          {fb({ en: 'Get Detailed Reports', fr: 'Obtenir des rapports d\u00e9taill\u00e9s', de: 'Detaillierte Berichte erhalten', es: 'Obtener informes detallados' }, lang)}
        </a>
      </div>
    </section>

    <FAQSection items={t.faq} />
  </article>
</BaseLayout>

<style>
  .page-body {
    padding-top: 2.5rem;
    padding-bottom: 4rem;
  }
  .page-body h2 {
    font-family: 'Public Sans', sans-serif;
    font-size: 1.75rem; font-weight: 800; letter-spacing: -0.02em;
    color: #0F1F3D; margin-top: 3rem; margin-bottom: 1rem;
  }
  .page-body p {
    font-size: 1rem; line-height: 1.75; color: #334155;
    margin-bottom: 1rem;
  }

  /* Status legend */
  .status-legend {
    display: flex;
    gap: 1.5rem;
    margin: 1.5rem 0 0.5rem;
    flex-wrap: wrap;
  }
  .status-legend__item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: #475569;
  }
  .status-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }

  /* Country grid */
  .country-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .country-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    text-decoration: none;
    color: #0F1F3D;
    transition: box-shadow 0.2s, border-color 0.2s;
  }
  .country-card:hover {
    border-color: #2563eb;
    box-shadow: 0 4px 16px rgba(37, 99, 235, 0.12);
  }
  .country-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .country-card__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .country-card__flag {
    font-size: 1.5rem;
  }
  .country-card__name {
    font-weight: 700;
    font-size: 1rem;
  }
  .country-card__status {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .country-card__meta {
    display: flex;
    gap: 1.5rem;
  }
  .country-card__meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .country-card__meta-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #94a3b8;
  }
  .country-card__meta-value {
    font-size: 0.9rem;
    font-weight: 700;
    color: #0F1F3D;
  }
  .country-card__gap-bar {
    width: 100%;
    height: 4px;
    background: #e2e8f0;
    border-radius: 2px;
    overflow: hidden;
  }
  .country-card__gap-fill {
    height: 100%;
    background: linear-gradient(90deg, #22c55e, #eab308, #ef4444);
    border-radius: 2px;
    transition: width 0.3s;
  }
  .country-card__link {
    font-size: 0.8rem;
    font-weight: 600;
    color: #2563eb;
  }

  /* Internal links */
  .internal-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }
  .internal-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    background: #f1f5f9;
    color: #0F1F3D;
    transition: background 0.2s;
  }
  .internal-link:hover {
    background: #e2e8f0;
  }
  .internal-link--cta {
    background: #2563eb;
    color: #fff;
  }
  .internal-link--cta:hover {
    background: #1d4ed8;
  }
</style>
