// --------------- getStaticPaths ---------------
export function getStaticPaths() {
  const paths: Array<{ params: { lang: string; country: string }; props: { countryCode: string; lang: string } }> = [];
  for (const lang of Object.keys(languages)) {
    const slugs = countrySlugsByLang[lang];
    for (const [code, slug] of Object.entries(slugs)) {
      paths.push({
        params: { lang, country: slug },
        props: { countryCode: code, lang },
      });
    }
  }
  return paths;
}

// --------------- Page props ---------------
const { countryCode, lang } = Astro.props;
const t = fb(i18n, lang);
const data = transparencyData[countryCode];
const countryName = fb(countryNames[countryCode], lang);
const flag = countryFlags[countryCode];
const slugs = countrySlugsByLang[lang] || countrySlugsByLang.en;
const sc = statusConfig[data.status];
const statusLabel = fb(sc.label, lang);
const euAvgGap = 12.7;
const gapAboveAvg = data.genderGap > euAvgGap;
const gapComparison = gapAboveAvg ? t.genderGapAbove : t.genderGapBelow;

// Build page strings
const h1 = t.h1Template.replace(/{country}/g, countryName);
const metaTitle = t.metaTitleTemplate.replace(/{country}/g, countryName).replace(/{status}/g, statusLabel).replace(/{gap}/g, String(data.genderGap));
const metaDesc = t.metaDescTemplate.replace(/{country}/g, countryName).replace(/{status}/g, statusLabel).replace(/{gap}/g, String(data.genderGap));

// Intro based on status
let introText: string;
if (data.status === 'implemented') {
  introText = t.introImplementedTemplate.replace(/{country}/g, countryName);
} else if (data.status === 'pending') {
  introText = t.introPendingTemplate.replace(/{country}/g, countryName);
} else {
  introText = t.introTemplate.replace(/{country}/g, countryName);
}

// TL;DR items
const tldrItems = t.tldrTemplates.map((tmpl: string) =>
  tmpl
    .replace(/{country}/g, countryName)
    .replace(/{status}/g, statusLabel)
    .replace(/{deadline}/g, data.deadline)
    .replace(/{gap}/g, String(data.genderGap))
    .replace(/{gapComparison}/g, gapAboveAvg
      ? fb({ en: 'above', fr: 'au-dessus de', de: '\u00fcber', es: 'por encima de' }, lang)
      : fb({ en: 'below', fr: 'en dessous de', de: 'unter', es: 'por debajo de' }, lang))
    .replace(/{threshold}/g, data.reportingThreshold)
    .replace(/{penalties}/g, data.penalties)
);

// FAQ items
const faqItems = t.faqTemplates.map((tmpl: { q: string; a: string }) => ({
  question: tmpl.q.replace(/{country}/g, countryName),
  answer: tmpl.a
    .replace(/{country}/g, countryName)
    .replace(/{statusLabel}/g, statusLabel)
    .replace(/{deadline}/g, data.deadline)
    .replace(/{gap}/g, String(data.genderGap))
    .replace(/{gapComparison}/g, gapAboveAvg
      ? fb({ en: 'above', fr: 'au-dessus de', de: '\u00fcber', es: 'por encima de' }, lang)
      : fb({ en: 'below', fr: 'en dessous de', de: 'unter', es: 'por debajo de' }, lang))
    .replace(/{penalties}/g, data.penalties)
    .replace(/{threshold}/g, data.reportingThreshold)
    .replace(/{firstRule}/g, data.keyRules[0]),
}));

// Other countries for cross-linking
const allCountries = Object.keys(transparencyData).filter((c) => c !== countryCode);
const otherCountryNames: Record<string, string> = Object.fromEntries(
  Object.keys(countryNames).map((code) => [code, fb(countryNames[code], lang)])
);

// Schema
const pageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: h1,
    author: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
    publisher: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['#quick-answer', '.page-hero__desc', '.faq-item'],
    },
    datePublished: '2026-03-20',
    dateModified: '2026-04-04',
    description: metaDesc,
    mainEntityOfPage: `https://eurosalary.eu/${lang}/salary-transparency/${slugs[countryCode]}/`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: { '@type': 'Answer', text: item.answer },
    })),
  },
];
---

<BaseLayout
  title={metaTitle}
  description={metaDesc}
  datePublished="2026-03-20"
  dateModified="2026-04-04"
  schema={pageSchema}
>
  <!-- Hero -->
  <section class="country-hero">
    <div class="country-hero__bg-icon">
      <span class="material-symbols-outlined">gavel</span>
    </div>
    <div class="container country-hero__inner">
      <nav class="country-hero__breadcrumbs" aria-label="Breadcrumb">
        <a href={`/${lang}/`}>{t.home}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <a href={`/${lang}/salary-transparency/`}>{t.breadcrumbIndex}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <span class="country-hero__breadcrumbs-current">{countryName}</span>
      </nav>

      <div class="country-hero__grid">
        <div class="country-hero__content">
          <div class="country-hero__badge">
            <span class="country-hero__flag">{flag}</span>
            <span class="country-hero__badge-text">{t.breadcrumbIndex}</span>
          </div>
          <h1 class="country-hero__title">{h1}</h1>
          <p class="country-hero__desc">{introText}</p>
        </div>

        <div class="country-hero__stats">
          <div class="country-hero__stat-card">
            <span class="country-hero__stat-label">{t.statusTitle}</span>
            <div class="country-hero__stat-badge" style={`background: ${sc.color}15; color: ${sc.color}; border: 2px solid ${sc.color}40`}>
              {statusLabel}
            </div>
          </div>
          <div class="country-hero__stat-card">
            <span class="country-hero__stat-label">{t.genderGapTitle}</span>
            <div class="country-hero__stat-value">{data.genderGap}%</div>
            <span class="country-hero__stat-note">{t.genderGapEuAvg}</span>
          </div>
          <div class="country-hero__stat-card">
            <span class="country-hero__stat-label">{t.deadlineLabel}</span>
            <div class="country-hero__stat-value stat-value--small">{data.deadline}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <article class="container tp-body">
    <TLDRBox items={tldrItems} />

    <!-- Key Rules -->
    <section class="tp-section">
      <h2 class="tp-section__title">
        <span class="material-symbols-outlined tp-section__icon">checklist</span>
        {t.keyRulesTitle}
      </h2>
      <ul class="tp-rules-list">
        {data.keyRules.map((rule) => (
          <li class="tp-rules-list__item">
            <span class="material-symbols-outlined tp-rules-list__check">check_circle</span>
            <span>{rule}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Gender Pay Gap -->
    <section class="tp-section">
      <h2 class="tp-section__title">
        <span class="material-symbols-outlined tp-section__icon">equalizer</span>
        {t.genderGapTitle}
      </h2>
      <div class="tp-gap-card">
        <div class="tp-gap-card__header">
          <div class="tp-gap-card__value">{data.genderGap}%</div>
          <div class="tp-gap-card__comparison">
            <span class={`tp-gap-card__arrow ${gapAboveAvg ? 'tp-gap-card__arrow--up' : 'tp-gap-card__arrow--down'}`}>
              {gapAboveAvg ? '\u25B2' : '\u25BC'}
            </span>
            <span>{gapComparison}</span>
          </div>
        </div>
        <div class="tp-gap-card__bar-container">
          <div class="tp-gap-card__bar-track">
            <div class="tp-gap-card__bar-fill" style={`width: ${Math.min((data.genderGap / 25) * 100, 100)}%`}></div>
            <div class="tp-gap-card__bar-marker" style={`left: ${(euAvgGap / 25) * 100}%`} title={t.genderGapEuAvg}></div>
          </div>
          <div class="tp-gap-card__bar-labels">
            <span>0%</span>
            <span class="tp-gap-card__bar-avg">{t.genderGapEuAvg}</span>
            <span>25%</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Reporting Threshold & Penalties -->
    <div class="tp-two-col">
      <section class="tp-section tp-info-card">
        <h2 class="tp-section__title">
          <span class="material-symbols-outlined tp-section__icon">business</span>
          {t.thresholdTitle}
        </h2>
        <div class="tp-info-card__value">{data.reportingThreshold}</div>
        <p class="tp-info-card__note">
          {fb({
            en: 'Companies at or above this threshold must report gender pay gap data under current or upcoming rules.',
            fr: 'Les entreprises atteignant ce seuil doivent d\u00e9clarer l\'\u00e9cart salarial selon les r\u00e8gles actuelles ou \u00e0 venir.',
            de: 'Unternehmen ab dieser Schwelle m\u00fcssen den Gender Pay Gap gem\u00e4\u00df aktuellen oder kommenden Regeln melden.',
            es: 'Las empresas que alcanzan este umbral deben reportar la brecha salarial seg\u00fan las reglas actuales o pr\u00f3ximas.',
          }, lang)}
        </p>
      </section>

      <section class="tp-section tp-info-card">
        <h2 class="tp-section__title">
          <span class="material-symbols-outlined tp-section__icon">gavel</span>
          {t.penaltiesTitle}
        </h2>
        <div class="tp-info-card__value tp-info-card__value--penalty">{data.penalties}</div>
        <p class="tp-info-card__note">
          {fb({
            en: 'Workers who suffer pay discrimination are also entitled to full compensation under the EU directive, including back pay.',
            fr: 'Les travailleurs victimes de discrimination salariale ont \u00e9galement droit \u00e0 une indemnisation compl\u00e8te en vertu de la directive UE.',
            de: 'Arbeitnehmer, die von Gehaltsdiskriminierung betroffen sind, haben gem\u00e4\u00df EU-Richtlinie Anspruch auf vollst\u00e4ndige Entsch\u00e4digung.',
            es: 'Los trabajadores v\u00edctimas de discriminaci\u00f3n salarial tambi\u00e9n tienen derecho a indemnizaci\u00f3n completa seg\u00fan la directiva UE.',
          }, lang)}
        </p>
      </section>
    </div>

    <!-- Implementation Timeline -->
    <section class="tp-section">
      <h2 class="tp-section__title">
        <span class="material-symbols-outlined tp-section__icon">timeline</span>
        {t.timelineTitle}
      </h2>
      <div class="tp-timeline">
        <div class="tp-timeline__item tp-timeline__item--past">
          <div class="tp-timeline__dot"></div>
          <div class="tp-timeline__content">
            <span class="tp-timeline__date">May 2023</span>
            <span class="tp-timeline__text">{t.timelineDirective}</span>
          </div>
        </div>
        <div class="tp-timeline__item tp-timeline__item--upcoming">
          <div class="tp-timeline__dot"></div>
          <div class="tp-timeline__content">
            <span class="tp-timeline__date">Jun 2026</span>
            <span class="tp-timeline__text">{t.timelineTranspose}</span>
          </div>
        </div>
        <div class="tp-timeline__item tp-timeline__item--future">
          <div class="tp-timeline__dot"></div>
          <div class="tp-timeline__content">
            <span class="tp-timeline__date">Jun 2027</span>
            <span class="tp-timeline__text">{t.timelineReport250}</span>
          </div>
        </div>
        <div class="tp-timeline__item tp-timeline__item--future">
          <div class="tp-timeline__dot"></div>
          <div class="tp-timeline__content">
            <span class="tp-timeline__date">Jun 2028</span>
            <span class="tp-timeline__text">{t.timelineReport150}</span>
          </div>
        </div>
        <div class="tp-timeline__item tp-timeline__item--future">
          <div class="tp-timeline__dot"></div>
          <div class="tp-timeline__content">
            <span class="tp-timeline__date">Jun 2031</span>
            <span class="tp-timeline__text">{t.timelineReport100}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Other Countries -->
    <section class="tp-section">
      <h2 class="tp-section__title">
        <span class="material-symbols-outlined tp-section__icon">public</span>
        {t.otherCountriesTitle}
      </h2>
      <p class="tp-text">{t.otherCountriesIntro}</p>
      <div class="tp-other-grid">
        {allCountries.map((code) => {
          const oSlug = slugs[code] || countrySlugsByLang.en[code];
          const oName = otherCountryNames[code] || countryNames[code]?.en;
          const oFlag = countryFlags[code];
          const oData = transparencyData[code];
          const oSc = statusConfig[oData.status];
          const oStatusLabel = fb(oSc.label, lang);
          return (
            <a href={`/${lang}/salary-transparency/${oSlug}/`} class="tp-other-card">
              <span class="tp-other-card__flag">{oFlag}</span>
              <span class="tp-other-card__name">{oName}</span>
              <span class="tp-other-card__status" style={`color: ${oSc.color}`}>{oStatusLabel}</span>
            </a>
          );
        })}
      </div>
    </section>

    <!-- Internal Links -->
    <section class="tp-section">
      <div class="tp-internal-links">
        <a href={`/${lang}/salary-transparency/`} class="tp-internal-link">
          <span class="material-symbols-outlined">arrow_back</span>
          {fb({ en: 'All Countries', fr: 'Tous les pays', de: 'Alle L\u00e4nder', es: 'Todos los pa\u00edses' }, lang)}
        </a>
        <a href={`/${lang}/country/${slugs[countryCode]}/`} class="tp-internal-link">
          <span class="material-symbols-outlined">payments</span>
          {fb({ en: `Salaries in ${countryName}`, fr: `Salaires en ${countryName}`, de: `Geh\u00e4lter in ${countryName}`, es: `Salarios en ${countryName}` }, lang)}
        </a>
        <a href={`/${lang}/premium/`} class="tp-internal-link tp-internal-link--cta">
          <span class="material-symbols-outlined">workspace_premium</span>
          {fb({ en: 'Get Detailed Reports', fr: 'Obtenir des rapports d\u00e9taill\u00e9s', de: 'Detaillierte Berichte erhalten', es: 'Obtener informes detallados' }, lang)}
        </a>
      </div>
    </section>

    <FAQSection items={faqItems} />
  </article>
</BaseLayout>

<style>
  /* Hero */
  .country-hero {
    position: relative;
    background: linear-gradient(135deg, #0F1F3D 0%, #1a2e54 100%);
    padding: 2.5rem 0 3rem;
    overflow: hidden;
  }
  .country-hero__bg-icon {
    position: absolute;
    right: -40px;
    top: -20px;
    opacity: 0.04;
    font-size: 280px;
    color: #fff;
    pointer-events: none;
  }
  .country-hero__inner {
    position: relative;
    z-index: 1;
  }
  .country-hero__breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 1.5rem;
  }
  .country-hero__breadcrumbs a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
  }
  .country-hero__breadcrumbs a:hover {
    color: #fff;
  }
  .country-hero__breadcrumbs .material-symbols-outlined {
    font-size: 14px;
  }
  .country-hero__breadcrumbs-current {
    color: rgba(255, 255, 255, 0.9);
    font-weight: 600;
  }
  .country-hero__grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 2.5rem;
    align-items: start;
  }
  @media (max-width: 768px) {
    .country-hero__grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
  .country-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 99px;
    padding: 0.35rem 1rem 0.35rem 0.5rem;
    margin-bottom: 1rem;
  }
  .country-hero__flag {
    font-size: 1.3rem;
  }
  .country-hero__badge-text {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.7);
  }
  .country-hero__title {
    font-family: 'Public Sans', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #fff;
    line-height: 1.2;
    margin-bottom: 1rem;
  }
  .country-hero__desc {
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.7);
    max-width: 600px;
  }
  .country-hero__stats {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .country-hero__stat-card {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .country-hero__stat-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.5);
  }
  .country-hero__stat-value {
    font-size: 1.75rem;
    font-weight: 800;
    color: #fff;
