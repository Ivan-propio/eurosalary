  }
  .stat-value--small {
    font-size: 1.25rem;
  }
  .country-hero__stat-badge {
    display: inline-flex;
    align-self: flex-start;
    padding: 0.35rem 1rem;
    border-radius: 99px;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .country-hero__stat-note {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.45);
  }

  /* Body */
  .tp-body {
    padding-top: 2.5rem;
    padding-bottom: 4rem;
  }
  .tp-section {
    margin-top: 2.5rem;
  }
  .tp-section__title {
    font-family: 'Public Sans', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #0F1F3D;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .tp-section__icon {
    font-size: 24px;
    color: #2563eb;
  }
  .tp-text {
    font-size: 1rem;
    line-height: 1.75;
    color: #334155;
    margin-bottom: 1rem;
  }

  /* Key Rules */
  .tp-rules-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .tp-rules-list__item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    font-size: 0.95rem;
    line-height: 1.6;
    color: #1e293b;
  }
  .tp-rules-list__check {
    color: #22c55e;
    font-size: 20px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* Gender Gap Card */
  .tp-gap-card {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 1.5rem;
  }
  .tp-gap-card__header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .tp-gap-card__value {
    font-size: 2.5rem;
    font-weight: 800;
    color: #0F1F3D;
    letter-spacing: -0.03em;
  }
  .tp-gap-card__comparison {
    font-size: 0.9rem;
    color: #64748b;
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .tp-gap-card__arrow--up {
    color: #ef4444;
  }
  .tp-gap-card__arrow--down {
    color: #22c55e;
  }
  .tp-gap-card__bar-container {
    margin-top: 0.5rem;
  }
  .tp-gap-card__bar-track {
    position: relative;
    height: 8px;
    background: #e2e8f0;
    border-radius: 4px;
    overflow: visible;
  }
  .tp-gap-card__bar-fill {
    height: 100%;
    background: linear-gradient(90deg, #22c55e, #eab308, #ef4444);
    border-radius: 4px;
  }
  .tp-gap-card__bar-marker {
    position: absolute;
    top: -4px;
    width: 2px;
    height: 16px;
    background: #0F1F3D;
    border-radius: 1px;
  }
  .tp-gap-card__bar-labels {
    display: flex;
    justify-content: space-between;
    margin-top: 0.35rem;
    font-size: 0.7rem;
    color: #94a3b8;
  }
  .tp-gap-card__bar-avg {
    font-weight: 600;
    color: #0F1F3D;
  }

  /* Two Column */
  .tp-two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 2.5rem;
  }
  @media (max-width: 640px) {
    .tp-two-col {
      grid-template-columns: 1fr;
    }
  }
  .tp-info-card {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 1.5rem;
    margin-top: 0;
  }
  .tp-info-card__value {
    font-size: 1.5rem;
    font-weight: 800;
    color: #0F1F3D;
    margin-bottom: 0.5rem;
  }
  .tp-info-card__value--penalty {
    color: #ef4444;
  }
  .tp-info-card__note {
    font-size: 0.85rem;
    line-height: 1.6;
    color: #64748b;
  }

  /* Timeline */
  .tp-timeline {
    position: relative;
    padding-left: 2rem;
  }
  .tp-timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: #e2e8f0;
  }
  .tp-timeline__item {
    position: relative;
    padding-bottom: 1.5rem;
    display: flex;
    align-items: flex-start;
    gap: 0;
  }
  .tp-timeline__item:last-child {
    padding-bottom: 0;
  }
  .tp-timeline__dot {
    position: absolute;
    left: -2rem;
    top: 4px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 3px solid #e2e8f0;
    background: #fff;
    z-index: 1;
  }
  .tp-timeline__item--past .tp-timeline__dot {
    background: #22c55e;
    border-color: #22c55e;
  }
  .tp-timeline__item--upcoming .tp-timeline__dot {
    background: #eab308;
    border-color: #eab308;
  }
  .tp-timeline__item--future .tp-timeline__dot {
    background: #fff;
    border-color: #cbd5e1;
  }
  .tp-timeline__content {
