---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TLDRBox from '../../components/TLDRBox.astro';
import FAQSection from '../../components/FAQSection.astro';
import { languages, type Lang } from '../../i18n/ui';
import { fb, useTranslations } from '../../i18n/utils';

const i18n: Record<string, {
  h1: string;
  metaTitle: string;
  metaDesc: string;
  home: string;
  breadcrumb: string;
  introAnswer: string;
  tldr: string[];
  whyTitle: string;
  whyDesc: string;
  features: { title: string; desc: string; icon: string }[];
  forEmployersTitle: string;
  forEmployersDesc: string;
  forRecruitersTitle: string;
  forRecruitersDesc: string;
  apiTitle: string;
  apiDesc: string;
  waitlistTitle: string;
  waitlistDesc: string;
  waitlistCTA: string;
  emailPlaceholder: string;
  faq: { question: string; answer: string }[];
}> = {
  en: {
    h1: 'What Premium Salary Intelligence Does EuroSalary Offer?',
    metaTitle: 'Premium Salary Intelligence | EuroSalary.eu',
    metaDesc: 'Access premium European salary reports, employer benchmarking dashboards, recruiter API, and transparency compliance tools. Built for HR teams, recruiters, and enterprises.',
    home: 'Home',
    breadcrumb: 'Premium',
    introAnswer: 'EuroSalary Premium provides deep salary intelligence including downloadable reports, employer benchmarking, recruiter API access, and EU salary transparency compliance tools — all powered by Eurostat-verified data across 27 European countries.',
    tldr: [
      'Premium salary reports with seniority bands, tax-adjusted pay, and city comparisons',
      'Employer benchmarking dashboards and transparency compliance tools',
      'Recruiter API with real-time salary data across all EU markets',
    ],
    whyTitle: 'Why Premium?',
    whyDesc: 'Free EuroSalary covers country-level averages. Premium unlocks granular intelligence that drives hiring decisions, compensation planning, and EU regulatory compliance.',
