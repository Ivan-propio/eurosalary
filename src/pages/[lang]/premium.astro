      { title: 'Salary Reports', desc: 'Downloadable PDF reports with salary distribution, seniority bands, top cities, tax-adjusted take-home, and EU peer comparison.', icon: 'description' },
      { title: 'Employer Benchmarking', desc: 'Compare your internal salary bands against market rates. Role, city, and country benchmarks with pay equity insights.', icon: 'monitoring' },
      { title: 'Recruiter API', desc: 'Machine-readable salary data via REST API. Real-time access to salary ranges, compare endpoints, and city-level data.', icon: 'api' },
      { title: 'Transparency Toolkit', desc: 'EU Salary Transparency Directive compliance tools. Pay range recommendations, disclosure templates, and readiness scores.', icon: 'verified_user' },
      { title: 'Salary Alerts', desc: 'Automated notifications when salary data changes for your tracked roles, countries, or cities.', icon: 'notifications_active' },
      { title: 'Custom Reports', desc: 'Tailored compensation analysis for your industry, country mix, and role portfolio. Enterprise-grade insights.', icon: 'tune' },
    ],
    forEmployersTitle: 'For Employers & HR Teams',
    forEmployersDesc: 'Benchmark your compensation against European market rates. Ensure compliance with the EU Pay Transparency Directive. Make data-driven hiring and retention decisions.',
    forRecruitersTitle: 'For Recruiters & Staffing',
    forRecruitersDesc: 'Access real-time salary ranges for any role in any EU market. Present verified market data to candidates and clients. Close offers faster with benchmark confidence.',
    apiTitle: 'For Developers & Platforms',
    apiDesc: 'Integrate EuroSalary data into your HR software, ATS, or compensation platform via our REST API. JSON responses with methodology version, confidence scores, and freshness timestamps.',
    waitlistTitle: 'Join the Premium Waitlist',
    waitlistDesc: 'Premium launches Q3 2026. Join the waitlist for early access and founding-member pricing.',
    waitlistCTA: 'Join Waitlist',
    emailPlaceholder: 'Your work email',
    faq: [
      { question: 'When does EuroSalary Premium launch?', answer: 'Premium is scheduled for Q3 2026. Waitlist members get early access and founding-member pricing.' },
      { question: 'What data sources power Premium reports?', answer: 'The same Eurostat, OECD, and verified job posting data that powers our free platform, plus enhanced city-level datasets, seniority bands, and tax modeling.' },
      { question: 'Is the API available during the waitlist period?', answer: 'We are onboarding select API beta partners. Join the waitlist and indicate API interest to be considered for early access.' },
      { question: 'How does the Transparency Toolkit help with EU compliance?', answer: 'The toolkit provides country-specific compliance checklists, pay range recommendations based on market data, and readiness scoring against the EU Pay Transparency Directive requirements.' },
      { question: 'What is the pricing model?', answer: 'Premium will offer tiered plans: Solo Recruiter, Startup HR, Scaleup, and Enterprise. Pricing is based on data access level, API quota, and user seats.' },
    ],
  },
  fr: {
    h1: 'Quelle intelligence salariale Premium offre EuroSalary ?',
    metaTitle: 'Intelligence Salariale Premium | EuroSalary.eu',
    metaDesc: 'Accédez aux rapports salariaux premium, tableaux de bord de benchmarking employeur, API recruteur et outils de conformité à la transparence. Pour les équipes RH et entreprises.',
    home: 'Accueil',
    breadcrumb: 'Premium',
    introAnswer: 'EuroSalary Premium fournit une intelligence salariale approfondie comprenant des rapports téléchargeables, du benchmarking employeur, un accès API recruteur et des outils de conformité à la transparence salariale de l\'UE.',
    tldr: [
      'Rapports salariaux premium avec bandes de séniorité et comparaisons par ville',
      'Tableaux de bord de benchmarking employeur et outils de conformité',
      'API recruteur avec données salariales en temps réel sur tous les marchés de l\'UE',
    ],
    whyTitle: 'Pourquoi Premium ?',
    whyDesc: 'Le EuroSalary gratuit couvre les moyennes nationales. Premium déverrouille une intelligence granulaire pour les décisions de recrutement et la conformité réglementaire.',
