const c = fb(i18n, lang);
---

<BaseLayout title={c.metaTitle} description={c.metaDesc}>
  <section class="dash">
    <div class="dash__container">

      <!-- Loading state -->
      <div class="dash__loading" id="dash-loading">
        <div class="dash__loading-spinner"></div>
        <p>{c.loading}</p>
      </div>

      <!-- Main content (hidden until session verified) -->
      <div class="dash__content" id="dash-content">

        <!-- Header row -->
        <div class="dash__header">
          <div>
            <h1 class="dash__h1">{c.h1}</h1>
            <p class="dash__welcome" id="dash-welcome">{c.welcome}</p>
          </div>
          <button class="dash__logout" id="logout-btn">
            <span class="material-symbols-outlined">logout</span>
            {c.logoutBtn}
          </button>
        </div>

        <!-- Plan + Status row -->
        <div class="dash__grid">
          <div class="dash__card">
            <div class="dash__card-label">{c.planLabel}</div>
            <div class="dash__card-value">
              <span id="plan-name">{c.freePlan}</span>
              <span class="dash__badge" id="plan-badge">{c.freePlan}</span>
            </div>
          </div>
          <div class="dash__card">
            <div class="dash__card-label">{c.statusLabel}</div>
            <div class="dash__card-value">
              <span class="dash__status dash__status--active" id="plan-status">{c.statusActive}</span>
            </div>
          </div>
          <div class="dash__card">
            <div class="dash__card-label">{c.nextBilling}</div>
            <div class="dash__card-value">
              <span id="next-billing">&mdash;</span>
            </div>
          </div>
        </div>

        <!-- API Key section -->
        <div class="dash__section">
          <h2 class="dash__section-title">
            <span class="material-symbols-outlined">key</span>
            {c.apiKeyTitle}
          </h2>
          <p class="dash__section-desc">{c.apiKeyDesc}</p>
          <div class="dash__api-key-row">
            <code class="dash__api-key" id="api-key-value">&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;</code>
            <button class="dash__copy-btn" id="copy-key-btn">
              <span class="material-symbols-outlined">content_copy</span>
              <span class="dash__copy-text">{c.copyBtn}</span>
            </button>
          </div>
        </div>

        <!-- Usage section -->
        <div class="dash__section">
          <h2 class="dash__section-title">
            <span class="material-symbols-outlined">bar_chart</span>
            {c.usageTitle}
          </h2>
          <div class="dash__usage-row">
            <span class="dash__usage-label">{c.usageToday}</span>
            <span class="dash__usage-count">
              <span id="usage-current">0</span> {c.usageOf} <span id="usage-limit">100</span> {c.requestsLabel}
            </span>
          </div>
          <div class="dash__usage-bar">
            <div class="dash__usage-fill" id="usage-fill" style="width: 0%"></div>
          </div>
        </div>

        <!-- Billing History (loaded client-side, paid plans only) -->
        <div class="dash__section" id="billing-section" style="display:none">
          <h2 class="dash__section-title">
            <span class="material-symbols-outlined">receipt_long</span>
            <span id="billing-title">Billing History</span>
          </h2>
          <div id="billing-list" class="dash__billing-list">
            <p class="dash__section-desc" id="billing-empty">No payments yet.</p>
          </div>
        </div>

        <!-- Purchased Reports (loaded client-side, paid plans only) -->
        <div class="dash__section" id="reports-section" style="display:none">
          <h2 class="dash__section-title">
            <span class="material-symbols-outlined">description</span>
            <span id="reports-title">Your Reports</span>
          </h2>
          <div id="reports-list" class="dash__reports-list">
            <p class="dash__section-desc" id="reports-empty">No reports purchased.</p>
          </div>
        </div>

        <!-- Quick Links -->
        <div class="dash__section">
          <h2 class="dash__section-title">
            <span class="material-symbols-outlined">link</span>
            {c.quickLinks}
          </h2>
          <div class="dash__links-grid">
            <a href={`/${lang}/calculator/`} class="dash__link-card">
              <span class="material-symbols-outlined">download</span>
              {c.linkCsvExport}
            </a>
            <a href={`/${lang}/calculator/net-salary/`} class="dash__link-card">
              <span class="material-symbols-outlined">calculate</span>
              {c.linkNetCalc}
            </a>
            <a href={`/${lang}/salary-api/`} class="dash__link-card">
              <span class="material-symbols-outlined">api</span>
              {c.linkApiDocs}
            </a>
            <a href={`/${lang}/countries/`} class="dash__link-card">
              <span class="material-symbols-outlined">public</span>
              {c.linkCountries}
            </a>
          </div>
        </div>

        <!-- Action buttons -->
        <div class="dash__actions">
          <button class="dash__btn dash__btn--primary" id="manage-sub-btn">
            <span class="material-symbols-outlined">credit_card</span>
            {c.manageSubscription}
          </button>
          <a href={`/${lang}/pricing/`} class="dash__btn dash__btn--upgrade" id="upgrade-btn">
            <span class="material-symbols-outlined">bolt</span>
            {c.upgradePlan}
          </a>
        </div>
        <p class="dash__upgrade-desc" id="upgrade-desc">{c.upgradeDesc}</p>

      </div>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ lang, statusActive: c.statusActive, statusInactive: c.statusInactive, copiedBtn: c.copiedBtn, copyBtn: c.copyBtn, freePlan: c.freePlan }}>
  const loadingEl = document.getElementById('dash-loading');
  const contentEl = document.getElementById('dash-content');

  async function initDashboard() {
    try {
      const res = await fetch('/api/auth/session');
      if (!res.ok) {
        window.location.href = `/${lang}/login/`;
        return;
      }
      const data = await res.json();
      if (!data.user) {
        window.location.href = `/${lang}/login/`;
        return;
      }

      // Populate user data
      const welcomeEl = document.getElementById('dash-welcome');
      if (data.user.email) {
        welcomeEl.textContent += `, ${data.user.email}`;
      }

      // Plan info — session returns { plan, entitlements: { plan, subscription_status, current_period_end, ... } }
      const plan = data.plan || data.entitlements?.plan || 'free';
      const planNameMap = { pro: 'Professional', business: 'Business', api_dev: 'API Developer', api_biz: 'API Business', employer_starter: 'Employer Starter', employer_pro: 'Employer Pro' };
      const planName = planNameMap[plan] || (plan === 'free' ? freePlan : plan);
      document.getElementById('plan-name').textContent = planName;
      document.getElementById('plan-badge').textContent = planName;

      // Store stripe_customer_id for manage subscription
      if (data.entitlements?.stripe_customer_id) {
        window.__stripeCustomerId = data.entitlements.stripe_customer_id;
      }

      // Status
      const statusEl = document.getElementById('plan-status');
      const subStatus = data.entitlements?.subscription_status;
      const isActive = subStatus === 'active' || subStatus === 'trialing' || plan === 'free';
      statusEl.textContent = isActive ? statusActive : statusInactive;
      statusEl.className = `dash__status ${isActive ? 'dash__status--active' : 'dash__status--inactive'}`;

      // Next billing
      if (data.entitlements?.current_period_end) {
        const date = new Date(data.entitlements.current_period_end);
        document.getElementById('next-billing').textContent = date.toLocaleDateString();
      }

      // API key
      if (data.api_key) {
        document.getElementById('api-key-value').textContent = data.api_key;
      }

      // Usage
      if (data.usage) {
        const current = data.usage.today || 0;
        const limit = data.usage.limit || 100;
        document.getElementById('usage-current').textContent = current;
        document.getElementById('usage-limit').textContent = limit;
        const pct = Math.min((current / limit) * 100, 100);
        document.getElementById('usage-fill').style.width = `${pct}%`;
        if (pct > 80) document.getElementById('usage-fill').classList.add('dash__usage-fill--warn');
      }

      // Hide upgrade section for paid plans + show paid sections
      if (plan !== 'free') {
        document.getElementById('upgrade-btn').style.display = 'none';
        document.getElementById('upgrade-desc').style.display = 'none';
        // Load billing history & reports for paid users
        loadBillingHistory();
        loadReports();
      }

      // i18n for dynamic sections
      const dashI18n = {
        en: { billing: 'Billing History', reports: 'Your Reports', noPayments: 'No payments yet.', noReports: 'No reports purchased.', download: 'Download', expired: 'Expired', amount: 'Amount', date: 'Date', status: 'Status' },
        fr: { billing: 'Historique de facturation', reports: 'Vos rapports', noPayments: 'Aucun paiement.', noReports: 'Aucun rapport acheté.', download: 'Télécharger', expired: 'Expiré', amount: 'Montant', date: 'Date', status: 'Statut' },
        de: { billing: 'Abrechnungsverlauf', reports: 'Ihre Berichte', noPayments: 'Keine Zahlungen.', noReports: 'Keine Berichte gekauft.', download: 'Herunterladen', expired: 'Abgelaufen', amount: 'Betrag', date: 'Datum', status: 'Status' },
        es: { billing: 'Historial de facturación', reports: 'Tus informes', noPayments: 'Sin pagos.', noReports: 'Sin informes comprados.', download: 'Descargar', expired: 'Expirado', amount: 'Importe', date: 'Fecha', status: 'Estado' },
      };
      const di = dashI18n[lang] || dashI18n.en;
      document.getElementById('billing-title').textContent = di.billing;
      document.getElementById('reports-title').textContent = di.reports;
      document.getElementById('billing-empty').textContent = di.noPayments;
      document.getElementById('reports-empty').textContent = di.noReports;

      loadingEl.style.display = 'none';
      contentEl.style.display = 'block';

    } catch (err) {
      window.location.href = `/${lang}/login/`;
    }
  }

  initDashboard();

  // Copy API key
  document.getElementById('copy-key-btn').addEventListener('click', async () => {
    const key = document.getElementById('api-key-value').textContent;
    try {
      await navigator.clipboard.writeText(key);
      const textEl = document.getElementById('copy-key-btn').querySelector('.dash__copy-text');
      textEl.textContent = copiedBtn;
      setTimeout(() => { textEl.textContent = copyBtn; }, 2000);
    } catch (e) { /* clipboard not available */ }
  });

  // Manage subscription — fetch stripe_customer_id from session, then open portal
  document.getElementById('manage-sub-btn').addEventListener('click', async () => {
    try {
      let customerId = window.__stripeCustomerId;
      if (!customerId) {
        // Fallback: fetch from session
        const sessRes = await fetch('/api/auth/session');
        const sessData = await sessRes.json();
        customerId = sessData.entitlements?.stripe_customer_id;
      }
      if (!customerId) {
        alert('No subscription found. Please contact support.');
        return;
      }
      const lang = window.location.pathname.split('/')[1] || 'en';
      const res = await fetch('/api/customer-portal', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ customerId, lang }),
      });
      const data = await res.json();
      if (data.url) window.location.href = data.url;
      else alert(data.error || 'Unable to open billing portal.');
    } catch (e) {
      alert('Error opening billing portal. Please try again.');
    }
  });

  // Logout
  document.getElementById('logout-btn').addEventListener('click', async () => {
    try {
      await fetch('/api/auth/logout', { method: 'POST' });
    } catch (e) { /* logout error */ }
    window.location.href = `/${lang}/login/`;
  });

  // Load billing history for paid users
  async function loadBillingHistory() {
    try {
      const res = await fetch('/api/dashboard/billing-history');
      if (!res.ok) return;
      const { data } = await res.json();
      const section = document.getElementById('billing-section');
      const list = document.getElementById('billing-list');
      if (!data || data.length === 0) {
        section.style.display = 'block';
        return;
      }
      const emptyEl = document.getElementById('billing-empty');
      if (emptyEl) emptyEl.remove();
      list.innerHTML = data.slice(0, 10).map(p => {
        const amt = (p.amount_eur / 100).toFixed(2);
        const date = new Date(p.created_at).toLocaleDateString();
        const statusClass = p.status === 'succeeded' ? 'dash__status--active' : 'dash__status--inactive';
        return `<div class="dash__billing-row">
          <span class="dash__billing-desc">${p.description || 'Payment'}</span>
          <span class="dash__billing-amount">€${amt}</span>
          <span class="dash__billing-date">${date}</span>
          <span class="dash__status ${statusClass}">${p.status}</span>
        </div>`;
      }).join('');
      section.style.display = 'block';
    } catch (e) { /* billing load failed silently */ }
  }

  // Load purchased reports for paid users
  async function loadReports() {
    try {
      const res = await fetch('/api/dashboard/reports');
      if (!res.ok) return;
      const { data } = await res.json();
      const section = document.getElementById('reports-section');
      const list = document.getElementById('reports-list');
      if (!data || data.length === 0) {
        section.style.display = 'block';
        return;
      }
      const emptyEl = document.getElementById('reports-empty');
      if (emptyEl) emptyEl.remove();
      list.innerHTML = data.map(r => {
        const date = new Date(r.created_at).toLocaleDateString();
        const country = r.country_code ? r.country_code.toUpperCase() : 'ALL';
        const isAvailable = r.status === 'available';
        const downloadBtn = isAvailable
          ? `<a href="/api/dashboard/reports/download?token=${r.download_token}" class="dash__report-dl" target="_blank">
               <span class="material-symbols-outlined" style="font-size:14px">download</span> PDF
             </a>`
          : `<span class="dash__status dash__status--inactive">${r.status}</span>`;
        return `<div class="dash__report-row">
          <span class="dash__report-country">${country}</span>
          <span class="dash__report-date">${date}</span>
          ${downloadBtn}
        </div>`;
      }).join('');
      section.style.display = 'block';
    } catch (e) { /* reports load failed silently */ }
  }
</script>

