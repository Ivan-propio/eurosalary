---

<BaseLayout title={c.metaTitle} description={c.metaDesc}>
  <section class="auth">
    <div class="auth__card">
      <div class="auth__header">
        <a href={`/${lang}/`} class="auth__logo" aria-label="EuroSalary.eu — Home">
          Euro<span>Salary</span><small>.eu</small>
        </a>
        <h1 class="auth__title">{c.h1}</h1>
        <p class="auth__subtitle">{c.subtitle}</p>
      </div>

      <form class="auth__form" id="forgot-form" novalidate>
        <div class="auth__field">
          <label for="forgot-email">{c.emailLabel}</label>
          <div class="auth__input-wrap">
            <span class="material-symbols-outlined">mail</span>
            <input type="email" id="forgot-email" name="email" placeholder={c.emailPlaceholder} required autocomplete="email" />
          </div>
        </div>

        <div class="auth__error" id="forgot-error" role="alert" aria-live="polite"></div>

        <div class="auth__success" id="forgot-success" role="status" aria-live="polite">
          <span class="material-symbols-outlined">check_circle</span>
          <span>{c.successMsg}</span>
        </div>

        <button type="submit" class="auth__submit" id="forgot-btn">
          <span class="auth__submit-text">{c.submitBtn}</span>
          <span class="auth__spinner"></span>
        </button>
      </form>

      <p class="auth__alt">
        <a href={`/${lang}/login/`}>&larr; {c.backToLogin}</a>
      </p>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ lang, errorNetwork: c.errorNetwork, errorGeneric: c.errorGeneric }}>
  const form = document.getElementById('forgot-form');
  const emailInput = document.getElementById('forgot-email');
  const errorEl = document.getElementById('forgot-error');
  const successEl = document.getElementById('forgot-success');
  const submitBtn = document.getElementById('forgot-btn');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.textContent = '';
    errorEl.classList.remove('auth__error--show');
    successEl.classList.remove('auth__success--show');
    submitBtn.classList.add('auth__submit--loading');
    submitBtn.disabled = true;

    const email = emailInput.value.trim();

    try {
      const res = await fetch('/api/auth/forgot-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, lang }),
      });

      if (res.ok) {
        successEl.classList.add('auth__success--show');
        form.querySelector('.auth__field').style.display = 'none';
        submitBtn.style.display = 'none';
      } else {
        errorEl.textContent = errorGeneric;
        errorEl.classList.add('auth__error--show');
      }
    } catch (err) {
      errorEl.textContent = err.message.includes('fetch') ? errorNetwork : errorGeneric;
      errorEl.classList.add('auth__error--show');
    } finally {
      submitBtn.classList.remove('auth__submit--loading');
      submitBtn.disabled = false;
    }
  });
</script>

<style>
  .auth {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    background:
      radial-gradient(ellipse at 30% 20%, rgba(37, 99, 235, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse at 70% 80%, rgba(37, 99, 235, 0.05) 0%, transparent 50%),
      var(--color-primary-container, #0F1F3D);
  }

  .auth__card {
    width: 100%;
    max-width: 440px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 2.5rem 2rem;
    backdrop-filter: blur(20px);
  }

  .auth__header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .auth__logo {
    font-family: var(--font-heading, 'Public Sans', sans-serif);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-white, #fff);
    text-decoration: none;
    letter-spacing: -0.02em;
  }
  .auth__logo span { color: var(--color-secondary, #2563EB); }
  .auth__logo small { font-size: 0.6em; opacity: 0.5; font-weight: 400; }

  .auth__title {
    font-family: var(--font-heading, 'Public Sans', sans-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-white, #fff);
    margin: 1.25rem 0 0.5rem;
  }

  .auth__subtitle {
    font-size: 0.9rem;
    color: rgba(203, 213, 225, 0.7);
    line-height: 1.5;
  }

