const c = fb(i18n, lang);
---

<BaseLayout title={c.metaTitle} description={c.processingDesc}>
  <section class="auth">
    <div class="auth__card">
      <div class="auth__header">
        <a href={`/${lang}/`} class="auth__logo" aria-label="EuroSalary.eu">
          Euro<span>Salary</span><small>.eu</small>
        </a>
      </div>

      <div class="callback__status" id="callback-processing">
        <div class="callback__spinner"></div>
        <h1 class="callback__title">{c.processing}</h1>
        <p class="callback__desc">{c.processingDesc}</p>
      </div>

      <div class="callback__status callback__status--hidden" id="callback-redirecting">
        <div class="callback__spinner"></div>
        <h1 class="callback__title">{c.redirecting}</h1>
      </div>

      <div class="callback__status callback__status--hidden" id="callback-error">
        <div class="callback__icon-error">
          <span class="material-symbols-outlined">error</span>
        </div>
        <h1 class="callback__title callback__title--error">{c.error}</h1>
        <p class="callback__desc">{c.errorDesc}</p>
        <a href={`/${lang}/login/`} class="callback__btn">{c.backToLogin}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ lang }}>
  (function () {
    var hash = window.location.hash.substring(1);
    var params = new URLSearchParams(hash);

    var accessToken = params.get('access_token');
    var refreshToken = params.get('refresh_token');
    var expiresIn = params.get('expires_in');
    var type = params.get('type');

    var processingEl = document.getElementById('callback-processing');
    var redirectingEl = document.getElementById('callback-redirecting');
    var errorEl = document.getElementById('callback-error');

    function showError() {
      processingEl.classList.add('callback__status--hidden');
      redirectingEl.classList.add('callback__status--hidden');
      errorEl.classList.remove('callback__status--hidden');
    }

    function showRedirecting() {
      processingEl.classList.add('callback__status--hidden');
      errorEl.classList.add('callback__status--hidden');
      redirectingEl.classList.remove('callback__status--hidden');
    }

    if (!accessToken || !refreshToken) {
      showError();
      return;
    }

    fetch('/api/auth/callback', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        access_token: accessToken,
        refresh_token: refreshToken,
        expires_in: expiresIn ? parseInt(expiresIn, 10) : 3600,
      }),
    })
      .then(function (res) {
        if (!res.ok) throw new Error('callback failed');
        return res.json();
      })
      .then(function () {
        showRedirecting();

        // Clear hash from URL
        if (window.history.replaceState) {
          window.history.replaceState(null, '', window.location.pathname);
        }

        if (type === 'recovery') {
          window.location.href = '/' + lang + '/auth/reset-password/';
        } else {
          window.location.href = '/' + lang + '/dashboard/';
        }
      })
      .catch(function () {
        showError();
      });
  })();
</script>

<style>
  .auth {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    background:
      radial-gradient(ellipse at 30% 20%, rgba(37, 99, 235, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse at 70% 80%, rgba(37, 99, 235, 0.05) 0%, transparent 50%),
      var(--color-primary-container, #0F1F3D);
  }

  .auth__card {
    width: 100%;
    max-width: 440px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 2.5rem 2rem;
    backdrop-filter: blur(20px);
  }

  .auth__header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .auth__logo {
    font-family: var(--font-heading, 'Public Sans', sans-serif);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-white, #fff);
    text-decoration: none;
    letter-spacing: -0.02em;
  }
  .auth__logo span { color: var(--color-secondary, #2563EB); }
  .auth__logo small { font-size: 0.6em; opacity: 0.5; font-weight: 400; }

  .callback__status {
    text-align: center;
  }

  .callback__status--hidden {
    display: none;
  }

  .callback__spinner {
    width: 40px;
    height: 40px;
    margin: 0 auto 1.25rem;
    border: 3px solid rgba(255, 255, 255, 0.1);
    border-top-color: var(--color-secondary, #2563EB);
    border-radius: 50%;
    animation: callback-spin 0.7s linear infinite;
  }

  @keyframes callback-spin {
    to { transform: rotate(360deg); }
  }

  .callback__icon-error {
    margin: 0 auto 1rem;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(248, 113, 113, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .callback__icon-error .material-symbols-outlined {
    font-size: 28px;
    color: #f87171;
  }

  .callback__title {
    font-family: var(--font-heading, 'Public Sans', sans-serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-white, #fff);
    margin: 0 0 0.5rem;
  }

  .callback__title--error {
    color: #f87171;
  }

  .callback__desc {
    font-size: 0.9rem;
    color: rgba(203, 213, 225, 0.7);
    line-height: 1.5;
    margin: 0 0 1.5rem;
  }

  .callback__btn {
    display: inline-block;
    padding: 0.7rem 1.5rem;
    background: var(--color-secondary, #2563EB);
    color: var(--color-white, #fff);
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s;
  }
  .callback__btn:hover {
    background: #1d4ed8;
  }

  @media (max-width: 480px) {
    .auth__card { padding: 2rem 1.25rem; }
  }
</style>
