export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = fb(i18n, lang);
---
<BaseLayout title={t.metaTitle} description={t.metaDesc} lang={lang}>

  <!-- Breadcrumbs -->
  <nav class="max-w-5xl mx-auto px-4 pt-6 text-sm text-slate-400" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2">
      <li><a href={`/${lang}/`} class="hover:text-blue-400 transition-colors">{t.home}</a></li>
      <li class="text-slate-600">/</li>
      <li><a href={`/${lang}/partners/`} class="hover:text-blue-400 transition-colors">{t.partners}</a></li>
      <li class="text-slate-600">/</li>
      <li class="text-slate-300">{t.breadcrumb}</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-4 py-12 text-center">
    <h1 class="text-3xl md:text-4xl font-bold text-white mb-4 font-['Public_Sans']">{t.h1}</h1>
    <p class="text-lg text-slate-300 max-w-3xl mx-auto mb-6">{t.introAnswer}</p>
    <p class="text-slate-400 max-w-2xl mx-auto">{t.heroSubtitle}</p>
  </section>

  <!-- TL;DR -->
  <TLDRBox items={t.tldr} />

  <!-- Use Cases -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-white text-center mb-8 font-['Public_Sans']">{t.whyTitle}</h2>
    <div class="grid md:grid-cols-2 gap-8">
      {t.useCases.map((uc) => (
        <div class="bg-[#162A4A] border border-slate-700/50 rounded-xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <span class="material-symbols-outlined text-blue-400 text-3xl">{uc.icon}</span>
            <h3 class="text-xl font-bold text-white font-['Public_Sans']">{uc.title}</h3>
          </div>
          <p class="text-slate-300 text-sm leading-relaxed">{uc.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Integration Architecture -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-white text-center mb-2 font-['Public_Sans']">{t.archTitle}</h2>
    <p class="text-slate-400 text-center mb-10 max-w-2xl mx-auto">{t.archDesc}</p>
    <div class="grid md:grid-cols-4 gap-6">
      {t.archSteps.map((s, i) => (
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-blue-600 text-white text-xl font-bold flex items-center justify-center mx-auto mb-4">{i + 1}</div>
          <h3 class="text-lg font-bold text-white mb-2">{s.step}</h3>
          <p class="text-slate-400 text-sm">{s.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Code Example -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-white text-center mb-2 font-['Public_Sans']">{t.codeTitle}</h2>
    <p class="text-slate-400 text-center mb-8">{t.codeDesc}</p>
    <div class="bg-[#0a1628] border border-slate-700/50 rounded-xl p-6 overflow-x-auto">
      <pre class="text-sm text-slate-300 font-mono leading-relaxed"><code><span class="text-blue-400">GET</span> https://eurosalary.eu/api/v1/salary?country=<span class="text-green-400">DE</span>&job=<span class="text-green-400">software-engineer</span>&level=<span class="text-green-400">mid</span>
<span class="text-slate-500">Authorization: Bearer YOUR_API_KEY</span>

<span class="text-slate-500">// Response (200 OK)</span>
&#123;
  "<span class="text-blue-300">country</span>": "<span class="text-green-400">DE</span>",
  "<span class="text-blue-300">job</span>": "<span class="text-green-400">software-engineer</span>",
  "<span class="text-blue-300">level</span>": "<span class="text-green-400">mid</span>",
  "<span class="text-blue-300">gross_annual</span>": &#123;
    "<span class="text-blue-300">median</span>": <span class="text-amber-400">62400</span>,
    "<span class="text-blue-300">p25</span>": <span class="text-amber-400">54200</span>,
    "<span class="text-blue-300">p75</span>": <span class="text-amber-400">73800</span>
  &#125;,
  "<span class="text-blue-300">net_annual_estimate</span>": <span class="text-amber-400">41500</span>,
  "<span class="text-blue-300">currency</span>": "<span class="text-green-400">EUR</span>",
  "<span class="text-blue-300">cost_of_living_index</span>": <span class="text-amber-400">82.3</span>,
  "<span class="text-blue-300">minimum_wage_annual</span>": <span class="text-amber-400">24924</span>,
  "<span class="text-blue-300">confidence</span>": <span class="text-amber-400">0.92</span>,
  "<span class="text-blue-300">sources</span>": ["<span class="text-green-400">eurostat</span>", "<span class="text-green-400">job_postings</span>"],
  "<span class="text-blue-300">last_updated</span>": "<span class="text-green-400">2026-04-01</span>"
&#125;</code></pre>
    </div>
  </section>

  <!-- Technical Specs -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-white text-center mb-8 font-['Public_Sans']">{t.specsTitle}</h2>
    <div class="max-w-3xl mx-auto bg-[#162A4A] border border-slate-700/50 rounded-xl overflow-hidden">
      <table class="w-full">
        <tbody>
          {t.specs.map((s, i) => (
            <tr class={i % 2 === 0 ? 'bg-[#162A4A]' : 'bg-[#1a3055]'}>
              <td class="px-6 py-3 text-sm text-slate-400 font-medium">{s.label}</td>
              <td class="px-6 py-3 text-sm text-white font-semibold text-right">{s.value}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Revenue Share -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-white text-center mb-2 font-['Public_Sans']">{t.revenueTitle}</h2>
    <p class="text-slate-400 text-center mb-8 max-w-2xl mx-auto">{t.revenueDesc}</p>
    <div class="max-w-3xl mx-auto bg-[#162A4A] border border-slate-700/50 rounded-xl p-8">
      <ul class="space-y-4">
        {t.revenueItems.map((item) => (
          <li class="flex items-start gap-3 text-slate-300">
            <span class="material-symbols-outlined text-green-400 text-base mt-0.5">check_circle</span>
            <span class="text-sm">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Sandbox -->
  <section class="max-w-5xl mx-auto px-4 py-12 text-center">
    <div class="bg-gradient-to-r from-blue-600/20 to-blue-400/10 border border-blue-500/30 rounded-xl p-8 max-w-3xl mx-auto">
      <span class="material-symbols-outlined text-blue-400 text-4xl mb-4">science</span>
      <h2 class="text-2xl font-bold text-white mb-4 font-['Public_Sans']">{t.sandboxTitle}</h2>
      <p class="text-slate-300 text-sm">{t.sandboxDesc}</p>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="max-w-3xl mx-auto px-4 py-12" id="apply">
    <h2 class="text-2xl font-bold text-white text-center mb-2 font-['Public_Sans']">{t.contactTitle}</h2>
    <p class="text-slate-400 text-center mb-8">{t.contactDesc}</p>
    <form id="api-partner-form" class="bg-[#162A4A] border border-slate-700/50 rounded-xl p-8 space-y-6">
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm text-slate-400 mb-1">{t.formLabels.company}</label>
          <input type="text" name="company" required class="w-full bg-[#0F1F3D] border border-slate-600 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none" />
        </div>
        <div>
          <label class="block text-sm text-slate-400 mb-1">{t.formLabels.email}</label>
          <input type="email" name="email" required class="w-full bg-[#0F1F3D] border border-slate-600 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none" />
        </div>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm text-slate-400 mb-1">{t.formLabels.integrationType}</label>
          <select name="integration_type" required class="w-full bg-[#0F1F3D] border border-slate-600 rounded-lg px-4 py-2.5 text-white focus:border-blue-500 focus:outline-none">
            <option value="" disabled selected>--</option>
            {t.integrationOptions.map((opt) => (
              <option value={opt}>{opt}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="block text-sm text-slate-400 mb-1">{t.formLabels.currentUsers}</label>
          <input type="text" name="current_users" class="w-full bg-[#0F1F3D] border border-slate-600 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none" />
        </div>
      </div>
      <div>
        <label class="block text-sm text-slate-400 mb-1">{t.formLabels.message}</label>
        <textarea name="message" rows="4" class="w-full bg-[#0F1F3D] border border-slate-600 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none resize-none"></textarea>
      </div>
      <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg transition-colors">
        {t.formLabels.submit}
      </button>
      <div id="form-status" class="text-center text-sm hidden"></div>
    </form>
  </section>

  <!-- FAQ -->
  <FAQSection items={t.faq} />

  <!-- Schema Markup -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": t.h1,
    "description": t.metaDesc,
    "dateModified": "2026-04-05",
    "publisher": { "@type": "Organization", "name": "EuroSalary.eu" },
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": t.faq.map((f) => ({
      "@type": "Question",
      "name": f.question,
      "acceptedAnswer": { "@type": "Answer", "text": f.answer },
    })),
  })} />

  <!-- hreflang -->
  {Object.keys(languages).map((l) => (
    <link slot="head" rel="alternate" hreflang={l} href={`https://eurosalary.eu/${l}/partners/api/`} />
  ))}

  <!-- Form Script -->
  <script>
    const form = document.getElementById('api-partner-form') as HTMLFormElement;
    const status = document.getElementById('form-status') as HTMLElement;
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form));
      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ...data, type: 'partner', source: 'api-partnership' }),
        });
        if (res.ok) {
          status.textContent = 'Application submitted! We will be in touch within 24 hours.';
          status.className = 'text-center text-sm text-green-400';
          form.reset();
        } else {
          status.textContent = 'Something went wrong. Please try again.';
          status.className = 'text-center text-sm text-red-400';
        }
      } catch {
        status.textContent = 'Network error. Please try again.';
        status.className = 'text-center text-sm text-red-400';
      }
    });
  </script>

</BaseLayout>
