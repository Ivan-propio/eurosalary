export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = fb(i18n, lang);
---
<BaseLayout title={t.metaTitle} description={t.metaDesc} lang={lang}>

  <!-- Breadcrumbs -->
  <nav class="max-w-5xl mx-auto px-4 pt-6 text-sm text-slate-400" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2">
      <li><a href={`/${lang}/`} class="hover:text-blue-400 transition-colors">{t.home}</a></li>
      <li class="text-slate-600">/</li>
      <li><a href={`/${lang}/partners/`} class="hover:text-blue-400 transition-colors">{t.partners}</a></li>
      <li class="text-slate-600">/</li>
      <li class="text-slate-300">{t.breadcrumb}</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-4 py-12 text-center">
    <h1 class="text-3xl md:text-4xl font-bold text-white mb-4 font-['Public_Sans']">{t.h1}</h1>
    <p class="text-lg text-slate-300 max-w-3xl mx-auto mb-6">{t.introAnswer}</p>
    <p class="text-slate-400 max-w-2xl mx-auto">{t.heroSubtitle}</p>
  </section>

  <!-- TL;DR -->
  <TLDRBox items={t.tldr} />

  <!-- What Data Is Available -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-white text-center mb-2 font-['Public_Sans']">{t.dataTitle}</h2>
    <p class="text-slate-400 text-center mb-8 max-w-2xl mx-auto">{t.dataDesc}</p>
    <div class="max-w-3xl mx-auto bg-[#162A4A] border border-slate-700/50 rounded-xl overflow-hidden">
      <table class="w-full">
        <tbody>
          {t.dataPoints.map((dp, i) => (
            <tr class={i % 2 === 0 ? 'bg-[#162A4A]' : 'bg-[#1a3055]'}>
              <td class="px-6 py-3 text-sm text-slate-400 font-medium">{dp.label}</td>
              <td class="px-6 py-3 text-sm text-white font-semibold text-right">{dp.value}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Licensing Tiers -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-white text-center mb-2 font-['Public_Sans']">{t.tiersTitle}</h2>
    <p class="text-slate-400 text-center mb-10 max-w-2xl mx-auto">{t.tiersDesc}</p>
    <div class="grid md:grid-cols-3 gap-8">
      {t.tiers.map((tier, i) => (
        <div class={`bg-[#162A4A] border rounded-xl p-6 flex flex-col ${i === 1 ? 'border-blue-500 ring-1 ring-blue-500/50' : 'border-slate-700/50'}`}>
          <h3 class="text-xl font-bold text-white mb-1 font-['Public_Sans']">{tier.name}</h3>
          <div class="text-2xl font-bold text-blue-400 mb-1">{tier.price.includes('Custom') || tier.price.includes('mesure') || tier.price.includes('Individuell') || tier.price.includes('Personalizado') || tier.price.includes('Personalizzato') || tier.price.includes('maat') || tier.price.includes('Indywidualnie') || tier.price.includes('Personalizat') || tier.price.includes('Individualni') || tier.price.includes('Anpassat') || tier.price.includes('Tilpasset') || tier.price.includes('Mukautettu') || tier.price.includes('Exatomikeymeno') || tier.price.includes('Egyedi') || tier.price.includes('Individualne') || tier.price.includes('Individualno') || tier.price.includes('Prilagodeno') || tier.price.includes('meri') || tier.price.includes('Individualiai') || tier.price.includes('Individuali') || tier.price.includes('Kohandatud') || tier.price.includes('Personalizzat') || tier.price.includes('Saincheaptha') ? tier.price : `\u20ac${tier.price}`}</div>
          <div class="text-sm text-slate-400 mb-6">{tier.frequency}</div>
          <ul class="space-y-3 flex-1">
            {tier.features.map((f) => (
              <li class="flex items-start gap-2 text-sm text-slate-300">
                <span class="material-symbols-outlined text-green-400 text-base mt-0.5">check_circle</span>
                <span>{f}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- Delivery Formats -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-white text-center mb-8 font-['Public_Sans']">{t.formatsTitle}</h2>
    <div class="grid md:grid-cols-3 gap-8">
      {t.formats.map((fmt) => (
        <div class="bg-[#162A4A] border border-slate-700/50 rounded-xl p-6 text-center">
          <span class="material-symbols-outlined text-blue-400 text-4xl mb-4">{fmt.icon}</span>
          <h3 class="text-lg font-bold text-white mb-3 font-['Public_Sans']">{fmt.name}</h3>
          <p class="text-slate-400 text-sm">{fmt.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Use Cases -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-white text-center mb-8 font-['Public_Sans']">{t.useCasesTitle}</h2>
    <div class="grid md:grid-cols-2 gap-8">
      {t.useCases.map((uc) => (
        <div class="bg-[#162A4A] border border-slate-700/50 rounded-xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <span class="material-symbols-outlined text-blue-400 text-3xl">{uc.icon}</span>
            <h3 class="text-xl font-bold text-white font-['Public_Sans']">{uc.title}</h3>
          </div>
          <p class="text-slate-300 text-sm leading-relaxed">{uc.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Contact Form -->
  <section class="max-w-3xl mx-auto px-4 py-12" id="apply">
    <h2 class="text-2xl font-bold text-white text-center mb-2 font-['Public_Sans']">{t.contactTitle}</h2>
    <p class="text-slate-400 text-center mb-8">{t.contactDesc}</p>
    <form id="data-licensing-form" class="bg-[#162A4A] border border-slate-700/50 rounded-xl p-8 space-y-6">
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm text-slate-400 mb-1">{t.formLabels.company}</label>
          <input type="text" name="company" required class="w-full bg-[#0F1F3D] border border-slate-600 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none" />
        </div>
        <div>
          <label class="block text-sm text-slate-400 mb-1">{t.formLabels.email}</label>
          <input type="email" name="email" required class="w-full bg-[#0F1F3D] border border-slate-600 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none" />
        </div>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm text-slate-400 mb-1">{t.formLabels.useCase}</label>
          <select name="use_case" required class="w-full bg-[#0F1F3D] border border-slate-600 rounded-lg px-4 py-2.5 text-white focus:border-blue-500 focus:outline-none">
            <option value="" disabled selected>--</option>
            {t.useCaseOptions.map((opt) => (
              <option value={opt}>{opt}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="block text-sm text-slate-400 mb-1">{t.formLabels.volumeEstimate}</label>
          <input type="text" name="volume_estimate" class="w-full bg-[#0F1F3D] border border-slate-600 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none" />
        </div>
      </div>
      <div>
        <label class="block text-sm text-slate-400 mb-1">{t.formLabels.message}</label>
        <textarea name="message" rows="4" class="w-full bg-[#0F1F3D] border border-slate-600 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none resize-none"></textarea>
      </div>
      <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg transition-colors">
        {t.formLabels.submit}
      </button>
      <div id="form-status" class="text-center text-sm hidden"></div>
    </form>
  </section>

  <!-- FAQ -->
  <FAQSection items={t.faq} />

  <!-- Schema Markup -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": t.h1,
    "description": t.metaDesc,
    "dateModified": "2026-04-05",
    "publisher": { "@type": "Organization", "name": "EuroSalary.eu" },
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": t.faq.map((f) => ({
      "@type": "Question",
      "name": f.question,
      "acceptedAnswer": { "@type": "Answer", "text": f.answer },
    })),
  })} />

  <!-- hreflang -->
  {Object.keys(languages).map((l) => (
    <link slot="head" rel="alternate" hreflang={l} href={`https://eurosalary.eu/${l}/partners/data-licensing/`} />
  ))}

  <!-- Form Script -->
  <script>
    const form = document.getElementById('data-licensing-form') as HTMLFormElement;
    const status = document.getElementById('form-status') as HTMLElement;
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form));
      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ...data, type: 'partner', source: 'data-licensing' }),
        });
        if (res.ok) {
          status.textContent = 'Request submitted! We will be in touch within 24 hours.';
          status.className = 'text-center text-sm text-green-400';
          form.reset();
        } else {
          status.textContent = 'Something went wrong. Please try again.';
          status.className = 'text-center text-sm text-red-400';
        }
      } catch {
        status.textContent = 'Network error. Please try again.';
        status.className = 'text-center text-sm text-red-400';
      }
    });
  </script>

</BaseLayout>
