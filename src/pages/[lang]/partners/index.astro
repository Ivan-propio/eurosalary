      { question: 'Cuanto puedo ganar como socio afiliado?', answer: 'Los socios afiliados ganan 25% de comision recurrente en cada suscripcion referida. Con nuestro plan Premium a 49\u20ac/mes, eso son 12,25\u20ac por cliente por mes durante toda la vida de la suscripcion. Los mejores afiliados ganan mas de 2.000\u20ac/mes en comisiones recurrentes.' },
      { question: 'Hay un requisito minimo de trafico para unirse?', answer: 'No. Aceptamos socios de todos los tamanos, desde coaches de carrera individuales hasta grandes plataformas de RRHH. El unico requisito es que su audiencia tenga interes en datos salariales europeos.' },
      { question: 'Como funciona la asociacion de datos?', answer: 'Los socios de datos contribuyen datos salariales anonimizados (sin informacion de identificacion personal) desde sus plataformas. A cambio, reciben acceso Premium gratuito, atribucion en nuestra pagina de metodologia y acceso anticipado a nuevos conjuntos de datos.' },
      { question: 'Que soporte de integracion proporcionan?', answer: 'Los socios de integracion reciben una clave API dedicada con limites elevados, soporte tecnico prioritario, desarrollo de endpoints personalizados y acceso a nuestro entorno de staging.' },
      { question: 'Como y cuando se pagan las comisiones?', answer: 'Las comisiones se calculan el 1 de cada mes y se pagan antes del 15. Admitimos transferencias bancarias (SEPA para socios UE) y PayPal. El umbral minimo de pago es de 50\u20ac.' },
      { question: 'Puedo combinar varios tipos de asociacion?', answer: 'Por supuesto. Muchos de nuestros socios mas exitosos operan como afiliados y socios de contenido simultaneamente, o como socios de datos e integracion. Los beneficios de cada tipo se acumulan.' },
    ],
  },
};

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = fb(i18n, lang);
const countryFlags: Record<string, string> = {
  DE: '\ud83c\udde9\ud83c\uddea', FR: '\ud83c\uddeb\ud83c\uddf7', ES: '\ud83c\uddea\ud83c\uddf8', NL: '\ud83c\uddf3\ud83c\uddf1', BE: '\ud83c\udde7\ud83c\uddea',
  IT: '\ud83c\uddee\ud83c\uddf9', PT: '\ud83c\uddf5\ud83c\uddf9', PL: '\ud83c\uddf5\ud83c\uddf1', SE: '\ud83c\uddf8\ud83c\uddea', AT: '\ud83c\udde6\ud83c\uddf9',
  CH: '\ud83c\udde8\ud83c\udded', LU: '\ud83c\uddf1\ud83c\uddfa', IE: '\ud83c\uddee\ud83c\uddea', DK: '\ud83c\udde9\ud83c\uddf0', FI: '\ud83c\uddeb\ud83c\uddee',
};
---
<BaseLayout title={t.metaTitle} description={t.metaDesc} lang={lang}>

  <!-- Breadcrumbs -->
  <nav class="max-w-5xl mx-auto px-4 pt-6 text-sm text-slate-400" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2">
      <li><a href={`/${lang}/`} class="hover:text-blue-400 transition-colors">{t.home}</a></li>
      <li class="text-slate-600">/</li>
      <li class="text-slate-300">{t.breadcrumb}</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-4 py-12 text-center">
    <h1 class="text-3xl md:text-4xl font-bold text-white mb-4 font-['Public_Sans']">{t.h1}</h1>
    <p class="text-lg text-slate-300 max-w-3xl mx-auto mb-6">{t.introAnswer}</p>
    <p class="text-slate-400 max-w-2xl mx-auto">{t.heroSubtitle}</p>
  </section>

  <!-- TL;DR -->
  <TLDRBox items={t.tldr} lang={lang} />

  <!-- Partner Types -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <div class="grid md:grid-cols-2 gap-8">
      {t.partnerTypes.map((pt) => (
        <div class="bg-[#162A4A] border border-slate-700/50 rounded-xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <span class="material-symbols-outlined text-blue-400 text-3xl">{pt.icon}</span>
            <h2 class="text-xl font-bold text-white font-['Public_Sans']">{pt.title}</h2>
          </div>
          <p class="text-slate-300 mb-4">{pt.desc}</p>
          <ul class="space-y-2">
            {pt.benefits.map((b) => (
              <li class="flex items-start gap-2 text-sm text-slate-400">
                <span class="material-symbols-outlined text-green-400 text-base mt-0.5">check_circle</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- Affiliate How It Works -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-white text-center mb-2 font-['Public_Sans']">{t.affiliateTitle}</h2>
    <p class="text-slate-400 text-center mb-10 max-w-2xl mx-auto">{t.affiliateDesc}</p>
    <div class="grid md:grid-cols-3 gap-8">
      {t.affiliateSteps.map((s, i) => (
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-blue-600 text-white text-xl font-bold flex items-center justify-center mx-auto mb-4">{i + 1}</div>
          <h3 class="text-lg font-bold text-white mb-2">{s.step}</h3>
          <p class="text-slate-400 text-sm">{s.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Stats -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-white text-center mb-8 font-['Public_Sans']">{t.statsTitle}</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {t.stats.map((s) => (
        <div class="bg-[#162A4A] border border-slate-700/50 rounded-xl p-6 text-center">
          <div class="text-3xl font-bold text-blue-400 mb-1">{s.value}</div>
          <div class="text-sm text-slate-400">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Partner Application Form -->
  <section class="max-w-3xl mx-auto px-4 py-12" id="apply">
    <h2 class="text-2xl font-bold text-white text-center mb-2 font-['Public_Sans']">{t.contactTitle}</h2>
    <p class="text-slate-400 text-center mb-8">{t.contactDesc}</p>
    <form id="partner-form" class="bg-[#162A4A] border border-slate-700/50 rounded-xl p-8 space-y-6">
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm text-slate-400 mb-1">{t.formLabels.name}</label>
          <input type="text" name="name" required class="w-full bg-[#0F1F3D] border border-slate-600 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none" />
        </div>
        <div>
          <label class="block text-sm text-slate-400 mb-1">{t.formLabels.email}</label>
          <input type="email" name="email" required class="w-full bg-[#0F1F3D] border border-slate-600 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none" />
        </div>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm text-slate-400 mb-1">{t.formLabels.company}</label>
          <input type="text" name="company" required class="w-full bg-[#0F1F3D] border border-slate-600 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none" />
        </div>
        <div>
          <label class="block text-sm text-slate-400 mb-1">{t.formLabels.website}</label>
          <input type="url" name="website" class="w-full bg-[#0F1F3D] border border-slate-600 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none" />
        </div>
      </div>
      <div>
        <label class="block text-sm text-slate-400 mb-1">{t.formLabels.type}</label>
        <select name="type" required class="w-full bg-[#0F1F3D] border border-slate-600 rounded-lg px-4 py-2.5 text-white focus:border-blue-500 focus:outline-none">
          <option value="" disabled selected>—</option>
          {t.partnerTypeOptions.map((opt) => (
            <option value={opt}>{opt}</option>
          ))}
        </select>
      </div>
      <div>
        <label class="block text-sm text-slate-400 mb-1">{t.formLabels.message}</label>
        <textarea name="message" rows="4" class="w-full bg-[#0F1F3D] border border-slate-600 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none resize-none"></textarea>
      </div>
      <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg transition-colors">
        {t.formLabels.submit}
      </button>
      <div id="form-status" class="text-center text-sm hidden"></div>
    </form>
  </section>

  <!-- FAQ -->
  <FAQSection items={t.faq} lang={lang} />

  <!-- Schema Markup -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": t.h1,
    "description": t.metaDesc,
    "dateModified": "2026-04-05",
    "publisher": { "@type": "Organization", "name": "EuroSalary.eu" },
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": t.faq.map((f) => ({
      "@type": "Question",
      "name": f.question,
      "acceptedAnswer": { "@type": "Answer", "text": f.answer },
    })),
  })} />

  <!-- hreflang -->
  {Object.keys(languages).map((l) => (
    <link slot="head" rel="alternate" hreflang={l} href={`https://eurosalary.eu/${l}/partners/`} />
  ))}

  <!-- Form Script -->
  <script>
    const form = document.getElementById('partner-form') as HTMLFormElement;
    const status = document.getElementById('form-status') as HTMLElement;
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form));
      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ...data, source: 'partner-application' }),
        });
        if (res.ok) {
          status.textContent = 'Application submitted! We will be in touch within 24 hours.';
          status.className = 'text-center text-sm text-green-400';
          form.reset();
        } else {
          status.textContent = 'Something went wrong. Please try again.';
          status.className = 'text-center text-sm text-red-400';
        }
      } catch {
        status.textContent = 'Network error. Please try again.';
        status.className = 'text-center text-sm text-red-400';
      }
    });
  </script>

</BaseLayout>
