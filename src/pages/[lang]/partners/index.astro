    stats: [
      { value: '25%', label: 'Recurring Commission' },
      { value: '90 days', label: 'Cookie Duration' },
      { value: '\u20ac50', label: 'Minimum Payout' },
      { value: '24h', label: 'Approval Time' },
    ],
    contactTitle: 'Apply to Become a Partner',
    contactDesc: 'Tell us about your organisation and how you would like to collaborate. We review applications within 24 hours.',
    formLabels: { name: 'Full Name', email: 'Work Email', company: 'Company / Website', website: 'Website URL', type: 'Partnership Type', message: 'How would you like to collaborate?', submit: 'Submit Application' },
    partnerTypeOptions: ['Affiliate Partner', 'Integration Partner', 'Data Partner', 'Content Partner'],
    faq: [
      { question: 'How much can I earn as an affiliate partner?', answer: 'Affiliate partners earn 25% recurring commission on every subscription they refer. With our Premium plan at \u20ac49/month, that is \u20ac12.25 per customer per month for the lifetime of the subscription. Top affiliates earn over \u20ac2,000/month from recurring commissions alone.' },
      { question: 'Is there a minimum traffic requirement to join?', answer: 'No. We welcome partners of all sizes, from individual career coaches to large HR platforms. The only requirement is that your audience or client base has an interest in European salary data or compensation management.' },
      { question: 'How does the data partnership work?', answer: 'Data partners contribute anonymised salary data (no personally identifiable information) from their platforms. In return, they receive free Premium access, attribution on our methodology page, and early access to new datasets. We handle all anonymisation and aggregation.' },
      { question: 'What integration support do you provide?', answer: 'Integration partners receive a dedicated API key with elevated rate limits, priority technical support, custom endpoint development, and access to our staging environment. We also provide co-branded API documentation and joint go-to-market support.' },
      { question: 'How and when are commissions paid?', answer: 'Commissions are calculated on the 1st of each month and paid by the 15th. We support bank transfers (SEPA for EU partners) and PayPal. The minimum payout threshold is \u20ac50. You can track your earnings in real-time through your affiliate dashboard.' },
      { question: 'Can I combine multiple partnership types?', answer: 'Absolutely. Many of our most successful partners operate as both affiliate and content partners, or as data and integration partners simultaneously. Each partnership type has its own benefits, and they stack.' },
    ],
  },
