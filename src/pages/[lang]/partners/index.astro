        benefits: ['Priority API access with elevated rate limits', 'Custom endpoint development', 'Co-branded documentation', 'Joint press releases and case studies', 'Revenue share on referred enterprise deals'],
      },
      {
        title: 'Data Partners',
        desc: 'Contribute anonymised salary data from your platform or research and receive free premium access. Ideal for job boards, recruitment agencies, and academic institutions.',
        icon: 'database',
        benefits: ['Free Premium account (worth \u20ac49/mo)', 'Named attribution in methodology page', 'Early access to new datasets', 'Quarterly data quality reports', 'Co-authored research publications'],
      },
      {
        title: 'Content Partners',
        desc: 'Collaborate on salary guides, market reports, and thought leadership. We provide the data; you provide the audience and expertise. Perfect for industry publications and research firms.',
        icon: 'edit_note',
        benefits: ['Exclusive data for original content', 'Co-branded salary reports', 'Guest posting opportunities', 'Social media cross-promotion', 'Early access to trend data'],
      },
    ],
    affiliateTitle: 'How the Affiliate Program Works',
    affiliateDesc: 'Start earning in three simple steps. No minimum traffic requirements, no approval delays.',
    affiliateSteps: [
      { step: 'Sign Up', desc: 'Complete the partner application form below. You will receive your unique tracking link and affiliate dashboard access within 24 hours.' },
      { step: 'Share', desc: 'Promote EuroSalary through your website, newsletter, social media, or client recommendations. Use our pre-built banners, widgets, and landing pages.' },
      { step: 'Earn', desc: 'Earn 25% of every subscription payment for the lifetime of the customer. Commissions are paid monthly via bank transfer or PayPal, with a minimum payout of 50.' },
    ],
