export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = fb(i18n, lang);
---
<BaseLayout title={t.metaTitle} description={t.metaDesc} lang={lang}>

  <!-- Breadcrumbs -->
  <nav class="max-w-5xl mx-auto px-4 pt-6 text-sm text-slate-400" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2">
      <li><a href={`/${lang}/`} class="hover:text-blue-400 transition-colors">{t.home}</a></li>
      <li class="text-slate-600">/</li>
      <li><a href={`/${lang}/partners/`} class="hover:text-blue-400 transition-colors">{t.partners}</a></li>
      <li class="text-slate-600">/</li>
      <li class="text-slate-300">{t.breadcrumb}</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-4 py-12 text-center">
    <h1 class="text-3xl md:text-4xl font-bold text-white mb-4 font-['Public_Sans']">{t.h1}</h1>
    <p class="text-lg text-slate-300 max-w-3xl mx-auto mb-6">{t.introAnswer}</p>
    <p class="text-slate-400 max-w-2xl mx-auto">{t.heroSubtitle}</p>
  </section>

  <!-- TL;DR -->
  <TLDRBox items={t.tldr} />

  <!-- How It Works -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-white text-center mb-2 font-['Public_Sans']">{t.howTitle}</h2>
    <p class="text-slate-400 text-center mb-10 max-w-2xl mx-auto">{t.howDesc}</p>
    <div class="grid md:grid-cols-3 gap-8">
      {t.howSteps.map((s, i) => (
        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-blue-600 text-white flex items-center justify-center mx-auto mb-4">
            <span class="material-symbols-outlined text-2xl">{s.icon}</span>
          </div>
          <div class="text-sm text-blue-400 font-bold mb-1">{i + 1}</div>
          <h3 class="text-lg font-bold text-white mb-2 font-['Public_Sans']">{s.step}</h3>
          <p class="text-slate-400 text-sm">{s.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Commission Structure -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-white text-center mb-2 font-['Public_Sans']">{t.commissionTitle}</h2>
    <p class="text-slate-400 text-center mb-8">{t.commissionDesc}</p>
    <div class="max-w-3xl mx-auto bg-[#162A4A] border border-slate-700/50 rounded-xl overflow-hidden">
      <table class="w-full">
        <tbody>
          {t.commissionItems.map((item, i) => (
            <tr class={i % 2 === 0 ? 'bg-[#162A4A]' : 'bg-[#1a3055]'}>
              <td class="px-6 py-3 text-sm text-slate-400 font-medium">{item.label}</td>
              <td class="px-6 py-3 text-sm text-white font-semibold text-right">{item.value}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Who It's For -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-white text-center mb-2 font-['Public_Sans']">{t.whoTitle}</h2>
    <p class="text-slate-400 text-center mb-8">{t.whoDesc}</p>
    <div class="grid md:grid-cols-2 gap-8">
      {t.audiences.map((a) => (
        <div class="bg-[#162A4A] border border-slate-700/50 rounded-xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <span class="material-symbols-outlined text-blue-400 text-3xl">{a.icon}</span>
            <h3 class="text-xl font-bold text-white font-['Public_Sans']">{a.title}</h3>
          </div>
          <p class="text-slate-300 text-sm leading-relaxed">{a.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Dashboard Preview -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-white text-center mb-2 font-['Public_Sans']">{t.dashboardTitle}</h2>
    <p class="text-slate-400 text-center mb-8">{t.dashboardDesc}</p>
    <div class="grid md:grid-cols-2 gap-6">
      {t.dashboardFeatures.map((f) => (
        <div class="bg-[#162A4A] border border-slate-700/50 rounded-xl p-6">
          <div class="flex items-center gap-3 mb-3">
            <span class="material-symbols-outlined text-blue-400 text-2xl">{f.icon}</span>
            <h3 class="text-lg font-bold text-white">{f.label}</h3>
          </div>
          <p class="text-slate-400 text-sm">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-5xl mx-auto px-4 py-12 text-center">
    <div class="bg-gradient-to-r from-blue-600/20 to-blue-400/10 border border-blue-500/30 rounded-xl p-8 max-w-3xl mx-auto">
      <span class="material-symbols-outlined text-blue-400 text-4xl mb-4">rocket_launch</span>
      <h2 class="text-2xl font-bold text-white mb-4 font-['Public_Sans']">{t.ctaTitle}</h2>
      <p class="text-slate-300 text-sm">{t.ctaDesc}</p>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="max-w-3xl mx-auto px-4 py-12" id="apply">
    <h2 class="text-2xl font-bold text-white text-center mb-2 font-['Public_Sans']">{t.contactTitle}</h2>
    <p class="text-slate-400 text-center mb-8">{t.contactDesc}</p>
    <form id="referral-form" class="bg-[#162A4A] border border-slate-700/50 rounded-xl p-8 space-y-6">
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm text-slate-400 mb-1">{t.formLabels.name}</label>
          <input type="text" name="name" required class="w-full bg-[#0F1F3D] border border-slate-600 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none" />
        </div>
        <div>
          <label class="block text-sm text-slate-400 mb-1">{t.formLabels.email}</label>
          <input type="email" name="email" required class="w-full bg-[#0F1F3D] border border-slate-600 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none" />
        </div>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm text-slate-400 mb-1">{t.formLabels.website}</label>
          <input type="url" name="website" class="w-full bg-[#0F1F3D] border border-slate-600 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none" />
        </div>
        <div>
          <label class="block text-sm text-slate-400 mb-1">{t.formLabels.audienceSize}</label>
          <input type="text" name="audience_size" class="w-full bg-[#0F1F3D] border border-slate-600 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 focus:border-blue-500 focus:outline-none" />
        </div>
      </div>
      <div>
        <label class="block text-sm text-slate-400 mb-1">{t.formLabels.promotionMethod}</label>
        <select name="promotion_method" required class="w-full bg-[#0F1F3D] border border-slate-600 rounded-lg px-4 py-2.5 text-white focus:border-blue-500 focus:outline-none">
          <option value="" disabled selected>--</option>
          {t.promotionOptions.map((opt) => (
            <option value={opt}>{opt}</option>
          ))}
        </select>
      </div>
      <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg transition-colors">
        {t.formLabels.submit}
      </button>
      <div id="form-status" class="text-center text-sm hidden"></div>
    </form>
  </section>

  <!-- FAQ -->
  <FAQSection items={t.faq} />

  <!-- Schema Markup -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": t.h1,
    "description": t.metaDesc,
    "dateModified": "2026-04-05",
    "publisher": { "@type": "Organization", "name": "EuroSalary.eu" },
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": t.faq.map((f) => ({
      "@type": "Question",
      "name": f.question,
      "acceptedAnswer": { "@type": "Answer", "text": f.answer },
    })),
  })} />

  <!-- hreflang -->
  {Object.keys(languages).map((l) => (
    <link slot="head" rel="alternate" hreflang={l} href={`https://eurosalary.eu/${l}/partners/referral/`} />
  ))}

  <!-- Form Script -->
  <script>
    const form = document.getElementById('referral-form') as HTMLFormElement;
    const status = document.getElementById('form-status') as HTMLElement;
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form));
      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ...data, type: 'partner', source: 'referral-program' }),
        });
        if (res.ok) {
          status.textContent = 'Application submitted! We will be in touch within 24 hours.';
          status.className = 'text-center text-sm text-green-400';
          form.reset();
        } else {
          status.textContent = 'Something went wrong. Please try again.';
          status.className = 'text-center text-sm text-red-400';
        }
      } catch {
        status.textContent = 'Network error. Please try again.';
        status.className = 'text-center text-sm text-red-400';
      }
    });
  </script>

</BaseLayout>
