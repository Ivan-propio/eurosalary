const c = fb(i18n, lang);
---

<BaseLayout title={c.metaTitle} description={c.metaDesc}>
  <section class="auth">
    <div class="auth__card">
      <div class="auth__header">
        <a href={`/${lang}/`} class="auth__logo" aria-label="EuroSalary.eu — Home">
          Euro<span>Salary</span><small>.eu</small>
        </a>
        <h1 class="auth__title">{c.h1}</h1>
        <p class="auth__subtitle">{c.subtitle}</p>
      </div>

      <div class="auth__success" id="signup-success" role="status" aria-live="polite">
        <span class="material-symbols-outlined">check_circle</span>
        <div>
          <strong>{c.successTitle}</strong>
          <p>{c.successMsg}</p>
        </div>
      </div>

      <form class="auth__form" id="signup-form" novalidate>
        <div class="auth__field">
          <label for="signup-email">{c.emailLabel}</label>
          <div class="auth__input-wrap">
            <span class="material-symbols-outlined">mail</span>
            <input type="email" id="signup-email" name="email" placeholder={c.emailPlaceholder} required autocomplete="email" />
          </div>
        </div>

        <div class="auth__field">
          <label for="signup-password">{c.passwordLabel}</label>
          <div class="auth__input-wrap">
            <span class="material-symbols-outlined">lock</span>
            <input type="password" id="signup-password" name="password" placeholder={c.passwordPlaceholder} required autocomplete="new-password" minlength="8" />
            <button type="button" class="auth__toggle-pw" aria-label="Toggle password visibility">
              <span class="material-symbols-outlined">visibility</span>
            </button>
          </div>
          <span class="auth__hint">{c.passwordHint}</span>
        </div>

        <div class="auth__field">
          <label for="signup-confirm">{c.confirmPasswordLabel}</label>
          <div class="auth__input-wrap">
            <span class="material-symbols-outlined">lock</span>
            <input type="password" id="signup-confirm" name="confirm" placeholder={c.confirmPasswordPlaceholder} required autocomplete="new-password" minlength="8" />
            <button type="button" class="auth__toggle-pw" aria-label="Toggle password visibility">
              <span class="material-symbols-outlined">visibility</span>
            </button>
          </div>
        </div>

        <div class="auth__field auth__terms-field">
          <label class="auth__checkbox-label">
            <input type="checkbox" id="signup-terms" name="terms" required />
            <span>{c.termsLabel} <a href={`/${lang}/terms/`}>{c.termsLink}</a> &amp; <a href={`/${lang}/privacy/`}>{c.privacyLink}</a></span>
          </label>
        </div>

        <div class="auth__error" id="signup-error" role="alert" aria-live="polite"></div>

        <button type="submit" class="auth__submit" id="signup-btn">
          <span class="auth__submit-text">{c.signupBtn}</span>
          <span class="auth__spinner"></span>
        </button>
      </form>

      <p class="auth__alt">
        {c.hasAccount} <a href={`/${lang}/login/`}>{c.loginLink}</a>
      </p>
    </div>
  </section>
</BaseLayout>

<script define:vars={{
  lang,
  errorPasswordLength: c.errorPasswordLength,
  errorPasswordMatch: c.errorPasswordMatch,
  errorTerms: c.errorTerms,
  errorEmailUsed: c.errorEmailUsed,
  errorNetwork: c.errorNetwork,
  errorGeneric: c.errorGeneric,
}}>
  const form = document.getElementById('signup-form');
  const emailInput = document.getElementById('signup-email');
  const passwordInput = document.getElementById('signup-password');
  const confirmInput = document.getElementById('signup-confirm');
  const termsCheckbox = document.getElementById('signup-terms');
  const errorEl = document.getElementById('signup-error');
  const successEl = document.getElementById('signup-success');
  const submitBtn = document.getElementById('signup-btn');

  // Toggle password visibility
  document.querySelectorAll('.auth__toggle-pw').forEach((btn) => {
    btn.addEventListener('click', () => {
      const input = btn.parentElement.querySelector('input');
      const icon = btn.querySelector('.material-symbols-outlined');
      if (input.type === 'password') {
        input.type = 'text';
        icon.textContent = 'visibility_off';
      } else {
        input.type = 'password';
        icon.textContent = 'visibility';
      }
    });
  });

  function showError(msg) {
    errorEl.textContent = msg;
    errorEl.classList.add('auth__error--show');
  }

  function hideError() {
    errorEl.textContent = '';
    errorEl.classList.remove('auth__error--show');
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideError();
    submitBtn.classList.add('auth__submit--loading');
    submitBtn.disabled = true;

    const email = emailInput.value.trim();
    const password = passwordInput.value;
    const confirm = confirmInput.value;

    // Client-side validation
    if (password.length < 8) {
      showError(errorPasswordLength);
      submitBtn.classList.remove('auth__submit--loading');
      submitBtn.disabled = false;
      return;
    }

    if (password !== confirm) {
      showError(errorPasswordMatch);
      submitBtn.classList.remove('auth__submit--loading');
      submitBtn.disabled = false;
      return;
    }

    if (!termsCheckbox.checked) {
      showError(errorTerms);
      submitBtn.classList.remove('auth__submit--loading');
      submitBtn.disabled = false;
      return;
    }

    try {
      const res = await fetch('/api/auth/signup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ email, password, lang }),
      });

      if (res.ok) {
        const data = await res.json().catch(() => ({}));
        if (data.confirmation_required) {
          // Email confirmation required — show success message
          form.style.display = 'none';
          document.querySelector('.auth__alt').style.display = 'none';
          successEl.classList.add('auth__success--show');
        } else {
          // Account created and auto-logged in — redirect to dashboard
          window.location.href = `/${lang}/dashboard/`;
        }
      } else {
        const data = await res.json().catch(() => ({}));
        if (res.status === 409 || (data.error && data.error.toLowerCase().includes('already'))) {
          showError(errorEmailUsed);
        } else {
          showError(data.error || errorGeneric);
        }
      }
    } catch (err) {
      showError(err.message.includes('fetch') ? errorNetwork : errorGeneric);
    } finally {
      submitBtn.classList.remove('auth__submit--loading');
      submitBtn.disabled = false;
    }
  });
</script>

<style>
  .auth {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    background:
      radial-gradient(ellipse at 30% 20%, rgba(37, 99, 235, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse at 70% 80%, rgba(37, 99, 235, 0.05) 0%, transparent 50%),
      var(--color-primary-container, #0F1F3D);
  }

  .auth__card {
    width: 100%;
    max-width: 440px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 2.5rem 2rem;
    backdrop-filter: blur(20px);
  }

  .auth__header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .auth__logo {
    font-family: var(--font-heading, 'Public Sans', sans-serif);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-white, #fff);
    text-decoration: none;
    letter-spacing: -0.02em;
  }
  .auth__logo span { color: var(--color-secondary, #2563EB); }
  .auth__logo small { font-size: 0.6em; opacity: 0.5; font-weight: 400; }

  .auth__title {
    font-family: var(--font-heading, 'Public Sans', sans-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-white, #fff);
    margin: 1.25rem 0 0.5rem;
  }

  .auth__subtitle {
    font-size: 0.9rem;
    color: rgba(203, 213, 225, 0.7);
    line-height: 1.5;
  }

  .auth__form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .auth__field label {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    color: rgba(203, 213, 225, 0.9);
    margin-bottom: 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .auth__hint {
    display: block;
    font-size: 0.75rem;
    color: rgba(148, 163, 184, 0.5);
    margin-top: 0.3rem;
  }

  .auth__input-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    padding: 0 0.75rem;
    transition: border-color 0.15s;
  }
  .auth__input-wrap:focus-within {
    border-color: var(--color-secondary, #2563EB);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
  }
  .auth__input-wrap .material-symbols-outlined {
    font-size: 18px;
    color: rgba(148, 163, 184, 0.6);
  }
  .auth__input-wrap input {
    flex: 1;
    background: none;
    border: none;
    color: var(--color-white, #fff);
    font-size: 0.95rem;
    padding: 0.7rem 0;
    outline: none;
    font-family: var(--font-sans, 'Inter', sans-serif);
  }
  .auth__input-wrap input::placeholder {
    color: rgba(148, 163, 184, 0.4);
  }

  .auth__toggle-pw {
    background: none;
    border: none;
    cursor: pointer;
    padding: 2px;
    display: flex;
  }
  .auth__toggle-pw .material-symbols-outlined {
    font-size: 18px;
    color: rgba(148, 163, 184, 0.5);
    transition: color 0.15s;
  }
  .auth__toggle-pw:hover .material-symbols-outlined { color: rgba(203, 213, 225, 0.8); }

  .auth__terms-field {
    margin-top: 0.25rem;
  }

  .auth__checkbox-label {
    display: flex !important;
    align-items: flex-start;
    gap: 0.5rem;
    text-transform: none !important;
    letter-spacing: normal !important;
    font-weight: 400 !important;
    font-size: 0.85rem !important;
    color: rgba(203, 213, 225, 0.7) !important;
    cursor: pointer;
  }

  .auth__checkbox-label input[type="checkbox"] {
    width: 16px;
    height: 16px;
    margin-top: 2px;
    accent-color: var(--color-secondary, #2563EB);
    flex-shrink: 0;
  }

  .auth__checkbox-label a {
    color: var(--color-secondary, #2563EB);
    text-decoration: none;
    font-weight: 500;
