const c = fb(i18n, lang);
---

<BaseLayout title={c.metaTitle} description={c.metaDesc}>
  <section class="auth">
    <div class="auth__card">
      <div class="auth__header">
        <a href={`/${lang}/`} class="auth__logo" aria-label="EuroSalary.eu — Home">
          Euro<span>Salary</span><small>.eu</small>
        </a>
        <h1 class="auth__title">{c.h1}</h1>
        <p class="auth__subtitle">{c.subtitle}</p>
      </div>

      <!-- Success message (hidden by default) -->
      <div class="auth__success" id="signup-success">
        <span class="material-symbols-outlined auth__success-icon">mark_email_read</span>
        <h2 class="auth__success-title">{c.successTitle}</h2>
        <p class="auth__success-msg">{c.successMsg}</p>
        <a href={`/${lang}/login/`} class="auth__success-link">{c.loginLink} &rarr;</a>
      </div>

      <form class="auth__form" id="signup-form" novalidate>
        <div class="auth__field">
          <label for="signup-email">{c.emailLabel}</label>
          <div class="auth__input-wrap">
            <span class="material-symbols-outlined">mail</span>
            <input type="email" id="signup-email" name="email" placeholder={c.emailPlaceholder} required autocomplete="email" />
          </div>
        </div>
        <div class="auth__field">
          <label for="signup-password">{c.passwordLabel}</label>
          <div class="auth__input-wrap">
            <span class="material-symbols-outlined">lock</span>
            <input type="password" id="signup-password" name="password" placeholder={c.passwordPlaceholder} required minlength="8" autocomplete="new-password" />
            <button type="button" class="auth__toggle-pw" aria-label="Toggle password visibility">
              <span class="material-symbols-outlined">visibility</span>
            </button>
          </div>
        </div>
        <div class="auth__field">
          <label for="signup-confirm">{c.confirmLabel}</label>
          <div class="auth__input-wrap">
            <span class="material-symbols-outlined">lock</span>
            <input type="password" id="signup-confirm" name="confirm" placeholder={c.confirmPlaceholder} required minlength="8" autocomplete="new-password" />
            <button type="button" class="auth__toggle-pw" aria-label="Toggle password visibility">
              <span class="material-symbols-outlined">visibility</span>
            </button>
          </div>
        </div>

        <div class="auth__error" id="signup-error" role="alert" aria-live="polite"></div>

        <button type="submit" class="auth__submit" id="signup-btn">
          <span class="auth__submit-text">{c.signupBtn}</span>
          <span class="auth__spinner"></span>
        </button>

        <p class="auth__terms">
          {c.termsText} <a href={`/${lang}/terms/`}>{c.termsLink}</a> & <a href={`/${lang}/privacy/`}>{c.privacyLink}</a>.
        </p>
      </form>

      <p class="auth__alt">
        {c.hasAccount} <a href={`/${lang}/login/`}>{c.loginLink}</a>
      </p>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ lang, errorMismatch: c.errorMismatch, errorWeak: c.errorWeak, errorExists: c.errorExists, errorNetwork: c.errorNetwork, errorGeneric: c.errorGeneric }}>
  const form = document.getElementById('signup-form');
  const emailInput = document.getElementById('signup-email');
  const passwordInput = document.getElementById('signup-password');
  const confirmInput = document.getElementById('signup-confirm');
  const errorEl = document.getElementById('signup-error');
  const submitBtn = document.getElementById('signup-btn');
  const successEl = document.getElementById('signup-success');

  // Toggle password visibility
  document.querySelectorAll('.auth__toggle-pw').forEach((btn) => {
    btn.addEventListener('click', () => {
      const input = btn.parentElement.querySelector('input');
      const icon = btn.querySelector('.material-symbols-outlined');
      if (input.type === 'password') {
        input.type = 'text';
        icon.textContent = 'visibility_off';
      } else {
        input.type = 'password';
        icon.textContent = 'visibility';
      }
    });
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.textContent = '';
    errorEl.classList.remove('auth__error--show');
    submitBtn.classList.add('auth__submit--loading');
    submitBtn.disabled = true;

    const email = emailInput.value.trim();
    const password = passwordInput.value;
    const confirm = confirmInput.value;

    // Client-side validation
    if (password.length < 8) {
      errorEl.textContent = errorWeak;
      errorEl.classList.add('auth__error--show');
      submitBtn.classList.remove('auth__submit--loading');
      submitBtn.disabled = false;
      return;
    }
    if (password !== confirm) {
      errorEl.textContent = errorMismatch;
      errorEl.classList.add('auth__error--show');
      submitBtn.classList.remove('auth__submit--loading');
      submitBtn.disabled = false;
      return;
    }

    try {
      const res = await fetch('/api/auth/signup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password }),
      });

      if (res.ok) {
        form.style.display = 'none';
        document.querySelector('.auth__alt').style.display = 'none';
        successEl.classList.add('auth__success--show');
      } else {
        const data = await res.json().catch(() => ({}));
        if (res.status === 409 || (data.error && data.error.toLowerCase().includes('exist'))) {
          errorEl.textContent = errorExists;
        } else {
          errorEl.textContent = data.error || errorGeneric;
        }
        errorEl.classList.add('auth__error--show');
      }
    } catch (err) {
      errorEl.textContent = err.message.includes('fetch') ? errorNetwork : errorGeneric;
      errorEl.classList.add('auth__error--show');
    } finally {
      submitBtn.classList.remove('auth__submit--loading');
      submitBtn.disabled = false;
    }
  });
</script>

<style>
  .auth {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    background:
      radial-gradient(ellipse at 30% 20%, rgba(37, 99, 235, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse at 70% 80%, rgba(37, 99, 235, 0.05) 0%, transparent 50%),
      var(--color-primary-container, #0F1F3D);
  }

  .auth__card {
    width: 100%;
    max-width: 440px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 2.5rem 2rem;
    backdrop-filter: blur(20px);
  }

  .auth__header { text-align: center; margin-bottom: 2rem; }

  .auth__logo {
    font-family: var(--font-heading, 'Public Sans', sans-serif);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-white, #fff);
    text-decoration: none;
    letter-spacing: -0.02em;
  }
  .auth__logo span { color: var(--color-secondary, #2563EB); }
  .auth__logo small { font-size: 0.6em; opacity: 0.5; font-weight: 400; }

  .auth__title {
    font-family: var(--font-heading, 'Public Sans', sans-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-white, #fff);
    margin: 1.25rem 0 0.5rem;
  }

  .auth__subtitle {
    font-size: 0.9rem;
    color: rgba(203, 213, 225, 0.7);
    line-height: 1.5;
  }

  .auth__form { display: flex; flex-direction: column; gap: 1.25rem; }

  .auth__field label {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    color: rgba(203, 213, 225, 0.9);
    margin-bottom: 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .auth__input-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    padding: 0 0.75rem;
    transition: border-color 0.15s;
  }
  .auth__input-wrap:focus-within {
    border-color: var(--color-secondary, #2563EB);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
  }
  .auth__input-wrap .material-symbols-outlined { font-size: 18px; color: rgba(148, 163, 184, 0.6); }
  .auth__input-wrap input {
    flex: 1;
    background: none;
    border: none;
    color: var(--color-white, #fff);
    font-size: 0.95rem;
    padding: 0.7rem 0;
    outline: none;
    font-family: var(--font-sans, 'Inter', sans-serif);
  }
  .auth__input-wrap input::placeholder { color: rgba(148, 163, 184, 0.4); }

  .auth__toggle-pw {
    background: none; border: none; cursor: pointer; padding: 2px; display: flex;
  }
  .auth__toggle-pw .material-symbols-outlined { font-size: 18px; color: rgba(148, 163, 184, 0.5); transition: color 0.15s; }
  .auth__toggle-pw:hover .material-symbols-outlined { color: rgba(203, 213, 225, 0.8); }

  .auth__error {
    font-size: 0.85rem;
    color: #f87171;
    background: rgba(248, 113, 113, 0.08);
    border: 1px solid rgba(248, 113, 113, 0.2);
    border-radius: 8px;
    padding: 0.6rem 0.75rem;
    display: none;
  }
  .auth__error--show { display: block; }

  .auth__submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.8rem;
    background: var(--color-secondary, #2563EB);
    color: var(--color-white, #fff);
    border: none;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    font-family: var(--font-sans, 'Inter', sans-serif);
    cursor: pointer;
    transition: background 0.15s, transform 0.1s;
  }
  .auth__submit:hover { background: #1d4ed8; }
  .auth__submit:active { transform: scale(0.98); }
  .auth__submit:disabled { opacity: 0.7; cursor: not-allowed; }

  .auth__spinner {
    display: none;
    width: 16px; height: 16px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: auth-spin 0.6s linear infinite;
  }
  .auth__submit--loading .auth__submit-text { display: none; }
  .auth__submit--loading .auth__spinner { display: block; }

  @keyframes auth-spin { to { transform: rotate(360deg); } }

  .auth__terms {
    font-size: 0.78rem;
    color: rgba(148, 163, 184, 0.5);
    text-align: center;
    line-height: 1.5;
  }
  .auth__terms a { color: rgba(148, 163, 184, 0.7); text-decoration: underline; }
  .auth__terms a:hover { color: var(--color-white, #fff); }

  .auth__alt {
    text-align: center;
    margin-top: 1.5rem;
    font-size: 0.88rem;
    color: rgba(203, 213, 225, 0.6);
  }
  .auth__alt a { color: var(--color-secondary, #2563EB); text-decoration: none; font-weight: 600; }
  .auth__alt a:hover { text-decoration: underline; }

  /* Success state */
  .auth__success {
    display: none;
    text-align: center;
    padding: 1rem 0;
  }
  .auth__success--show { display: block; }
  .auth__success-icon {
    font-size: 48px;
    color: #34d399;
    margin-bottom: 0.75rem;
  }
  .auth__success-title {
    font-family: var(--font-heading, 'Public Sans', sans-serif);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-white, #fff);
    margin-bottom: 0.5rem;
  }
  .auth__success-msg {
    font-size: 0.9rem;
    color: rgba(203, 213, 225, 0.7);
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }
  .auth__success-link {
    display: inline-block;
    color: var(--color-secondary, #2563EB);
    font-weight: 600;
    text-decoration: none;
    font-size: 0.9rem;
  }
  .auth__success-link:hover { text-decoration: underline; }

  @media (max-width: 480px) {
    .auth__card { padding: 2rem 1.25rem; }
    .auth__title { font-size: 1.3rem; }
  }
</style>
