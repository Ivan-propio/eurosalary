// ─── Data preparation ────────────────────────────────────────────────────────

const taxCodes = Object.keys(taxData);
const langSlugs = (countrySlugsByLang as Record<string, Record<string, string>>)[lang] || {};
const clientCountryNames: Record<string, string> = {};
const clientCountrySlugs: Record<string, string> = {};
const clientAvgSalaries: Record<string, number> = {};

for (const code of taxCodes) {
  clientCountryNames[code] = fb(countryNames[code] || {en: code}, lang) as string;
  clientCountrySlugs[code] = langSlugs[code] || code.toLowerCase();
  clientAvgSalaries[code] = countryDataMap[code]?.avgSalary || 0;
}

const clientLabels = {
  netLabel: fb(colNet, lang),
  monthlyLabel: fb(monthlyLabel, lang),
  vsAvgLabel: fb(vsAvgLabel, lang),
  viewCountryLabel: fb(viewCountryLabel, lang),
};

// Country select options (all 27, sorted by name in current language)
const countryOptions = taxCodes
  .map(code => ({ code, name: clientCountryNames[code] }))
  .sort((a, b) => a.name.localeCompare(b.name));

const faqItems = fb(faqData, lang) as { question: string; answer: string }[];

