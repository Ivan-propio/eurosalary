---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TLDRBox from '../../../components/TLDRBox.astro';
import FAQSection from '../../../components/FAQSection.astro';
import { languages } from '../../../i18n/ui';
import { fb, useTranslations } from '../../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
    props: { lang },
  }));
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// --------------- i18n strings ---------------
const i18n: Record<string, {
  h1: string;
  metaTitle: string;
  metaDesc: string;
  home: string;
  breadcrumbCalc: string;
  breadcrumb: string;
  introAnswer: string;
  tldr: string[];
  calcTitle: string;
  calcDesc: string;
  countryLabel: string;
  countryPlaceholder: string;
  grossLabel: string;
  grossPlaceholder: string;
  statusLabel: string;
  statusSingle: string;
  statusMarried: string;
  statusMarriedChildren: string;
  calculateBtn: string;
  resultGross: string;
  resultIncomeTax: string;
  resultSocial: string;
  resultNet: string;
  resultTitle: string;
  breakdownTitle: string;
  compareTitle: string;
  compareDesc: string;
  disclaimerTitle: string;
  disclaimerText: string;
  faq: { question: string; answer: string }[];
}> = {
  en: {
    h1: 'How Much Will You Take Home After Taxes in Europe?',
