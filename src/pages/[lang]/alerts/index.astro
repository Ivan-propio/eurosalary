  datePublished: '2026-04-04',
  dateModified: '2026-04-04',
  author: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
  publisher: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu', logo: { '@type': 'ImageObject', url: 'https://eurosalary.eu/logo.svg' } },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: c.faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<BaseLayout
  title={c.metaTitle}
  description={c.metaDesc}
  datePublished="2026-04-04"
  dateModified="2026-04-04"
  schema={[articleSchema, faqSchema]}
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="page-hero__dots"></div>
    <div class="container page-hero__inner">
      <nav class="page-hero__breadcrumbs" aria-label="Breadcrumb">
        <a href={`/${lang}/`}>{c.home}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <span class="page-hero__breadcrumbs-current">{c.breadcrumb}</span>
      </nav>
      <h1 class="page-hero__title">{c.h1}</h1>
      <p class="page-hero__desc">{c.introAnswer}</p>
    </div>
  </section>

  <div class="container page-body">
    <!-- TL;DR -->
    <TLDRBox items={c.tldr} />

    <!-- How It Works -->
    <section class="section">
      <h2>{c.howItWorksTitle}</h2>
      <div class="steps-grid">
        {c.steps.map((step) => (
          <div class="step-card">
            <div class="step-card__num">{step.num}</div>
            <span class="material-symbols-outlined step-card__icon">{step.icon}</span>
            <h3>{step.title}</h3>
            <p>{step.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Alert Types -->
    <section class="section">
      <h2>{c.alertTypesTitle}</h2>
      <div class="alert-types-grid">
        {c.alertTypes.map((at) => (
          <div class="alert-type-card">
            <span class="material-symbols-outlined alert-type-card__icon">{at.icon}</span>
            <h3>{at.title}</h3>
            <p>{at.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Configuration Form -->
    <section class="section">
      <h2>{c.configTitle}</h2>
      <p class="section-desc">{c.configDesc}</p>
      <form class="alert-form" id="alertForm">
        <div class="alert-form__row">
          <div class="alert-form__field">
            <label for="alertCountry">{c.selectCountryLabel}</label>
            <select id="alertCountry" name="country" required>
              <option value="" disabled selected>{c.selectCountryPlaceholder}</option>
              {countries.map((country) => (
                <option value={country.code}>{fb(country, lang)}</option>
              ))}
            </select>
          </div>
          <div class="alert-form__field">
            <label for="alertJob">{c.selectJobLabel}</label>
            <select id="alertJob" name="job" required>
              <option value="" disabled selected>{c.selectJobPlaceholder}</option>
              {jobs.map((job) => (
                <option value={job}>{job}</option>
              ))}
            </select>
          </div>
        </div>
        <div class="alert-form__row">
          <div class="alert-form__field">
            <label for="alertEmail">{c.emailLabel}</label>
            <input type="email" id="alertEmail" name="email" placeholder={c.emailPlaceholder} required />
          </div>
          <div class="alert-form__field">
            <label for="alertFreq">{c.frequencyLabel}</label>
            <select id="alertFreq" name="frequency" required>
              <option value="weekly">{c.frequencyWeekly}</option>
              <option value="monthly">{c.frequencyMonthly}</option>
            </select>
          </div>
        </div>
        <button type="submit" class="alert-form__submit">{c.submitLabel}</button>
      </form>
    </section>

    <!-- Pricing -->
    <section class="section">
      <h2>{c.pricingTitle}</h2>
      <p class="section-desc">{c.pricingDesc}</p>
      <div class="pricing-grid">
        {c.tiers.map((tier) => (
          <div class:list={['pricing-card', { 'pricing-card--highlight': tier.highlight }]}>
            <h3 class="pricing-card__name">{tier.name}</h3>
            <div class="pricing-card__price">{tier.price}</div>
            <ul class="pricing-card__features">
              {tier.features.map((f) => (
                <li><span class="material-symbols-outlined">check_circle</span>{f}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <FAQSection items={c.faq} />
  </div>
</BaseLayout>

<style>
  .page-body { padding: 2.5rem 0 4rem; }
  .page-body h2 {
    font-family: 'Public Sans', sans-serif;
    font-size: 1.75rem; font-weight: 800; letter-spacing: -0.02em;
    color: #0F1F3D; margin-top: 2.5rem; margin-bottom: 1rem;
  }
  .section { margin-bottom: 3rem; }
  .section-desc { color: #4b5563; margin-bottom: 1.5rem; line-height: 1.7; }

  /* Steps */
  .steps-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem; margin-top: 1.5rem; }
  .step-card {
    background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px;
    padding: 2rem; position: relative; text-align: center;
  }
  .step-card__num {
    position: absolute; top: -14px; left: 50%; transform: translateX(-50%);
    width: 28px; height: 28px; border-radius: 50%;
    background: #2563EB; color: #fff; font-weight: 800; font-size: 0.875rem;
    display: flex; align-items: center; justify-content: center;
  }
  .step-card__icon { font-size: 2rem; color: #2563EB; margin-bottom: 0.5rem; }
  .step-card h3 { font-size: 1.125rem; font-weight: 700; color: #0F1F3D; margin-bottom: 0.5rem; }
  .step-card p { font-size: 0.9rem; color: #4b5563; line-height: 1.6; }

  /* Alert Types */
  .alert-types-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-top: 1.5rem; }
  .alert-type-card {
    background: #0F1F3D; border-radius: 12px; padding: 2rem; color: #fff;
  }
  .alert-type-card__icon { font-size: 2rem; color: #2563EB; margin-bottom: 0.75rem; display: block; }
  .alert-type-card h3 { font-size: 1.125rem; font-weight: 700; margin-bottom: 0.5rem; }
  .alert-type-card p { font-size: 0.9rem; color: rgba(255, 255, 255, 0.8); line-height: 1.6; }

  /* Form */
  .alert-form {
    background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px;
    padding: 2rem; max-width: 640px;
  }
  .alert-form__row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
  @media (max-width: 600px) { .alert-form__row { grid-template-columns: 1fr; } }
  .alert-form__field label {
    display: block; font-size: 0.8rem; font-weight: 700; color: #0F1F3D;
    margin-bottom: 0.375rem; text-transform: uppercase; letter-spacing: 0.05em;
  }
  .alert-form__field select,
  .alert-form__field input {
    width: 100%; padding: 0.625rem 0.75rem; border: 1px solid #d1d5db; border-radius: 8px;
    font-size: 0.9rem; background: #fff; color: #0F1F3D;
  }
  .alert-form__submit {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 0.75rem 2rem; background: #2563EB; color: #fff;
    border: none; border-radius: 8px; font-size: 1rem; font-weight: 700;
    cursor: pointer; transition: background 0.2s;
  }
  .alert-form__submit:hover { background: #1d4ed8; }

  /* Pricing */
  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem; margin-top: 1.5rem; }
  .pricing-card {
    background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px;
    padding: 2rem; text-align: center;
  }
  .pricing-card--highlight { background: #0F1F3D; color: #fff; border-color: #2563EB; }
  .pricing-card__name { font-size: 1.25rem; font-weight: 800; margin-bottom: 0.5rem; }
  .pricing-card--highlight .pricing-card__name { color: #fff; }
  .pricing-card__price { font-size: 2rem; font-weight: 800; color: #2563EB; margin-bottom: 1.25rem; }
  .pricing-card__features { list-style: none; padding: 0; text-align: left; }
  .pricing-card__features li {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.9rem; padding: 0.375rem 0; color: inherit;
  }
  .pricing-card__features li .material-symbols-outlined { font-size: 1.125rem; color: #2563EB; }
  .pricing-card--highlight .pricing-card__features li { color: rgba(255, 255, 255, 0.9); }
</style>
