const faqItems: Record<string, Array<{question: string; answer: string}>> = {
  en: [
    { question: 'What is the EU Pay Transparency Directive?', answer: 'The EU Pay Transparency Directive (2023/970/EU) is a law adopted by the European Parliament in April 2023 requiring EU member states to implement new rules on pay transparency by June 7, 2026. It covers salary disclosure in job ads, employee rights to pay information, gender pay gap reporting, and stronger enforcement mechanisms.' },
    { question: 'When does the EU Pay Transparency Directive come into effect?', answer: 'EU member states must transpose the directive into national law by June 7, 2026. Some countries (France, Spain, Ireland, Sweden, Portugal) already have similar measures in place. Companies will have additional time after transposition — 250+ employee firms report from year one, 150-249 employees from year three, and 100-149 employees from year five.' },
    { question: 'Who does the EU Pay Transparency Directive apply to?', answer: 'The directive applies to all employers in EU member states, regardless of size, for provisions on job ad salary disclosure and pay information rights. Gender pay gap reporting requirements apply to companies with 100 or more employees, with phased-in thresholds.' },
    { question: 'Does the directive require salary disclosure in job ads?', answer: 'Yes. Employers must provide salary information — either a specific salary or a salary range — before the first interview. This can be in the job posting or communicated separately. Employers cannot ask candidates about their salary history.' },
    { question: 'What are the penalties for non-compliance?', answer: 'Penalties vary by member state, but the directive requires "effective, proportionate and dissuasive" sanctions. EU countries must set specific fines. Crucially, the burden of proof is reversed — if an employee claims pay discrimination, the employer must prove the difference is justified, not the employee.' },
    { question: 'What rights do employees get under the directive?', answer: 'Employees have the right to request information from their employer about: their own pay level, the average pay level (broken down by gender) for workers doing the same work or work of equal value. Employers must respond within 2 months. Employees cannot be penalized for exercising these rights.' },
    { question: 'How does the directive affect companies outside the EU?', answer: 'Non-EU companies operating in the EU must comply if they employ workers in EU member states. The directive applies to employment relationships governed by EU member state law, regardless of where the employer is headquartered.' },
  ],
  fr: [
    { question: 'Qu\'est-ce que la directive sur la transparence salariale de l\'UE ?', answer: 'La directive européenne sur la transparence salariale (2023/970/UE) est une loi adoptée par le Parlement européen en avril 2023 obligeant les États membres de l\'UE à mettre en œuvre de nouvelles règles sur la transparence des salaires d\'ici le 7 juin 2026.' },
    { question: 'Quand la directive entre-t-elle en vigueur ?', answer: 'Les États membres de l\'UE doivent transposer la directive en droit national avant le 7 juin 2026. Certains pays ont déjà des mesures similaires en place. Les entreprises bénéficient d\'un délai supplémentaire après la transposition selon leur taille.' },
    { question: 'À qui s\'applique la directive ?', answer: 'La directive s\'applique à tous les employeurs des États membres de l\'UE pour les dispositions relatives à la divulgation des salaires dans les offres d\'emploi. Les exigences de rapport sur l\'écart de rémunération s\'appliquent aux entreprises de 100 salariés ou plus.' },
    { question: 'La directive impose-t-elle la divulgation des salaires dans les offres d\'emploi ?', answer: 'Oui. Les employeurs doivent fournir des informations salariales avant le premier entretien. Ils ne peuvent pas demander aux candidats leurs antécédents salariaux.' },
    { question: 'Quelles sont les sanctions en cas de non-conformité ?', answer: 'Les sanctions varient selon les États membres, mais la directive exige des sanctions effectives et dissuasives. La charge de la preuve est inversée en faveur des employés.' },
    { question: 'Quels droits les employés ont-ils en vertu de la directive ?', answer: 'Les employés ont le droit de demander des informations sur leur niveau de rémunération et le niveau moyen de rémunération pour des travailleurs effectuant un travail comparable.' },
    { question: 'Comment la directive affecte-t-elle les entreprises hors de l\'UE ?', answer: 'Les entreprises non européennes opérant dans l\'UE doivent se conformer si elles emploient des travailleurs dans des États membres de l\'UE.' },
  ],
  de: [
    { question: 'Was ist die EU-Gehaltstransparenzrichtlinie?', answer: 'Die EU-Richtlinie zur Gehaltstransparenz (2023/970/EU) ist ein Gesetz, das im April 2023 vom Europäischen Parlament verabschiedet wurde und EU-Mitgliedstaaten verpflichtet, bis zum 7. Juni 2026 neue Regeln zur Gehaltstransparenz umzusetzen.' },
    { question: 'Wann tritt die Richtlinie in Kraft?', answer: 'EU-Mitgliedstaaten müssen die Richtlinie bis zum 7. Juni 2026 in nationales Recht umsetzen. Einige Länder haben bereits ähnliche Maßnahmen. Unternehmen erhalten nach der Umsetzung zusätzliche Zeit je nach Größe.' },
    { question: 'Für wen gilt die Richtlinie?', answer: 'Die Richtlinie gilt für alle Arbeitgeber in EU-Mitgliedstaaten. Berichtspflichten zur Geschlechterlohnlücke gelten für Unternehmen mit 100 oder mehr Mitarbeitern.' },
    { question: 'Verlangt die Richtlinie Gehaltsangaben in Stellenanzeigen?', answer: 'Ja. Arbeitgeber müssen vor dem ersten Gespräch Gehaltsinformationen bereitstellen. Sie dürfen Bewerber nicht nach ihrem bisherigen Gehalt fragen.' },
    { question: 'Was sind die Strafen bei Nichteinhaltung?', answer: 'Strafen variieren je nach Mitgliedstaat. Wichtig: Die Beweislast ist umgekehrt — der Arbeitgeber muss Gehaltsunterschiede rechtfertigen.' },
    { question: 'Welche Rechte erhalten Arbeitnehmer?', answer: 'Arbeitnehmer haben das Recht, Informationen über ihr eigenes Gehalt und das Durchschnittsgehalt für vergleichbare Tätigkeiten anzufordern.' },
    { question: 'Wie wirkt sich die Richtlinie auf Unternehmen außerhalb der EU aus?', answer: 'Nicht-EU-Unternehmen, die in der EU tätig sind, müssen sich an die Richtlinie halten, wenn sie Arbeitnehmer in EU-Mitgliedstaaten beschäftigen.' },
  ],
  es: [
    { question: '¿Qué es la Directiva de transparencia salarial de la UE?', answer: 'La Directiva sobre transparencia salarial de la UE (2023/970/UE) es una ley adoptada por el Parlamento Europeo en abril de 2023 que obliga a los estados miembros a implementar nuevas normas sobre transparencia salarial antes del 7 de junio de 2026.' },
    { question: '¿Cuándo entra en vigor la directiva?', answer: 'Los estados miembros de la UE deben transponer la directiva antes del 7 de junio de 2026. Algunos países ya tienen medidas similares.' },
    { question: '¿A quién aplica la directiva?', answer: 'La directiva aplica a todos los empleadores en los estados miembros de la UE. Los requisitos de reporte de brecha salarial aplican a empresas con 100 o más empleados.' },
    { question: '¿La directiva exige divulgar salarios en las ofertas de empleo?', answer: 'Sí. Los empleadores deben proporcionar información salarial antes de la primera entrevista. No pueden preguntar a los candidatos su historial salarial.' },
    { question: '¿Cuáles son las sanciones por incumplimiento?', answer: 'Las sanciones varían según el estado miembro. Crucialmente, la carga de la prueba se invierte: el empleador debe justificar las diferencias salariales.' },
    { question: '¿Qué derechos tienen los empleados?', answer: 'Los empleados tienen derecho a solicitar información sobre su nivel salarial y el nivel salarial promedio para puestos comparables.' },
    { question: '¿Cómo afecta la directiva a empresas fuera de la UE?', answer: 'Las empresas no europeas que operan en la UE deben cumplir si emplean trabajadores en estados miembros.' },
  ],
  it: [{ question: 'Cos\'è la Direttiva UE sulla trasparenza retributiva?', answer: 'La Direttiva UE sulla trasparenza retributiva (2023/970/UE) è una legge adottata dal Parlamento europeo nell\'aprile 2023 che obbliga gli stati membri a implementare nuove regole sulla trasparenza retributiva entro il 7 giugno 2026.' }, { question: 'Quando entra in vigore?', answer: 'Gli stati membri devono recepire la direttiva entro il 7 giugno 2026. Alcuni paesi hanno già misure simili.' }, { question: 'A chi si applica?', answer: 'Si applica a tutti i datori di lavoro nell\'UE. I requisiti di segnalazione del divario retributivo si applicano alle aziende con 100 o più dipendenti.' }, { question: 'La direttiva richiede la divulgazione dei salari negli annunci?', answer: 'Sì. I datori di lavoro devono fornire informazioni salariali prima del primo colloquio.' }, { question: 'Quali sono le sanzioni?', answer: 'Le sanzioni variano per stato membro. L\'onere della prova è invertito in favore dei dipendenti.' }, { question: 'Quali diritti hanno i dipendenti?', answer: 'I dipendenti possono richiedere informazioni sulla propria retribuzione e sulla retribuzione media per ruoli comparabili.' }, { question: 'Come influisce sulle aziende extra-UE?', answer: 'Le aziende non UE che operano nell\'UE devono conformarsi se assumono lavoratori negli stati membri.' }],
  pt: [{ question: 'O que é a Diretiva da UE sobre transparência salarial?', answer: 'A Diretiva da UE sobre transparência salarial (2023/970/UE) foi adotada em abril de 2023 e exige que os estados membros implementem novas regras até 7 de junho de 2026.' }, { question: 'Quando entra em vigor?', answer: 'Os estados membros devem transpor a diretiva até 7 de junho de 2026.' }, { question: 'A quem se aplica?', answer: 'Aplica-se a todos os empregadores na UE. Os requisitos de reporte aplicam-se a empresas com 100 ou mais funcionários.' }, { question: 'Exige divulgação de salários em anúncios?', answer: 'Sim. Os empregadores devem fornecer informações salariais antes da primeira entrevista.' }, { question: 'Quais são as sanções?', answer: 'As sanções variam por estado membro, com inversão do ónus da prova.' }, { question: 'Que direitos têm os funcionários?', answer: 'Os funcionários podem solicitar informações sobre a sua remuneração e a remuneração média para funções comparáveis.' }, { question: 'Como afeta empresas fora da UE?', answer: 'Empresas fora da UE que operam na UE devem cumprir se empregam trabalhadores nos estados membros.' }],
  nl: [{ question: 'Wat is de EU-richtlijn loontransparantie?', answer: 'De EU-richtlijn loontransparantie (2023/970/EU) is aangenomen in april 2023 en verplicht EU-lidstaten nieuwe regels te implementeren vóór 7 juni 2026.' }, { question: 'Wanneer treedt de richtlijn in werking?', answer: 'Lidstaten moeten de richtlijn omzetten vóór 7 juni 2026.' }, { question: 'Voor wie geldt de richtlijn?', answer: 'De richtlijn geldt voor alle werkgevers in de EU. Rapportageverplichtingen gelden voor bedrijven met 100 of meer werknemers.' }, { question: 'Verplicht de richtlijn tot salarisopenbaarmaking in vacatures?', answer: 'Ja. Werkgevers moeten salarisinfo verstrekken vóór het eerste gesprek.' }, { question: 'Wat zijn de sancties?', answer: 'Sancties variëren per lidstaat, met omkering van de bewijslast.' }, { question: 'Welke rechten krijgen werknemers?', answer: 'Werknemers mogen informatie opvragen over hun loon en het gemiddelde loon voor vergelijkbare functies.' }, { question: 'Geldt de richtlijn voor niet-EU bedrijven?', answer: 'Ja, als zij werknemers in EU-lidstaten in dienst hebben.' }],
  pl: [{ question: 'Czym jest dyrektywa UE o przejrzystości wynagrodzeń?', answer: 'Dyrektywa UE o przejrzystości wynagrodzeń (2023/970/UE) zobowiązuje państwa członkowskie do wdrożenia nowych przepisów do 7 czerwca 2026 r.' }, { question: 'Kiedy wchodzi w życie?', answer: 'Państwa członkowskie muszą przetransponować dyrektywę do 7 czerwca 2026 r.' }, { question: 'Kogo dotyczy?', answer: 'Dotyczy wszystkich pracodawców w UE. Obowiązki sprawozdawcze dotyczą firm z 100 lub więcej pracownikami.' }, { question: 'Czy wymaga ujawniania wynagrodzeń w ogłoszeniach?', answer: 'Tak. Pracodawcy muszą podać informacje o wynagrodzeniu przed pierwszą rozmową.' }, { question: 'Jakie są kary?', answer: 'Kary różnią się w zależności od państwa członkowskiego, z odwróceniem ciężaru dowodu.' }, { question: 'Jakie prawa mają pracownicy?', answer: 'Pracownicy mogą żądać informacji o swoim wynagrodzeniu i średnim wynagrodzeniu na porównywalnych stanowiskach.' }, { question: 'Czy dotyczy firm spoza UE?', answer: 'Tak, jeśli zatrudniają pracowników w państwach członkowskich UE.' }],
  ro: [{ question: 'Ce este Directiva UE privind transparența salarială?', answer: 'Directiva UE (2023/970/UE) obligă statele membre să implementeze noi reguli până pe 7 iunie 2026.' }, { question: 'Când intră în vigoare?', answer: 'Statele membre trebuie să transpună directiva până pe 7 iunie 2026.' }, { question: 'Cui se aplică?', answer: 'Se aplică tuturor angajatorilor din UE. Cerințele de raportare vizează companiile cu 100+ angajați.' }, { question: 'Impune divulgarea salariilor în anunțuri?', answer: 'Da. Angajatorii trebuie să furnizeze informații salariale înainte de primul interviu.' }, { question: 'Care sunt sancțiunile?', answer: 'Sancțiunile variază, cu inversarea sarcinii probei.' }, { question: 'Ce drepturi au angajații?', answer: 'Angajații pot solicita informații despre salariul lor și salariul mediu pentru roluri comparabile.' }, { question: 'Se aplică companiilor din afara UE?', answer: 'Da, dacă angajează lucrători în statele membre.' }],
  cs: [{ question: 'Co je směrnice EU o transparentnosti odměňování?', answer: 'Směrnice EU (2023/970/EU) zavazuje členské státy k implementaci nových pravidel do 7. června 2026.' }, { question: 'Kdy vstupuje v platnost?', answer: 'Členské státy musí transponovat směrnici do 7. června 2026.' }, { question: 'Na koho se vztahuje?', answer: 'Vztahuje se na všechny zaměstnavatele v EU. Povinnosti hlášení platí pro firmy se 100 a více zaměstnanci.' }, { question: 'Vyžaduje zveřejnění platů v inzerátech?', answer: 'Ano. Zaměstnavatelé musí poskytnout platové informace před prvním pohovorem.' }, { question: 'Jaké jsou sankce?', answer: 'Sankce se liší, s obrácením důkazního břemene.' }, { question: 'Jaká práva mají zaměstnanci?', answer: 'Zaměstnanci mohou žádat informace o svém platu a průměrném platu pro srovnatelné pozice.' }, { question: 'Platí pro firmy mimo EU?', answer: 'Ano, pokud zaměstnávají pracovníky v členských státech EU.' }],
  sv: [{ question: 'Vad är EU:s lönetransparensdirektiv?', answer: 'EU:s lönetransparensdirektiv (2023/970/EU) ålägger EU:s medlemsstater att implementera nya regler senast den 7 juni 2026.' }, { question: 'När träder direktivet i kraft?', answer: 'Medlemsstater måste genomföra direktivet senast den 7 juni 2026.' }, { question: 'Vem omfattas?', answer: 'Direktivet gäller alla arbetsgivare i EU. Rapporteringskrav gäller företag med 100 eller fler anställda.' }, { question: 'Kräver direktivet löneuppgifter i jobbannonser?', answer: 'Ja. Arbetsgivare måste ge löneinformation innan första intervjun.' }, { question: 'Vilka sanktioner finns?', answer: 'Sanktioner varierar, med omvänd bevisbörda.' }, { question: 'Vilka rättigheter får anställda?', answer: 'Anställda kan begära information om sin lön och genomsnittslön för jämförbara tjänster.' }, { question: 'Gäller det för icke-EU-företag?', answer: 'Ja, om de anställer arbetstagare i EU-medlemsstater.' }],
  da: [{ question: 'Hvad er EU\'s løngennemsigtighedsdirektiv?', answer: 'EU\'s direktiv (2023/970/EU) forpligter EU\'s medlemsstater til at implementere nye regler senest den 7. juni 2026.' }, { question: 'Hvornår træder det i kraft?', answer: 'Medlemsstater skal gennemføre direktivet inden den 7. juni 2026.' }, { question: 'Hvem er omfattet?', answer: 'Direktivet gælder alle arbejdsgivere i EU. Rapporteringskrav gælder virksomheder med 100 eller flere ansatte.' }, { question: 'Kræver direktivet lønoplysninger i jobopslag?', answer: 'Ja. Arbejdsgivere skal give lønoplysninger inden første samtale.' }, { question: 'Hvad er sanktionerne?', answer: 'Sanktioner varierer, med omvendt bevisbyrde.' }, { question: 'Hvilke rettigheder får medarbejdere?', answer: 'Medarbejdere kan anmode om oplysninger om deres løn og gennemsnitsløn for sammenlignelige stillinger.' }, { question: 'Gælder det for ikke-EU virksomheder?', answer: 'Ja, hvis de ansætter arbejdstagere i EU-medlemsstater.' }],
  fi: [{ question: 'Mikä on EU:n palkkatasa-arvodirektiivi?', answer: 'EU:n direktiivi (2023/970/EU) velvoittaa jäsenvaltiot panemaan täytäntöön uudet säännöt 7. kesäkuuta 2026 mennessä.' }, { question: 'Milloin se tulee voimaan?', answer: 'Jäsenvaltioiden on siirrettävä direktiivi kansalliseen lainsäädäntöön 7. kesäkuuta 2026 mennessä.' }, { question: 'Ketä se koskee?', answer: 'Direktiivi koskee kaikkia työnantajia EU:ssa. Raportointivaatimukset koskevat yrityksiä, joilla on 100 tai enemmän työntekijöitä.' }, { question: 'Edellyttääkö direktiivi palkkatietojen julkistamista?', answer: 'Kyllä. Työnantajien on annettava palkkatietoja ennen ensimmäistä haastattelua.' }, { question: 'Mitkä ovat seuraamukset?', answer: 'Seuraamukset vaihtelevat, todistustaakka kääntyy.' }, { question: 'Mitä oikeuksia työntekijät saavat?', answer: 'Työntekijät voivat pyytää tietoja palkastaan ja vertailukelpoisten tehtävien keskipalkasta.' }, { question: 'Koskeeko se EU:n ulkopuolisia yrityksiä?', answer: 'Kyllä, jos ne palkkaavat työntekijöitä EU:n jäsenvaltioissa.' }],
  el: [{ question: 'Τι είναι η οδηγία ΕΕ για τη διαφάνεια αμοιβών;', answer: 'Η οδηγία ΕΕ (2023/970/ΕΕ) υποχρεώνει τα κράτη μέλη να εφαρμόσουν νέους κανόνες έως τις 7 Ιουνίου 2026.' }, { question: 'Πότε τίθεται σε ισχύ;', answer: 'Τα κράτη μέλη πρέπει να ενσωματώσουν την οδηγία έως τις 7 Ιουνίου 2026.' }, { question: 'Σε ποιους εφαρμόζεται;', answer: 'Εφαρμόζεται σε όλους τους εργοδότες στην ΕΕ. Οι απαιτήσεις υποβολής εκθέσεων αφορούν εταιρείες με 100+ εργαζόμενους.' }, { question: 'Απαιτεί αποκάλυψη μισθών σε αγγελίες;', answer: 'Ναι. Οι εργοδότες πρέπει να παρέχουν πληροφορίες αμοιβής πριν από την πρώτη συνέντευξη.' }, { question: 'Ποιες είναι οι κυρώσεις;', answer: 'Οι κυρώσεις ποικίλουν, με αντιστροφή του βάρους απόδειξης.' }, { question: 'Ποια δικαιώματα αποκτούν οι εργαζόμενοι;', answer: 'Μπορούν να ζητήσουν πληροφορίες για αμοιβές σε συγκρίσιμες θέσεις.' }, { question: 'Ισχύει για μη-ΕΕ εταιρείες;', answer: 'Ναι, αν απασχολούν εργαζόμενους σε κράτη μέλη.' }],
  hu: [{ question: 'Mi az EU bérezési átláthatósági irányelv?', answer: 'Az EU irányelve (2023/970/EU) kötelezi a tagállamokat az új szabályok 2026. június 7-ig történő bevezetésére.' }, { question: 'Mikor lép hatályba?', answer: 'A tagállamoknak 2026. június 7-ig kell átültetniük az irányelvet.' }, { question: 'Kire vonatkozik?', answer: 'Az irányelv az EU összes munkáltatójára vonatkozik. A jelentési kötelezettségek a 100+ munkavállalóval rendelkező cégekre.' }, { question: 'Megköveteli a fizetések feltüntetését az álláshirdetésekben?', answer: 'Igen. A munkáltatóknak bértájékoztatást kell adniuk az első interjú előtt.' }, { question: 'Mik a szankciók?', answer: 'A szankciók tagállamonként eltérnek, bizonyítási teher megfordítással.' }, { question: 'Milyen jogokat kapnak a munkavállalók?', answer: 'Joguk van bértájékoztatást kérni összehasonlítható munkakörökre vonatkozóan.' }, { question: 'Vonatkozik az EU-n kívüli cégekre?', answer: 'Igen, ha EU tagállamokban foglalkoztatnak munkavállalókat.' }],
  sk: [{ question: 'Čo je smernica EÚ o transparentnosti odmeňovania?', answer: 'Smernica EÚ (2023/970/EÚ) zaväzuje členské štáty implementovať nové pravidlá do 7. júna 2026.' }, { question: 'Kedy nadobudne účinnosť?', answer: 'Členské štáty musia transponovať smernicu do 7. júna 2026.' }, { question: 'Na koho sa vzťahuje?', answer: 'Vzťahuje sa na všetkých zamestnávateľov v EÚ. Povinnosti hlásenia platia pre firmy so 100 a viac zamestnancami.' }, { question: 'Vyžaduje zverejnenie platov v inzerátoch?', answer: 'Áno. Zamestnávatelia musia poskytnúť platové informácie pred prvým pohovorom.' }, { question: 'Aké sú sankcie?', answer: 'Sankcie sa líšia, s prenesením dôkazného bremena.' }, { question: 'Aké práva majú zamestnanci?', answer: 'Môžu žiadať informácie o platoch na porovnateľných pozíciách.' }, { question: 'Platí pre firmy mimo EÚ?', answer: 'Áno, ak zamestnávajú pracovníkov v členských štátoch EÚ.' }],
  bg: [{ question: 'Какво е директивата на ЕС за прозрачност на заплащането?', answer: 'Директивата на ЕС (2023/970/ЕС) задължава държавите членки да прилагат нови правила до 7 юни 2026 г.' }, { question: 'Кога влиза в сила?', answer: 'Държавите членки трябва да транспонират директивата до 7 юни 2026 г.' }, { question: 'За кого се прилага?', answer: 'Прилага се за всички работодатели в ЕС. Изискванията за отчетност се прилагат за фирми с 100+ служители.' }, { question: 'Изисква ли се оповестяване на заплати в обяви?', answer: 'Да. Работодателите трябва да предоставят информация за заплатите преди първото интервю.' }, { question: 'Какви са санкциите?', answer: 'Санкциите варират, с обръщане на тежестта на доказване.' }, { question: 'Какви права имат служителите?', answer: 'Могат да искат информация за заплащането за сравними длъжности.' }, { question: 'Прилага ли се за фирми извън ЕС?', answer: 'Да, ако наемат работници в държавите членки.' }],
  hr: [{ question: 'Što je direktiva EU o transparentnosti plaća?', answer: 'Direktiva EU (2023/970/EU) obvezuje države članice na implementaciju novih pravila do 7. lipnja 2026.' }, { question: 'Kada stupa na snagu?', answer: 'Države članice moraju transponirati direktivu do 7. lipnja 2026.' }, { question: 'Na koga se primjenjuje?', answer: 'Primjenjuje se na sve poslodavce u EU. Zahtjevi izvješćivanja odnose se na tvrtke sa 100+ zaposlenika.' }, { question: 'Zahtijeva li objavu plaća u oglasima?', answer: 'Da. Poslodavci moraju pružiti informacije o plaći prije prvog razgovora.' }, { question: 'Koje su sankcije?', answer: 'Sankcije se razlikuju, s preokretom tereta dokazivanja.' }, { question: 'Koja prava dobivaju zaposlenici?', answer: 'Mogu zahtijevati informacije o plaćama za usporedive uloge.' }, { question: 'Primjenjuje li se na tvrtke izvan EU?', answer: 'Da, ako zapošljavaju radnike u državama članicama.' }],
  sl: [{ question: 'Kaj je direktiva EU o preglednosti plač?', answer: 'Direktiva EU (2023/970/EU) zavezuje države članice k uvedbi novih pravil do 7. junija 2026.' }, { question: 'Kdaj začne veljati?', answer: 'Države članice morajo prenesti direktivo do 7. junija 2026.' }, { question: 'Na koga se nanaša?', answer: 'Nanaša se na vse delodajalce v EU. Zahteve poročanja se nanašajo na podjetja s 100+ zaposlenimi.' }, { question: 'Ali zahteva razkritje plač v oglasih?', answer: 'Da. Delodajalci morajo pred prvim razgovorom zagotoviti informacije o plači.' }, { question: 'Kakšne so sankcije?', answer: 'Sankcije se razlikujejo, z obratom dokaznega bremena.' }, { question: 'Kakšne pravice dobijo zaposleni?', answer: 'Zahtevajo lahko informacije o plačah za primerljive vloge.' }, { question: 'Velja za podjetja zunaj EU?', answer: 'Da, če zaposlujejo delavce v državah članicah.' }],
  lt: [{ question: 'Kas yra ES darbo užmokesčio skaidrumo direktyva?', answer: 'ES direktyva (2023/970/ES) įpareigoja valstybes nares iki 2026 m. birželio 7 d. įgyvendinti naujus reikalavimus.' }, { question: 'Kada įsigalioja?', answer: 'Valstybės narės turi perkelti direktyvą iki 2026 m. birželio 7 d.' }, { question: 'Kam taikoma?', answer: 'Taikoma visiems darbdaviams ES. Ataskaitų teikimo reikalavimai taikomi įmonėms, kuriose dirba 100+ darbuotojų.' }, { question: 'Ar reikia skelbti atlyginimus darbo skelbimuose?', answer: 'Taip. Darbdaviai turi suteikti informaciją apie atlyginimą prieš pirmą pokalbį.' }, { question: 'Kokios sankcijos?', answer: 'Sankcijos skiriasi, įrodinėjimo pareiga perkeliama.' }, { question: 'Kokias teises gauna darbuotojai?', answer: 'Gali prašyti informacijos apie atlyginimus panašiose pareigose.' }, { question: 'Ar taikoma ne ES įmonėms?', answer: 'Taip, jei jos įdarbina darbuotojus valstybėse narėse.' }],
  lv: [{ question: 'Kas ir ES algu pārredzamības direktīva?', answer: 'ES direktīva (2023/970/ES) uzliek dalībvalstīm pienākumu ieviest jaunus noteikumus līdz 2026. gada 7. jūnijam.' }, { question: 'Kad tā stājas spēkā?', answer: 'Dalībvalstīm direktīva jāpārceļ nacionālajos tiesību aktos līdz 2026. gada 7. jūnijam.' }, { question: 'Uz ko tā attiecas?', answer: 'Tā attiecas uz visiem darba devējiem ES. Ziņošanas prasības attiecas uz uzņēmumiem ar 100+ darbiniekiem.' }, { question: 'Vai tā prasa algu atklāšanu sludinājumos?', answer: 'Jā. Darba devējiem jāsniedz algas informācija pirms pirmās intervijas.' }, { question: 'Kādas ir sankcijas?', answer: 'Sankcijas atšķiras, pierādīšanas pienākums tiek apgriezts.' }, { question: 'Kādas tiesības gūst darbinieki?', answer: 'Var pieprasīt informāciju par algām salīdzināmās lomās.' }, { question: 'Vai tas attiecas uz uzņēmumiem ārpus ES?', answer: 'Jā, ja tie nodarbina darbiniekus dalībvalstīs.' }],
  et: [{ question: 'Mis on EL-i palgaläbipaistvuse direktiiv?', answer: 'EL-i direktiiv (2023/970/EL) kohustab liikmesriike kehtestama uued reeglid 7. juuniks 2026.' }, { question: 'Millal see jõustub?', answer: 'Liikmesriigid peavad direktiivi üle võtma 7. juuniks 2026.' }, { question: 'Keda see puudutab?', answer: 'See puudutab kõiki tööandjaid EL-is. Aruandlusnõuded kehtivad ettevõtetele, kus on 100+ töötajat.' }, { question: 'Kas see nõuab palkade avaldamist kuulutustes?', answer: 'Jah. Tööandjad peavad andma palgainfot enne esimest vestlust.' }, { question: 'Millised on sanktsioonid?', answer: 'Sanktsioonid erinevad, tõendamiskohustus pöördub ümber.' }, { question: 'Millised õigused saavad töötajad?', answer: 'Nad võivad nõuda teavet võrreldavate ametikohtade palkade kohta.' }, { question: 'Kas see kehtib EL-i välistele ettevõtetele?', answer: 'Jah, kui nad tõmblevad töötajaid liikmesriikides.' }],
  mt: [{ question: 'X\'inhi d-Direttiva tal-UE dwar it-trasparenza tal-pagi?', answer: 'Id-Direttiva tal-UE (2023/970/UE) tobbliga l-Istati Membri jimplimentaw regoli ġodda sal-7 ta\' Ġunju 2026.' }, { question: 'Meta tidħol fis-seħħ?', answer: 'L-Istati Membri jridu jittrasponu d-direttiva sal-7 ta\' Ġunju 2026.' }, { question: 'Għal min tapplika?', answer: 'Tapplika għal min iħaddem fl-UE. Ir-rekwiżiti ta\' rappurtar japplikaw għal kumpaniji b\'100+ impjegat.' }, { question: 'Tirrikjedi divulgazzjoni tas-salarju fl-avviżi?', answer: 'Iva. L-impjegaturi jridu jipprovdu informazzjoni dwar il-pagi qabel l-ewwel intervista.' }, { question: 'X\'inhuma s-sanzjonijiet?', answer: 'Is-sanzjonijiet jvarjaw, bil-piż tal-prova inverz.' }, { question: 'X\'drittijiet jiksbu l-impjegati?', answer: 'Jistgħu jitolbu informazzjoni dwar il-pagi f\'rwoli komparabbli.' }, { question: 'Japplika għal kumpaniji barra l-UE?', answer: 'Iva, jekk jimpjegaw ħaddiema fl-Istati Membri.' }],
