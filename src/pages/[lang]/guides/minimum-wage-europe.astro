  ro: [{ question: 'Care este salariul minim în Germania?', answer: 'Salariul minim legal în Germania este de 12,82 €/oră din ianuarie 2026, echivalent cu aproximativ 2.222 €/lună.' }, { question: 'Ce țară UE are cel mai mare salariu minim?', answer: 'Luxemburg are cel mai mare salariu minim legal din UE: 2.570 €/lună (brut) în 2026.' }, { question: 'Ce țară UE are cel mai mic salariu minim?', answer: 'Bulgaria are cel mai mic salariu minim național din UE — aproximativ 551 €/lună în 2026.' }, { question: 'Germania are salariu minim?', answer: 'Da. Germania a introdus primul salariu minim de 8,50 €/oră în 2015 și l-a majorat la 12,82 €/oră în 2026.' }, { question: 'Franța are salariu minim?', answer: 'Da. SMIC-ul francez este 11,65 €/oră sau 1.801 €/lună brut în 2026.' }, { question: 'De ce Danemarca și Suedia nu au salariu minim?', answer: 'Piețele lor de muncă se bazează pe acorduri colective sectoriale care acoperă majoritatea lucrătorilor.' }, { question: 'Care este salariul minim în Spania?', answer: 'SMI-ul spaniol este 1.184 €/lună brut în 2026 — aproape dublat față de 2019.' }, { question: 'Este suficient salariul minim în Europa pentru a trăi?', answer: 'Depinde mult de țară. În Luxemburg (2.570 €/lună) da; în Bulgaria (551 €/lună) puterea de cumpărare locală acoperă cheltuielile de bază.' }],
  cs: [{ question: 'Jaká je minimální mzda v Německu?', answer: 'Zákonná minimální mzda v Německu je 12,82 €/hod. od ledna 2026, tedy přibližně 2 222 €/měsíc.' }, { question: 'Která země EU má nejvyšší minimální mzdu?', answer: 'Lucembursko má nejvyšší zákonnou minimální mzdu v EU: 2 570 €/měsíc (hrubé) v roce 2026.' }, { question: 'Která země EU má nejnižší minimální mzdu?', answer: 'Bulharsko má nejnižší národní minimální mzdu v EU — přibližně 551 €/měsíc v roce 2026.' }, { question: 'Má Německo minimální mzdu?', answer: 'Ano. Německo zavedlo první minimální mzdu 8,50 €/hod. v roce 2015 a zvýšilo ji na 12,82 €/hod. v roce 2026.' }, { question: 'Má Francie minimální mzdu?', answer: 'Ano. Francouzský SMIC je 11,65 €/hod. nebo 1 801 €/měsíc hrubého v roce 2026.' }, { question: 'Proč Dánsko a Švédsko nemají minimální mzdu?', answer: 'Jejich trhy práce fungují na základě sektorových kolektivních smluv pokrývajících většinu pracovníků.' }, { question: 'Jaká je minimální mzda ve Španělsku?', answer: 'Španělský SMI je 1 184 €/měsíc hrubého v roce 2026 — téměř zdvojnásobeno od roku 2019.' }, { question: 'Stačí minimální mzda v Evropě k životu?', answer: 'Záleží na zemi. V Lucembursku (2 570 €/měsíc) ano; v Bulharsku (551 €/měsíc) místní kupní síla pokrývá základní výdaje.' }],
  sv: [{ question: 'Vad är minimilönen i Tyskland?', answer: 'Den lagstadgade minimilönen i Tyskland är €12,82/timme från januari 2026, vilket motsvarar ca €2 222/månad.' }, { question: 'Vilket EU-land har den högsta minimilönen?', answer: 'Luxemburg har den högsta lagstadgade minimilönen i EU: €2 570/månad (brutto) 2026.' }, { question: 'Vilket EU-land har den lägsta minimilönen?', answer: 'Bulgarien har den lägsta nationella minimilönen i EU — ca €551/månad 2026.' }, { question: 'Har Tyskland en minimilön?', answer: 'Ja. Tyskland introducerade den första minimilönen på €8,50/timme 2015 och har höjt den till €12,82/timme 2026.' }, { question: 'Har Frankrike en minimilön?', answer: 'Ja. Den franska SMIC är €11,65/timme eller €1 801/månad brutto 2026.' }, { question: 'Varför har Danmark och Sverige ingen minimilön?', answer: 'Deras arbetsmarknader fungerar med sektoriella kollektivavtal som täcker de flesta arbetstagare.' }, { question: 'Vad är minimilönen i Spanien?', answer: 'Den spanska SMI är €1 184/månad brutto 2026 — nästan fördubblad sedan 2019.' }, { question: 'Räcker minimilönen i Europa att leva på?', answer: 'Det beror på landet. I Luxemburg (€2 570/månad) ja; i Bulgarien (€551/månad) täcker lokal köpkraft grundläggande utgifter.' }],
  da: [{ question: 'Hvad er mindstelønnen i Tyskland?', answer: 'Den lovpligtige mindsteløn i Tyskland er €12,82/time fra januar 2026, svarende til ca. €2.222/måned.' }, { question: 'Hvilket EU-land har den højeste mindsteløn?', answer: 'Luxembourg har den højeste lovpligtige mindsteløn i EU: €2.570/måned (brutto) i 2026.' }, { question: 'Hvilket EU-land har den laveste mindsteløn?', answer: 'Bulgarien har den laveste nationale mindsteløn i EU — ca. €551/måned i 2026.' }, { question: 'Har Tyskland en mindsteløn?', answer: 'Ja. Tyskland introducerede den første mindsteløn på €8,50/time i 2015 og har hævet den til €12,82/time i 2026.' }, { question: 'Har Frankrig en mindsteløn?', answer: 'Ja. Den franske SMIC er €11,65/time eller €1.801/måned brutto i 2026.' }, { question: 'Hvorfor har Danmark og Sverige ingen mindsteløn?', answer: 'Deres arbejdsmarkeder fungerer med sektorielle kollektive aftaler, der dækker de fleste arbejdstagere.' }, { question: 'Hvad er mindstelønnen i Spanien?', answer: 'Den spanske SMI er €1.184/måned brutto i 2026 — næsten fordoblet siden 2019.' }, { question: 'Er mindstelønnen i Europa nok til at leve af?', answer: 'Det afhænger meget af landet. I Luxembourg (€2.570/måned) ja; i Bulgarien (€551/måned) dækker lokal købekraft grundlæggende udgifter.' }],
  fi: [{ question: 'Mikä on minimipalkka Saksassa?', answer: 'Saksan lakisääteinen minimipalkka on 12,82 €/tunti tammikuusta 2026 alkaen, eli noin 2 222 €/kuukausi.' }, { question: 'Millä EU-maalla on korkein minimipalkka?', answer: 'Luxemburgilla on EU:n korkein lakisääteinen minimipalkka: 2 570 €/kuukausi (brutto) vuonna 2026.' }, { question: 'Millä EU-maalla on alhaisin minimipalkka?', answer: 'Bulgarialla on EU:n alhaisin kansallinen minimipalkka — noin 551 €/kuukausi vuonna 2026.' }, { question: 'Onko Saksalla minimipalkka?', answer: 'On. Saksa otti ensimmäisen minimipalkakseen 8,50 €/tunti vuonna 2015 ja on nostanut sen 12,82 €/tunniin vuoteen 2026 mennessä.' }, { question: 'Onko Ranskalla minimipalkka?', answer: 'On. Ranskan SMIC on 11,65 €/tunti tai 1 801 €/kuukausi brutto vuonna 2026.' }, { question: 'Miksi Tanskalla ja Ruotsilla ei ole minimipalkkaa?', answer: 'Heidän työmarkkinansa toimivat alakohtaisilla työehtosopimuksilla, jotka kattavat useimmat työntekijät.' }, { question: 'Mikä on minimipalkka Espanjassa?', answer: 'Espanjan SMI on 1 184 €/kuukausi brutto vuonna 2026 — lähes kaksinkertaistunut vuodesta 2019.' }, { question: 'Riittääkö minimipalkka Euroopassa elämiseen?', answer: 'Se riippuu paljon maasta. Luxemburgissa (2 570 €/kk) kyllä; Bulgariassa (551 €/kk) paikallinen ostovoima kattaa perusmenot.' }],
  el: [{ question: 'Ποιος είναι ο κατώτατος μισθός στη Γερμανία;', answer: 'Ο νόμιμος κατώτατος μισθός στη Γερμανία είναι €12,82/ώρα από τον Ιανουάριο 2026, δηλαδή περίπου €2.222/μήνα.' }, { question: 'Ποια χώρα ΕΕ έχει τον υψηλότερο κατώτατο μισθό;', answer: 'Το Λουξεμβούργο έχει τον υψηλότερο νόμιμο κατώτατο μισθό στην ΕΕ: €2.570/μήνα (μεικτά) το 2026.' }, { question: 'Ποια χώρα ΕΕ έχει τον χαμηλότερο κατώτατο μισθό;', answer: 'Η Βουλγαρία έχει τον χαμηλότερο εθνικό κατώτατο μισθό στην ΕΕ — περίπου €551/μήνα το 2026.' }, { question: 'Έχει η Γερμανία κατώτατο μισθό;', answer: 'Ναι. Η Γερμανία εισήγαγε πρώτο κατώτατο μισθό €8,50/ώρα το 2015 και τον αύξησε σε €12,82/ώρα το 2026.' }, { question: 'Έχει η Γαλλία κατώτατο μισθό;', answer: 'Ναι. Ο γαλλικός SMIC είναι €11,65/ώρα ή €1.801/μήνα μεικτά το 2026.' }, { question: 'Γιατί η Δανία και η Σουηδία δεν έχουν κατώτατο μισθό;', answer: 'Οι αγορές εργασίας τους λειτουργούν με κλαδικές συλλογικές συμβάσεις που καλύπτουν τους περισσότερους εργαζομένους.' }, { question: 'Ποιος είναι ο κατώτατος μισθός στην Ισπανία;', answer: 'Ο ισπανικός SMI είναι €1.184/μήνα μεικτά το 2026 — σχεδόν διπλάσιος από το 2019.' }, { question: 'Αρκεί ο κατώτατος μισθός στην Ευρώπη για να ζήσει κάποιος;', answer: 'Εξαρτάται από τη χώρα. Στο Λουξεμβούργο (€2.570/μήνα) ναι· στη Βουλγαρία (€551/μήνα) η τοπική αγοραστική δύναμη καλύπτει βασικές δαπάνες.' }],
  hu: [{ question: 'Mennyi a minimálbér Németországban?', answer: 'A törvényes minimálbér Németországban 2026 januárjától 12,82 €/óra, ami 40 órás munkahétnél kb. 2 222 €/hó.' }, { question: 'Melyik EU-tagállamnak van a legmagasabb minimálbére?', answer: 'Luxemburgnak van a legmagasabb törvényes minimálbére az EU-ban: 2 570 €/hó (bruttó) 2026-ban.' }, { question: 'Melyik EU-tagállamnak van a legalacsonyabb minimálbére?', answer: 'Bulgáriának van a legalacsonyabb nemzeti minimálbére az EU-ban — kb. 551 €/hó 2026-ban.' }, { question: 'Van-e Németországnak minimálbére?', answer: 'Igen. Németország 2015-ben vezette be az első 8,50 €/óra minimálbért, amit 2026-ra 12,82 €/órára emelt.' }, { question: 'Van-e Franciaországnak minimálbére?', answer: 'Igen. A francia SMIC 11,65 €/óra vagy 1 801 €/hó bruttó 2026-ban.' }, { question: 'Miért nincs Dániának és Svédországnak minimálbére?', answer: 'Munkaerőpiacaik ágazati kollektív szerződéseken alapulnak, amelyek a legtöbb munkavállalót fedik.' }, { question: 'Mennyi a minimálbér Spanyolországban?', answer: 'A spanyol SMI 1 184 €/hó bruttó 2026-ban — közel kétszerese a 2019-es szintnek.' }, { question: 'Elég-e a minimálbér Európában megélni?', answer: 'Ez nagymértékben az országtól függ. Luxemburgban (2 570 €/hó) igen; Bulgáriában (551 €/hó) a helyi vásárlóerő fedezi az alapkiadásokat.' }],
  sk: [{ question: 'Aká je minimálna mzda v Nemecku?', answer: 'Zákonná minimálna mzda v Nemecku je 12,82 €/hod. od januára 2026, čo zodpovedá asi 2 222 €/mesiac.' }, { question: 'Ktorá krajina EÚ má najvyššiu minimálnu mzdu?', answer: 'Luxembursko má najvyššiu zákonná minimálnu mzdu v EÚ: 2 570 €/mesiac (hrubé) v roku 2026.' }, { question: 'Ktorá krajina EÚ má najnižšiu minimálnu mzdu?', answer: 'Bulharsko má najnižšiu národnú minimálnu mzdu v EÚ — asi 551 €/mesiac v roku 2026.' }, { question: 'Má Nemecko minimálnu mzdu?', answer: 'Áno. Nemecko zaviedlo prvú minimálnu mzdu 8,50 €/hod. v roku 2015 a zvýšilo ju na 12,82 €/hod. v roku 2026.' }, { question: 'Má Francúzsko minimálnu mzdu?', answer: 'Áno. Francúzsky SMIC je 11,65 €/hod. alebo 1 801 €/mesiac hrubého v roku 2026.' }, { question: 'Prečo Dánsko a Švédsko nemajú minimálnu mzdu?', answer: 'Ich trhy práce fungujú na základe odvetvových kolektívnych zmlúv pokrývajúcich väčšinu pracovníkov.' }, { question: 'Aká je minimálna mzda v Španielsku?', answer: 'Španielsky SMI je 1 184 €/mesiac hrubého v roku 2026 — takmer zdvojnásobený od roku 2019.' }, { question: 'Stačí minimálna mzda v Európe na živobytie?', answer: 'Záleží na krajine. V Luxembursku (2 570 €/mes.) áno; v Bulharsku (551 €/mes.) miestna kúpna sila pokrýva základné výdaje.' }],
  bg: [{ question: 'Каква е минималната заплата в Германия?', answer: 'Законовата минимална заплата в Германия е 12,82 €/час от януари 2026 г., равностойно на около 2 222 €/месец.' }, { question: 'Коя страна от ЕС има най-висока минимална заплата?', answer: 'Люксембург има най-висока законова минимална заплата в ЕС: 2 570 €/месец (бруто) за 2026 г.' }, { question: 'Коя страна от ЕС има най-ниска минимална заплата?', answer: 'България има най-ниска национална минимална заплата в ЕС — около 551 €/месец за 2026 г.' }, { question: 'Има ли Германия минимална заплата?', answer: 'Да. Германия въведе първата минимална заплата от 8,50 €/час през 2015 г. и я повиши до 12,82 €/час за 2026 г.' }, { question: 'Има ли Франция минимална заплата?', answer: 'Да. Френският SMIC е 11,65 €/час или 1 801 €/месец бруто за 2026 г.' }, { question: 'Защо Дания и Швеция нямат минимална заплата?', answer: 'Техните трудови пазари работят с секторни колективни споразумения, обхващащи повечето работници.' }, { question: 'Каква е минималната заплата в Испания?', answer: 'Испанският SMI е 1 184 €/месец бруто за 2026 г. — почти удвоен от 2019 г.' }, { question: 'Достатъчна ли е минималната заплата в Европа за живот?', answer: 'Зависи от страната. В Люксембург (2 570 €/месец) да; в България (551 €/месец) местната покупателна способност покрива основни разходи.' }],
  hr: [{ question: 'Koja je minimalna plaća u Njemačkoj?', answer: 'Zakonska minimalna plaća u Njemačkoj je 12,82 €/sat od siječnja 2026., što odgovara oko 2.222 €/mjesec.' }, { question: 'Koja zemlja EU-a ima najveću minimalnu plaću?', answer: 'Luksemburg ima najveću zakonsku minimalnu plaću u EU-u: 2.570 €/mjesec (bruto) 2026.' }, { question: 'Koja zemlja EU-a ima najnižu minimalnu plaću?', answer: 'Bugarska ima najnižu nacionalnu minimalnu plaću u EU-u — oko 551 €/mjesec 2026.' }, { question: 'Ima li Njemačka minimalnu plaću?', answer: 'Da. Njemačka je uvela prvu minimalnu plaću od 8,50 €/sat 2015. i podigla je na 12,82 €/sat 2026.' }, { question: 'Ima li Francuska minimalnu plaću?', answer: 'Da. Francuski SMIC je 11,65 €/sat ili 1.801 €/mjesec bruto 2026.' }, { question: 'Zašto Danska i Švedska nemaju minimalnu plaću?', answer: 'Njihova tržišta rada funkcioniraju na temelju sektorskih kolektivnih ugovora koji pokrivaju većinu radnika.' }, { question: 'Koja je minimalna plaća u Španjolskoj?', answer: 'Španjolski SMI je 1.184 €/mjesec bruto 2026. — gotovo udvostručen od 2019.' }, { question: 'Je li minimalna plaća u Europi dovoljna za život?', answer: 'Ovisi o zemlji. U Luksemburgu (2.570 €/mj.) da; u Bugarskoj (551 €/mj.) lokalna kupovna moć pokriva osnovne troškove.' }],
  sl: [{ question: 'Kakšna je minimalna plača v Nemčiji?', answer: 'Zakonska minimalna plača v Nemčiji je 12,82 €/uro od januarja 2026, kar ustreza ok. 2.222 €/mesec.' }, { question: 'Katera država EU ima najvišjo minimalno plačo?', answer: 'Luksemburg ima najvišjo zakonsko minimalno plačo v EU: 2.570 €/mesec (bruto) v 2026.' }, { question: 'Katera država EU ima najnižjo minimalno plačo?', answer: 'Bolgarija ima najnižjo nacionalno minimalno plačo v EU — ok. 551 €/mesec v 2026.' }, { question: 'Ali ima Nemčija minimalno plačo?', answer: 'Da. Nemčija je uvedla prvo minimalno plačo 8,50 €/uro leta 2015 in jo zvišala na 12,82 €/uro do leta 2026.' }, { question: 'Ali ima Francija minimalno plačo?', answer: 'Da. Francoski SMIC je 11,65 €/uro ali 1.801 €/mesec bruto v 2026.' }, { question: 'Zakaj Danska in Švedska nimata minimalne plače?', answer: 'Njuni trgi dela delujejo na podlagi sektorskih kolektivnih pogodb, ki pokrivajo večino delavcev.' }, { question: 'Kakšna je minimalna plača v Španiji?', answer: 'Španski SMI je 1.184 €/mesec bruto v 2026 — skoraj podvojen od leta 2019.' }, { question: 'Ali je minimalna plača v Evropi dovolj za življenje?', answer: 'Odvisno od države. V Luksemburgu (2.570 €/mes.) da; v Bolgariji (551 €/mes.) lokalna kupna moč pokriva osnovne stroške.' }],
  lt: [{ question: 'Koks minimalus atlyginimas Vokietijoje?', answer: 'Įstatyminis minimalus atlyginimas Vokietijoje nuo 2026 m. sausio yra 12,82 €/val., tai yra apie 2 222 €/mėn.' }, { question: 'Kuri ES šalis turi aukščiausią minimalų atlyginimą?', answer: 'Liuksemburgas turi aukščiausią įstatyminį minimalų atlyginimą ES: 2 570 €/mėn. (bruto) 2026 m.' }, { question: 'Kuri ES šalis turi žemiausią minimalų atlyginimą?', answer: 'Bulgarija turi žemiausią nacionalinį minimalų atlyginimą ES — apie 551 €/mėn. 2026 m.' }, { question: 'Ar Vokietija turi minimalų atlyginimą?', answer: 'Taip. Vokietija 2015 m. įvedė pirmą 8,50 €/val. minimalų atlyginimą ir padidino jį iki 12,82 €/val. 2026 m.' }, { question: 'Ar Prancūzija turi minimalų atlyginimą?', answer: 'Taip. Prancūzijos SMIC yra 11,65 €/val. arba 1 801 €/mėn. bruto 2026 m.' }, { question: 'Kodėl Danija ir Švedija neturi minimalaus atlyginimo?', answer: 'Jų darbo rinkos veikia sektorinių kolektyvinių sutarčių pagrindu, apimančių daugumą darbuotojų.' }, { question: 'Koks minimalus atlyginimas Ispanijoje?', answer: 'Ispanijos SMI yra 1 184 €/mėn. bruto 2026 m. — beveik dvigubai daugiau nei 2019 m.' }, { question: 'Ar Europoje minimalaus atlyginimo pakanka pragyvenimui?', answer: 'Priklauso nuo šalies. Liuksemburge (2 570 €/mėn.) taip; Bulgarijoje (551 €/mėn.) vietinė perkamoji galia dengia pagrindinius poreikius.' }],
  lv: [{ question: 'Kāda ir minimālā alga Vācijā?', answer: 'Vācijas likumiskā minimālā alga no 2026. gada janvāra ir 12,82 €/stundā, kas atbilst aptuveni 2 222 €/mēnesī.' }, { question: 'Kurai ES valstij ir augstākā minimālā alga?', answer: 'Luksemburgai ir augstākā likumiskā minimālā alga ES: 2 570 €/mēnesī (bruto) 2026. gadā.' }, { question: 'Kurai ES valstij ir zemākā minimālā alga?', answer: 'Bulgārijai ir zemākā valsts minimālā alga ES — aptuveni 551 €/mēnesī 2026. gadā.' }, { question: 'Vai Vācijai ir minimālā alga?', answer: 'Jā. Vācija ieviesa pirmo 8,50 €/st. minimālo algu 2015. gadā un palielināja to līdz 12,82 €/st. 2026. gadā.' }, { question: 'Vai Francijai ir minimālā alga?', answer: 'Jā. Francijas SMIC ir 11,65 €/st. vai 1 801 €/mēnesī bruto 2026. gadā.' }, { question: 'Kāpēc Dānijai un Zviedrijai nav minimālās algas?', answer: 'To darba tirgi darbojas ar nozaru kolektīvajiem līgumiem, kas aptver lielāko daļu darba ņēmēju.' }, { question: 'Kāda ir minimālā alga Spānijā?', answer: 'Spānijas SMI 2026. gadā ir 1 184 €/mēnesī bruto — gandrīz divkāršojies kopš 2019. gada.' }, { question: 'Vai Eiropas minimālā alga ir pietiekama dzīvošanai?', answer: 'Atkarīgs no valsts. Luksemburgā (2 570 €/mēn.) jā; Bulgārijā (551 €/mēn.) vietējā pirktspēja sedz pamatvajadzības.' }],
  et: [{ question: 'Milline on miinimumpalk Saksamaal?', answer: 'Saksamaa seadusjärgne miinimumpalk on alates 2026. aasta jaanuarist 12,82 €/tund, mis vastab umbes 2 222 €/kuus.' }, { question: 'Millisel EL-i riigil on kõrgeim miinimumpalk?', answer: 'Luksemburgil on EL-i kõrgeim seadusjärgne miinimumpalk: 2 570 €/kuus (brutona) 2026. aastal.' }, { question: 'Millisel EL-i riigil on madalaim miinimumpalk?', answer: 'Bulgaarial on EL-i madalaim riiklik miinimumpalk — umbes 551 €/kuus 2026. aastal.' }, { question: 'Kas Saksamaal on miinimumpalk?', answer: 'Jah. Saksamaa võttis kasutusele esimese 8,50 €/tunni miinimumpalga 2015. aastal ja tõstis selle 12,82 €/tunnini 2026. aastaks.' }, { question: 'Kas Prantsusmaal on miinimumpalk?', answer: 'Jah. Prantsuse SMIC on 11,65 €/tund või 1 801 €/kuus brutona 2026. aastal.' }, { question: 'Miks Taanil ja Rootsil pole miinimumpalka?', answer: 'Nende tööturgudel toimivad sektorilepingud, mis katavad enamiku töötajaid.' }, { question: 'Milline on miinimumpalk Hispaanias?', answer: 'Hispaania SMI on 1 184 €/kuus brutona 2026. aastal — peaaegu kahekordistunud 2019. aastast.' }, { question: 'Kas Euroopa miinimumpalk on eluks piisav?', answer: 'Oleneb riigist. Luksemburgis (2 570 €/kuu) jah; Bulgaarias (551 €/kuu) katab kohalik ostujõud põhikulud.' }],
  mt: [{ question: 'X\'inhu s-salarju minimu fil-Ġermanja?', answer: 'Is-salarju minimu legali fil-Ġermanja huwa €12,82/siegħa mill-Jannar 2026, ekwivalenti għal madwar €2,222/xahar.' }, { question: 'Liema pajjiż tal-UE għandu l-ogħla salarju minimu?', answer: 'Il-Lussemburgu għandu l-ogħla salarju minimu legali fl-UE: €2,570/xahar (gross) fl-2026.' }, { question: 'Liema pajjiż tal-UE għandu l-inqas salarju minimu?', answer: 'Il-Bulgarija għandha l-inqas salarju minimu nazzjonali fl-UE — madwar €551/xahar fl-2026.' }, { question: 'Il-Ġermanja għandha salarju minimu?', answer: 'Iva. Il-Ġermanja introduċiet l-ewwel salarju minimu ta\' €8.50/siegħa fl-2015 u rafa\'tu sa €12.82/siegħa fl-2026.' }, { question: 'Franza għandha salarju minimu?', answer: 'Iva. Il-SMIC Franċiż huwa €11.65/siegħa jew €1,801/xahar gross fl-2026.' }, { question: 'Għaliex id-Danimarka u l-Isvezja ma għandhomx salarju minimu?', answer: 'Is-swieq tax-xogħol tagħhom joperaw fuq ftehimiet kollettivi settorjali li jkopru l-maġġoranza tal-ħaddiema.' }, { question: 'X\'inhu s-salarju minimu fi Spanja?', answer: 'L-SMI Spanjol huwa €1,184/xahar gross fl-2026 — kważi rduppjat mill-2019.' }, { question: 'Is-salarju minimu fl-Ewropa huwa biżżejjed biex tgħix?', answer: 'Jiddependi ħafna mill-pajjiż. Fil-Lussemburgu (€2,570/xahar) iva; fil-Bulgarija (€551/xahar) il-qawwa tax-xiri lokali tkopri l-ispejjeż bażiċi.' }],
  ga: [{ question: 'Cad é pá íosta na Gearmáine?', answer: 'Is é €12.82 san uair an phá íosta reachtúil sa Ghearmáin ó Eanáir 2026, comhionann le thart ar €2,222 sa mhí.' }, { question: 'Cé acu tír AE a bhfuil an pá íosta is airde?', answer: 'Tá an pá íosta reachtúil is airde san AE ag Lucsamburg: €2,570 sa mhí (comhlán) in 2026.' }, { question: 'Cé acu tír AE a bhfuil an pá íosta is ísle?', answer: 'Tá an pá íosta náisiúnta is ísle san AE ag an mBulgáir — thart ar €551 sa mhí in 2026.' }, { question: 'An bhfuil pá íosta ag an nGearmáin?', answer: 'Tá. Thug an Ghearmáin isteach an chéad phá íosta €8.50 san uair in 2015 agus ardaíodh go €12.82 san uair in 2026 é.' }, { question: 'An bhfuil pá íosta ag an bhFrainc?', answer: 'Tá. Is é €11.65 san uair nó €1,801 sa mhí (comhlán) an SMIC Francach in 2026.' }, { question: 'Cén fáth nach bhfuil pá íosta ag an Danmhairg agus ag an tSualainn?', answer: 'Oibríonn a gcuid margaí saothair ar chomhaontuithe comhchoiteanna earnála a chlúdaíonn formhór na n-oibrithe.' }, { question: 'Cad é pá íosta na Spáinne?', answer: 'Is é €1,184 sa mhí (comhlán) SMI na Spáinne in 2026 — beagnach dhá oiread ó 2019.' }, { question: 'An leor pá íosta na hEorpa le maireachtáil?', answer: 'Braitheann sé go mór ar an tír. I Lucsamburg (€2,570/mí) is leor; sa Bhulgáir (€551/mí) clúdaíonn cumhacht ceannaigh áitiúil caiteachas bunúsach.' }],
};

