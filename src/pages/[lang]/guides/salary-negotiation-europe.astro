const faqItems: Record<string, Array<{question: string; answer: string}>> = {
  en: [
    { question: 'How do I negotiate salary in Germany?', answer: 'In Germany, salary negotiations are data-driven and formal. Research market rates thoroughly using sources like EuroSalary, Gehalt.de, and Bundesagentur für Arbeit data. Present your case with specific numbers and justifications. Avoid emotional appeals — Germans respect preparation and facts. The best time to negotiate is after receiving a written offer. Expect to negotiate once; multiple counter-offers are less common than in the UK or US.' },
    { question: 'Is it normal to negotiate salary in France?', answer: 'Yes, but with nuance. French workplace culture is hierarchical, so how you negotiate matters. Frame requests in terms of the value you bring to the organisation rather than personal need. Large companies (grandes entreprises) have more rigid salary scales; startups and SMEs offer more flexibility. Avoid negotiating too aggressively — subtlety and diplomacy are valued. Many French employers expect a token negotiation but have a firm upper limit.' },
    { question: 'How do Dutch employers approach salary negotiation?', answer: 'The Netherlands has a direct negotiation culture — you are generally expected to negotiate. Dutch employers will often give a salary range rather than a fixed figure, explicitly inviting negotiation. Be straightforward, present market data, and make a clear counter-offer. Benefits like extra holiday days (above the 20-day legal minimum), NS business card for commuting, and pension contributions are also negotiable and valuable.' },
    { question: 'Is salary negotiation common in Spain?', answer: 'Spain has a relationship-oriented work culture, and salary negotiations often happen after you\'ve established some rapport. In smaller companies and startups, negotiation is standard. In larger corporations, salary scales are often set by collective agreements (convenios colectivos), leaving less room. The concept of "complementos salariales" (salary supplements like productivity bonuses and transport allowances) is important to understand — these often exceed the base salary in practice.' },
    { question: 'When is the best time to negotiate a salary increase?', answer: 'The optimal time is during or just after your annual performance review, when your contributions are fresh in your manager\'s mind. Another strong moment is when you take on additional responsibilities. In job offer negotiations, always negotiate before accepting — companies expect it and rarely rescind offers due to counter-proposals. Avoid raising salary right after a company has announced layoffs, restructuring, or poor financial results.' },
    { question: 'What should I ask for beyond base salary?', answer: 'Beyond base salary, consider negotiating: additional pension contributions, extra holiday days (even 2-3 extra days has significant value), home office days per week, annual training or conference budget, health insurance upgrades, a signing bonus to offset any loss from leaving your current employer, and performance review dates (earlier first review means earlier pay increase opportunity). In some countries, company cars, meal vouchers, and transport subsidies are standard parts of the package.' },
    { question: 'How do I use salary data to negotiate?', answer: 'Present market data as third-party evidence, not personal demands. Say: "Based on EuroSalary data and industry reports, the market rate for this role in [city] is €X–€Y. My experience and qualifications position me in the upper range. I\'d like to discuss aligning my compensation accordingly." This frames the conversation as a market correction, not a personal ask. Use data from EuroSalary\'s salary check tool to benchmark your specific role, experience level, and location.' },
  ],
  fr: [
    { question: 'Comment négocier son salaire en Allemagne ?', answer: 'En Allemagne, les négociations salariales sont axées sur les données et formelles. Recherchez les taux du marché et présentez des chiffres concrets. Évitez les arguments émotionnels — les Allemands respectent la préparation et les faits. Le meilleur moment est après avoir reçu une offre écrite.' },
    { question: 'Est-il normal de négocier son salaire en France ?', answer: 'Oui, mais avec nuance. La culture française est hiérarchique, donc la manière de négocier compte. Cadrez les demandes en termes de valeur apportée à l\'organisation. Les grandes entreprises ont des grilles salariales rigides ; les startups offrent plus de flexibilité.' },
    { question: 'Comment les employeurs néerlandais abordent-ils la négociation salariale ?', answer: 'Les Pays-Bas ont une culture de négociation directe — vous êtes généralement censé négocier. Les employeurs donnent souvent une fourchette salariale plutôt qu\'un chiffre fixe.' },
    { question: 'La négociation salariale est-elle courante en Espagne ?', answer: 'L\'Espagne a une culture de travail axée sur les relations. Dans les petites entreprises et les startups, la négociation est standard. Dans les grandes corporations, les grilles sont souvent fixées par des conventions collectives.' },
    { question: 'Quand est-il préférable de négocier une augmentation ?', answer: 'Le moment optimal est pendant ou juste après votre évaluation annuelle de performance. Évitez de soulever le sujet des salaires juste après des licenciements ou de mauvais résultats financiers.' },
    { question: 'Que demander au-delà du salaire de base ?', answer: 'Au-delà du salaire de base, envisagez de négocier : cotisations retraite supplémentaires, jours de congé supplémentaires, jours de télétravail, budget formation, assurance santé améliorée, prime de signature.' },
    { question: 'Comment utiliser les données salariales pour négocier ?', answer: 'Présentez les données du marché comme preuve tierce, pas comme des demandes personnelles. Utilisez les données d\'EuroSalary comme référence.' },
  ],
  de: [
    { question: 'Wie verhandelt man in Deutschland über Gehalt?', answer: 'In Deutschland sind Gehaltsverhandlungen datengetrieben und formal. Recherchieren Sie Marktgehälter gründlich und präsentieren Sie Ihren Fall mit konkreten Zahlen. Deutsche schätzen Vorbereitung und Fakten.' },
    { question: 'Ist Gehaltsverhandlung in Frankreich normal?', answer: 'Ja, aber mit Fingerspitzengefühl. Die französische Arbeitskultur ist hierarchisch. Formulieren Sie Anfragen in Bezug auf den Mehrwert, den Sie der Organisation bringen.' },
    { question: 'Wie gehen niederländische Arbeitgeber mit Gehaltsverhandlungen um?', answer: 'Die Niederlande haben eine direkte Verhandlungskultur — es wird erwartet, dass Sie verhandeln. Arbeitgeber geben oft eine Gehaltsspanne statt einer festen Zahl an.' },
    { question: 'Ist Gehaltsverhandlung in Spanien üblich?', answer: 'Spanien hat eine beziehungsorientierte Arbeitskultur. In kleineren Unternehmen und Startups ist Verhandlung Standard. In großen Konzernen werden Gehälter oft durch Tarifverträge festgelegt.' },
    { question: 'Wann ist der beste Zeitpunkt für eine Gehaltserhöhung?', answer: 'Der optimale Zeitpunkt ist während oder kurz nach Ihrer jährlichen Leistungsbeurteilung. Vermeiden Sie das Thema Gehalt kurz nach Entlassungen oder schlechten Finanzergebnissen.' },
    { question: 'Was sollte ich über das Grundgehalt hinaus fordern?', answer: 'Verhandeln Sie über: zusätzliche Rentenleistungen, Urlaubstage, Homeoffice-Tage, Weiterbildungsbudget, Krankenversicherung, Antrittsprämie.' },
    { question: 'Wie nutze ich Gehaltsdaten für Verhandlungen?', answer: 'Präsentieren Sie Marktdaten als Drittanbieter-Beweise. Nutzen Sie EuroSalary-Daten als Benchmark für Ihre spezifische Rolle.' },
