  ],
  it: [{ question: 'Come negozio lo stipendio in Germania?', answer: 'In Germania le trattative sono formali e basate sui dati. Presenta il tuo caso con cifre concrete.' }, { question: 'È normale negoziare lo stipendio in Francia?', answer: 'Sì, ma con delicatezza. La cultura francese è gerarchica: inquadra le richieste in termini di valore portato.' }, { question: 'Come si approccia la negoziazione in Olanda?', answer: 'I Paesi Bassi hanno una cultura di negoziazione diretta — ci si aspetta che tu negozi.' }, { question: 'La negoziazione è comune in Spagna?', answer: 'La Spagna ha una cultura lavorativa orientata alle relazioni. Nelle grandi aziende i salari sono spesso fissati da contratti collettivi.' }, { question: 'Quando è meglio chiedere un aumento?', answer: 'Il momento ottimale è durante o subito dopo la valutazione annuale delle performance.' }, { question: 'Cosa chiedere oltre alla paga base?', answer: 'Considera: contributi pensione aggiuntivi, giorni ferie extra, smart working, budget formazione.' }, { question: 'Come usare i dati salariali per negoziare?', answer: 'Presenta i dati di mercato come prova di terze parti, non come richieste personali.' }],
  pt: [{ question: 'Como negocio salário na Alemanha?', answer: 'Na Alemanha, as negociações são formais e baseadas em dados. Apresente o seu caso com números concretos.' }, { question: 'É normal negociar salário em França?', answer: 'Sim, mas com nuance. A cultura francesa é hierárquica; enquadre pedidos em termos de valor que traz.' }, { question: 'Como abordam os empregadores neerlandeses a negociação?', answer: 'Os Países Baixos têm uma cultura de negociação direta — espera-se que negocie.' }, { question: 'É comum negociar salário em Espanha?', answer: 'Espanha tem uma cultura de trabalho orientada para as relações. Nas grandes empresas os salários são frequentemente fixados por convenções coletivas.' }, { question: 'Quando é o melhor momento para negociar?', answer: 'O momento ideal é durante ou imediatamente após a avaliação anual de desempenho.' }, { question: 'O que pedir além do salário base?', answer: 'Considere: contribuições adicionais para pensão, dias de férias extra, dias de teletrabalho, orçamento de formação.' }, { question: 'Como usar dados salariais para negociar?', answer: 'Apresente dados de mercado como evidência de terceiros. Use os dados do EuroSalary como referência.' }],
  nl: [{ question: 'Hoe onderhandel ik over salaris in Duitsland?', answer: 'In Duitsland zijn salarisonderhandelingen datagestuurd en formeel. Presenteer je zaak met concrete cijfers.' }, { question: 'Is salarisnegociatie normaal in Frankrijk?', answer: 'Ja, maar met nuance. De Franse werkcultuur is hiërarchisch; formuleer verzoeken in termen van toegevoegde waarde.' }, { question: 'Hoe benaderen Nederlandse werkgevers salarisonderhandeling?', answer: 'Nederland heeft een directe onderhandelingscultuur — je wordt verwacht te onderhandelen.' }, { question: 'Is salarisnegociatie gebruikelijk in Spanje?', answer: 'Spanje heeft een relatiegerichte werkcultuur. Bij grote bedrijven zijn salarissen vaak vastgelegd in cao\'s.' }, { question: 'Wanneer is het beste moment om te onderhandelen?', answer: 'Het optimale moment is tijdens of kort na je jaarlijkse beoordeling.' }, { question: 'Wat te vragen naast het basissalaris?', answer: 'Overweeg: extra pensioenbijdragen, extra vakantiedagen, thuiswerkdagen, trainingsbudget.' }, { question: 'Hoe gebruik ik salarisdata bij onderhandelen?', answer: 'Presenteer marktdata als onafhankelijk bewijs. Gebruik EuroSalary-data als benchmark.' }],
  pl: [{ question: 'Jak negocjować wynagrodzenie w Niemczech?', answer: 'W Niemczech negocjacje są formalne i oparte na danych. Przedstaw swój przypadek z konkretnymi liczbami.' }, { question: 'Czy negocjowanie wynagrodzenia jest normalne we Francji?', answer: 'Tak, ale z niuansami. Kultura pracy we Francji jest hierarchiczna; formułuj prośby w kategoriach wartości.' }, { question: 'Jak holenderscy pracodawcy podchodzą do negocjacji?', answer: 'Holandia ma bezpośrednią kulturę negocjacji — oczekuje się, że będziesz negocjować.' }, { question: 'Czy negocjacje są powszechne w Hiszpanii?', answer: 'Hiszpania ma zorientowaną na relacje kulturę pracy. W dużych firmach wynagrodzenia są często ustalane w zbiorowych umowach.' }, { question: 'Kiedy najlepiej negocjować podwyżkę?', answer: 'Optymalny czas to podczas lub zaraz po rocznej ocenie wyników.' }, { question: 'O co pytać poza wynagrodzeniem podstawowym?', answer: 'Rozważ: dodatkowe składki emerytalne, dodatkowe dni urlopu, dni pracy zdalnej, budżet szkoleniowy.' }, { question: 'Jak używać danych o wynagrodzeniach do negocjacji?', answer: 'Przedstaw dane rynkowe jako dowód stron trzecich. Użyj danych EuroSalary jako wzorca.' }],
  ro: [{ question: 'Cum negociez salariul în Germania?', answer: 'În Germania negocierile sunt formale și bazate pe date. Prezintă-ți cazul cu cifre concrete.' }, { question: 'Este normal să negociezi salariul în Franța?', answer: 'Da, dar cu nuanță. Cultura muncii din Franța este ierarhică; formulează solicitările în termeni de valoare adusă.' }, { question: 'Cum abordează angajatorii olandezi negocierea salariului?', answer: 'Olanda are o cultură directă de negociere — se așteaptă să negociezi.' }, { question: 'Negocierea salariului este obișnuită în Spania?', answer: 'Spania are o cultură de muncă orientată spre relații. La marile companii salariile sunt adesea fixate prin convenții colective.' }, { question: 'Când este cel mai bun moment să negociezi?', answer: 'Momentul optim este în timpul sau imediat după evaluarea anuală de performanță.' }, { question: 'Ce să ceri dincolo de salariul de bază?', answer: 'Ia în considerare: contribuții suplimentare la pensie, zile extra de concediu, zile de telemuncă, buget de formare.' }, { question: 'Cum să folosești datele salariale pentru negociere?', answer: 'Prezintă datele de piață ca dovezi terțe. Folosește datele EuroSalary ca reper.' }],
  cs: [{ question: 'Jak vyjednávám plat v Německu?', answer: 'V Německu jsou jednání formální a datově orientovaná. Předložte svůj případ s konkrétními čísly.' }, { question: 'Je normální vyjednávat plat ve Francii?', answer: 'Ano, ale s nuancemi. Francouzská pracovní kultura je hierarchická; formulujte požadavky v termínech přidané hodnoty.' }, { question: 'Jak přistupují holandští zaměstnavatelé k vyjednávání?', answer: 'Nizozemsko má přímou kulturu vyjednávání — očekává se, že budete vyjednávat.' }, { question: 'Je vyjednávání běžné ve Španělsku?', answer: 'Španělsko má pracovní kulturu orientovanou na vztahy. Ve velkých firmách jsou platy často stanoveny kolektivními smlouvami.' }, { question: 'Kdy je nejlepší čas vyjednávat zvýšení?', answer: 'Optimální čas je při nebo krátce po ročním hodnocení výkonu.' }, { question: 'O co žádat nad základní plat?', answer: 'Zvažte: další příspěvky do důchodu, extra dny dovolené, dny práce z domova, tréninkový rozpočet.' }, { question: 'Jak používat platová data k vyjednávání?', answer: 'Prezentujte tržní data jako důkaz třetí strany. Použijte data EuroSalary jako benchmark.' }],
  sv: [{ question: 'Hur förhandlar jag lön i Tyskland?', answer: 'I Tyskland är löneförhandlingar datadrivna och formella. Presentera ditt ärende med konkreta siffror.' }, { question: 'Är löneförhandling normalt i Frankrike?', answer: 'Ja, men med nyans. Fransk arbetskultur är hierarkisk; formulera förfrågningar i termer av värde.' }, { question: 'Hur hanterar nederländska arbetsgivare löneförhandling?', answer: 'Nederländerna har en direkt förhandlingskultur — man förväntas förhandla.' }, { question: 'Är löneförhandling vanligt i Spanien?', answer: 'Spanien har en relationsorienterad arbetskultur. Hos stora företag är löner ofta fastställda i kollektivavtal.' }, { question: 'När är bäst tid att förhandla?', answer: 'Optimalt tillfälle är under eller strax efter din årliga utvärdering.' }, { question: 'Vad ska man be om utöver grundlönen?', answer: 'Förhandla om: extra pensionsavsättningar, extra semesterdagar, hemarbetsdagar, utbildningsbudget.' }, { question: 'Hur använder jag lönedata för förhandling?', answer: 'Presentera marknadsdata som tredjeparts bevis. Använd EuroSalarys data som riktmärke.' }],
  da: [{ question: 'Hvordan forhandler jeg løn i Tyskland?', answer: 'I Tyskland er lønforhandlinger datadrevne og formelle. Præsenter din sag med konkrete tal.' }, { question: 'Er lønforhandling normalt i Frankrig?', answer: 'Ja, men med nuance. Fransk arbejdskultur er hierarkisk; formuler anmodninger i termer af tilføjet værdi.' }, { question: 'Hvordan håndterer hollandske arbejdsgivere lønforhandling?', answer: 'Holland har en direkte forhandlingskultur — man forventes at forhandle.' }, { question: 'Er lønforhandling udbredt i Spanien?', answer: 'Spanien har en relationsorienteret arbejdskultur. Hos store virksomheder er løn ofte fastsat i overenskomster.' }, { question: 'Hvornår er det bedste tidspunkt at forhandle?', answer: 'Optimalt tidspunkt er under eller kort efter din årlige evaluering.' }, { question: 'Hvad skal man bede om ud over grundlønnen?', answer: 'Forhandl om: ekstra pensionsbidrag, ekstra feriedage, hjemmearbejdsdage, uddannelsesbudget.' }, { question: 'Hvordan bruger jeg løndata til forhandling?', answer: 'Præsenter markedsdata som tredjepartsbeviser. Brug EuroSalarys data som benchmark.' }],
  fi: [{ question: 'Kuinka neuvottelen palkasta Saksassa?', answer: 'Saksassa palkkaNeuvottelut ovat datavetoisia ja muodollisia. Esitä tapauksesi konkreettisilla luvuilla.' }, { question: 'Onko palkkaNeuvottelu normaalia Ranskassa?', answer: 'Kyllä, mutta vivahteilla. Ranskalainen työkulttuuri on hierarkkinen; muotoile pyynnöt tuoman arvon näkökulmasta.' }, { question: 'Kuinka hollantilaiset työnantajat lähestyvät palkkaneuvotteluita?', answer: 'Alankomaissa on suora neuvottelukulttuuri — sinun odotetaan neuvottelevan.' }, { question: 'Onko palkkaneuvottelu yleistä Espanjassa?', answer: 'Espanjassa on suhdekeskeinen työkulttuuri. Suurissa yrityksissä palkat ovat usein työehtosopimusten mukaisia.' }, { question: 'Milloin on paras aika neuvotella?', answer: 'Optimaalinen aika on vuosiarvioinnin aikana tai heti sen jälkeen.' }, { question: 'Mitä pyytää peruspalkkan lisäksi?', answer: 'Neuvottele: lisäeläkemaksut, ylimääräiset lomapäivät, etätyöpäivät, koulutusbudjetti.' }, { question: 'Kuinka käyttää palkkatietoja neuvotteluissa?', answer: 'Esitä markkinatiedot kolmannen osapuolen todisteina. Käytä EuroSalaryn tietoja vertailukohteena.' }],
  el: [{ question: 'Πώς διαπραγματεύομαι μισθό στη Γερμανία;', answer: 'Στη Γερμανία οι διαπραγματεύσεις είναι δεδομενοκεντρικές και επίσημες. Παρουσιάστε την υπόθεσή σας με συγκεκριμένους αριθμούς.' }, { question: 'Είναι φυσιολογικό να διαπραγματεύομαι στη Γαλλία;', answer: 'Ναι, αλλά με αποχρώσεις. Η γαλλική κουλτούρα είναι ιεραρχική.' }, { question: 'Πώς προσεγγίζουν οι Ολλανδοί εργοδότες τη διαπραγμάτευση;', answer: 'Η Ολλανδία έχει άμεση κουλτούρα διαπραγμάτευσης.' }, { question: 'Είναι συνηθισμένη η διαπραγμάτευση στην Ισπανία;', answer: 'Η Ισπανία έχει σχεσιοστραμμένη εργασιακή κουλτούρα.' }, { question: 'Πότε είναι ο καλύτερος χρόνος να διαπραγματευτώ;', answer: 'Κατά ή αμέσως μετά την ετήσια αξιολόγηση.' }, { question: 'Τι να ζητήσω πέρα από τον βασικό μισθό;', answer: 'Συντάξεις, επιπλέον άδειες, τηλεργασία, εκπαιδευτικό προϋπολογισμό.' }, { question: 'Πώς να χρησιμοποιήσω δεδομένα μισθού;', answer: 'Παρουσιάστε δεδομένα αγοράς ως απόδειξη τρίτου μέρους.' }],
  hu: [{ question: 'Hogyan tárgyalok fizetésről Németországban?', answer: 'Németországban a tárgyalások adatvezéreltek és formálisak. Konkrét számokkal mutassa be esetét.' }, { question: 'Normális a fizetési tárgyalás Franciaországban?', answer: 'Igen, de árnyaltan. A francia munkakultúra hierarchikus.' }, { question: 'Hogyan közelítik meg a holland munkáltatók a tárgyalást?', answer: 'Hollandiában közvetlen tárgyalási kultúra van — elvárják, hogy tárgyaljon.' }, { question: 'Spanyolországban szokásos a fizetési tárgyalás?', answer: 'Spanyolországban kapcsolatorientált munkakultúra van. Nagy cégeknél a fizetéseket kollektív szerződések rögzítik.' }, { question: 'Mikor a legjobb tárgyalni?', answer: 'Az optimális idő az éves teljesítményértékelés alatt vagy után.' }, { question: 'Mit kérjek az alapbéren felül?', answer: 'Tárgyaljon: kiegészítő nyugdíjjárulék, extra szabadnapok, otthoni munkavégzési napok, képzési keret.' }, { question: 'Hogyan használjam a béradatokat a tárgyalásnál?', answer: 'Mutassa be a piaci adatokat harmadik fél bizonyítékaként. Használja az EuroSalary adatait referenciaként.' }],
  sk: [{ question: 'Ako vyjednávam plat v Nemecku?', answer: 'V Nemecku sú rokovania formálne a datovo orientované. Predložte svoju vec s konkrétnymi číslami.' }, { question: 'Je vyjednávanie platu bežné vo Francúzsku?', answer: 'Áno, ale s nuansami. Francúzska pracovná kultúra je hierarchická.' }, { question: 'Ako pristupujú holandskí zamestnávatelia k vyjednávaniu?', answer: 'Holandsko má priamu kultúru vyjednávania — od vás sa očakáva, že budete vyjednávať.' }, { question: 'Je vyjednávanie bežné v Španielsku?', answer: 'Španielsko má pracovnú kultúru orientovanú na vzťahy.' }, { question: 'Kedy je najlepší čas vyjednávať?', answer: 'Optimálny čas je počas ročného hodnotenia výkonu alebo krátko po ňom.' }, { question: 'O čo žiadať nad základný plat?', answer: 'Zvažte: dôchodkové príspevky, extra dni dovolenky, dni práce z domu, tréningový rozpočet.' }, { question: 'Ako využiť platové dáta pri vyjednávaní?', answer: 'Prezentujte trhové dáta ako dôkaz tretej strany. Použite dáta EuroSalary ako referenčné.' }],
  bg: [{ question: 'Как договарям заплата в Германия?', answer: 'В Германия преговорите са формални и базирани на данни. Представете случая си с конкретни числа.' }, { question: 'Нормално ли е да се договаря заплата във Франция?', answer: 'Да, но с нюанси. Французката работна култура е йерархична.' }, { question: 'Как нидерландските работодатели подхождат към преговорите?', answer: 'Нидерландия има пряка преговорна култура — очаква се да преговаряте.' }, { question: 'Обичайно ли е договарянето на заплата в Испания?', answer: 'Испания има работна култура, ориентирана към взаимоотношения.' }, { question: 'Кога е най-доброто време за преговори?', answer: 'Оптималното времето е по време на или след годишната оценка на изпълнението.' }, { question: 'Какво да искам освен основната заплата?', answer: 'Помислете за: допълнителни пенсионни вноски, допълнителни отпускни дни, дни за работа от вкъщи, бюджет за обучение.' }, { question: 'Как да използвам данни за заплатите при преговори?', answer: 'Представяйте пазарните данни като доказателства от трета страна.' }],
  hr: [{ question: 'Kako pregovaram o plaći u Njemačkoj?', answer: 'U Njemačkoj su pregovori formalni i temeljeni na podacima. Predstavite slučaj s konkretnim brojevima.' }, { question: 'Je li normalno pregovarati o plaći u Francuskoj?', answer: 'Da, ali s nijansama. Francuska radna kultura je hijerarhična.' }, { question: 'Kako nizozemski poslodavci pristupaju pregovorima?', answer: 'Nizozemska ima izravnu kulturu pregovaranja — od vas se očekuje da pregovarate.' }, { question: 'Je li pregovaranje uobičajeno u Španjolskoj?', answer: 'Španjolska ima radno-kulturni odnos orijentiran na odnose.' }, { question: 'Kada je najbolje pregovarati?', answer: 'Optimalno vrijeme je za vrijeme ili neposredno nakon godišnje ocjene učinka.' }, { question: 'Što tražiti osim osnovne plaće?', answer: 'Razmotrite: dodatne mirovinske doprinose, extra dane godišnjeg odmora, dane rada od kuće, budžet za obuku.' }, { question: 'Kako koristiti podatke o plaćama za pregovaranje?', answer: 'Predstavljajte tržišne podatke kao dokaze treće strane.' }],
  sl: [{ question: 'Kako se pogajam o plači v Nemčiji?', answer: 'V Nemčiji so pogajanja formalna in podatkovno usmerjena. Predstavite primer s konkretnimi številkami.' }, { question: 'Je normalno pogajanje o plači v Franciji?', answer: 'Da, a z odtenki. Francoska delovna kultura je hierarhična.' }, { question: 'Kako se nizozemski delodajalci lotijo pogajanj?', answer: 'Nizozemska ima neposredno kulturo pogajanj — od vas se pričakuje, da se pogajate.' }, { question: 'Je pogajanje o plači pogosto v Španiji?', answer: 'Španija ima delovno kulturo, usmerjeno v odnose.' }, { question: 'Kdaj je najboljši čas za pogajanje?', answer: 'Optimalni čas je med ali takoj po letni oceni uspešnosti.' }, { question: 'Kaj zahtevati poleg osnovne plače?', answer: 'Premislite: dodatne pokojninske prispevke, dodatne dni dopusta, dneve dela od doma, izobraževalni proračun.' }, { question: 'Kako uporabiti podatke o plačah za pogajanje?', answer: 'Predstavljajte tržne podatke kot dokaze tretjih oseb.' }],
  lt: [{ question: 'Kaip derėtis dėl atlyginimo Vokietijoje?', answer: 'Vokietijoje derybos yra formalios ir duomenimis pagrįstos. Pateikite savo atvejį konkrečiais skaičiais.' }, { question: 'Ar normalu derėtis dėl atlyginimo Prancūzijoje?', answer: 'Taip, bet su niuansais. Prancūzų darbo kultūra yra hierarchinė.' }, { question: 'Kaip olandų darbdaviai požiūriu į derybas?', answer: 'Nyderlanduose tiesioginio derybų kultūra — tikimasi, kad derėsitės.' }, { question: 'Ar derybos dėl atlyginimo įprastos Ispanijoje?', answer: 'Ispanija turi santykiais orientuotą darbo kultūrą.' }, { question: 'Kada geriausia derėtis?', answer: 'Optimalus laikas yra metinės veiklos vertinimo metu arba iš karto po jo.' }, { question: 'Ko prašyti be bazinio atlyginimo?', answer: 'Apsvarstykite: papildomus pensijų įnašus, papildomas atostogų dienas, nuotolinio darbo dienas, mokymo biudžetą.' }, { question: 'Kaip naudoti atlyginimų duomenis derybose?', answer: 'Pateikite rinkos duomenis kaip trečiosios šalies įrodymus.' }],
  lv: [{ question: 'Kā es sarunu vedu par algu Vācijā?', answer: 'Vācijā sarunas ir formālas un datoriski orientētas. Prezentējiet savu gadījumu ar konkrētiem skaitļiem.' }, { question: 'Vai sarunu vešana par algu ir normāla Francijā?', answer: 'Jā, bet ar niansēm. Francijas darba kultūra ir hierarhiska.' }, { question: 'Kā Nīderlandes darba devēji pieiet sarunām?', answer: 'Nīderlandē ir tieša sarunu kultūra — tiek gaidīts, ka sarunu vedat.' }, { question: 'Vai sarunu vešana par algu ir izplatīta Spānijā?', answer: 'Spānijai ir attiecībās orientēta darba kultūra.' }, { question: 'Kad ir labākais laiks sarunām?', answer: 'Optimālais laiks ir gada darbības pārskata laikā vai tūlīt pēc tā.' }, { question: 'Ko pieprasīt papildus pamatalgu?', answer: 'Apsveriet: papildu pensijas iemaksas, papildu atvaļinājuma dienas, attālinātā darba dienas, apmācību budžetu.' }, { question: 'Kā izmantot algu datus sarunās?', answer: 'Prezentējiet tirgus datus kā trešās puses pierādījumus.' }],
  et: [{ question: 'Kuidas pean läbirääkimisi Saksamaal?', answer: 'Saksamaal on läbirääkimised formaalsed ja andmepõhised. Esitage oma juhtum konkreetsete numbritega.' }, { question: 'Kas Prantsusmaal on palgaläbirääkimised normaalsed?', answer: 'Jah, kuid nüanssidega. Prantsuse töökultuur on hierarhiline.' }, { question: 'Kuidas Hollandi tööandjad läbirääkimistele lähenevad?', answer: 'Hollandil on otsene läbirääkimiskultuur — eeldatakse, et peate läbirääkimisi.' }, { question: 'Kas Hispaanias on palgaläbirääkimised levinud?', answer: 'Hispaanial on suhetele orienteeritud töökultuur.' }, { question: 'Millal on parim aeg läbirääkimisteks?', answer: 'Optimaalne aeg on aastase tulemuslikkuse hindamise ajal või kohe pärast seda.' }, { question: 'Mida küsida põhipalga kõrval?', answer: 'Kaaluge: lisapensioni sissemakseid, lisapuhkusepäevi, kaugtöö päevi, koolituseelarvet.' }, { question: 'Kuidas kasutada palgaandmeid läbirääkimistel?', answer: 'Esitage turuandmed kolmanda osapoole tõenditena.' }],
