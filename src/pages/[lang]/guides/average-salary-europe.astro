  fi: [{ question: 'Mikä on keskipalkka Euroopassa 2026?', answer: 'EU:n laajuinen bruttopalkka on noin 33 500€ vuonna 2026. Länsi- ja Pohjois-Eurooppa keskiarvo 40 000–65 000€+.' }, { question: 'Millä maalla on korkein keskipalkka Euroopassa?', answer: 'EU-jäsenvaltioista Luxemburgilla on korkein keskimääräinen bruttovuosipalkka — noin 66 000€.' }, { question: 'Millä EU-maalla on alhaisin keskipalkka?', answer: 'Bulgarialla on alhaisin keskimääräinen bruttovuosipalkka EU-jäsenmaista — noin 13 500€.' }, { question: 'Mikä on keskipalkka Saksassa?', answer: 'Saksan keskimääräinen bruttovuosipalkka on noin 44 000€ vuonna 2026.' }, { question: 'Kuinka ostovoima vaikuttaa palkkatasojen vertailuun?', answer: '15 000€ Bulgariassa on huomattavasti suurempi todellinen ostovoima kuin Luxemburgissa.' }, { question: 'Mitkä alat maksavat eniten Euroopassa?', answer: 'Rahoituspalvelut, teknologia ja lääketeollisuus maksavat johdonmukaisesti korkeimpia palkkoja.' }, { question: 'Miten eurooppalaiset palkat ovat muuttuneet?', answer: 'Eurooppalaiset palkat nousivat merkittävästi 2022-2024. Vuosina 2025-2026 kasvu hidastui 2-4%:iin.' }],
  el: [{ question: 'Ποιος είναι ο μέσος μισθός στην Ευρώπη το 2026;', answer: 'Ο μέσος ακαθάριστος ετήσιος μισθός στην ΕΕ το 2026 είναι περίπου €33.500. Δυτική και Βόρεια Ευρώπη μέσο €40.000–€65.000+.' }, { question: 'Ποια χώρα έχει τον υψηλότερο μέσο μισθό στην Ευρώπη;', answer: 'Μεταξύ των κρατών μελών της ΕΕ, το Λουξεμβούργο έχει τον υψηλότερο μέσο ακαθάριστο ετήσιο μισθό — περίπου €66.000.' }, { question: 'Ποια χώρα της ΕΕ έχει τον χαμηλότερο μέσο μισθό;', answer: 'Η Βουλγαρία έχει τον χαμηλότερο μέσο ακαθάριστο ετήσιο μισθό — περίπου €13.500.' }, { question: 'Ποιος είναι ο μέσος μισθός στη Γερμανία;', answer: 'Ο μέσος ακαθάριστος ετήσιος μισθός στη Γερμανία είναι περίπου €44.000 το 2026.' }, { question: 'Πώς επηρεάζει η αγοραστική δύναμη τις συγκρίσεις μισθών;', answer: '€15.000 στη Βουλγαρία έχουν πολύ μεγαλύτερη πραγματική αγοραστική δύναμη από ό,τι στο Λουξεμβούργο.' }, { question: 'Ποιοι τομείς πληρώνουν περισσότερο στην Ευρώπη;', answer: 'Χρηματοοικονομικές υπηρεσίες, τεχνολογία και φαρμακευτική βιομηχανία πληρώνουν σταθερά τους υψηλότερους μισθούς.' }, { question: 'Πώς άλλαξαν οι ευρωπαϊκοί μισθοί τα τελευταία χρόνια;', answer: 'Οι μισθοί αυξήθηκαν σημαντικά το 2022-2024. Το 2025-2026 η αύξηση μετριάστηκε σε 2-4%.' }],
  hu: [{ question: 'Mekkora az átlagfizetés Európában 2026-ban?', answer: 'Az EU-szintű átlagos bruttó éves kereset 2026-ban kb. 33 500€. Nyugat- és Észak-Európa átlaga 40 000–65 000€+.' }, { question: 'Melyik ország rendelkezik a legmagasabb átlagfizetéssel Európában?', answer: 'Az EU tagállamai közül Luxemburgban a legmagasabb az átlagos bruttó éves kereset — kb. 66 000€.' }, { question: 'Melyik EU-tagállamnak a legalacsonyabb az átlagfizetése?', answer: 'Bulgáriában a legalacsonyabb az átlagos bruttó éves kereset az EU tagállamai között — kb. 13 500€.' }, { question: 'Mekkora az átlagfizetés Németországban?', answer: 'Németország átlagos bruttó éves keresete kb. 44 000€ 2026-ban.' }, { question: 'Hogyan befolyásolja a vásárlóerő a bérhasonlításokat?', answer: '15 000€ Bulgáriában lényegesen nagyobb valódi vásárlóerőt jelent, mint Luxemburgban.' }, { question: 'Mely szektorok fizetnek a legtöbbet Európában?', answer: 'Pénzügyi szolgáltatások, technológia és gyógyszer folyamatosan a legmagasabb fizetéseket nyújtják.' }, { question: 'Hogyan változtak az európai fizetések az elmúlt években?', answer: 'Az európai fizetések 2022-2024-ben jelentősen emelkedtek. 2025-2026-ban a növekedés 2-4%-ra mérséklődött.' }],
  sk: [{ question: 'Aký je priemerný plat v Európe v roku 2026?', answer: 'Priemerný hrubý ročný plat v EÚ v roku 2026 je približne 33 500€. Západ a sever Európy priemerne 40 000–65 000€+.' }, { question: 'Ktorá krajina má v Európe najvyšší priemerný plat?', answer: 'Spomedzi členských štátov EÚ má Luxembursko najvyšší priemerný hrubý ročný plat — približne 66 000€.' }, { question: 'Ktorá krajina EÚ má najnižší priemerný plat?', answer: 'Bulharsko má najnižší priemerný hrubý ročný plat — približne 13 500€.' }, { question: 'Aký je priemerný plat v Nemecku?', answer: 'Priemerný hrubý ročný plat v Nemecku je približne 44 000€ v roku 2026.' }, { question: 'Ako kúpna sila ovplyvňuje porovnania platov?', answer: '15 000€ v Bulharsku má oveľa vyššiu reálnu kúpnu silu ako v Luxembursku.' }, { question: 'Ktoré sektory platia v Európe najviac?', answer: 'Finančné služby, technológie a farmaceutický priemysel konzistentne platia najvyššie platy.' }, { question: 'Ako sa vyvíjali európske platy?', answer: 'Európske platy výrazne vzrástli v rokoch 2022-2024. V rokoch 2025-2026 sa rast zmiernil na 2-4%.' }],
