    pricingDevLabel: 'Desarrollador -- 49\u00a0\u20ac/mes',
    pricingDevDesc: '10.000 solicitudes por d\u00eda. Clave API con panel de uso. Soporte por email.',
    pricingBizLabel: 'Business -- 199\u00a0\u20ac/mes',
    pricingBizDesc: '100.000 solicitudes por d\u00eda. Soporte prioritario. Notificaciones webhook para actualizaciones de datos.',
    pricingEntLabel: 'Enterprise -- Personalizado',
    pricingEntDesc: 'Solicitudes ilimitadas. Gestor de cuenta dedicado. SLA personalizado y exportaciones de datos.',
    sdkTitle: 'SDK y ejemplos de c\u00f3digo',
    sdkDesc: 'Integra los datos de EuroSalary en tu aplicaci\u00f3n con estos ejemplos listos para usar.',
    ctaTitle: '\u00bfListo para empezar?',
    ctaDesc: 'Crea una cuenta gratuita para empezar a usar la API de inmediato. Actualiza tu plan en cualquier momento seg\u00fan crezca tu uso.',
    ctaButton: 'Crear cuenta gratuita',
    paramCountry: 'C\u00f3digo de pa\u00eds ISO 3166-1 alfa-2 (ej. DE, FR, ES)',
    paramJob: 'Slug del puesto en kebab-case (ej. software-engineer)',
    paramLevel: 'Nivel de experiencia: junior, mid o senior',
    paramFormat: 'Formato de respuesta: json (por defecto) o csv',
    parametersTitle: 'Par\u00e1metros de consulta',
    faq: [
      { question: '\u00bfEs gratuita la API de EuroSalary?', answer: 'S\u00ed. El nivel gratuito te da 100 solicitudes por hora sin clave API. Es suficiente para proyectos personales, investigaci\u00f3n acad\u00e9mica y prototipos. Los planes de pago est\u00e1n disponibles cuando necesites l\u00edmites m\u00e1s altos o soporte dedicado.' },
      { question: '\u00bfQu\u00e9 pa\u00edses y puestos cubre la API?', answer: 'La API cubre actualmente 15 pa\u00edses europeos (Alemania, Francia, Espa\u00f1a, Pa\u00edses Bajos, B\u00e9lgica, Austria, Suiza, Luxemburgo, Irlanda, Portugal, Italia, Polonia, Rep\u00fablica Checa, Suecia, Dinamarca) y 21 categor\u00edas laborales en tecnolog\u00eda, finanzas, salud, ingenier\u00eda y m\u00e1s.' },
      { question: '\u00bfCon qu\u00e9 frecuencia se actualizan los datos salariales?', answer: 'Los datos salariales se actualizan semanalmente desde portales de empleo y trimestralmente desde Eurostat. La API siempre sirve los \u00faltimos datos disponibles. Consulta el campo last_updated en cada respuesta para saber exactamente cu\u00e1ndo se actualizaron los datos.' },
      { question: '\u00bfPuedo usar la API en un producto comercial?', answer: 'S\u00ed. Todos los planes de pago incluyen licencia de uso comercial. El nivel gratuito est\u00e1 limitado a uso no comercial y personal. Si est\u00e1s construyendo un producto que muestra o revende datos salariales, necesitas al menos el plan Desarrollador.' },
      { question: '\u00bfQu\u00e9 sucede si excedo mi l\u00edmite de velocidad?', answer: 'Cuando excedes tu l\u00edmite, la API devuelve una respuesta 429 Too Many Requests con un encabezado Retry-After indicando cu\u00e1ntos segundos esperar. Los l\u00edmites del nivel gratuito se restablecen cada hora. Los l\u00edmites de planes de pago se restablecen diariamente a medianoche UTC.' },
    ],
  },
};

// --------------- getStaticPaths ---------------
export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
    props: { lang },
  }));
}

// --------------- Page data ---------------
const { lang } = Astro.params;
const t = fb(i18n, lang) || i18n.en;
const ui = useTranslations(lang as any);

const pageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: t.h1,
    author: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
    publisher: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
    datePublished: '2026-04-01',
    dateModified: '2026-04-04',
    description: t.metaDesc,
    mainEntityOfPage: `https://eurosalary.eu/${lang}/salary-api/`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: t.faq.map((item: any) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  },
];
---

<BaseLayout
  title={t.metaTitle}
  description={t.metaDesc}
  datePublished="2026-04-01"
  dateModified="2026-04-04"
  schema={pageSchema}
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="page-hero__dots"></div>
    <div class="container page-hero__inner">
      <nav class="page-hero__breadcrumbs" aria-label="Breadcrumb">
        <a href={`/${lang}/`}>{t.home}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <span class="page-hero__breadcrumbs-current">{t.breadcrumb}</span>
      </nav>
      <div class="page-hero__grid">
        <div class="page-hero__content">
          <h1 class="page-hero__title">{t.h1}</h1>
          <p class="page-hero__desc">{t.intro}</p>
        </div>
        <div class="page-hero__side">
          <div class="page-hero__card api-version-card">
            <span class="page-hero__card-label">API</span>
            <p class="page-hero__card-item">v1.0</p>
            <p class="page-hero__card-item">REST / JSON</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <article class="container page-body">

    <!-- TL;DR -->
    <TLDRBox items={t.tldr} />

    <!-- Quick Start -->
    <section class="section">
      <h2>{t.quickStartTitle}</h2>
      <p>{t.quickStartDesc}</p>
      <div class="code-block">
        <div class="code-block__header">
          <span class="code-block__lang">bash</span>
          <span class="code-block__label">curl</span>
        </div>
        <pre><code>{`curl -s "https://api.eurosalary.eu/v1/salary?country=DE&job=software-engineer&level=mid" | jq .`}</code></pre>
      </div>
    </section>

    <!-- Endpoints -->
    <section class="section">
      <h2>{t.endpointsTitle}</h2>

      <!-- Salary endpoint -->
      <div class="endpoint">
        <h3>{t.endpointSalaryTitle}</h3>
        <p>{t.endpointSalaryDesc}</p>
        <div class="code-block">
          <div class="code-block__header">
            <span class="code-block__method">GET</span>
            <span class="code-block__label">/api/v1/salary</span>
          </div>
          <pre><code>GET /api/v1/salary?country=DE&amp;job=software-engineer&amp;level=mid</code></pre>
        </div>
      </div>

      <!-- Compare endpoint -->
      <div class="endpoint">
        <h3>{t.endpointCompareTitle}</h3>
        <p>{t.endpointCompareDesc}</p>
        <div class="code-block">
          <div class="code-block__header">
            <span class="code-block__method">GET</span>
            <span class="code-block__label">/api/v1/compare</span>
          </div>
          <pre><code>GET /api/v1/compare?job=software-engineer&amp;level=mid</code></pre>
        </div>
      </div>

      <!-- Minimum wage endpoint -->
      <div class="endpoint">
        <h3>{t.endpointMinWageTitle}</h3>
        <p>{t.endpointMinWageDesc}</p>
        <div class="code-block">
          <div class="code-block__header">
            <span class="code-block__method">GET</span>
            <span class="code-block__label">/api/v1/minimum-wage</span>
          </div>
          <pre><code>GET /api/v1/minimum-wage?country=DE</code></pre>
        </div>
      </div>

      <!-- Query Parameters -->
      <div class="endpoint">
        <h3>{t.parametersTitle}</h3>
        <table class="api-table">
          <thead>
            <tr>
              <th>Parameter</th>
              <th>Type</th>
              <th>Description</th>
            </tr>
          </thead>
          <tbody>
            <tr><td><code>country</code></td><td><code>string</code></td><td>{t.paramCountry}</td></tr>
            <tr><td><code>job</code></td><td><code>string</code></td><td>{t.paramJob}</td></tr>
            <tr><td><code>level</code></td><td><code>string</code></td><td>{t.paramLevel}</td></tr>
            <tr><td><code>format</code></td><td><code>string</code></td><td>{t.paramFormat}</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Response Examples -->
    <section class="section">
      <h2>{t.responseTitle}</h2>
      <p>{t.responseDesc}</p>

      <div class="code-block">
        <div class="code-block__header">
          <span class="code-block__lang">json</span>
          <span class="code-block__label">/api/v1/salary</span>
        </div>
        <pre><code>{`{
  "status": "ok",
  "data": {
    "country": "DE",
    "country_name": "Germany",
    "job": "software-engineer",
    "job_title": "Software Engineer",
    "level": "mid",
    "currency": "EUR",
    "salary_gross_annual": 62400,
    "salary_net_annual": 39200,
    "salary_gross_monthly": 5200,
    "salary_net_monthly": 3267,
    "tax_rate": 0.372,
    "social_contributions": 0.205,
    "last_updated": "2026-03-31T00:00:00Z",
    "sources": ["eurostat", "job_boards", "submissions"],
    "sample_size": 1842,
    "confidence": "high"
  }
}`}</code></pre>
      </div>

      <div class="code-block">
        <div class="code-block__header">
          <span class="code-block__lang">json</span>
          <span class="code-block__label">/api/v1/minimum-wage</span>
        </div>
        <pre><code>{`{
  "status": "ok",
  "data": {
    "country": "DE",
    "country_name": "Germany",
    "currency": "EUR",
    "minimum_wage_monthly": 2054,
    "minimum_wage_hourly": 12.82,
    "effective_date": "2026-01-01",
    "last_updated": "2026-03-31T00:00:00Z"
  }
}`}</code></pre>
      </div>
    </section>

    <!-- Authentication -->
    <section class="section">
      <h2>{t.authTitle}</h2>
      <p>{t.authDesc}</p>
      <div class="auth-methods">
        <div class="auth-card">
          <div class="auth-card__badge auth-card__badge--free">Free</div>
          <p>{t.authFree}</p>
        </div>
        <div class="auth-card">
          <div class="auth-card__badge auth-card__badge--paid">Paid</div>
          <p>{t.authPaid}</p>
          <div class="code-block code-block--compact">
            <pre><code>Authorization: Bearer YOUR_API_KEY</code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- Rate Limits -->
    <section class="section">
      <h2>{t.rateLimitsTitle}</h2>
      <p>{t.rateLimitsDesc}</p>
      <table class="api-table">
        <thead>
          <tr>
            <th>{t.rateLimitTier}</th>
            <th>{t.rateLimitRequests}</th>
            <th>{t.rateLimitWindow}</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Free</td><td>100</td><td>1 hour</td></tr>
          <tr><td>Developer</td><td>10,000</td><td>24 hours</td></tr>
          <tr><td>Business</td><td>100,000</td><td>24 hours</td></tr>
          <tr><td>Enterprise</td><td>Unlimited</td><td>--</td></tr>
        </tbody>
      </table>
    </section>

    <!-- Pricing -->
    <section class="section">
      <h2>{t.pricingTitle}</h2>
      <p>{t.pricingDesc}</p>
      <div class="pricing-grid">
        <div class="pricing-card">
          <div class="pricing-card__header">
            <h3>{t.pricingFreeLabel}</h3>
            <span class="pricing-card__price">&euro;0</span>
          </div>
          <p>{t.pricingFreeDesc}</p>
        </div>
        <div class="pricing-card pricing-card--popular">
          <div class="pricing-card__header">
            <h3>{t.pricingDevLabel}</h3>
            <span class="pricing-card__price">&euro;49<small>/mo</small></span>
          </div>
          <p>{t.pricingDevDesc}</p>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__header">
            <h3>{t.pricingBizLabel}</h3>
            <span class="pricing-card__price">&euro;199<small>/mo</small></span>
          </div>
          <p>{t.pricingBizDesc}</p>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__header">
            <h3>{t.pricingEntLabel}</h3>
            <span class="pricing-card__price">Custom</span>
          </div>
          <p>{t.pricingEntDesc}</p>
        </div>
      </div>
    </section>

    <!-- SDK Examples -->
    <section class="section">
      <h2>{t.sdkTitle}</h2>
      <p>{t.sdkDesc}</p>

      <!-- JavaScript -->
      <div class="code-block">
        <div class="code-block__header">
          <span class="code-block__lang">javascript</span>
          <span class="code-block__label">Node.js / Browser</span>
        </div>
        <pre><code>{`const response = await fetch(
  "https://api.eurosalary.eu/v1/salary?country=DE&job=software-engineer&level=mid"
);
const { data } = await response.json();

console.log(data.salary_gross_annual); // 62400
console.log(data.salary_net_monthly);  // 3267`}</code></pre>
      </div>

      <!-- Python -->
      <div class="code-block">
        <div class="code-block__header">
          <span class="code-block__lang">python</span>
          <span class="code-block__label">Python 3</span>
        </div>
        <pre><code>{`import requests

response = requests.get(
    "https://api.eurosalary.eu/v1/salary",
    params={"country": "DE", "job": "software-engineer", "level": "mid"}
)
data = response.json()["data"]

print(f"Gross: €{data['salary_gross_annual']:,}")  # Gross: €62,400
print(f"Net:   €{data['salary_net_monthly']:,}")    # Net:   €3,267`}</code></pre>
      </div>

      <!-- curl with auth -->
      <div class="code-block">
        <div class="code-block__header">
          <span class="code-block__lang">bash</span>
          <span class="code-block__label">curl (authenticated)</span>
        </div>
        <pre><code>{`curl -H "Authorization: Bearer YOUR_API_KEY" \\
  "https://api.eurosalary.eu/v1/compare?job=software-engineer&level=mid" | jq .`}</code></pre>
      </div>
    </section>

    <!-- FAQ -->
    <FAQSection items={t.faq} />

    <!-- CTA -->
    <section class="section cta-section">
      <h2>{t.ctaTitle}</h2>
      <p>{t.ctaDesc}</p>
      <a href={`/${lang}/premium/`} class="cta-button">{t.ctaButton}</a>
    </section>

  </article>
</BaseLayout>

<style>
  /* ---- Page body ---- */
  .page-body {
    padding-top: 2.5rem;
    padding-bottom: 4rem;
  }
  .page-body h2 {
    font-family: 'Public Sans', sans-serif;
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #0F1F3D;
    margin-top: 3rem;
    margin-bottom: 1rem;
  }
  .page-body h3 {
    font-family: 'Public Sans', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #0F1F3D;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .page-body p {
    line-height: 1.7;
    color: rgba(15, 31, 61, 0.85);
    margin-bottom: 1rem;
  }

  /* ---- API version card ---- */
  .api-version-card {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }

  /* ---- Code blocks ---- */
  .code-block {
    background: #1a1a2e;
    border-radius: 8px;
    margin: 1rem 0 1.5rem;
    overflow: hidden;
    border: 1px solid rgba(37, 99, 235, 0.2);
  }
  .code-block__header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .code-block__lang {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #2563EB;
    background: rgba(37, 99, 235, 0.15);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }
  .code-block__method {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #10b981;
    background: rgba(16, 185, 129, 0.15);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }
  .code-block__label {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
  }
  .code-block pre {
    margin: 0;
    padding: 1rem 1.25rem;
    overflow-x: auto;
  }
  .code-block code {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.85rem;
    line-height: 1.6;
    color: #e2e8f0;
    white-space: pre;
  }
  .code-block--compact {
    margin: 0.75rem 0 0;
  }

  /* ---- Endpoint blocks ---- */
  .endpoint {
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(15, 31, 61, 0.08);
  }
  .endpoint:last-child {
    border-bottom: none;
  }

  /* ---- API tables ---- */
  .api-table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.9rem;
  }
  .api-table thead {
    background: #0F1F3D;
    color: #fff;
  }
  .api-table th {
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .api-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(15, 31, 61, 0.08);
    color: rgba(15, 31, 61, 0.85);
  }
  .api-table code {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.8rem;
    color: #2563EB;
    background: rgba(37, 99, 235, 0.08);
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
  }
  .api-table tbody tr:hover {
    background: rgba(37, 99, 235, 0.03);
  }

  /* ---- Auth cards ---- */
  .auth-methods {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 1rem;
  }
  .auth-card {
    background: #f8fafc;
    border: 1px solid rgba(15, 31, 61, 0.1);
    border-radius: 8px;
    padding: 1.5rem;
  }
  .auth-card p {
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }
  .auth-card__badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    margin-bottom: 0.75rem;
  }
  .auth-card__badge--free {
    color: #10b981;
    background: rgba(16, 185, 129, 0.1);
  }
  .auth-card__badge--paid {
    color: #2563EB;
    background: rgba(37, 99, 235, 0.1);
  }

  /* ---- Pricing grid ---- */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-top: 1.5rem;
  }
  .pricing-card {
    background: #f8fafc;
    border: 1px solid rgba(15, 31, 61, 0.1);
    border-radius: 8px;
    padding: 1.5rem;
    transition: border-color 0.2s;
  }
  .pricing-card:hover {
    border-color: rgba(37, 99, 235, 0.3);
  }
  .pricing-card--popular {
    border-color: #2563EB;
    background: linear-gradient(180deg, rgba(37, 99, 235, 0.04) 0%, #f8fafc 100%);
    position: relative;
  }
  .pricing-card__header {
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(15, 31, 61, 0.08);
  }
  .pricing-card__header h3 {
    margin: 0 0 0.5rem;
    font-size: 1rem;
    color: #0F1F3D;
  }
  .pricing-card__price {
    font-family: 'Public Sans', sans-serif;
    font-size: 1.75rem;
    font-weight: 800;
    color: #0F1F3D;
  }
  .pricing-card__price small {
    font-size: 0.9rem;
    font-weight: 500;
    color: rgba(15, 31, 61, 0.5);
  }
  .pricing-card p {
    font-size: 0.85rem;
    color: rgba(15, 31, 61, 0.7);
    line-height: 1.6;
  }

  /* ---- CTA section ---- */
  .cta-section {
    text-align: center;
    padding: 3rem 2rem;
    margin-top: 2rem;
    background: linear-gradient(135deg, #0F1F3D 0%, #1a2f5a 100%);
    border-radius: 12px;
    color: #fff;
  }
  .cta-section h2 {
    color: #fff;
  }
  .cta-section p {
    color: rgba(255, 255, 255, 0.8);
    max-width: 500px;
    margin: 0 auto 1.5rem;
  }
  .cta-button {
    display: inline-block;
    padding: 0.85rem 2rem;
    background: #2563EB;
    color: #fff;
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
  }
  .cta-button:hover {
    background: #1d4ed8;
    transform: translateY(-1px);
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .pricing-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .auth-methods {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 600px) {
    .pricing-grid {
      grid-template-columns: 1fr;
    }
    .api-table {
      font-size: 0.8rem;
    }
    .api-table th,
    .api-table td {
      padding: 0.5rem 0.65rem;
    }
    .code-block code {
      font-size: 0.75rem;
    }
  }
</style>
