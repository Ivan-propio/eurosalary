      { title: 'Multi-Lander-Berichte', desc: 'Laden Sie PDF- und CSV-Gehaltsberichte fur 15 EU-Lander herunter mit Perzentilen, Trends und Kaufkraftvergleichen.', icon: 'summarize' },
      { title: 'API-Zugang', desc: 'Integrieren Sie europaische Gehaltsdaten in Ihr HRIS oder Ihre Vergutungsplattform uber unsere REST-API mit Vertrauenswerten.', icon: 'api' },
