      { name: 'Professionnel', price: '299\u20ac/mois', features: ['15 rapports pays par mois', 'Tableau de bord de benchmarking avance', 'Analyse de l\'ecart salarial', 'Acces API (1 000 appels/mois)', 'Support prioritaire'] },
