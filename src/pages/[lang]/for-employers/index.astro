---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TLDRBox from '../../../components/TLDRBox.astro';
import FAQSection from '../../../components/FAQSection.astro';
import { languages } from '../../../i18n/ui';
import { fb, useTranslations } from '../../../i18n/utils';

// --------------- i18n strings ---------------
const i18n: Record<string, {
  h1: string;
  metaTitle: string;
  metaDesc: string;
  home: string;
  breadcrumb: string;
  introAnswer: string;
  tldr: string[];
  heroSubtitle: string;
  featureCards: { title: string; desc: string; icon: string }[];
  pricingTitle: string;
  pricingDesc: string;
  tiers: { name: string; price: string; features: string[] }[];
  ctaLabel: string;
  testimonialsTitle: string;
  testimonials: { quote: string; name: string; role: string; company: string }[];
  faq: { question: string; answer: string }[];
}> = {
  en: {
    h1: 'How Can EuroSalary Help Your Company Set Competitive Salaries?',
    metaTitle: 'For Employers: Salary Benchmarking & EU Compliance | EuroSalary.eu',
    metaDesc: 'EuroSalary helps HR teams benchmark salaries across Europe, comply with the EU Pay Transparency Directive, and access multi-country compensation reports via API.',
    home: 'Home',
    breadcrumb: 'For Employers',
    introAnswer: 'EuroSalary gives compensation and HR teams the data they need to set competitive salaries, benchmark against European markets, and prepare for EU Pay Transparency Directive compliance across 15 countries.',
    tldr: [
      'Benchmark your salary offers against verified market rates in 15 EU countries',
      'Ready-made compliance toolkit for the EU Pay Transparency Directive (2026 deadline)',
      'REST API to integrate real-time European salary data directly into your HRIS',
    ],
    heroSubtitle: 'Eurostat-verified salary intelligence for compensation teams, HR directors, and CFOs. Stop guessing pay bands — start benchmarking with institutional-grade data.',
    featureCards: [
      { title: 'Salary Benchmarking', desc: 'Compare your offers against market rates across Europe. See where you stand by role, seniority, and city in 15 EU countries. Identify underpaid roles before your competitors poach talent.', icon: 'leaderboard' },
      { title: 'Compliance Toolkit', desc: 'The EU Pay Transparency Directive requires pay range disclosure by 2026. Our toolkit generates compliant pay bands, gender pay gap reports, and disclosure templates for every country you operate in.', icon: 'verified_user' },
      { title: 'Multi-Country Reports', desc: 'Download PDF and CSV salary reports covering 15 EU countries. Each report includes distribution percentiles, year-over-year trends, tax-adjusted take-home, and purchasing power comparisons.', icon: 'summarize' },
      { title: 'API Access', desc: 'Integrate European salary data into your HRIS, compensation platform, or internal dashboards via our REST API. JSON responses with confidence scores, methodology versioning, and freshness timestamps.', icon: 'api' },
    ],
    pricingTitle: 'Simple, Transparent Pricing',
    pricingDesc: 'Choose the plan that matches your team size and data needs. All plans include EU Pay Transparency Directive readiness tools.',
    tiers: [
      { name: 'Starter', price: '\u20ac99/mo', features: ['5 country reports per month', 'Basic salary benchmarking', 'Compliance checklist', 'Email support'] },
      { name: 'Professional', price: '\u20ac299/mo', features: ['15 country reports per month', 'Advanced benchmarking dashboard', 'Gender pay gap analysis', 'API access (1,000 calls/mo)', 'Priority support'] },
      { name: 'Enterprise', price: 'Custom', features: ['Unlimited reports', 'Custom integrations', 'Dedicated account manager', 'SLA guarantee', 'On-demand custom analysis'] },
    ],
    ctaLabel: 'Get Started',
    testimonialsTitle: 'Trusted by European HR Teams',
    testimonials: [
      { quote: 'EuroSalary cut our compensation benchmarking time from two weeks to two hours. The multi-country reports are exactly what we needed for our pan-European hiring strategy.', name: 'Katrin Schneider', role: 'Head of People', company: 'TechScale GmbH, Berlin' },
