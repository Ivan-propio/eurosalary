    ctaLabel: 'Commencer',
    testimonialsTitle: 'La confiance des equipes RH europeennes',
    testimonials: [
      { quote: 'EuroSalary a reduit notre temps de benchmarking de deux semaines a deux heures. Les rapports multi-pays sont exactement ce qu\'il nous fallait.', name: 'Katrin Schneider', role: 'Directrice des RH', company: 'TechScale GmbH, Berlin' },
