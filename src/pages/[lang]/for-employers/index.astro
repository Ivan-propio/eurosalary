      { name: 'Professional', price: '299\u20ac/Monat', features: ['15 Landerberichte pro Monat', 'Erweitertes Benchmarking-Dashboard', 'Gender-Pay-Gap-Analyse', 'API-Zugang (1.000 Aufrufe/Monat)', 'Prioritats-Support'] },
      { name: 'Enterprise', price: 'Individuell', features: ['Unbegrenzte Berichte', 'Individuelle Integrationen', 'Dedizierter Ansprechpartner', 'SLA-Garantie', 'Individuelle Analysen'] },
    ],
    ctaLabel: 'Jetzt starten',
    testimonialsTitle: 'Vertraut von europaischen HR-Teams',
    testimonials: [
      { quote: 'EuroSalary hat unsere Benchmarking-Zeit von zwei Wochen auf zwei Stunden reduziert. Die Multi-Lander-Berichte sind genau das, was wir brauchten.', name: 'Katrin Schneider', role: 'Leiterin People', company: 'TechScale GmbH, Berlin' },
      { quote: 'Das Compliance-Toolkit hat uns die Beauftragung eines externen Beraters fur die Transparenzrichtlinie erspart. Alles ist vorgefertigt und auditbereit.', name: 'Marc Dubois', role: 'VP Human Resources', company: 'LogiConnect SA, Paris' },
      { quote: 'Wir haben die API innerhalb eines Tages in unsere Workday-Instanz integriert. Jetzt sehen unsere Recruiter Echtzeit-Marktdaten direkt im Genehmigungsworkflow.', name: 'Sofia Rinaldi', role: 'Vergutungsmanagerin', company: 'NovaBuild S.p.A., Mailand' },
    ],
