      { quote: 'Shábháil na huirlisí comhlíonachta comhairleoir seachtrach a fhostú dúinn don treoir trédhearcachta. Tá gach rud réamhthógtha agus réidh le hiniúchadh.', name: 'Marc Dubois', role: 'Leas-Uachtarán Acmhainní Daonna', company: 'LogiConnect SA, Páras' },
      { quote: 'Chomhtáthaíomar an API inár n-ásc Workday i níos lú ná lá. Anois feiceann ár n-earcaitheoirí sonraí margaidh i bhfíor-am.', name: 'Sofia Rinaldi', role: 'Bainisteoir Cúitimh', company: 'NovaBuild S.p.A., Milano' },
    ],
    faq: [
      { question: 'Cé mhéad tír a chlúdaíonn EuroSalary?', answer: 'Soláthraíonn EuroSalary sonraí tuarastail faoi láthair do 15 thír AE. Cuirimid tíortha nua leis gach ráithe de réir mar a bhíonn sonraí fíoraithe ar fáil.' },
      { question: 'Conas a théann treoir trédhearcachta pá i bhfeidhm ar mo chuideachta?', answer: 'Éilíonn an treoir raonta tuarastail a nochtadh i bhfógraí poist agus tuairisciú ar bhearnaí pá inscne. Caithfidh na Ballstáit é a thrasuí faoi Mheitheamh 2026.' },
      { question: 'An féidir liom sonraí EuroSalary a chomhtháthú i mo chórais AD reatha?', answer: 'Is féidir. Soláthraíonn ár API REST sonraí i bhformáid JSON le críochphointí d\'iarratais aonair, iarratais bhaisc agus maitrisí comparáide.' },
      { question: 'Cé chomh nuashonraithe is atá na sonraí tuarastail?', answer: 'Comhcheanglaíonn ár bpíblíne ceithre fhoinse: Eurostat (ráithiúil), fógraí poist (seachtainiúil), táscairí ECFE (leathbhliantúil) agus aighneachtaí anaithnide (fíor-am). Athríomh iomlán ar an 1ú lá de gach mí.' },
      { question: 'Cad atá sna tuarascálacha tuarastail ilthíre?', answer: 'Clúdaíonn gach tuarascáil peircintílí dáileacháin, rátaí fáis bliantúla, glanpháigh tar éis cánach, coigeartuithe costas maireachtála agus táscairí bearna pá.' },
    ],
    heroCardLabel: 'Faisnéis d\'fhostóirí',
    heroCardCountries: '15 thír AE',
    heroCardData: 'Sonraí fíoraithe ag Eurostat',
    badgeMostPopular: 'Is mó tóir air',
    relatedPremium: 'Pleananna Premium',
    relatedCalculator: 'Áireamhán tuarastail',
    relatedMethodology: 'Ár modheolaíocht',
    relatedRecruiters: 'D\'earcaitheoirí',
  },
};

// --------------- getStaticPaths ---------------
export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
    props: { lang },
  }));
}

// --------------- Page data ---------------
const { lang } = Astro.params;
const t = fb(i18n, lang) || i18n.en;
const ui = useTranslations(lang as any);

const pageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: t.h1,
    author: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
    publisher: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
    datePublished: '2026-04-04',
    dateModified: '2026-04-04',
    description: t.metaDesc,
    mainEntityOfPage: `https://eurosalary.eu/${lang}/for-employers/`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: t.faq.map((item: any) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  },
];
---

<BaseLayout
  title={t.metaTitle}
  description={t.metaDesc}
  datePublished="2026-04-04"
  dateModified="2026-04-04"
  schema={pageSchema}
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="page-hero__dots"></div>
    <div class="container page-hero__inner">
      <nav class="page-hero__breadcrumbs" aria-label="Breadcrumb">
        <a href={`/${lang}/`}>{t.home}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <span class="page-hero__breadcrumbs-current">{t.breadcrumb}</span>
      </nav>
      <div class="page-hero__grid">
        <div class="page-hero__content">
          <h1 class="page-hero__title">{t.h1}</h1>
          <p class="page-hero__desc">{t.introAnswer}</p>
        </div>
        <div class="page-hero__side">
          <div class="page-hero__card">
            <span class="page-hero__card-label"><span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;margin-right:4px;">business</span> {t.heroCardLabel}</span>
            <p class="page-hero__card-item">{t.heroCardCountries}</p>
            <p class="page-hero__card-item">{t.heroCardData}</p>
          </div>
        </div>
      </div>
      <p class="hero-subtitle">{t.heroSubtitle}</p>
    </div>
  </section>

  <article class="container page-body">
    <TLDRBox items={t.tldr} />

    <!-- Feature Cards -->
    <section class="section features-section">
      <div class="features-grid">
        {t.featureCards.map((card) => (
          <div class="feature-card">
            <div class="feature-card__icon">
              <span class="material-symbols-outlined">{card.icon}</span>
            </div>
            <h2 class="feature-card__title">{card.title}</h2>
            <p class="feature-card__desc">{card.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Pricing Teaser -->
    <section class="section pricing-section">
      <h2 class="section-title">{t.pricingTitle}</h2>
      <p class="section-desc">{t.pricingDesc}</p>
      <div class="pricing-grid">
        {t.tiers.map((tier, i) => (
          <div class={`pricing-card ${i === 1 ? 'pricing-card--featured' : ''}`}>
            {i === 1 && <span class="pricing-card__badge">{t.badgeMostPopular}</span>}
            <h3 class="pricing-card__name">{tier.name}</h3>
            <p class="pricing-card__price">{tier.price}</p>
            <ul class="pricing-card__features">
              {tier.features.map((f) => (
                <li><span class="material-symbols-outlined" style="font-size:16px;color:#2563EB;vertical-align:middle;margin-right:6px;">check_circle</span>{f}</li>
              ))}
            </ul>
            <a href={`/${lang}/premium/`} class="pricing-card__cta">{t.ctaLabel}</a>
          </div>
        ))}
      </div>
    </section>

    <!-- Testimonials -->
    <section class="section testimonials-section">
      <h2 class="section-title">{t.testimonialsTitle}</h2>
      <div class="testimonials-grid">
        {t.testimonials.map((test) => (
          <div class="testimonial-card">
            <span class="material-symbols-outlined testimonial-card__quote-icon">format_quote</span>
            <blockquote class="testimonial-card__quote">{test.quote}</blockquote>
            <div class="testimonial-card__author">
              <p class="testimonial-card__name">{test.name}</p>
              <p class="testimonial-card__role">{test.role}, {test.company}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Internal links -->
    <section class="section related-section">
      <div class="related-links">
        <a href={`/${lang}/premium/`} class="related-link">
          <span class="material-symbols-outlined">diamond</span>
          {t.relatedPremium}
        </a>
        <a href={`/${lang}/calculator/`} class="related-link">
          <span class="material-symbols-outlined">calculate</span>
          {t.relatedCalculator}
        </a>
        <a href={`/${lang}/methodology/`} class="related-link">
          <span class="material-symbols-outlined">science</span>
          {t.relatedMethodology}
        </a>
        <a href={`/${lang}/for-recruiters/`} class="related-link">
          <span class="material-symbols-outlined">person_search</span>
          {t.relatedRecruiters}
        </a>
      </div>
    </section>

    <FAQSection items={t.faq} />
  </article>
</BaseLayout>

<style>
  .page-body {
    padding-top: 2.5rem;
    padding-bottom: 2rem;
  }

  .page-body :global(.section) {
    padding: var(--space-12) 0;
  }

  .page-body :global(.faq-section) {
    padding-top: var(--space-8);
    padding-bottom: var(--space-4);
  }

  .hero-subtitle {
    margin-top: 1.5rem;
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.7);
    max-width: 700px;
    line-height: var(--leading-relaxed);
  }

  .section-title {
    font-family: 'Public Sans', sans-serif;
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #0F1F3D;
    margin-bottom: 0.5rem;
  }

  .section-desc {
    color: #4B5563;
    margin-bottom: 2rem;
    max-width: 600px;
  }

  /* Feature Cards */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .feature-card {
    background: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-radius: 12px;
    padding: 2rem;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .feature-card:hover {
    border-color: #2563EB;
    box-shadow: 0 4px 24px rgba(37, 99, 235, 0.08);
  }

  .feature-card__icon {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    background: rgba(37, 99, 235, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .feature-card__icon .material-symbols-outlined {
    font-size: 24px;
    color: #2563EB;
  }

  .feature-card__title {
    font-family: 'Public Sans', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #0F1F3D;
    margin-bottom: 0.5rem;
  }

  .feature-card__desc {
    font-size: var(--text-sm);
    color: #4B5563;
    line-height: var(--leading-relaxed);
  }

  /* Pricing */
  .pricing-section {
    margin-top: 3rem;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .pricing-card {
    background: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-radius: 12px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .pricing-card--featured {
    border-color: #2563EB;
    box-shadow: 0 4px 24px rgba(37, 99, 235, 0.12);
  }

  .pricing-card__badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: #2563EB;
    color: #FFFFFF;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 4px 16px;
    border-radius: 20px;
  }

  .pricing-card__name {
    font-family: 'Public Sans', sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: #0F1F3D;
    margin-bottom: 0.25rem;
  }

  .pricing-card__price {
    font-family: 'Public Sans', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    color: #2563EB;
    margin-bottom: 1.5rem;
  }

  .pricing-card__features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .pricing-card__features li {
    font-size: var(--text-sm);
    color: #374151;
    line-height: 1.5;
  }

  .pricing-card__cta {
    display: block;
    text-align: center;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: var(--text-sm);
    text-decoration: none;
    background: #0F1F3D;
    color: #FFFFFF;
    transition: background 0.2s ease;
  }

  .pricing-card--featured .pricing-card__cta {
    background: #2563EB;
  }

  .pricing-card__cta:hover {
    background: #2563EB;
  }

  .pricing-card--featured .pricing-card__cta:hover {
    background: #1D4ED8;
  }

  /* Testimonials */
  .testimonials-section {
    margin-top: 3rem;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .testimonial-card {
    background: #F9FAFB;
    border: 1px solid #E5E7EB;
    border-radius: 12px;
    padding: 2rem;
    position: relative;
  }

  .testimonial-card__quote-icon {
    color: #2563EB;
    font-size: 32px;
    opacity: 0.3;
    margin-bottom: 0.5rem;
  }

  .testimonial-card__quote {
    font-size: var(--text-sm);
    color: #374151;
    line-height: var(--leading-relaxed);
    font-style: italic;
    margin-bottom: 1.25rem;
  }

  .testimonial-card__name {
    font-weight: 700;
    font-size: var(--text-sm);
    color: #0F1F3D;
  }

  .testimonial-card__role {
    font-size: 12px;
    color: #6B7280;
  }

  /* Related links */
  .related-section {
    margin-top: 2rem;
    margin-bottom: 0;
  }

  .related-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .related-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 0.625rem 1.25rem;
    border: 1px solid #E5E7EB;
    border-radius: 8px;
    font-size: var(--text-sm);
    font-weight: 600;
    color: #0F1F3D;
    text-decoration: none;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .related-link:hover {
    border-color: #2563EB;
    background: rgba(37, 99, 235, 0.04);
  }

  .related-link .material-symbols-outlined {
    font-size: 18px;
    color: #2563EB;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
    .pricing-grid {
      grid-template-columns: 1fr;
    }
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
