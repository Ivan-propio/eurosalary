      { title: 'Informes multi-pais', desc: 'Descargue informes salariales en PDF y CSV para 15 paises de la UE con percentiles, tendencias y comparaciones de poder adquisitivo.', icon: 'summarize' },
      { title: 'Acceso API', desc: 'Integre datos salariales europeos en su HRIS o plataforma de compensacion mediante nuestra API REST con puntuaciones de confianza.', icon: 'api' },
    ],
