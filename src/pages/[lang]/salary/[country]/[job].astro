  sl: [
    { question: `Kakšna je povprečna plača za ${jobName} v ${countryName} v letu ${year}?`, answer: `Mediana bruto plače za ${jobName} v ${countryName} je ${fmt(midRow.median)} na leto na srednji ravni. ${salaryRows.length > 1 ? `Začetniki zaslužijo približno ${fmt(salaryRows[0].median)}, medtem ko višji strokovnjaki lahko pričakujejo ${fmt(salaryRows[salaryRows.length - 1].median)} ali več.` : ''} Ti podatki temeljijo na Eurostatu in preverjenih zaposlitvenih oglasih.` },
    { question: `Koliko zasluži ${jobName} po obdavčitvi v ${countryName}?`, answer: `${jobName} na srednji ravni, ki zasluži ${fmt(midRow.median)} bruto v ${countryName}, domov odnese približno ${fmt(midRow.netEstimate)} neto letno. ${taxNotes || 'Davčne stopnje se razlikujejo glede na osebne okoliščine.'}` },
    { question: `Kako se plača za ${jobName} v ${countryName} primerja z drugimi državami EU?`, answer: compareItems.length > 0 ? `${countryName} je na #${euRank} mestu za plače ${jobName}. ${compareItems[0] ? `${compareItems[0].countryName} vodi z ${fmt(compareItems[0].medianSalary)}.` : ''}` : `Primerjalni podatki se pripravljajo.` },
    { question: `Kateri dejavniki vplivajo na plačo za ${jobName} v ${countryName}?`, answer: `Ključni dejavniki vključujejo raven izkušenj, mesto, industrijski sektor, velikost podjetja in specifična tehnična znanja. Davčne stopnje in življenjski stroški prav tako pomembno vplivajo na neto plačo.` },
    { question: `Ali so podatki o plačah zanesljivi?`, answer: `Da. EuroSalary zbira podatke iz Eurostata, preverjenih zaposlitvenih oglasov z več kot 50 evropskih portalov in potrjenih anonimnih poročil o plačah. Naša metodologija je pregledna in se nenehno posodablja.` },
  ],
  lt: [
    { question: `Koks yra vidutinis ${jobName} atlyginimas šalyje ${countryName} ${year} m.?`, answer: `${jobName} medianos bruto atlyginimas šalyje ${countryName} yra ${fmt(midRow.median)} per metus vidutiniu lygiu. ${salaryRows.length > 1 ? `Pradedantieji uždirba apie ${fmt(salaryRows[0].median)}, o vyresni specialistai gali tikėtis ${fmt(salaryRows[salaryRows.length - 1].median)} ar daugiau.` : ''} Šie duomenys pagrįsti Eurostatu ir patikrintais darbo skelbimais.` },
    { question: `Kiek uždirba ${jobName} po mokesčių šalyje ${countryName}?`, answer: `Vidutinio lygio ${jobName}, uždirbantis ${fmt(midRow.median)} bruto šalyje ${countryName}, gauna apie ${fmt(midRow.netEstimate)} neto per metus. ${taxNotes || 'Mokesčių tarifai skiriasi priklausomai nuo asmeninių aplinkybių.'}` },
    { question: `Kaip ${jobName} atlyginimas šalyje ${countryName} lyginasi su kitomis ES šalimis?`, answer: compareItems.length > 0 ? `${countryName} užima #${euRank} vietą pagal ${jobName} atlyginimus. ${compareItems[0] ? `${compareItems[0].countryName} pirmauja su ${fmt(compareItems[0].medianSalary)}.` : ''}` : `Lyginamieji duomenys renkami.` },
    { question: `Kokie veiksniai turi įtakos ${jobName} atlyginimui šalyje ${countryName}?`, answer: `Pagrindiniai veiksniai apima patirties lygį, miestą, pramonės sektorių, įmonės dydį ir konkrečius techninius įgūdžius. Mokesčių tarifai ir pragyvenimo išlaidos taip pat reikšmingai veikia grynąjį atlyginimą.` },
    { question: `Ar atlyginimų duomenys yra patikimi?`, answer: `Taip. EuroSalary surenka duomenis iš Eurostato, patikrintų darbo skelbimų iš daugiau nei 50 Europos portalų ir patvirtintų anoniminių atlyginimų ataskaitų. Mūsų metodologija yra skaidri ir nuolat atnaujinama.` },
  ],
  lv: [
    { question: `Kāda ir vidējā ${jobName} alga valstī ${countryName} ${year}. gadā?`, answer: `${jobName} mediānā bruto alga valstī ${countryName} ir ${fmt(midRow.median)} gadā vidējā līmenī. ${salaryRows.length > 1 ? `Iesācēji pelna aptuveni ${fmt(salaryRows[0].median)}, savukārt augstākā līmeņa speciālisti var sagaidīt ${fmt(salaryRows[salaryRows.length - 1].median)} vai vairāk.` : ''} Šie dati ir balstīti uz Eurostat un verificētiem darba sludinājumiem.` },
    { question: `Cik pelna ${jobName} pēc nodokļiem valstī ${countryName}?`, answer: `Vidējā līmeņa ${jobName}, kas pelna ${fmt(midRow.median)} bruto valstī ${countryName}, saņem aptuveni ${fmt(midRow.netEstimate)} neto gadā. ${taxNotes || 'Nodokļu likmes atšķiras atkarībā no personīgajiem apstākļiem.'}` },
    { question: `Kā ${jobName} alga valstī ${countryName} salīdzinās ar citām ES valstīm?`, answer: compareItems.length > 0 ? `${countryName} ieņem #${euRank} vietu ${jobName} algās. ${compareItems[0] ? `${compareItems[0].countryName} ir līderis ar ${fmt(compareItems[0].medianSalary)}.` : ''}` : `Salīdzinošie dati tiek apkopoti.` },
    { question: `Kādi faktori ietekmē ${jobName} algu valstī ${countryName}?`, answer: `Galvenie faktori ietver pieredzes līmeni, pilsētu, nozari, uzņēmuma lielumu un specifiskas tehniskās prasmes. Nodokļu likmes un dzīves dārdzība arī būtiski ietekmē neto algu.` },
    { question: `Vai algu dati ir uzticami?`, answer: `Jā. EuroSalary apkopo datus no Eurostat, verificētiem darba sludinājumiem no vairāk nekā 50 Eiropas portāliem un validētiem anonīmiem algu ziņojumiem. Mūsu metodoloģija ir pārskatāma un pastāvīgi atjaunināta.` },
  ],
  et: [
    { question: `Milline on ${jobName} keskmine palk riigis ${countryName} aastal ${year}?`, answer: `${jobName} mediaanbrutopalk riigis ${countryName} on ${fmt(midRow.median)} aastas keskmisel tasemel. ${salaryRows.length > 1 ? `Algajad teenivad umbes ${fmt(salaryRows[0].median)}, samas vanemspetsialistid võivad oodata ${fmt(salaryRows[salaryRows.length - 1].median)} või rohkem.` : ''} Need andmed põhinevad Eurostatil ja kontrollitud tööpakkumistel.` },
    { question: `Kui palju teenib ${jobName} pärast makse riigis ${countryName}?`, answer: `Kesktaseme ${jobName}, kes teenib ${fmt(midRow.median)} bruto riigis ${countryName}, saab kätte ligikaudu ${fmt(midRow.netEstimate)} neto aastas. ${taxNotes || 'Maksumäärad varieeruvad sõltuvalt isiklikest asjaoludest.'}` },
    { question: `Kuidas võrdleb ${jobName} palk riigis ${countryName} teiste EL-i riikidega?`, answer: compareItems.length > 0 ? `${countryName} on #${euRank} kohal ${jobName} palkade osas. ${compareItems[0] ? `${compareItems[0].countryName} on esikohal ${fmt(compareItems[0].medianSalary)}-ga.` : ''}` : `Võrdlusandmeid koostatakse.` },
    { question: `Millised tegurid mõjutavad ${jobName} palka riigis ${countryName}?`, answer: `Peamised tegurid hõlmavad kogemuse taset, linna, tööstusharu, ettevõtte suurust ja spetsiifilisi tehnilisi oskusi. Maksumäärad ja elukallidus mõjutavad samuti oluliselt netopalka.` },
    { question: `Kas palgaandmed on usaldusväärsed?`, answer: `Jah. EuroSalary koondab andmeid Eurostatist, kontrollitud tööpakkumistest enam kui 50 Euroopa portaalist ja valideeritud anonüümsetest palgaaruannetest. Meie metoodika on läbipaistev ja pidevalt uuendatav.` },
  ],
  mt: [
    { question: `Kemm hu s-salarju medju ta' ${jobName} f'${countryName} fl-${year}?`, answer: `Is-salarju gross medjan għal ${jobName} f'${countryName} huwa ${fmt(midRow.median)} fis-sena f'livell medju. ${salaryRows.length > 1 ? `Il-professjonisti tal-bidu jaqilgħu madwar ${fmt(salaryRows[0].median)}, filwaqt li s-senjuri jistgħu jistennew ${fmt(salaryRows[salaryRows.length - 1].median)} jew aktar.` : ''} Dawn iċ-ċifri huma bbażati fuq Eurostat u reklami ta' xogħol verifikati.` },
    { question: `Kemm jaqla' ${jobName} wara t-taxxi f'${countryName}?`, answer: `${jobName} ta' livell medju li jaqla' ${fmt(midRow.median)} gross f'${countryName} jieħu madwar ${fmt(midRow.netEstimate)} nett fis-sena. ${taxNotes || 'Ir-rati tat-taxxa jvarjaw skont iċ-ċirkostanzi personali.'}` },
    { question: `Kif jitqabbel is-salarju ta' ${jobName} f'${countryName} ma' pajjiżi oħra tal-UE?`, answer: compareItems.length > 0 ? `${countryName} jokkupa l-post #${euRank} għas-salarji ta' ${jobName}. ${compareItems[0] ? `${compareItems[0].countryName} jmexxi b'${fmt(compareItems[0].medianSalary)}.` : ''}` : `Id-data komparattiva qed tiġi kompilata.` },
    { question: `Liema fatturi jaffettwaw is-salarju ta' ${jobName} f'${countryName}?`, answer: `Il-fatturi ewlenin jinkludu l-livell ta' esperjenza, il-belt, is-settur industrijali, id-daqs tal-kumpanija u ħiliet tekniċi speċifiċi. Ir-rati tat-taxxa u l-għoli tal-ħajja wkoll jaffettwaw b'mod sinifikanti s-salarju nett.` },
    { question: `Id-data dwar is-salarji hija affidabbli?`, answer: `Iva. EuroSalary tiġbor data minn Eurostat, reklami ta' xogħol verifikati minn aktar minn 50 portal Ewropew u rapporti ta' salarji anonimi validati. Il-metodoloġija tagħna hija trasparenti u aġġornata b'mod kontinwu.` },
  ],
  ga: [
    { question: `Cad é an meántuarastal do ${jobName} in ${countryName} i ${year}?`, answer: `Is é an meántuarastal comhlán meánach do ${jobName} in ${countryName} ná ${fmt(midRow.median)} sa bhliain ag meánleibhéal. ${salaryRows.length > 1 ? `Tuilleann gairmithe sóisearacha thart ar ${fmt(salaryRows[0].median)}, agus is féidir le gairmithe sinsearacha ${fmt(salaryRows[salaryRows.length - 1].median)} nó níos mó a bheith ag súil leo.` : ''} Tá na figiúirí seo bunaithe ar Eurostat agus ar fhógraí poist deimhnithe.` },
    { question: `Cé mhéad a thuilleann ${jobName} tar éis cánacha in ${countryName}?`, answer: `Faigheann ${jobName} meánleibhéil a thuilleann ${fmt(midRow.median)} comhlán in ${countryName} thart ar ${fmt(midRow.netEstimate)} glan sa bhliain. ${taxNotes || 'Athraíonn rátaí cánach ag brath ar chúinsí pearsanta.'}` },
    { question: `Conas a dhéanann tuarastal ${jobName} in ${countryName} comparáid le tíortha eile an AE?`, answer: compareItems.length > 0 ? `Tá ${countryName} sa #${euRank} áit do thuarastail ${jobName}. ${compareItems[0] ? `Tá ${compareItems[0].countryName} chun tosaigh le ${fmt(compareItems[0].medianSalary)}.` : ''}` : `Tá sonraí comparáideacha á dtiomsú.` },
    { question: `Cad iad na tosca a théann i bhfeidhm ar thuarastal ${jobName} in ${countryName}?`, answer: `I measc na bpríomhthosca tá leibhéal taithí, cathair, earnáil tionsclaíochta, méid na cuideachta agus scileanna teicniúla sonracha. Bíonn tionchar suntasach ag rátaí cánach agus costas maireachtála ar an nglantuarastal freisin.` },
    { question: `An bhfuil na sonraí tuarastail iontaofa?`, answer: `Tá. Bailíonn EuroSalary sonraí ó Eurostat, fógraí poist deimhnithe ó 50+ tairseach Eorpach agus tuairiscí tuarastail anaithnid bailíochtaithe. Tá ár modheolaíocht trédhearcach agus á nuashonrú go leanúnach.` },
  ],
};
const faqItems = faqByLang[lang] || faqByLang.en;

const pageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: fb(titles, lang),
    author: { '@type': 'Organization', name: 'EuroSalary.eu' },
    datePublished: '2026-01-15',
    dateModified: '2026-04-04',
    publisher: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Dataset',
    name: `${jobName} Salary Data — ${countryName} ${year}`,
    description: fb(descriptions, lang),
    url: `https://eurosalary.eu/${lang}/salary/${countrySlug}/${Astro.params.job}/`,
    creator: { '@type': 'Organization', name: 'EuroSalary.eu' },
    temporalCoverage: `2025/${year}`,
    spatialCoverage: { '@type': 'Place', name: countryName },
    variableMeasured: 'Annual gross salary in EUR',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((f: { question: string; answer: string }) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['#quick-answer', '.salary-hero__answer'],
    },
    url: `https://eurosalary.eu/${lang}/salary/${countrySlug}/${Astro.params.job}/`,
  },
];

const flag = countryFlags[countryCode] || '';
---

<BaseLayout
  title={fb(titles, lang)}
  description={fb(descriptions, lang)}
  datePublished="2026-01-15"
  dateModified="2026-04-01"
  schema={pageSchema}
>
  <!-- Hero -->
  <section class="salary-hero">
    <div class="salary-hero__dots"></div>
    <div class="container salary-hero__inner">
      <nav class="salary-hero__breadcrumbs" aria-label="Breadcrumb">
        <a href={`/${lang}/`}>{fb(uiLabels.home, lang)}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <a href={`/${lang}/countries/`}>{fb(uiLabels.salaries, lang)}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <a href={`/${lang}/country/${countrySlug}/`}>{countryName}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <span class="salary-hero__breadcrumbs-current">{jobName}</span>
      </nav>

      <div class="salary-hero__grid">
        <div class="salary-hero__content">
          <div class="salary-hero__flag">{flag}</div>
          <h1 class="salary-hero__title">{fb(titles, lang)}</h1>
          <p class="salary-hero__answer" set:html={fb(answerTexts, lang)} />
        </div>

        <div class="salary-hero__stat-card">
          <div class="salary-hero__stat-top">
            <span class="salary-hero__stat-label">{t('hero.salary.statLabel')}</span>
            <div class="salary-hero__stat-value">{fmt(midRow.median)}</div>
            <div class="salary-hero__stat-sub">
              <span>{t('hero.salary.netLabel')} ~{fmt(midRow.netEstimate)}</span>
            </div>
          </div>
          {compareItems.length > 0 && (
            <div class="salary-hero__rank">
              <span class="material-symbols-outlined">leaderboard</span>
              {t('hero.salary.rankInEU').replace('{rank}', String(euRank)).replace('{job}', jobName)}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Body -->
  <article class="container salary-body">
    <TLDRBox items={fb(tldrLabels, lang)} />

    <section class="salary-section">
      <h2 class="salary-section__title">{labels.breakdown}</h2>
      <SalaryTable
        rows={salaryRows}
        lang={lang}
        countryName={countryName}
        jobName={jobName}
        currency={currency}
      />
    </section>

    {compareItems.length > 0 && (
      <section class="salary-section">
        <CountryCompare
          items={compareItems}
          lang={lang}
          jobName={jobName}
          jobSlug={Astro.params.job}
        />
      </section>
    )}

    <!-- Sources -->
    <section class="salary-section salary-sources">
      <h2 class="salary-section__title">{labels.sources}</h2>
      <p class="salary-sources__intro">{labels.sourceIntro}</p>
      <div class="salary-sources__grid">
        <div class="source-card">
          <span class="material-symbols-outlined source-card__icon">account_balance</span>
          <strong>Eurostat</strong>
          <p>{fb(uiLabels.sourceEurostatDesc, lang)}</p>
        </div>
        <div class="source-card">
          <span class="material-symbols-outlined source-card__icon">work</span>
          <strong>{fb(uiLabels.sourceJobPostingsTitle, lang)}</strong>
          <p>{fb(uiLabels.sourceJobPostingsDesc, lang)}</p>
        </div>
        <div class="source-card">
          <span class="material-symbols-outlined source-card__icon">group</span>
          <strong>{fb(uiLabels.sourceReportsTitle, lang)}</strong>
          <p>{fb(uiLabels.sourceReportsDesc, lang)}</p>
        </div>
      </div>
      <p class="salary-sources__updated">{labels.lastUpdated}</p>
    </section>

    <FAQSection items={faqItems} />

    <section class="salary-section">
      <JobAffiliateCTA country={countryName} job={jobName} lang={lang} />
    </section>

    <section class="salary-section">
      <SalaryForm lang={lang} />
    </section>
  </article>
</BaseLayout>

<style>
  /* Body */
  .salary-body { padding: var(--space-10) 0 var(--space-16); }
  .salary-section { margin-top: var(--space-12); }
  .salary-section__title {
    font-family: var(--font-headline, 'Public Sans', sans-serif);
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-primary-container, #0F1F3D);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-6);
  }

  /* Sources */
  .salary-sources__intro {
    color: #45474e;
    margin-bottom: var(--space-6);
  }
  .salary-sources__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }
  .source-card {
    background: white;
    border: 1px solid #e6e8ea;
    border-left: 4px solid var(--color-secondary, #0051d5);
    padding: var(--space-6);
    border-radius: 4px;
  }
  .source-card__icon {
    font-size: 20px;
    color: var(--color-secondary, #0051d5);
    display: block;
    margin-bottom: var(--space-2);
  }
  .source-card strong {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-primary-container, #0F1F3D);
    margin-bottom: 4px;
  }
  .source-card p {
    font-size: 12px;
    color: #75777e;
    line-height: 1.5;
  }
  .salary-sources__updated {
    font-size: 12px;
    color: #75777e;
    margin-top: var(--space-4);
  }

  @media (max-width: 768px) {
    .salary-sources__grid { grid-template-columns: 1fr; }
  }
</style>
