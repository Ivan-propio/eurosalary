import { uiLabels, countryNames, jobNames } from '../../../../i18n/translations';

export async function getStaticPaths() {
  const { data: salaryData } = await supabase
    .from('salary_data')
    .select(`
      salary_min, salary_max, salary_median, salary_net_estimate, experience_level,
      jobs!inner(slug, name_en, name_fr, name_de, name_es),
      countries!inner(slug, code, name_en, name_fr, name_de, name_es, currency, tax_notes)
    `);

  if (!salaryData) return [];

  const grouped: Record<string, any[]> = {};
  for (const row of salaryData) {
    const key = `${(row.jobs as any).slug}__${(row.countries as any).code}`;
    if (!grouped[key]) grouped[key] = [];
    grouped[key].push(row);
  }

  const langs = Object.keys(languages);
  const paths: any[] = [];

  for (const [key, rows] of Object.entries(grouped)) {
    const [jobSlug, countryCode] = key.split('__');
    const job = rows[0].jobs as any;
    const country = rows[0].countries as any;

    const levelOrder = { junior: 0, mid: 1, senior: 2, lead: 3 };
    const salaryRows = rows
      .sort((a: any, b: any) => (levelOrder[a.experience_level as keyof typeof levelOrder] ?? 0) - (levelOrder[b.experience_level as keyof typeof levelOrder] ?? 0))
      .map((r: any) => ({
        level: r.experience_level,
        min: r.salary_min,
        median: r.salary_median,
        max: r.salary_max,
        netEstimate: r.salary_net_estimate,
      }));

    const compareRows = salaryData.filter(
      (r: any) => (r.jobs as any).slug === jobSlug && (r.countries as any).code !== countryCode && r.experience_level === 'mid'
    );

    for (const lang of langs) {
      const countrySlug = fb(countrySlugsByLang, lang)?.[countryCode];
      const jobSlugLocalized = fb(jobSlugsByLang, lang)?.[jobSlug];
      if (!countrySlug || !jobSlugLocalized) continue;

      const jobName = fb(jobNames[(job as any).slug], lang) || (job as any).name_en;
      const countryName = fb(countryNames[countryCode], lang) || (country as any).name_en;

      const compareItems = compareRows.map((r: any) => ({
        countryName: fb(countryNames[(r.countries as any).code], lang) || (r.countries as any).name_en,
        countrySlug: fb(countrySlugsByLang, lang)?.[(r.countries as any).code] || (r.countries as any).slug,
        countryCode: (r.countries as any).code,
        flag: countryFlags[(r.countries as any).code] || '',
        medianSalary: r.salary_median,
      })).sort((a: any, b: any) => b.medianSalary - a.medianSalary).slice(0, 8);

      const midRow = salaryRows.find((r: any) => r.level === 'mid') || salaryRows[0];

      paths.push({
        params: { lang, country: countrySlug, job: jobSlugLocalized },
        props: {
          lang, jobSlug, jobName, countryCode, countryName, countrySlug,
          salaryRows, compareItems, midRow, currency: country.currency || 'EUR',
          taxNotes: country.tax_notes || '',
        },
      });
    }
  }

  return paths;
}

