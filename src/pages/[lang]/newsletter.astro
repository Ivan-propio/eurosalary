  lt: 'Naudojame Resend el. laiškams siųsti. Jūsų el. paštas saugomas saugiai ir niekada nesidalijama. Atsisakykite prenumeratos bet kuriuo metu vienu paspaudimu.',
  lv: 'Mēs izmantojam Resend e-pastu sūtīšanai. Jūsu e-pasts tiek droši glabāts un nekad netiek kopīgots. Atteicieties jebkurā laikā ar vienu klikšķi.',
  et: 'Kasutame emailide saatmiseks Resendit. Teie email on turvaliselt salvestatud ja seda ei jagata kunagi. Tühistage tellimus igal ajal ühe klikiga.',
  mt: 'Nużaw Resend biex nibagħtu emails. L-email tiegħek huwa maħżun b\'mod sigur u qatt ma jiġi kondiviż. Ikkanċella l-abbonament fi kwalunkwe ħin b\'klikk wieħed.',
  ga: 'Úsáidimid Resend chun ríomhphoist a sheoladh. Stóráiltear do ríomhphost go slán agus ní roinntear riamh é. Díliostáil am ar bith le clic amháin.',
};

const homeBreadcrumb: Record<string, string> = {
  en: 'Home', fr: 'Accueil', de: 'Startseite', es: 'Inicio', it: 'Home', pt: 'Início', nl: 'Home', pl: 'Strona główna',
  ro: 'Acasă', cs: 'Domů', sv: 'Hem', da: 'Hjem', fi: 'Etusivu', el: 'Αρχική', hu: 'Főoldal', sk: 'Domov',
  bg: 'Начало', hr: 'Početna', sl: 'Domov', lt: 'Pradžia', lv: 'Sākums', et: 'Avaleht', mt: 'Paġna Ewlenija', ga: 'Baile',
};
const newsletterBreadcrumb: Record<string, string> = {
  en: 'Newsletter', fr: 'Newsletter', de: 'Newsletter', es: 'Boletín', it: 'Newsletter', pt: 'Newsletter', nl: 'Nieuwsbrief', pl: 'Newsletter',
  ro: 'Newsletter', cs: 'Newsletter', sv: 'Nyhetsbrev', da: 'Nyhedsbrev', fi: 'Uutiskirje', el: 'Newsletter', hu: 'Hírlevél', sk: 'Newsletter',
  bg: 'Бюлетин', hr: 'Newsletter', sl: 'Novice', lt: 'Naujienlaiškis', lv: 'Jaunumu vēstule', et: 'Uudiskiri', mt: 'Newsletter', ga: 'Nuachtlitir',
};

// --------------- Schema ---------------
const pageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: fb(h1, lang),
    description: fb(metaDescription, lang),
    url: `https://eurosalary.eu/${lang}/newsletter/`,
    inLanguage: lang,
    datePublished: '2026-01-15',
    dateModified: '2026-04-02',
    publisher: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
  },
];
---

<BaseLayout
  title={fb(h1, lang)}
  description={fb(metaDescription, lang)}
  datePublished="2026-01-15"
  dateModified="2026-04-02"
  schema={pageSchema}
>
  <section class="page-hero">
    <div class="page-hero__dots"></div>
    <div class="container page-hero__inner">
      <nav class="page-hero__breadcrumbs" aria-label="Breadcrumb">
        <a href={`/${lang}/`}>{fb(homeBreadcrumb, lang)}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <span class="page-hero__breadcrumbs-current">{fb(newsletterBreadcrumb, lang)}</span>
      </nav>
      <h1 class="page-hero__title">Salary Pulse<br/><span class="page-hero__accent">{t('hero.newsletter.title2')}</span></h1>
      <p class="page-hero__desc">{fb(introText, lang)}</p>
    </div>
  </section>

  <div class="container page-body">
    <!-- What subscribers get -->
    <section class="section">
      <h2>{fb(whatYouGetTitle, lang)}</h2>
      <ul>
        {fb(whatYouGetItems, lang).map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>

    <!-- Sample content -->
    <section class="section">
      <h2>{fb(sampleTitle, lang)}</h2>
      <ul>
        {fb(sampleItems, lang).map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>

    <!-- Newsletter signup -->
    <section class="section">
      <h2>{fb(signupTitle, lang)}</h2>
      <NewsletterForm />
    </section>

    <!-- Archive -->
    <section class="section">
      <h2>{fb(archiveTitle, lang)}</h2>
      <p>{fb(archiveText, lang)}</p>
    </section>

    <!-- GDPR -->
    <section class="section">
      <h2>{fb(gdprTitle, lang)}</h2>
      <p>{fb(gdprText, lang)}</p>
    </section>
  </div>
</BaseLayout>

<style>
  .page-body { padding: 2.5rem 0 4rem; }
  .page-body h2 {
    font-family: 'Public Sans', sans-serif;
    font-size: 1.75rem; font-weight: 800; letter-spacing: -0.02em;
    color: #0F1F3D; margin-top: 2.5rem; margin-bottom: 1rem;
  }
</style>
