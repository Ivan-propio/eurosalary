const introText: Record<string, string> = {
  en: 'Stay ahead of the European salary curve. Every Tuesday, we send a concise email packed with the latest salary trends, country-specific insights, and job market analysis — all backed by real data.',
  fr: 'Restez en avance sur les tendances salariales européennes. Chaque mardi, nous envoyons un email concis avec les dernières tendances salariales, des analyses par pays et une étude du marché de l\'emploi — le tout basé sur des données réelles.',
  de: 'Bleiben Sie bei europäischen Gehaltstrends auf dem Laufenden. Jeden Dienstag senden wir eine kompakte E-Mail mit den neuesten Gehaltstrends, länderspezifischen Einblicken und Arbeitsmarktanalysen — alles auf echten Daten basierend.',
  es: 'Manténgase a la vanguardia de las tendencias salariales europeas. Cada martes, enviamos un email conciso con las últimas tendencias salariales, análisis por país y perspectivas del mercado laboral — todo respaldado por datos reales.',
  it: 'Resta al passo con le tendenze salariali europee. Ogni martedì inviamo un\'email concisa con le ultime tendenze retributive, approfondimenti per paese e analisi del mercato del lavoro — il tutto basato su dati reali.',
  pt: 'Mantenha-se à frente das tendências salariais europeias. Todas as terças-feiras, enviamos um email conciso com as últimas tendências salariais, análises por país e perspetivas do mercado de trabalho — tudo baseado em dados reais.',
  nl: 'Blijf voorop bij Europese salaristrends. Elke dinsdag sturen we een beknopte email met de nieuwste salaristrends, landspecifieke inzichten en arbeidsmarktanalyse — allemaal onderbouwd met echte data.',
  pl: 'Bądź na bieżąco z europejskimi trendami wynagrodzeń. W każdy wtorek wysyłamy zwięzły email z najnowszymi trendami płacowymi, analizami krajów i rynku pracy — wszystko poparte prawdziwymi danymi.',
  ro: 'Rămâneți în fața tendințelor salariale europene. În fiecare marți, trimitem un email concis cu cele mai recente tendințe salariale, analize pe țări și piața muncii — toate susținute de date reale.',
  cs: 'Buďte napřed v evropských platových trendech. Každé úterý posíláme stručný email s nejnovějšími platovými trendy, analýzami zemí a trhu práce — vše podložené reálnými daty.',
  sv: 'Håll dig steget före i europeiska lönetrender. Varje tisdag skickar vi ett koncist mail med de senaste lönetrenderna, landsspecifika insikter och arbetsmarknadsanalys — allt baserat på verklig data.',
  da: 'Hold dig foran de europæiske løntendenser. Hver tirsdag sender vi en kort email med de seneste løntendenser, landespecifikke indsigter og arbejdsmarkedsanalyse — alt understøttet af reelle data.',
  fi: 'Pysy Euroopan palkkatrendien edellä. Joka tiistai lähetämme tiiviin sähköpostin uusimmista palkkatrendeistä, maakohtaisista analyyseistä ja työmarkkinakatsauksesta — kaikki todelliseen dataan perustuen.',
  el: 'Μείνετε μπροστά στις ευρωπαϊκές μισθολογικές τάσεις. Κάθε Τρίτη στέλνουμε ένα σύντομο email με τις τελευταίες τάσεις μισθών, αναλύσεις ανά χώρα και ανάλυση αγοράς εργασίας — όλα βασισμένα σε πραγματικά δεδομένα.',
  hu: 'Maradjon az európai bértrendek élén. Minden kedden küldünk egy tömör emailt a legfrissebb béres trendekkel, országspecifikus elemzésekkel és munkaerőpiaci áttekintéssel — mindezt valós adatokra alapozva.',
  sk: 'Buďte vpredu v európskych platových trendoch. Každý utorok posielame stručný email s najnovšími platovými trendmi, analýzami krajín a trhu práce — všetko podložené reálnymi údajmi.',
  bg: 'Бъдете пред кривата на европейските заплати. Всеки вторник изпращаме кратък имейл с последните тенденции в заплатите, анализи по страни и пазар на труда — всичко подкрепено с реални данни.',
  hr: 'Budite ispred europskih trendova plaća. Svakog utorka šaljemo sažet email s najnovijim trendovima plaća, analizama po zemljama i tržištu rada — sve potkrijepljeno stvarnim podacima.',
  sl: 'Bodite korak pred evropskimi plačnimi trendi. Vsak torek pošljemo jedrnat email z najnovejšimi plačnimi trendi, analizami po državah in trgom dela — vse podprto z resničnimi podatki.',
  lt: 'Būkite priekyje Europos atlyginimų tendencijų. Kiekvieną antradienį siunčiame glaustą el. laišką su naujausiais atlyginimų trendais, šalių analizėmis ir darbo rinkos apžvalga — viskas pagrįsta realiais duomenimis.',
  lv: 'Esiet soli priekšā Eiropas algu tendencēm. Katru otrdienu sūtām kodolīgu e-pastu ar jaunākajām algu tendencēm, valstu analīzēm un darba tirgus pārskatu — viss balstīts uz reāliem datiem.',
  et: 'Olge Euroopa palgatrendidest sammu ees. Igal teisipäeval saadame lühikese emaili uusimate palgatrendide, riigipõhiste analüüside ja tööturuülevaatega — kõik toetatud tõeliste andmetega.',
  mt: 'Ibqa quddiem ix-xejriet tas-salarji Ewropej. Kull nhar ta\' Tlieta nibagħtu email qasir bl-aħħar xejriet tas-salarji, analiżi speċifiċi għall-pajjiżi u analiżi tas-suq tax-xogħol — kollox ibbażat fuq data reali.',
  ga: 'Fan chun tosaigh ar threochtaí tuarastail na hEorpa. Gach Máirt, seolaimid ríomhphost gonta leis na treochtaí tuarastail is déanaí, léargais shonracha tíre agus anailís mhargaidh fostaíochta — go léir bunaithe ar shonraí fíora.',
};

