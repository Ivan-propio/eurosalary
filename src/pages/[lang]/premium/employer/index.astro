      { title: 'Salary Benchmarking', desc: 'Compare your salary offers to market median, P25, P50, P75, and P90 for any role in any of our 27 EU countries. Filter by seniority, city, industry, and company size. Updated monthly with Eurostat-verified data.', icon: 'leaderboard' },
