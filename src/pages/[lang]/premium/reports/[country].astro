---

<BaseLayout title={c.metaTitle} description={c.metaDesc} datePublished="2026-04-04" dateModified="2026-04-04" schema={pageSchema}>
  <!-- Hero -->
  <section class="report-hero">
    <div class="report-hero__dots"></div>
    <div class="container report-hero__inner">
      <nav class="report-hero__breadcrumbs" aria-label="Breadcrumb">
        <a href={`/${lang}/`}>{c.home}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <a href={`/${lang}/premium/`}>{c.premium}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <span>{c.reports}</span>
        <span class="material-symbols-outlined">chevron_right</span>
        <span>{countryName}</span>
      </nav>
      <div class="report-hero__badge">
        <span class="material-symbols-outlined">workspace_premium</span>
        Premium Report
      </div>
      <h1>{flag} {c.h1}</h1>
      <p class="report-hero__answer">{c.introAnswer}</p>
    </div>
  </section>

  <article class="container report-body">
    <TLDRBox items={c.tldr} />

    <!-- Sample Data Table (Preview with blur) -->
    <section class="report-section">
      <h2>{c.previewTitle}</h2>
      <p class="report-section__note">{c.previewNote}</p>
      <div class="report-table-wrapper">
        <table class="report-table">
          <thead>
            <tr>
              <th>{c.role}</th>
              <th>{c.juniorLabel}</th>
              <th>{c.midLabel}</th>
              <th>{c.seniorLabel}</th>
              <th>{c.leadLabel}</th>
            </tr>
          </thead>
          <tbody>
            {sampleRoles.map((row, i) => (
              <tr>
                <td class="report-table__role">{row.role}</td>
                <td>{i < 2 ? `\u20AC${row.junior}` : ''}<span class={i >= 2 ? 'blurred-cell' : 'hidden'}>{i >= 2 ? `\u20AC${row.junior}` : ''}</span></td>
                <td>{i < 2 ? `\u20AC${row.mid}` : ''}<span class={i >= 2 ? 'blurred-cell' : 'hidden'}>{i >= 2 ? `\u20AC${row.mid}` : ''}</span></td>
                <td><span class="blurred-cell">{`\u20AC${row.senior}`}</span></td>
                <td><span class="blurred-cell">{`\u20AC${row.lead}`}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
        <div class="report-table__overlay">
          <span class="material-symbols-outlined">lock</span>
          <span>{c.blurredLabel}</span>
        </div>
      </div>
    </section>

    <!-- What's Included -->
    <section class="report-section">
      <h2>{c.includedTitle}</h2>
      <div class="report-included">
        {c.included.map((item, i) => (
          <div class="report-included__item">
            <span class="report-included__number">{i + 1}</span>
            <span class="report-included__text">{item}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Pricing -->
    <section class="report-section report-pricing">
      <h2>{c.pricingTitle}</h2>
      <div class="report-pricing__cards">
        <div class="report-pricing__card">
          <div class="report-pricing__card-header">
            <span class="material-symbols-outlined">description</span>
            <h3>{c.singleCountryLabel}</h3>
          </div>
          <div class="report-pricing__price">
            <span class="report-pricing__amount">&euro;49</span>
            <span class="report-pricing__period">one-time</span>
          </div>
          <p class="report-pricing__desc">{c.singleCountryDesc}</p>
          <a href="#" class="report-pricing__cta">{c.buyReport}</a>
        </div>
        <div class="report-pricing__card report-pricing__card--featured">
          <div class="report-pricing__best-value">{c.bestValue}</div>
          <div class="report-pricing__card-header">
            <span class="material-symbols-outlined">public</span>
            <h3>{c.allCountriesLabel}</h3>
          </div>
          <div class="report-pricing__price">
            <span class="report-pricing__amount">&euro;149</span>
