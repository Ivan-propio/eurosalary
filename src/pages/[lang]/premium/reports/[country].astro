---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import TLDRBox from '../../../../components/TLDRBox.astro';
import FAQSection from '../../../../components/FAQSection.astro';
import { countrySlugsByLang, countryFlags } from '../../../../data/slugs';
import { languages, type Lang } from '../../../../i18n/ui';
import { fb, useTranslations } from '../../../../i18n/utils';
import { countryNames, uiLabels } from '../../../../i18n/translations';

export function getStaticPaths() {
  const paths = [];
  for (const lang of Object.keys(languages)) {
    const slugs = countrySlugsByLang[lang];
    for (const [code, slug] of Object.entries(slugs)) {
      paths.push({
        params: { lang, country: slug },
        props: { countryCode: code, lang },
      });
    }
  }
  return paths;
}

const { countryCode, lang } = Astro.props as { countryCode: string; lang: Lang };
const t = useTranslations(lang as Lang);
const flag = countryFlags[countryCode] || '';
const countryName = fb(countryNames[countryCode], lang) || countryCode;

// --------------- Sample salary data (teaser) ---------------
