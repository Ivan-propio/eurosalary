    { q: 'Wie hoch ist die typische Mindestvergütung in {country}?', a: 'Obwohl es keinen gesetzlichen Mindestlohn gibt, setzen die meisten Tarifverträge in {country} effektive Mindestlöhne fest, die oft höher sind als gesetzliche Mindestlöhne in anderen EU-Ländern, typischerweise zwischen 1.500 und 2.500 €/Monat.' },
    { q: 'Wird {country} einen gesetzlichen Mindestlohn einführen?', a: 'Die EU-Mindestlohnrichtlinie (2022/2041) verlangt von den Mitgliedstaaten, angemessene Löhne zu fördern. {country} hat jedoch sein Tarifverhandlungsmodell beibehalten, das die Richtlinie als gültigen Ansatz anerkennt.' },
    { q: 'Wie schneidet {country} im Vergleich zu EU-Ländern mit Mindestlohn ab?', a: 'Trotz fehlendem gesetzlichen Mindestlohn verdienen Arbeitnehmer in {country} durch Tarifverträge in der Regel höhere Mindestlöhne als Arbeitnehmer in vielen Ländern mit gesetzlichen Mindestlöhnen.' },
  ],
  es: [
    { q: '¿Tiene {country} un salario mínimo en 2026?', a: 'No, {country} no tiene un salario mínimo legal. {note}. Los niveles de remuneración mínima se establecen mediante convenios colectivos entre empleadores y sindicatos.' },
    { q: '¿Cómo se determinan los salarios en {country}?', a: 'En {country}, los salarios se determinan mediante convenios colectivos negociados entre sindicatos y organizaciones patronales. Estos acuerdos sectoriales establecen niveles de remuneración mínima para cada industria.' },
    { q: '¿Cuál es la remuneración mínima típica en {country}?', a: 'Aunque no existe un mínimo legal, la mayoría de los convenios colectivos en {country} fijan salarios mínimos efectivos que a menudo superan los mínimos legales de otros países europeos, generalmente entre 1.500 y 2.500 €/mes.' },
    { q: '¿Introducirá {country} un salario mínimo legal?', a: 'La Directiva europea sobre salarios mínimos (2022/2041) exige a los Estados miembros promover salarios adecuados. Sin embargo, {country} ha mantenido su modelo de negociación colectiva, reconocido como enfoque válido.' },
    { q: '¿Cómo se compara {country} con los países de la UE con salario mínimo?', a: 'A pesar de no tener un mínimo legal, los trabajadores en {country} generalmente ganan salarios mínimos más altos a través de convenios colectivos que los trabajadores en muchos países con mínimos legales.' },
  ],
};

// --------------- EU ranking data (sorted by monthly, desc) ---------------
const euRanking: Array<{ code: string; monthly: number | null }> = [
  { code: 'LU', monthly: 2571 },
  { code: 'NL', monthly: 2300 },
  { code: 'DE', monthly: 2220 },
  { code: 'IE', monthly: 2200 },
  { code: 'BE', monthly: 2030 },
  { code: 'AT', monthly: 1890 },
  { code: 'FR', monthly: 1767 },
  { code: 'ES', monthly: 1323 },
  { code: 'PL', monthly: 890 },
  { code: 'PT', monthly: 870 },
];

const rankingTitleByLang: Record<string, string> = {
  en: 'among EU countries with a statutory minimum',
  fr: 'parmi les pays de l\'UE avec un minimum légal',
  de: 'unter den EU-Ländern mit gesetzlichem Mindestlohn',
  es: 'entre los países de la UE con mínimo legal',
};

// --------------- getStaticPaths ---------------
export function getStaticPaths() {
  const paths: Array<{ params: { lang: string; country: string }; props: { countryCode: string; lang: string } }> = [];
  for (const lang of Object.keys(languages)) {
    const slugs = countrySlugsByLang[lang];
    for (const [code, slug] of Object.entries(slugs)) {
      paths.push({
        params: { lang, country: slug },
        props: { countryCode: code, lang },
      });
    }
  }
  return paths;
}

// --------------- Page props ---------------
const { countryCode, lang } = Astro.props;
const t = useTranslations(lang as any);
const data = minWageData[countryCode]!;
const countryName = fb(countryNames[countryCode], lang);
const countrySlug = countrySlugsByLang[lang][countryCode];
const flag = countryFlags[countryCode];
const titles = fb(sectionTitles, lang);

function formatEur(amount: number): string {
  return new Intl.NumberFormat(lang, { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 }).format(amount);
}

function formatEurHourly(amount: number): string {
  return new Intl.NumberFormat(lang, { style: 'currency', currency: 'EUR', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(amount);
}

// Computed values
const netMonthly = data.monthly ? Math.round(data.monthly * 0.75) : 0;
const netAnnual = data.annual ? Math.round(data.annual * 0.75) : 0;

// Ranking position
const rankIndex = euRanking.findIndex(r => r.code === countryCode);
const rankPosition = rankIndex >= 0 ? rankIndex + 1 : null;
const rankTextTemplates: Record<string, Record<string, string>> = {
  en: { high: 'among the highest', mid: 'in the middle', low: 'among the lowest' },
  fr: { high: 'parmi les plus élevés', mid: 'au milieu', low: 'parmi les plus bas' },
  de: { high: 'unter den höchsten', mid: 'im Mittelfeld', low: 'unter den niedrigsten' },
  es: { high: 'entre los más altos', mid: 'en la mitad', low: 'entre los más bajos' },
};
let rankText = '';
if (rankPosition !== null) {
  const rt = fb(rankTextTemplates, lang);
  if (rankPosition <= 3) rankText = rt.high;
  else if (rankPosition <= 7) rankText = rt.mid;
  else rankText = rt.low;
}

const h1 = fb(h1Templates, lang).replace('{country}', countryName);

// Intro paragraph
let introText: string;
if (data.hasMinWage && data.monthly && data.hourly && data.annual) {
  introText = fb(introTemplatesStatutory, lang)
    .replace(/{country}/g, countryName)
    .replace(/{hourly}/g, formatEurHourly(data.hourly))
    .replace(/{monthly}/g, formatEur(data.monthly))
    .replace(/{annual}/g, formatEur(data.annual))
    .replace(/{note}/g, data.note);
} else {
  introText = fb(introTemplatesNoStatutory, lang)
    .replace(/{country}/g, countryName)
    .replace(/{note}/g, data.note);
}

// TL;DR items
const tldrItems: string[] = data.hasMinWage && data.hourly && data.monthly && data.annual
  ? [
      `${fb({ en: 'Hourly rate', fr: 'Taux horaire', de: 'Stundensatz', es: 'Tarifa por hora' }, lang)}: ${formatEurHourly(data.hourly)} (${data.lastUpdate})`,
      `${fb({ en: 'Monthly / Annual', fr: 'Mensuel / Annuel', de: 'Monatlich / Jährlich', es: 'Mensual / Anual' }, lang)}: ${formatEur(data.monthly)} / ${formatEur(data.annual)} ${fb({ en: 'gross', fr: 'brut', de: 'brutto', es: 'bruto' }, lang)}`,
      `${data.note}`,
    ]
  : [
      `${fb({ en: 'No statutory minimum wage', fr: 'Pas de salaire minimum légal', de: 'Kein gesetzlicher Mindestlohn', es: 'Sin salario mínimo legal' }, lang)}`,
      `${data.note}`,
      `${fb({ en: 'Wages set through collective bargaining agreements', fr: 'Salaires fixés par conventions collectives', de: 'Löhne durch Tarifverträge festgelegt', es: 'Salarios fijados por convenios colectivos' }, lang)}`,
    ];

// FAQ items
const faqRaw = data.hasMinWage
  ? fb(faqTemplatesStatutory, lang)
  : fb(faqTemplatesNoStatutory, lang);

const faqItems = faqRaw.map((item) => ({
  question: item.q.replace(/{country}/g, countryName),
  answer: item.a
    .replace(/{country}/g, countryName)
    .replace(/{hourly}/g, data.hourly ? formatEurHourly(data.hourly) : '')
    .replace(/{monthly}/g, data.monthly ? formatEur(data.monthly) : '')
    .replace(/{annual}/g, data.annual ? formatEur(data.annual) : '')
    .replace(/{netMonthly}/g, netMonthly ? formatEur(netMonthly) : '')
    .replace(/{netAnnual}/g, netAnnual ? formatEur(netAnnual) : '')
    .replace(/{lastUpdate}/g, data.lastUpdate)
    .replace(/{note}/g, data.note)
    .replace(/{rankText}/g, rankText),
}));

// Link labels
const links = fb(linkLabels, lang);

// SEO
const pageTitle = `${h1} | EuroSalary.eu`;
const pageDescriptions: Record<string, string> = {
  en: data.hasMinWage
    ? `Minimum wage in ${countryName} 2026: ${formatEurHourly(data.hourly!)} per hour, ${formatEur(data.monthly!)} per month. Historical increases, EU ranking, and after-tax estimates.`
    : `${countryName} has no statutory minimum wage in 2026. Learn how collective agreements determine pay levels and how it compares to other EU countries.`,
  fr: data.hasMinWage
    ? `Salaire minimum en ${countryName} 2026 : ${formatEurHourly(data.hourly!)} de l'heure, ${formatEur(data.monthly!)} par mois. Historique, classement UE et estimation nette.`
    : `${countryName} n'a pas de salaire minimum légal en 2026. Découvrez comment les conventions collectives déterminent les niveaux de rémunération.`,
  de: data.hasMinWage
    ? `Mindestlohn in ${countryName} 2026: ${formatEurHourly(data.hourly!)} pro Stunde, ${formatEur(data.monthly!)} pro Monat. Historische Entwicklung, EU-Ranking und Nettoschätzung.`
    : `${countryName} hat 2026 keinen gesetzlichen Mindestlohn. Erfahren Sie, wie Tarifverträge die Lohnniveaus bestimmen.`,
  es: data.hasMinWage
    ? `Salario mínimo en ${countryName} 2026: ${formatEurHourly(data.hourly!)} por hora, ${formatEur(data.monthly!)} al mes. Historial, ranking UE y estimación neta.`
    : `${countryName} no tiene salario mínimo legal en 2026. Descubra cómo la negociación colectiva determina los niveles salariales.`,
};
const pageDescription = fb(pageDescriptions, lang);

const pageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: h1,
    description: pageDescription,
    author: { '@type': 'Organization', name: 'EuroSalary.eu' },
    datePublished: '2026-01-15',
    dateModified: '2026-04-07',
    publisher: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['#quick-answer', '.minwage-hero__desc', '.faq-item'],
    },
  },
  ...(data.hasMinWage ? [{
    '@context': 'https://schema.org',
    '@type': 'Dataset',
    name: `Minimum Wage Data — ${countryName} 2026`,
    description: pageDescription,
    url: `https://eurosalary.eu/${lang}/minimum-wage/${countrySlug}/`,
    creator: { '@type': 'Organization', name: 'EuroSalary.eu' },
    temporalCoverage: '2015/2026',
    spatialCoverage: { '@type': 'Place', name: countryName },
    variableMeasured: ['Hourly minimum wage in EUR', 'Monthly minimum wage in EUR', 'Annual minimum wage in EUR'],
  }] : []),
];

// Collective explanation for no-min-wage countries
const collectiveExplanation = !data.hasMinWage && collectiveExplanations[countryCode]
  ? fb(collectiveExplanations[countryCode], lang)
  : '';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  datePublished="2026-01-15"
  dateModified="2026-04-04"
  schema={pageSchema}
>
  <!-- Hero -->
  <section class="mw-hero">
    <div class="mw-hero__bg-icon">
      <span class="material-symbols-outlined">gavel</span>
    </div>
    <div class="container mw-hero__inner">
      <nav class="mw-hero__breadcrumbs" aria-label="Breadcrumb">
        <a href={`/${lang}/`}>{fb(uiLabels.home, lang)}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <span>{fb(uiLabels.minimumWage, lang)}</span>
        <span class="material-symbols-outlined">chevron_right</span>
        <span class="mw-hero__breadcrumbs-current">{countryName}</span>
      </nav>

      <div class="mw-hero__grid">
        <div class="mw-hero__content">
          <div class="mw-hero__badge">
            <span class="mw-hero__flag">{flag}</span>
            <span class="mw-hero__badge-text">{fb(uiLabels.minimumWage, lang)} 2026</span>
          </div>
          <h1 class="mw-hero__title">{h1}</h1>
          <p class="mw-hero__desc">{introText}</p>
        </div>

        <div class="mw-hero__stats">
          {data.hasMinWage && data.hourly && data.monthly && data.annual ? (
            <>
              <div class="mw-hero__stat-card">
                <span class="mw-hero__stat-label">{fb({ en: 'Hourly Rate', fr: 'Taux horaire', de: 'Stundenlohn', es: 'Tarifa por hora' }, lang)}</span>
                <div class="mw-hero__stat-value">{formatEurHourly(data.hourly)}</div>
                <span class="mw-hero__stat-note">{fb({ en: 'per hour', fr: 'de l\'heure', de: 'pro Stunde', es: 'por hora' }, lang)}</span>
              </div>
              <div class="mw-hero__stat-card">
                <span class="mw-hero__stat-label">{fb({ en: 'Monthly Gross', fr: 'Mensuel brut', de: 'Monatsbrutto', es: 'Mensual bruto' }, lang)}</span>
                <div class="mw-hero__stat-value">{formatEur(data.monthly)}</div>
                <span class="mw-hero__stat-note">{fb({ en: 'per month', fr: 'par mois', de: 'pro Monat', es: 'al mes' }, lang)}</span>
              </div>
              <div class="mw-hero__stat-card">
                <span class="mw-hero__stat-label">{fb({ en: 'Annual Gross', fr: 'Annuel brut', de: 'Jahresbrutto', es: 'Anual bruto' }, lang)}</span>
                <div class="mw-hero__stat-value">{formatEur(data.annual)}</div>
                <span class="mw-hero__stat-note">{fb({ en: 'per year', fr: 'par an', de: 'pro Jahr', es: 'al año' }, lang)}</span>
              </div>
            </>
          ) : (
            <div class="mw-hero__stat-card mw-hero__stat-card--wide">
              <span class="mw-hero__stat-label">{fb({ en: 'No Statutory Minimum Wage', fr: 'Pas de salaire minimum légal', de: 'Kein gesetzlicher Mindestlohn', es: 'Sin salario mínimo legal' }, lang)}</span>
              <div class="mw-hero__stat-value mw-hero__stat-na">N/A</div>
              <span class="mw-hero__stat-note">{data.note}</span>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <article class="container mw-body">
    <!-- TL;DR -->
    <TLDRBox items={tldrItems} />

    {data.hasMinWage && data.hourly && data.monthly && data.annual ? (
      <>
        <!-- Key Facts Card -->
        <section class="mw-section">
          <h2 class="mw-section__title">{titles.keyFacts}</h2>
          <div class="mw-facts-grid">
            <div class="mw-fact-card">
              <span class="material-symbols-outlined mw-fact-card__icon">schedule</span>
              <div class="mw-fact-card__label">{fb({ en: 'Hourly', fr: 'Horaire', de: 'Stündlich', es: 'Por hora' }, lang)}</div>
              <div class="mw-fact-card__value">{formatEurHourly(data.hourly)}</div>
            </div>
            <div class="mw-fact-card">
              <span class="material-symbols-outlined mw-fact-card__icon">calendar_month</span>
              <div class="mw-fact-card__label">{fb({ en: 'Monthly', fr: 'Mensuel', de: 'Monatlich', es: 'Mensual' }, lang)}</div>
              <div class="mw-fact-card__value">{formatEur(data.monthly)}</div>
            </div>
            <div class="mw-fact-card">
              <span class="material-symbols-outlined mw-fact-card__icon">event</span>
              <div class="mw-fact-card__label">{fb({ en: 'Annual', fr: 'Annuel', de: 'Jährlich', es: 'Anual' }, lang)}</div>
              <div class="mw-fact-card__value">{formatEur(data.annual)}</div>
            </div>
            <div class="mw-fact-card">
              <span class="material-symbols-outlined mw-fact-card__icon">update</span>
              <div class="mw-fact-card__label">{fb({ en: 'Last Update', fr: 'Dernière mise à jour', de: 'Letzte Aktualisierung', es: 'Última actualización' }, lang)}</div>
              <div class="mw-fact-card__value mw-fact-card__value--sm">{data.lastUpdate}</div>
            </div>
            <div class="mw-fact-card">
              <span class="material-symbols-outlined mw-fact-card__icon">account_balance_wallet</span>
              <div class="mw-fact-card__label">{fb({ en: 'Net Monthly (est.)', fr: 'Net mensuel (est.)', de: 'Netto monatl. (gesch.)', es: 'Neto mensual (est.)' }, lang)}</div>
              <div class="mw-fact-card__value">~{formatEur(netMonthly)}</div>
            </div>
            <div class="mw-fact-card">
              <span class="material-symbols-outlined mw-fact-card__icon">savings</span>
              <div class="mw-fact-card__label">{fb({ en: 'Net Annual (est.)', fr: 'Net annuel (est.)', de: 'Netto jährl. (gesch.)', es: 'Neto anual (est.)' }, lang)}</div>
              <div class="mw-fact-card__value">~{formatEur(netAnnual)}</div>
            </div>
          </div>
          <p class="mw-disclaimer">{fb({ en: 'Net estimates assume ~25% effective tax and social contribution rate. Actual amounts vary by personal situation.', fr: 'Les estimations nettes supposent un taux effectif de ~25% d\'impôts et cotisations. Les montants réels varient selon la situation personnelle.', de: 'Nettoschätzungen basieren auf einem effektiven Steuer- und Abgabensatz von ~25%. Tatsächliche Beträge variieren je nach persönlicher Situation.', es: 'Las estimaciones netas asumen una tasa efectiva de ~25% de impuestos y contribuciones. Los montos reales varían según la situación personal.' }, lang)}</p>
        </section>

        <!-- Historical Increases Timeline -->
        {data.increases.length > 0 && (
          <section class="mw-section">
            <h2 class="mw-section__title">{titles.history}</h2>
            <div class="mw-timeline">
              {data.increases.map((inc, i) => {
                const [year, value] = inc.split(': ');
                const isLatest = i === data.increases.length - 1;
                return (
                  <div class={`mw-timeline__item ${isLatest ? 'mw-timeline__item--current' : ''}`}>
                    <div class="mw-timeline__dot"></div>
                    <div class="mw-timeline__content">
                      <span class="mw-timeline__year">{year}</span>
                      <span class="mw-timeline__value">{value}{fb({ en: '/hour', fr: '/heure', de: '/Stunde', es: '/hora' }, lang)}</span>
                      {isLatest && <span class="mw-timeline__badge">{fb({ en: 'Current', fr: 'Actuel', de: 'Aktuell', es: 'Actual' }, lang)}</span>}
                    </div>
                  </div>
                );
              })}
            </div>
          </section>
        )}

        <!-- EU Ranking Comparison -->
        <section class="mw-section">
          <h2 class="mw-section__title">{titles.ranking}</h2>
          <p class="mw-text">{fb({ en: `At ${formatEur(data.monthly)}/month, ${countryName}'s minimum wage ranks #${rankPosition} ${fb(rankingTitleByLang, lang)}.`, fr: `À ${formatEur(data.monthly)}/mois, le salaire minimum de ${countryName} se classe #${rankPosition} ${fb(rankingTitleByLang, lang)}.`, de: `Mit ${formatEur(data.monthly)}/Monat liegt der Mindestlohn in ${countryName} auf Platz ${rankPosition} ${fb(rankingTitleByLang, lang)}.`, es: `Con ${formatEur(data.monthly)}/mes, el salario mínimo de ${countryName} ocupa el puesto #${rankPosition} ${fb(rankingTitleByLang, lang)}.` }, lang)}</p>
          <div class="mw-ranking">
            {euRanking.map((r) => {
              const isActive = r.code === countryCode;
              const rName = fb(countryNames[r.code], lang);
              const rFlag = countryFlags[r.code];
              const barWidth = r.monthly ? Math.round((r.monthly / 2571) * 100) : 0;
              return (
                <div class={`mw-ranking__row ${isActive ? 'mw-ranking__row--active' : ''}`}>
                  <div class="mw-ranking__country">
                    <span class="mw-ranking__flag">{rFlag}</span>
                    <span class="mw-ranking__name">{rName}</span>
                  </div>
                  <div class="mw-ranking__bar-wrap">
                    <div class="mw-ranking__bar" style={`width: ${barWidth}%`}></div>
                  </div>
                  <div class="mw-ranking__amount">{r.monthly ? formatEur(r.monthly) : 'N/A'}</div>
                </div>
              );
            })}
          </div>
          <p class="mw-ranking__note">{fb({ en: 'Countries without a statutory minimum (Italy, Sweden, Denmark, Finland, Switzerland) are not included.', fr: 'Les pays sans minimum légal (Italie, Suède, Danemark, Finlande, Suisse) ne sont pas inclus.', de: 'Länder ohne gesetzlichen Mindestlohn (Italien, Schweden, Dänemark, Finnland, Schweiz) sind nicht enthalten.', es: 'Los países sin mínimo legal (Italia, Suecia, Dinamarca, Finlandia, Suiza) no están incluidos.' }, lang)}</p>
        </section>
      </>
    ) : (
      <>
        <!-- Collective Agreement System Explanation -->
        <section class="mw-section">
          <h2 class="mw-section__title">{titles.collectiveSystem}</h2>
          <div class="mw-collective-box">
            <span class="material-symbols-outlined mw-collective-box__icon">groups</span>
            <div class="mw-collective-box__content">
              <p class="mw-text">{collectiveExplanation}</p>
            </div>
          </div>
        </section>

        <!-- EU Ranking Comparison (for context) -->
        <section class="mw-section">
          <h2 class="mw-section__title">{titles.ranking}</h2>
          <p class="mw-text">{fb({ en: `While ${countryName} does not have a statutory minimum wage, here is how EU countries with statutory minimums compare. Collective bargaining in ${countryName} typically results in higher effective minimums than most of these countries.`, fr: `Bien que ${countryName} n'ait pas de minimum légal, voici comment se comparent les pays de l'UE avec un minimum légal. La négociation collective en ${countryName} résulte généralement en des minimums effectifs plus élevés.`, de: `Obwohl ${countryName} keinen gesetzlichen Mindestlohn hat, zeigt diese Übersicht die EU-Länder mit gesetzlichem Mindestlohn. Tarifverhandlungen in ${countryName} führen in der Regel zu höheren effektiven Mindestlöhnen.`, es: `Aunque ${countryName} no tiene un salario mínimo legal, así se comparan los países de la UE con mínimos legales. La negociación colectiva en ${countryName} normalmente resulta en mínimos efectivos más altos.` }, lang)}</p>
          <div class="mw-ranking">
            {euRanking.map((r) => {
              const rName = fb(countryNames[r.code], lang);
              const rFlag = countryFlags[r.code];
              const barWidth = r.monthly ? Math.round((r.monthly / 2571) * 100) : 0;
              return (
                <div class="mw-ranking__row">
                  <div class="mw-ranking__country">
                    <span class="mw-ranking__flag">{rFlag}</span>
                    <span class="mw-ranking__name">{rName}</span>
                  </div>
                  <div class="mw-ranking__bar-wrap">
                    <div class="mw-ranking__bar" style={`width: ${barWidth}%`}></div>
                  </div>
                  <div class="mw-ranking__amount">{r.monthly ? formatEur(r.monthly) : 'N/A'}</div>
                </div>
              );
            })}
          </div>
        </section>
      </>
    )}

    <!-- Internal links -->
    <section class="mw-section">
      <h2 class="mw-section__title">{titles.links}</h2>
      <div class="mw-links-grid">
        <a href={`/${lang}/country/${countrySlug}/`} class="mw-link-card">
          <span class="material-symbols-outlined">flag</span>
          <span>{links.countryPage.replace('{country}', countryName)}</span>
          <span class="material-symbols-outlined mw-link-card__arrow">chevron_right</span>
        </a>
        <a href={`/${lang}/compare/software-engineer/`} class="mw-link-card">
          <span class="material-symbols-outlined">compare_arrows</span>
          <span>{links.comparePage}</span>
          <span class="material-symbols-outlined mw-link-card__arrow">chevron_right</span>
        </a>
      </div>
    </section>

    <FAQSection items={faqItems} />
  </article>
</BaseLayout>

<style>
  /* =========== Hero =========== */
  .mw-hero {
    background: var(--color-primary-container, #0F1F3D);
    color: white;
    padding: var(--space-10) 0 var(--space-12);
    position: relative;
    overflow: hidden;
  }
  .mw-hero__bg-icon {
    position: absolute;
