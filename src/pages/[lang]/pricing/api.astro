      { feature: 'Datos historicos', free: 'Ano actual', dev: '1 ano', biz: '3 anos', ent: 'Archivo completo' },
      { feature: 'Campos personalizados', free: '\u2014', dev: '\u2014', biz: '\u2713', ent: '\u2713' },
    ],
    codeTitle: 'Ejemplos de inicio rapido',
    codeFreeLabel: 'Nivel gratuito (sin clave)',
    codeFreeDesc: 'Comience a hacer solicitudes inmediatamente sin configuracion:',
    codeDevLabel: 'Desarrollador (clave API)',
    codeDevDesc: 'Autentiquese con su clave API para limites mas altos:',
    codeBizLabel: 'Business (webhooks)',
    codeBizDesc: 'Registre un webhook para recibir notificaciones de actualizacion:',
    faq: [
      { question: 'Que pasa cuando alcanzo el limite de solicitudes?', answer: 'La API devuelve un codigo 429 con un encabezado Retry-After. Los limites del nivel gratuito se reinician cada hora. Los limites de Desarrollador y Business se reinician a medianoche UTC.' },
      { question: 'Como funciona la autenticacion para planes de pago?', answer: 'Los planes de pago se autentican mediante un token Bearer en el encabezado Authorization. Recibe su clave API al instante. Desarrollador obtiene una clave, Business hasta 5, Enterprise claves ilimitadas.' },
      { question: 'Cual es la garantia de disponibilidad para Business y Enterprise?', answer: 'Los planes Business incluyen un SLA del 99,5%. Enterprise ofrece 99,9% o mas, negociado por contrato. Los creditos SLA se aplican automaticamente.' },
      { question: 'Puedo cambiar de plan API a mitad del ciclo de facturacion?', answer: 'Si. Las mejoras son inmediatas con facturacion prorrateada. Las bajadas de plan se aplican en el siguiente ciclo.' },
      { question: 'Soportan descargas de datos masivas?', answer: 'Los planes Business y Enterprise tienen acceso a endpoints masivos. Enterprise soporta exportaciones programadas por webhook o SFTP.' },
      { question: 'Que formatos de datos estan disponibles?', answer: 'Gratuito devuelve solo JSON. Desarrollador agrega CSV. Business incluye JSON, CSV y Excel. Enterprise soporta todos los formatos y esquemas personalizados.' },
    ],
  },
};

const c = fb(i18n, lang);

const pageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: c.h1,
    author: { '@type': 'Organization', name: 'EuroSalary.eu' },
    datePublished: '2026-04-05',
    dateModified: '2026-04-05',
    publisher: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: c.faq.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer },
    })),
  },
];
---

<BaseLayout title={c.metaTitle} description={c.metaDesc} datePublished="2026-04-05" dateModified="2026-04-05" schema={pageSchema}>
  <!-- Hero -->
  <section class="page-hero">
    <div class="page-hero__dots"></div>
    <div class="container page-hero__inner">
      <nav class="page-hero__breadcrumbs" aria-label="Breadcrumb">
        <a href={`/${lang}/`}>{c.home}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <a href={`/${lang}/pricing/`}>{c.pricingLabel}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <span class="page-hero__breadcrumbs-current">{c.breadcrumb}</span>
      </nav>
      <div class="api-hero__badge">
        <span class="material-symbols-outlined">api</span>
        {c.breadcrumb}
      </div>
      <h1>{c.h1}</h1>
      <p class="api-hero__answer">{c.introAnswer}</p>
    </div>
  </section>

  <article class="container page-body">
    <TLDRBox items={c.tldr} />

    <!-- Pricing Cards -->
    <section class="section">
      <h2 class="section__title">{c.plansTitle}</h2>
      <div class="api-cards">
        <!-- Free -->
        <div class="api-card">
          <div class="api-card__header">
            <h3>{c.free.name}</h3>
            <p class="api-card__desc">{c.free.desc}</p>
          </div>
          <div class="api-card__price">
            <span class="api-card__amount">{c.free.price}</span>
          </div>
          <a href={`/${lang}/salary-api/`} class="btn btn--outline">{c.free.cta}</a>
          <ul class="api-card__features">
            {c.free.features.map((f) => (
              <li><span class="api-card__check">&#10003;</span>{f}</li>
            ))}
          </ul>
        </div>

        <!-- Developer -->
        <div class="api-card">
          <div class="api-card__header">
            <h3>{c.dev.name}</h3>
            <p class="api-card__desc">{c.dev.desc}</p>
          </div>
          <div class="api-card__price">
            <span class="api-card__amount">{c.dev.price}</span>
          </div>
          <a href="#" class="btn btn--outline">{c.dev.cta}</a>
          <ul class="api-card__features">
            {c.dev.features.map((f) => (
              <li><span class="api-card__check">&#10003;</span>{f}</li>
            ))}
          </ul>
        </div>

        <!-- Business -->
        <div class="api-card api-card--featured">
          <div class="api-card__popular">{c.biz.badge}</div>
          <div class="api-card__header">
            <h3>{c.biz.name}</h3>
            <p class="api-card__desc">{c.biz.desc}</p>
          </div>
          <div class="api-card__price">
            <span class="api-card__amount">{c.biz.price}</span>
          </div>
          <a href="#" class="btn btn--filled">{c.biz.cta}</a>
          <ul class="api-card__features">
            {c.biz.features.map((f) => (
              <li><span class="api-card__check api-card__check--featured">&#10003;</span>{f}</li>
            ))}
          </ul>
        </div>

        <!-- Enterprise -->
        <div class="api-card">
          <div class="api-card__header">
            <h3>{c.ent.name}</h3>
            <p class="api-card__desc">{c.ent.desc}</p>
          </div>
          <div class="api-card__price">
            <span class="api-card__amount">{c.ent.price}</span>
          </div>
          <a href={`/${lang}/pricing/enterprise/`} class="btn btn--outline">{c.ent.cta}</a>
          <ul class="api-card__features">
            {c.ent.features.map((f) => (
              <li><span class="api-card__check">&#10003;</span>{f}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Feature Matrix -->
    <section class="section">
      <h2 class="section__title">{c.matrixTitle}</h2>
      <div class="api-matrix-wrap">
        <table class="data-table api-matrix">
          <thead>
            <tr>
              {c.matrixHeaders.map((h) => <th>{h}</th>)}
            </tr>
          </thead>
          <tbody>
            {c.matrixRows.map((row) => (
              <tr>
                <td class="api-matrix__feature">{row.feature}</td>
                <td>{row.free}</td>
                <td>{row.dev}</td>
                <td class="api-matrix__biz">{row.biz}</td>
                <td>{row.ent}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Code Examples -->
    <section class="section">
      <h2 class="section__title">{c.codeTitle}</h2>

      <div class="api-code-block">
        <h3>{c.codeFreeLabel}</h3>
        <p>{c.codeFreeDesc}</p>
        <pre><code>curl https://eurosalary.eu/api/v1/salary?country=DE&amp;job=software-engineer&amp;level=mid</code></pre>
      </div>

      <div class="api-code-block">
        <h3>{c.codeDevLabel}</h3>
        <p>{c.codeDevDesc}</p>
        <pre><code>curl -H "Authorization: Bearer YOUR_API_KEY" \
  "https://eurosalary.eu/api/v1/salary?country=DE&amp;job=software-engineer&amp;format=csv"</code></pre>
      </div>

      <div class="api-code-block">
        <h3>{c.codeBizLabel}</h3>
        <p>{c.codeBizDesc}</p>
        <pre><code>curl -X POST \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -H "Content-Type: application/json" \
  -d '&#123;"url":"https://your-app.com/webhook","events":["data.updated"]&#125;' \
  "https://eurosalary.eu/api/v1/webhooks"</code></pre>
      </div>
    </section>

    <FAQSection items={c.faq} />

    <!-- Cross-links -->
    <section class="section api-links">
      <p>
        <span class="material-symbols-outlined">description</span>
        <a href={`/${lang}/salary-api/`}>{fb({ en: 'Full API documentation', fr: 'Documentation API complete', de: 'Vollstandige API-Dokumentation', es: 'Documentacion API completa' }, lang)}</a>
        &nbsp;&middot;&nbsp;
        <a href={`/${lang}/pricing/`}>{fb({ en: 'All pricing plans', fr: 'Tous les plans tarifaires', de: 'Alle Preisplane', es: 'Todos los planes de precios' }, lang)}</a>
        &nbsp;&middot;&nbsp;
        <a href={`/${lang}/pricing/enterprise/`}>{fb({ en: 'Enterprise solutions', fr: 'Solutions entreprise', de: 'Enterprise-Losungen', es: 'Soluciones empresariales' }, lang)}</a>
      </p>
    </section>
  </article>
</BaseLayout>

<style>
  /* ===== Hero extras ===== */
  .api-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(37, 99, 235, 0.2);
    border: 1px solid rgba(37, 99, 235, 0.3);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #93c5fd;
    margin-bottom: var(--space-4);
  }
  .api-hero__badge .material-symbols-outlined { font-size: 14px; }
  .api-hero__answer {
    font-size: 1.05rem;
    line-height: 1.65;
    color: rgba(203, 213, 225, 0.85);
    max-width: 720px;
  }

  /* ===== Section titles ===== */
  .section { margin-top: var(--space-12); }
  .section__title {
    font-family: var(--font-headline, 'Public Sans', sans-serif);
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    font-weight: 800;
    color: var(--color-primary-container, #0F1F3D);
    margin-bottom: var(--space-6);
  }

  /* ===== Cards ===== */
  .api-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
    align-items: start;
  }
  .api-card {
    background: white;
    border: 1px solid #e6e8ea;
    border-radius: 10px;
    padding: var(--space-7);
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .api-card--featured {
    border-color: var(--color-secondary, #2563EB);
    border-width: 2px;
    box-shadow: 0 4px 24px rgba(37, 99, 235, 0.12);
    padding-top: calc(var(--space-7) + 8px);
  }
  .api-card__popular {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-secondary, #2563EB);
    color: white;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 16px;
    border-radius: 12px;
    white-space: nowrap;
  }
  .api-card__header h3 {
    font-family: var(--font-headline, 'Public Sans', sans-serif);
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-primary-container, #0F1F3D);
    margin-bottom: var(--space-1);
  }
  .api-card__desc {
    font-size: 13px;
    color: #75777e;
    line-height: 1.5;
    margin-bottom: var(--space-5);
  }
  .api-card__price {
    display: flex;
    align-items: baseline;
    gap: 4px;
    margin-bottom: var(--space-5);
  }
  .api-card__amount {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-primary-container, #0F1F3D);
    letter-spacing: -0.02em;
  }
  .api-card__features {
    list-style: none;
    padding: 0;
    margin: var(--space-5) 0 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .api-card__features li {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 13px;
    color: #374151;
    line-height: 1.45;
  }
  .api-card__check {
    flex-shrink: 0;
    color: #16a34a;
    font-weight: 700;
    font-size: 14px;
    line-height: 1.3;
  }
  .api-card__check--featured { color: var(--color-secondary, #2563EB); }

  /* ===== Buttons ===== */
  .btn {
    display: block;
    text-align: center;
    padding: 12px 20px;
    font-weight: 700;
    font-size: 14px;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.15s;
  }
  .btn--outline {
    border: 2px solid var(--color-secondary, #2563EB);
    color: var(--color-secondary, #2563EB);
    background: transparent;
  }
  .btn--outline:hover { background: var(--color-secondary, #2563EB); color: white; }
  .btn--filled {
    background: var(--color-secondary, #2563EB);
    color: white;
    border: 2px solid var(--color-secondary, #2563EB);
  }
  .btn--filled:hover { background: #1d4ed8; border-color: #1d4ed8; }

  /* ===== Matrix ===== */
  .api-matrix-wrap { overflow-x: auto; }
  .api-matrix {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  .api-matrix th {
    background: var(--color-primary-container, #0F1F3D);
    color: white;
    padding: 12px 16px;
    text-align: left;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .api-matrix td {
    padding: 12px 16px;
    border-bottom: 1px solid #e6e8ea;
    color: #374151;
  }
  .api-matrix__feature {
    font-weight: 600;
    color: var(--color-primary-container, #0F1F3D);
    white-space: nowrap;
  }
  .api-matrix__biz {
    background: rgba(37, 99, 235, 0.04);
    font-weight: 600;
  }
  .api-matrix tbody tr:hover { background: #f8fafc; }

  /* ===== Code Examples ===== */
  .api-code-block {
    background: #f8fafc;
    border: 1px solid #e6e8ea;
    border-radius: 10px;
    padding: var(--space-6);
    margin-bottom: var(--space-6);
  }
  .api-code-block h3 {
    font-family: var(--font-headline, 'Public Sans', sans-serif);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-primary-container, #0F1F3D);
    margin-bottom: var(--space-2);
  }
  .api-code-block p {
    font-size: 13px;
    color: #75777e;
    margin-bottom: var(--space-4);
  }
  .api-code-block pre {
    background: var(--color-primary-container, #0F1F3D);
    color: #93c5fd;
    padding: var(--space-4);
    border-radius: 6px;
    overflow-x: auto;
    font-size: 13px;
    line-height: 1.6;
    margin: 0;
  }
  .api-code-block code { font-family: 'JetBrains Mono', 'Fira Code', monospace; }

  /* ===== Cross-links ===== */
  .api-links p {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: var(--text-sm);
    color: #45474e;
    flex-wrap: wrap;
  }
  .api-links .material-symbols-outlined {
    font-size: 18px;
    color: var(--color-secondary, #2563EB);
  }
  .api-links a {
    color: var(--color-secondary, #2563EB);
    font-weight: 600;
  }

  /* ===== Responsive ===== */
  @media (max-width: 1024px) {
    .api-cards { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .api-cards { grid-template-columns: 1fr; }
  }
</style>
