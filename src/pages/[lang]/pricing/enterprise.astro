      { title: 'Licencia de datos personalizada', desc: 'Licencie datos EuroSalary para dashboards internos, informes a clientes o integraciones de terceros. Negocie derechos de uso y redistribucion.', icon: 'database' },
      { title: 'Informes marca blanca', desc: 'Genere informes salariales con su logo, colores y dominio. Entregue a consejos y clientes. Disponible en PDF, HTML e iframe.', icon: 'description' },
      { title: 'Integracion SSO / SAML', desc: 'Soporte SAML 2.0 y OpenID Connect para Okta, Azure AD, Google Workspace, OneLogin, Ping Identity y Auth0.', icon: 'lock' },
      { title: 'Gestor de exito dedicado', desc: 'Un CSM nombrado que conoce su organizacion, realiza revisiones trimestrales y sirve como punto de escalacion directo. Tiempo de respuesta promedio menor a 2 horas.', icon: 'support_agent' },
      { title: 'SLA personalizado', desc: 'Garantia de disponibilidad del 99,9% o superior con creditos SLA automaticos. Ventanas de mantenimiento personalizadas y respuesta prioritaria a incidentes.', icon: 'verified_user' },
      { title: 'Acceso API masivo', desc: 'Solicitudes API ilimitadas con limites dedicados, endpoints personalizados, webhooks y soporte para JSON, CSV, Excel, XML y Parquet.', icon: 'api' },
      { title: 'Auditoria de cumplimiento incluida', desc: 'Evaluacion anual de la directiva de transparencia salarial UE. Analisis de brecha salarial y documentacion lista para auditoria.', icon: 'gavel' },
      { title: 'Integraciones personalizadas', desc: 'Conectores pre-construidos para SAP SuccessFactors, Workday, BambooHR y Personio. Soporte de integracion personalizado de nuestro equipo de ingenieria.', icon: 'integration_instructions' },
    ],
    compareTitle: 'Construir internamente vs. EuroSalary Enterprise',
    compareDesc: 'Muchas organizaciones consideran construir inteligencia salarial internamente. Asi se compara.',
    compareHeaders: ['Aspecto', 'Construccion interna', 'EuroSalary Enterprise'],
    compareRows: [
      { aspect: 'Tiempo a produccion', inHouse: '6 a 12 meses', euroSalary: '2 a 4 semanas' },
      { aspect: 'Coste anual', inHouse: '150K a 500K+ (ingenieria + datos)', euroSalary: 'Fraccion del coste interno' },
      { aspect: 'Cobertura de paises', inHouse: 'Depende de capacidad de sourcing', euroSalary: '15+ paises UE, estandarizados' },
      { aspect: 'Mantenimiento de datos', inHouse: 'Esfuerzo de ingenieria continuo', euroSalary: 'Automatizado, actualizaciones semanales' },
      { aspect: 'Herramientas de cumplimiento', inHouse: 'Construir desde cero', euroSalary: 'Incluidas y mantenidas' },
      { aspect: 'Aseguramiento de calidad', inHouse: 'Validacion autogestionada', euroSalary: 'Metodologia verificada por Eurostat' },
    ],
    logosTitle: 'La confianza de empresas europeas',
    logosDesc: 'Organizaciones lideres en tecnologia, salud, consultoria y servicios financieros confian en EuroSalary.',
    logos: ['NordTech Group', 'AlpineHR Consulting', 'MedEuropa Healthcare', 'Baltic Financial Partners', 'Rhineland Manufacturing AG', 'Southern Digital Solutions'],
    processTitle: 'Como funciona el onboarding Enterprise',
    processDesc: 'Del primer contacto a produccion en solo dos semanas.',
    steps: [
      { title: 'Llamada de descubrimiento', desc: 'Conocemos su organizacion, necesidades de datos, requisitos de integracion y objetivos de cumplimiento. Tipicamente 30 minutos.', icon: 'call' },
      { title: 'Propuesta personalizada', desc: 'En 48 horas recibe una propuesta adaptada con alcance, precios, terminos SLA y cronograma.', icon: 'draft' },
      { title: 'Fase piloto', desc: 'Un piloto de 2 semanas con acceso completo para probar integraciones, validar datos y confirmar la adecuacion.', icon: 'science' },
      { title: 'Despliegue en produccion', desc: 'Configuracion SSO, credenciales API, webhooks y plantillas de informes marca blanca. Su CSM gestiona todo el despliegue.', icon: 'rocket_launch' },
    ],
    formTitle: 'Solicite una propuesta Enterprise personalizada',
    formDesc: 'Cuentenos sobre su organizacion y prepararemos una propuesta adaptada en 48 horas.',
    formLabels: {
      name: 'Nombre completo',
      email: 'Email corporativo',
      company: 'Nombre de la empresa',
      companySize: 'Tamano de la empresa',
      useCase: 'Caso de uso principal',
      budget: 'Presupuesto anual estimado',
      submit: 'Solicitar propuesta',
    },
    companySizes: ['1 a 50 empleados', '51 a 200', '201 a 1.000', '1.001 a 5.000', '5.001+'],
    useCases: ['Benchmarking de compensacion', 'Informes marca blanca', 'Integracion API (HRIS)', 'Cumplimiento transparencia salarial UE', 'Reclutamiento y adquisicion de talento', 'Otro'],
    budgetRanges: ['Menos de 10K al ano', '10K a 25K', '25K a 50K', '50K a 100K', '100K+', 'Aun no definido'],
    faq: [
      { question: 'Como son tipicamente los precios Enterprise?', answer: 'Los precios Enterprise dependen del numero de paises, volumen API, numero de usuarios y derechos de licencia. La mayoria de los acuerdos van de 500 a 5.000 por mes con facturacion anual. Proporcionamos un presupuesto personalizado tras la llamada de descubrimiento.' },
      { question: 'Hay una duracion minima de contrato?', answer: 'Los acuerdos Enterprise comienzan en 12 meses con renovacion anual. Ofrecemos facturacion trimestral y descuentos por volumen para compromisos plurianuales.' },
      { question: 'Podemos redistribuir datos EuroSalary a nuestros propios clientes?', answer: 'Si, con un acuerdo de licencia de datos. Los planes Enterprise pueden incluir derechos de redistribucion para informes marca blanca y analitica embebida.' },
      { question: 'Como se maneja la seguridad de datos Enterprise?', answer: 'Todos los datos se procesan en UE-Oeste (Frankfurt) en infraestructura conforme SOC 2 Tipo II. Tenancy dedicado disponible. Cumplimiento RGPD completo con DPA estandar.' },
      { question: 'Que pasa durante la fase piloto?', answer: 'El piloto de 2 semanas da acceso completo a todas las funciones Enterprise. Pruebe integraciones API, valide datos, configure SSO y genere informes. Sin pago durante el piloto.' },
      { question: 'Que tan rapido podemos ir a produccion tras firmar?', answer: 'La mayoria de clientes Enterprise estan operativos en 2 a 4 semanas. Configuracion SSO en 1 a 2 dias, integracion API segun sus sistemas, plantillas de informes en una semana.' },
    ],
  },
};

const c = fb(i18n, lang);

const pageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: c.h1,
    author: { '@type': 'Organization', name: 'EuroSalary.eu' },
    datePublished: '2026-04-05',
    dateModified: '2026-04-05',
    publisher: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: c.faq.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer },
    })),
  },
];
---

<BaseLayout title={c.metaTitle} description={c.metaDesc} datePublished="2026-04-05" dateModified="2026-04-05" schema={pageSchema}>
  <!-- Hero -->
  <section class="page-hero">
    <div class="page-hero__dots"></div>
    <div class="container page-hero__inner">
      <nav class="page-hero__breadcrumbs" aria-label="Breadcrumb">
        <a href={`/${lang}/`}>{c.home}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <a href={`/${lang}/pricing/`}>{c.pricingLabel}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <span class="page-hero__breadcrumbs-current">{c.breadcrumb}</span>
      </nav>
      <div class="ent-hero__badge">
        <span class="material-symbols-outlined">corporate_fare</span>
        {c.breadcrumb}
      </div>
      <h1>{c.h1}</h1>
      <p class="ent-hero__answer">{c.introAnswer}</p>
    </div>
  </section>

  <article class="container page-body">
    <TLDRBox items={c.tldr} />

    <!-- Everything Included -->
    <section class="section">
      <h2 class="section__title">{c.everythingTitle}</h2>
      <p class="ent-section__desc">{c.everythingDesc}</p>
      <div class="ent-features">
        {c.features.map((feat) => (
          <div class="ent-feature">
            <div class="ent-feature__icon">
              <span class="material-symbols-outlined">{feat.icon}</span>
            </div>
            <div>
              <h3>{feat.title}</h3>
              <p>{feat.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Build vs Buy Comparison -->
    <section class="section">
      <h2 class="section__title">{c.compareTitle}</h2>
      <p class="ent-section__desc">{c.compareDesc}</p>
      <div class="ent-compare-wrap">
        <table class="data-table ent-compare">
          <thead>
            <tr>
              {c.compareHeaders.map((h) => <th>{h}</th>)}
            </tr>
          </thead>
          <tbody>
            {c.compareRows.map((row) => (
              <tr>
                <td class="ent-compare__aspect">{row.aspect}</td>
                <td class="ent-compare__inhouse">{row.inHouse}</td>
                <td class="ent-compare__euro">{row.euroSalary}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Customer Logos -->
    <section class="section">
      <h2 class="section__title ent-logos__title">{c.logosTitle}</h2>
      <p class="ent-section__desc">{c.logosDesc}</p>
      <div class="ent-logos">
        {c.logos.map((name) => (
          <div class="ent-logo">
            <span class="material-symbols-outlined">business</span>
            <span>{name}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Onboarding Process -->
    <section class="section">
      <h2 class="section__title">{c.processTitle}</h2>
      <p class="ent-section__desc">{c.processDesc}</p>
      <div class="ent-steps">
        {c.steps.map((step, i) => (
          <div class="ent-step">
            <div class="ent-step__number">{i + 1}</div>
            <div class="ent-step__icon">
              <span class="material-symbols-outlined">{step.icon}</span>
            </div>
            <h3>{step.title}</h3>
            <p>{step.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Contact Form -->
    <section class="section" id="enterprise-form">
      <div class="ent-form-wrapper">
        <h2 class="section__title">{c.formTitle}</h2>
        <p class="ent-section__desc">{c.formDesc}</p>
        <form class="ent-form" method="POST" action="/api/contact">
          <input type="hidden" name="type" value="enterprise" />
          <input type="hidden" name="lang" value={lang} />

          <div class="ent-form__row">
            <div class="ent-form__field">
              <label for="ent-name">{c.formLabels.name}</label>
              <input type="text" id="ent-name" name="name" required />
            </div>
            <div class="ent-form__field">
              <label for="ent-email">{c.formLabels.email}</label>
              <input type="email" id="ent-email" name="email" required />
            </div>
          </div>

          <div class="ent-form__row">
            <div class="ent-form__field">
              <label for="ent-company">{c.formLabels.company}</label>
              <input type="text" id="ent-company" name="company" required />
            </div>
            <div class="ent-form__field">
              <label for="ent-size">{c.formLabels.companySize}</label>
              <select id="ent-size" name="company_size" required>
                <option value="">--</option>
                {c.companySizes.map((size) => (
                  <option value={size}>{size}</option>
                ))}
              </select>
            </div>
          </div>

          <div class="ent-form__row">
            <div class="ent-form__field">
              <label for="ent-usecase">{c.formLabels.useCase}</label>
              <select id="ent-usecase" name="use_case" required>
                <option value="">--</option>
                {c.useCases.map((uc) => (
                  <option value={uc}>{uc}</option>
                ))}
              </select>
            </div>
            <div class="ent-form__field">
              <label for="ent-budget">{c.formLabels.budget}</label>
              <select id="ent-budget" name="budget_range">
                <option value="">--</option>
                {c.budgetRanges.map((br) => (
                  <option value={br}>{br}</option>
                ))}
              </select>
            </div>
          </div>

          <button type="submit" class="btn btn--filled ent-form__submit">{c.formLabels.submit}</button>
        </form>
      </div>
    </section>

    <FAQSection items={c.faq} />

    <!-- Cross-links -->
    <section class="section ent-links">
      <p>
        <span class="material-symbols-outlined">link</span>
        <a href={`/${lang}/pricing/`}>{fb({ en: 'All pricing plans', fr: 'Tous les plans tarifaires', de: 'Alle Preisplane', es: 'Todos los planes' }, lang)}</a>
        &nbsp;&middot;&nbsp;
        <a href={`/${lang}/pricing/api/`}>{fb({ en: 'API pricing', fr: 'Tarifs API', de: 'API-Preise', es: 'Precios API' }, lang)}</a>
        &nbsp;&middot;&nbsp;
        <a href={`/${lang}/pricing/employer/`}>{fb({ en: 'Employer pricing', fr: 'Tarifs employeur', de: 'Arbeitgeber-Preise', es: 'Precios empleador' }, lang)}</a>
      </p>
    </section>
  </article>
</BaseLayout>

<style>
  /* ===== Hero extras ===== */
  .ent-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(37, 99, 235, 0.2);
    border: 1px solid rgba(37, 99, 235, 0.3);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #93c5fd;
    margin-bottom: var(--space-4);
  }
  .ent-hero__badge .material-symbols-outlined { font-size: 14px; }
  .ent-hero__answer {
    font-size: 1.05rem;
    line-height: 1.65;
    color: rgba(203, 213, 225, 0.85);
    max-width: 720px;
  }

  /* ===== Section titles ===== */
  .section { margin-top: var(--space-12); }
  .section__title {
    font-family: var(--font-headline, 'Public Sans', sans-serif);
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    font-weight: 800;
    color: var(--color-primary-container, #0F1F3D);
    margin-bottom: var(--space-4);
  }
  .ent-section__desc {
    font-size: 1rem;
    color: #45474e;
    line-height: 1.6;
    margin-bottom: var(--space-6);
    max-width: 700px;
  }

  /* ===== Feature Cards ===== */
  .ent-features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-5);
  }
  .ent-feature {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    background: #f8fafc;
    border: 1px solid #e6e8ea;
    border-radius: 10px;
    padding: var(--space-6);
  }
  .ent-feature__icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(37, 99, 235, 0.1);
    border-radius: 10px;
  }
  .ent-feature__icon .material-symbols-outlined {
    font-size: 22px;
    color: var(--color-secondary, #2563EB);
  }
  .ent-feature h3 {
    font-family: var(--font-headline, 'Public Sans', sans-serif);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-primary-container, #0F1F3D);
    margin-bottom: var(--space-1);
  }
  .ent-feature p {
    font-size: 13px;
    color: #45474e;
    line-height: 1.55;
    margin: 0;
  }

  /* ===== Comparison Table ===== */
  .ent-compare-wrap { overflow-x: auto; }
  .ent-compare {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  .ent-compare th {
    background: var(--color-primary-container, #0F1F3D);
    color: white;
    padding: 12px 16px;
    text-align: left;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .ent-compare td {
    padding: 12px 16px;
    border-bottom: 1px solid #e6e8ea;
    color: #374151;
  }
  .ent-compare__aspect {
    font-weight: 600;
    color: var(--color-primary-container, #0F1F3D);
    white-space: nowrap;
  }
  .ent-compare__inhouse { color: #dc2626; }
  .ent-compare__euro {
    color: #16a34a;
    font-weight: 600;
    background: rgba(22, 163, 106, 0.04);
  }
  .ent-compare tbody tr:hover { background: #f8fafc; }

  /* ===== Customer Logos ===== */
  .ent-logos__title { text-align: center; }
  .ent-logos {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }
  .ent-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #f8fafc;
    border: 1px solid #e6e8ea;
    border-radius: 8px;
    padding: var(--space-4) var(--space-5);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary-container, #0F1F3D);
  }
  .ent-logo .material-symbols-outlined {
    font-size: 20px;
    color: #94a3b8;
  }

  /* ===== Process Steps ===== */
  .ent-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
  }
  .ent-step {
    background: white;
    border: 1px solid #e6e8ea;
    border-radius: 10px;
    padding: var(--space-6);
    position: relative;
    text-align: center;
  }
  .ent-step__number {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    width: 24px;
    height: 24px;
    background: var(--color-secondary, #2563EB);
    color: white;
    font-size: 12px;
    font-weight: 800;
    line-height: 24px;
    text-align: center;
    border-radius: 50%;
  }
  .ent-step__icon {
    margin: var(--space-2) auto var(--space-3);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(37, 99, 235, 0.1);
    border-radius: 12px;
  }
  .ent-step__icon .material-symbols-outlined {
    font-size: 24px;
    color: var(--color-secondary, #2563EB);
  }
  .ent-step h3 {
    font-family: var(--font-headline, 'Public Sans', sans-serif);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-primary-container, #0F1F3D);
    margin-bottom: var(--space-2);
  }
  .ent-step p {
    font-size: 13px;
    color: #45474e;
    line-height: 1.5;
    margin: 0;
  }

  /* ===== Contact Form ===== */
  .ent-form-wrapper {
    background: linear-gradient(135deg, #0F1F3D 0%, #1e3a5f 100%);
    border-radius: 12px;
    padding: var(--space-10);
    color: white;
  }
  .ent-form-wrapper .section__title { color: white; }
  .ent-form-wrapper .ent-section__desc { color: rgba(203, 213, 225, 0.85); }
  .ent-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .ent-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }
  .ent-form__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .ent-form__field label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #93c5fd;
  }
  .ent-form__field input,
  .ent-form__field select {
    padding: 12px 14px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 6px;
    color: white;
    font-size: 14px;
    transition: border-color 0.15s;
  }
  .ent-form__field input::placeholder { color: rgba(203, 213, 225, 0.5); }
  .ent-form__field input:focus,
  .ent-form__field select:focus {
    outline: none;
    border-color: var(--color-secondary, #2563EB);
    background: rgba(255, 255, 255, 0.12);
  }
  .ent-form__field select option { background: #0F1F3D; color: white; }
  .ent-form__submit {
    align-self: flex-start;
    cursor: pointer;
    padding: 14px 32px;
    font-size: 15px;
  }

  /* ===== Buttons ===== */
  .btn {
    display: inline-block;
    text-align: center;
    padding: 12px 20px;
    font-weight: 700;
    font-size: 14px;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.15s;
    border: none;
  }
  .btn--filled {
    background: var(--color-secondary, #2563EB);
    color: white;
  }
  .btn--filled:hover { background: #1d4ed8; }

  /* ===== Cross-links ===== */
  .ent-links p {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: var(--text-sm);
    color: #45474e;
    flex-wrap: wrap;
  }
  .ent-links .material-symbols-outlined {
    font-size: 18px;
    color: var(--color-secondary, #2563EB);
  }
  .ent-links a {
    color: var(--color-secondary, #2563EB);
    font-weight: 600;
  }

  /* ===== Responsive ===== */
  @media (max-width: 1024px) {
    .ent-steps { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .ent-features { grid-template-columns: 1fr; }
    .ent-logos { grid-template-columns: 1fr; }
    .ent-steps { grid-template-columns: 1fr; }
    .ent-form__row { grid-template-columns: 1fr; }
    .ent-form-wrapper { padding: var(--space-6); }
  }
</style>
