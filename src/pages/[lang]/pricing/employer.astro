        'Actualizaciones semanales',
        'Analisis de brecha salarial de genero',
        'Exportacion CSV y Excel',
      ],
    },
    ent: {
      name: 'Enterprise',
      price: 'Personalizado',
      desc: 'Plataforma completa con SSO, CSM dedicado y herramientas de cumplimiento.',
      cta: 'Contactar ventas',
      features: [
        'Todos los paises de la UE',
        'Informes ilimitados',
        'Informes marca blanca',
        'Acceso API completo (ilimitado)',
        'Integracion SSO / SAML',
        'Gestor de exito dedicado',
        'Toolkit de cumplimiento de transparencia salarial UE',
        'Puestos de equipo ilimitados',
        'Actualizaciones en tiempo real',
        'Integraciones personalizadas (SAP, Workday)',
        'Auditoria de cumplimiento incluida',
      ],
    },
    matrixTitle: 'Comparacion de funciones',
    matrixHeaders: ['Funcion', 'Starter', 'Profesional', 'Enterprise'],
    matrixRows: [
      { feature: 'Paises cubiertos', starter: '5', pro: '15', ent: 'Todos UE' },
      { feature: 'Informes por mes', starter: '10', pro: '50', ent: 'Ilimitados' },
      { feature: 'Acceso API', starter: '\u2014', pro: '10K sol./dia', ent: 'Ilimitado' },
      { feature: 'Toolkit cumplimiento', starter: '\u2014', pro: 'Basico', ent: 'Suite completa' },
      { feature: 'Benchmarking', starter: 'Basico', pro: 'Avanzado', ent: 'Personalizado' },
      { feature: 'Puestos de equipo', starter: '2', pro: '10', ent: 'Ilimitados' },
      { feature: 'Nivel de soporte', starter: 'Email', pro: 'Email prioritario', ent: 'CSM dedicado' },
      { feature: 'Actualizacion de datos', starter: 'Mensual', pro: 'Semanal', ent: 'Tiempo real' },
      { feature: 'Analisis brecha salarial', starter: '\u2014', pro: '\u2713', ent: '\u2713' },
      { feature: 'Integraciones personalizadas', starter: '\u2014', pro: '\u2014', ent: '\u2713' },
    ],
    roiTitle: 'ROI: Por que las empresas eligen EuroSalary',
    roiDesc: 'Las empresas que usan EuroSalary ahorran en promedio un 15% en costes de benchmarking de compensacion comparado con consultoria tradicional.',
    roiMetrics: [
      { label: 'Ahorro promedio en costes de benchmarking', value: '15%' },
      { label: 'Tiempo ahorrado por ciclo de revision', value: '70%' },
      { label: 'Cumplimiento de equidad salarial mas rapido', value: '3x' },
      { label: 'Periodo promedio de recuperacion', value: '< 2 meses' },
    ],
    useCaseTitle: 'Ideal para',
    useCases: [
      { title: 'Equipos de RRHH pequenos', tier: 'Starter', desc: 'Una startup con 50 empleados en 2 mercados UE necesita benchmarks salariales basicos para ofertas competitivas. Starter proporciona los datos esenciales.', icon: 'groups' },
      { title: 'Equipos de compensacion en crecimiento', tier: 'Profesional', desc: 'Una empresa mediana con 500 empleados en 8 paises necesita informes personalizados y acceso API para su HRIS.', icon: 'trending_up' },
      { title: 'Operaciones HR Enterprise', tier: 'Enterprise', desc: 'Una multinacional con 5.000+ empleados necesita informes marca blanca, SSO y la suite completa de cumplimiento de la directiva de transparencia salarial UE.', icon: 'corporate_fare' },
    ],
    trialTitle: 'Comience su prueba gratuita de 14 dias',
    trialDesc: 'Pruebe cualquier plan sin riesgo durante 14 dias. Sin tarjeta de credito. Acceso completo a todas las funciones.',
    trialCta: 'Prueba gratuita',
    faq: [
      { question: 'Que paises estan cubiertos en cada plan?', answer: 'Starter cubre las 5 mayores economias de la UE: Alemania, Francia, Italia, Espana y Paises Bajos. Profesional cubre los 15 paises de la UE. Enterprise cubre todos los paises UE con opcion de anadir mercados fuera de la UE.' },
      { question: 'Podemos generar informes personalizados para presentaciones al consejo?', answer: 'Los planes Profesional y Enterprise incluyen generacion de informes personalizados. Puede seleccionar paises, familias de puestos, niveles de antiguedad y periodos. Disponibles en PDF, Excel y HTML interactivo.' },
      { question: 'Como funciona la herramienta de benchmarking de compensacion?', answer: 'Cargue sus bandas salariales actuales y la herramienta las compara con datos de mercado de EuroSalary, mostrando su posicion relativa a los percentiles 25, 50 y 75. Profesional ofrece benchmarking basico, Enterprise personalizado.' },
      { question: 'La plataforma cumple con los requisitos de transparencia salarial de la UE?', answer: 'Enterprise incluye un toolkit completo de cumplimiento con analisis automatizado de brecha salarial, plantillas de divulgacion por pais y documentacion lista para auditoria.' },
      { question: 'Podemos integrar EuroSalary con nuestros sistemas HR existentes?', answer: 'Profesional incluye acceso API. Enterprise ofrece conectores pre-construidos para SAP SuccessFactors, Workday, BambooHR y Personio, mas soporte de integracion personalizado.' },
      { question: 'Que pasa despues de que termina la prueba gratuita?', answer: 'Despues de 14 dias, puede suscribirse o pasar al nivel gratuito. Sin cargos automaticos. Sus datos se conservan 30 dias despues de la expiracion.' },
    ],
  },
};

const c = fb(i18n, lang);

const pageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: c.h1,
    author: { '@type': 'Organization', name: 'EuroSalary.eu' },
    datePublished: '2026-04-05',
    dateModified: '2026-04-05',
    publisher: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: c.faq.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer },
    })),
  },
];
---

<BaseLayout title={c.metaTitle} description={c.metaDesc} datePublished="2026-04-05" dateModified="2026-04-05" schema={pageSchema}>
  <!-- Hero -->
  <section class="page-hero">
    <div class="page-hero__dots"></div>
    <div class="container page-hero__inner">
      <nav class="page-hero__breadcrumbs" aria-label="Breadcrumb">
        <a href={`/${lang}/`}>{c.home}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <a href={`/${lang}/pricing/`}>{c.pricingLabel}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <span class="page-hero__breadcrumbs-current">{c.breadcrumb}</span>
      </nav>
      <div class="emp-hero__badge">
        <span class="material-symbols-outlined">business</span>
        {c.breadcrumb}
      </div>
      <h1>{c.h1}</h1>
      <p class="emp-hero__answer">{c.introAnswer}</p>
    </div>
  </section>

  <article class="container page-body">
    <TLDRBox items={c.tldr} />

    <!-- Pricing Cards -->
    <section class="section">
      <h2 class="section__title">{c.plansTitle}</h2>
      <div class="emp-cards">
        <!-- Starter -->
        <div class="emp-card">
          <div class="emp-card__header">
            <h3>{c.starter.name}</h3>
            <p class="emp-card__desc">{c.starter.desc}</p>
          </div>
          <div class="emp-card__price">
            <span class="emp-card__amount">{c.starter.price}</span>
          </div>
          <a href="#" class="btn btn--outline">{c.starter.cta}</a>
          <ul class="emp-card__features">
            {c.starter.features.map((f) => (
              <li><span class="emp-card__check">&#10003;</span>{f}</li>
            ))}
          </ul>
        </div>

        <!-- Professional -->
        <div class="emp-card emp-card--featured">
          <div class="emp-card__popular">{c.pro.badge}</div>
          <div class="emp-card__header">
            <h3>{c.pro.name}</h3>
            <p class="emp-card__desc">{c.pro.desc}</p>
          </div>
          <div class="emp-card__price">
            <span class="emp-card__amount">{c.pro.price}</span>
          </div>
          <a href="#" class="btn btn--filled">{c.pro.cta}</a>
          <ul class="emp-card__features">
            {c.pro.features.map((f) => (
              <li><span class="emp-card__check emp-card__check--featured">&#10003;</span>{f}</li>
            ))}
          </ul>
        </div>

        <!-- Enterprise -->
        <div class="emp-card">
          <div class="emp-card__header">
            <h3>{c.ent.name}</h3>
            <p class="emp-card__desc">{c.ent.desc}</p>
          </div>
          <div class="emp-card__price">
            <span class="emp-card__amount">{c.ent.price}</span>
          </div>
          <a href={`/${lang}/pricing/enterprise/`} class="btn btn--outline">{c.ent.cta}</a>
          <ul class="emp-card__features">
            {c.ent.features.map((f) => (
              <li><span class="emp-card__check">&#10003;</span>{f}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Feature Matrix -->
    <section class="section">
      <h2 class="section__title">{c.matrixTitle}</h2>
      <div class="emp-matrix-wrap">
        <table class="data-table emp-matrix">
          <thead>
            <tr>
              {c.matrixHeaders.map((h) => <th>{h}</th>)}
            </tr>
          </thead>
          <tbody>
            {c.matrixRows.map((row) => (
              <tr>
                <td class="emp-matrix__feature">{row.feature}</td>
                <td>{row.starter}</td>
                <td class="emp-matrix__pro">{row.pro}</td>
                <td>{row.ent}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- ROI Section -->
    <section class="section">
      <h2 class="section__title">{c.roiTitle}</h2>
      <p class="emp-roi__desc">{c.roiDesc}</p>
      <div class="emp-roi__grid">
        {c.roiMetrics.map((metric) => (
          <div class="emp-roi__card">
            <span class="emp-roi__value">{metric.value}</span>
            <span class="emp-roi__label">{metric.label}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Use Cases -->
    <section class="section">
      <h2 class="section__title">{c.useCaseTitle}</h2>
      <div class="emp-usecases">
        {c.useCases.map((uc) => (
          <div class="emp-usecase">
            <div class="emp-usecase__icon">
              <span class="material-symbols-outlined">{uc.icon}</span>
            </div>
            <div>
              <h3>{uc.title} <span class="emp-usecase__tier">{uc.tier}</span></h3>
              <p>{uc.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Trial CTA -->
    <section class="section">
      <div class="emp-trial">
        <span class="material-symbols-outlined">rocket_launch</span>
        <div>
          <strong>{c.trialTitle}</strong>
          <p>{c.trialDesc}</p>
        </div>
        <a href="#" class="btn btn--filled">{c.trialCta}</a>
      </div>
    </section>

    <FAQSection items={c.faq} />

    <!-- Cross-links -->
    <section class="section emp-links">
      <p>
        <span class="material-symbols-outlined">link</span>
        <a href={`/${lang}/pricing/`}>{fb({ en: 'All pricing plans', fr: 'Tous les plans tarifaires', de: 'Alle Preisplane', es: 'Todos los planes' }, lang)}</a>
        &nbsp;&middot;&nbsp;
        <a href={`/${lang}/pricing/api/`}>{fb({ en: 'API pricing', fr: 'Tarifs API', de: 'API-Preise', es: 'Precios API' }, lang)}</a>
        &nbsp;&middot;&nbsp;
        <a href={`/${lang}/pricing/enterprise/`}>{fb({ en: 'Enterprise solutions', fr: 'Solutions entreprise', de: 'Enterprise-Losungen', es: 'Soluciones empresariales' }, lang)}</a>
      </p>
    </section>
  </article>
</BaseLayout>

<style>
  /* ===== Hero extras ===== */
  .emp-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(37, 99, 235, 0.2);
    border: 1px solid rgba(37, 99, 235, 0.3);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #93c5fd;
    margin-bottom: var(--space-4);
  }
  .emp-hero__badge .material-symbols-outlined { font-size: 14px; }
  .emp-hero__answer {
    font-size: 1.05rem;
    line-height: 1.65;
    color: rgba(203, 213, 225, 0.85);
    max-width: 720px;
  }

  /* ===== Section titles ===== */
  .section { margin-top: var(--space-12); }
  .section__title {
    font-family: var(--font-headline, 'Public Sans', sans-serif);
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    font-weight: 800;
    color: var(--color-primary-container, #0F1F3D);
    margin-bottom: var(--space-6);
  }

  /* ===== Cards ===== */
  .emp-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
    align-items: start;
  }
  .emp-card {
    background: white;
    border: 1px solid #e6e8ea;
    border-radius: 10px;
    padding: var(--space-7);
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .emp-card--featured {
    border-color: var(--color-secondary, #2563EB);
    border-width: 2px;
    box-shadow: 0 4px 24px rgba(37, 99, 235, 0.12);
    padding-top: calc(var(--space-7) + 8px);
  }
  .emp-card__popular {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-secondary, #2563EB);
    color: white;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 16px;
    border-radius: 12px;
    white-space: nowrap;
  }
  .emp-card__header h3 {
    font-family: var(--font-headline, 'Public Sans', sans-serif);
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-primary-container, #0F1F3D);
    margin-bottom: var(--space-1);
  }
  .emp-card__desc {
    font-size: 13px;
    color: #75777e;
    line-height: 1.5;
    margin-bottom: var(--space-5);
  }
  .emp-card__price {
    display: flex;
    align-items: baseline;
    gap: 4px;
    margin-bottom: var(--space-5);
  }
  .emp-card__amount {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-primary-container, #0F1F3D);
    letter-spacing: -0.02em;
  }
  .emp-card__features {
    list-style: none;
    padding: 0;
    margin: var(--space-5) 0 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .emp-card__features li {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 13px;
    color: #374151;
    line-height: 1.45;
  }
  .emp-card__check {
    flex-shrink: 0;
    color: #16a34a;
    font-weight: 700;
    font-size: 14px;
    line-height: 1.3;
  }
  .emp-card__check--featured { color: var(--color-secondary, #2563EB); }

  /* ===== Buttons ===== */
  .btn {
    display: block;
    text-align: center;
    padding: 12px 20px;
    font-weight: 700;
    font-size: 14px;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.15s;
  }
  .btn--outline {
    border: 2px solid var(--color-secondary, #2563EB);
    color: var(--color-secondary, #2563EB);
    background: transparent;
  }
  .btn--outline:hover { background: var(--color-secondary, #2563EB); color: white; }
  .btn--filled {
    background: var(--color-secondary, #2563EB);
    color: white;
    border: 2px solid var(--color-secondary, #2563EB);
  }
  .btn--filled:hover { background: #1d4ed8; border-color: #1d4ed8; }

  /* ===== Matrix ===== */
  .emp-matrix-wrap { overflow-x: auto; }
  .emp-matrix {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  .emp-matrix th {
    background: var(--color-primary-container, #0F1F3D);
    color: white;
    padding: 12px 16px;
    text-align: left;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .emp-matrix td {
    padding: 12px 16px;
    border-bottom: 1px solid #e6e8ea;
    color: #374151;
  }
  .emp-matrix__feature {
    font-weight: 600;
    color: var(--color-primary-container, #0F1F3D);
    white-space: nowrap;
  }
  .emp-matrix__pro {
    background: rgba(37, 99, 235, 0.04);
    font-weight: 600;
  }
  .emp-matrix tbody tr:hover { background: #f8fafc; }

  /* ===== ROI ===== */
  .emp-roi__desc {
    font-size: 1rem;
    color: #45474e;
    line-height: 1.6;
    margin-bottom: var(--space-6);
    max-width: 680px;
  }
  .emp-roi__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
  }
  .emp-roi__card {
    background: #f8fafc;
    border: 1px solid #e6e8ea;
    border-radius: 10px;
    padding: var(--space-6);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .emp-roi__value {
    font-family: var(--font-headline, 'Public Sans', sans-serif);
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-secondary, #2563EB);
    letter-spacing: -0.02em;
  }
  .emp-roi__label {
    font-size: 13px;
    color: #75777e;
    line-height: 1.4;
  }

  /* ===== Use Cases ===== */
  .emp-usecases {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .emp-usecase {
    display: flex;
    align-items: flex-start;
    gap: var(--space-5);
    background: #f8fafc;
    border: 1px solid #e6e8ea;
    border-radius: 10px;
    padding: var(--space-6);
  }
  .emp-usecase__icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(37, 99, 235, 0.1);
    border-radius: 10px;
  }
  .emp-usecase__icon .material-symbols-outlined {
    font-size: 24px;
    color: var(--color-secondary, #2563EB);
  }
  .emp-usecase h3 {
    font-family: var(--font-headline, 'Public Sans', sans-serif);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-primary-container, #0F1F3D);
    margin-bottom: var(--space-2);
  }
  .emp-usecase__tier {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: rgba(37, 99, 235, 0.1);
    color: var(--color-secondary, #2563EB);
    padding: 2px 8px;
    border-radius: 4px;
    margin-left: 8px;
  }
  .emp-usecase p {
    font-size: 13px;
    color: #45474e;
    line-height: 1.55;
    margin: 0;
  }

  /* ===== Trial CTA ===== */
  .emp-trial {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    background: linear-gradient(135deg, #0F1F3D 0%, #1e3a5f 100%);
    border-radius: 10px;
    padding: var(--space-7);
    color: white;
  }
  .emp-trial .material-symbols-outlined {
    font-size: 36px;
    color: #93c5fd;
    flex-shrink: 0;
  }
  .emp-trial strong {
    display: block;
    font-family: var(--font-headline, 'Public Sans', sans-serif);
    font-size: 1.15rem;
    font-weight: 800;
    margin-bottom: var(--space-1);
  }
  .emp-trial p {
    font-size: 13px;
    color: rgba(203, 213, 225, 0.85);
    line-height: 1.5;
    margin: 0;
  }
  .emp-trial .btn {
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* ===== Cross-links ===== */
  .emp-links p {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: var(--text-sm);
    color: #45474e;
    flex-wrap: wrap;
  }
  .emp-links .material-symbols-outlined {
    font-size: 18px;
    color: var(--color-secondary, #2563EB);
  }
  .emp-links a {
    color: var(--color-secondary, #2563EB);
    font-weight: 600;
  }

  /* ===== Responsive ===== */
  @media (max-width: 1024px) {
    .emp-roi__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .emp-cards { grid-template-columns: 1fr; }
    .emp-roi__grid { grid-template-columns: 1fr; }
    .emp-trial { flex-direction: column; text-align: center; }
  }
</style>
