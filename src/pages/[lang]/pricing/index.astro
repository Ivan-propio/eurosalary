const c = fb(i18n, lang);

const pageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: c.h1,
    author: { '@type': 'Organization', name: 'EuroSalary.eu' },
    datePublished: '2026-04-04',
    dateModified: '2026-04-04',
    publisher: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: c.faq.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer },
    })),
  },
];
---

<BaseLayout title={c.metaTitle} description={c.metaDesc} datePublished="2026-04-04" dateModified="2026-04-07" schema={pageSchema}>
  <!-- Compact Hero with toggle integrated -->
  <section class="ph">
    <div class="container ph__inner">
      <nav class="ph__bc" aria-label="Breadcrumb">
        <a href={`/${lang}/`}>{c.home}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <span>{c.breadcrumb}</span>
      </nav>
      <h1 class="ph__h1">{c.h1}</h1>
      <p class="ph__desc">{c.introAnswer}</p>

      <!-- Toggle inside hero -->
      <div class="ph__toggle" id="billing-toggle">
        <button class="ph__toggle-btn ph__toggle-btn--active" data-period="monthly">{c.monthlyLabel}</button>
        <button class="ph__toggle-btn" data-period="annual">
          {c.annualLabel}
          <span class="ph__save">{c.annualSave}</span>
        </button>
      </div>
    </div>
  </section>

  <!-- Cards immediately after hero — no gap -->
  <section class="pc-wrap">
    <div class="container">
      <div class="pc-grid">
        <!-- Free -->
        <div class="pc">
          <h3 class="pc__name">{c.free.name}</h3>
          <p class="pc__desc">{c.free.desc}</p>
          <div class="pc__price">
            <span class="pc__amount">{c.free.price}</span>
          </div>
          <a href={`/${lang}/`} class="pc__cta pc__cta--ghost">{c.free.cta}</a>
          <ul class="pc__list">
            {c.free.features.map((f) => (
              <li><span class="pc__chk">&#10003;</span>{f}</li>
            ))}
          </ul>
        </div>

        <!-- Professional -->
        <div class="pc">
          <h3 class="pc__name">{c.pro.name}</h3>
          <p class="pc__desc">{c.pro.desc}</p>
          <div class="pc__price">
            <span class="pc__amount" data-monthly={c.pro.priceM} data-annual={c.pro.priceA}>{c.pro.priceM}</span>
            <span class="pc__period" data-monthly={c.perMonth} data-annual={c.perYear}>{c.perMonth}</span>
          </div>
          <a href="#" class="pc__cta pc__cta--outline" data-plan="pro" data-price-monthly="price_1TJZ3rFVaIUkPsQC12XKbrF3" data-price-annual="price_1TJZ3sFVaIUkPsQCZnLuFcWh">{c.pro.cta}</a>
          <ul class="pc__list">
            {c.pro.features.map((f) => (
              <li><span class="pc__chk">&#10003;</span>{f}</li>
            ))}
          </ul>
        </div>

        <!-- Business (Featured) -->
        <div class="pc pc--pop">
          <div class="pc__badge">{c.biz.badge}</div>
          <h3 class="pc__name">{c.biz.name}</h3>
          <p class="pc__desc">{c.biz.desc}</p>
          <div class="pc__price">
            <span class="pc__amount" data-monthly={c.biz.priceM} data-annual={c.biz.priceA}>{c.biz.priceM}</span>
            <span class="pc__period" data-monthly={c.perMonth} data-annual={c.perYear}>{c.perMonth}</span>
          </div>
          <a href="#" class="pc__cta pc__cta--fill" data-plan="business" data-price-monthly="price_1TJZ3sFVaIUkPsQCP8bnrUHZ" data-price-annual="price_1TJZ3sFVaIUkPsQCU4MsDyoT">{c.biz.cta}</a>
          <ul class="pc__list">
            {c.biz.features.map((f) => (
              <li><span class="pc__chk pc__chk--blue">&#10003;</span>{f}</li>
            ))}
          </ul>
        </div>

        <!-- Enterprise -->
        <div class="pc pc--dark">
          <h3 class="pc__name">{c.enterprise.name}</h3>
          <p class="pc__desc">{c.enterprise.desc}</p>
          <div class="pc__price">
            <span class="pc__amount">{c.custom}</span>
          </div>
          <a href={`/${lang}/enterprise/`} class="pc__cta pc__cta--white">{c.enterprise.cta}</a>
          <ul class="pc__list">
            {c.enterprise.features.map((f) => (
              <li><span class="pc__chk">&#10003;</span>{f}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust + Guarantee in one compact row -->
  <section class="trust-row">
    <div class="container">
      <div class="trust-row__badges">
        {c.trustBadges.map((badge, i) => (
          <div class="trust-row__badge">
            <span class="material-symbols-outlined">
              {i === 0 ? 'business' : i === 1 ? 'verified' : 'shield'}
            </span>
            {badge}
          </div>
        ))}
      </div>
      <div class="trust-row__guarantee">
        <span class="material-symbols-outlined">verified_user</span>
        <div>
          <strong>{c.guaranteeTitle}</strong>
          <p>{c.guaranteeDesc}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ compact -->
  <section class="faq-compact">
    <div class="container container--narrow">
      <FAQSection items={c.faq} />
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== Hero — compact, dark, toggle integrated ===== */
  .ph {
    background: var(--color-primary-container, #0F1F3D);
    color: white;
    padding: 5.5rem 0 2.5rem;
    text-align: center;
  }
  .ph__inner { max-width: 680px; margin: 0 auto; }
  .ph__bc {
    display: flex; align-items: center; justify-content: center;
    gap: 6px; font-size: 12px; color: rgba(203,213,225,0.5);
    margin-bottom: 1.25rem;
  }
  .ph__bc a { color: rgba(203,213,225,0.5); text-decoration: none; }
  .ph__bc a:hover { color: white; }
  .ph__bc .material-symbols-outlined { font-size: 14px; }
  .ph__h1 {
    font-family: var(--font-headline); font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800; letter-spacing: -0.025em; line-height: 1.15;
    margin-bottom: 0.75rem; color: white;
  }
  .ph__desc {
    font-size: 0.95rem; line-height: 1.6; color: rgba(203,213,225,0.8);
    max-width: 560px; margin: 0 auto 1.5rem;
  }
  .ph__toggle {
    display: inline-flex; background: rgba(255,255,255,0.08);
    border-radius: 8px; padding: 3px;
  }
  .ph__toggle-btn {
    padding: 8px 20px; background: transparent; border: none;
    font-size: 13px; font-weight: 600; color: rgba(203,213,225,0.7);
    cursor: pointer; border-radius: 6px; display: flex; align-items: center; gap: 6px;
    transition: all 0.15s;
  }
  .ph__toggle-btn--active {
    background: white; color: var(--color-primary-container);
    box-shadow: 0 1px 4px rgba(0,0,0,0.15);
  }
  .ph__save {
    font-size: 10px; font-weight: 700; background: rgba(22,163,106,0.2);
    color: #4ade80; padding: 2px 6px; border-radius: 8px;
  }
  .ph__toggle-btn--active .ph__save {
    background: #dcfce7; color: #16a34a;
  }

  /* ===== Cards — pulled up, no gap after hero ===== */
  .pc-wrap {
    background: var(--color-surface, #f7f9fb);
    padding: 2rem 0 2.5rem;
    margin-top: 0;
  }
  .pc-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 1rem; align-items: start;
  }
  .pc {
    background: white; border: 1px solid #e2e8f0;
    border-radius: 10px; padding: 1.5rem;
    display: flex; flex-direction: column; position: relative;
  }
  .pc--pop {
    border: 2px solid var(--color-secondary, #0051d5);
    box-shadow: 0 8px 32px rgba(0,81,213,0.12);
    transform: translateY(-8px);
    padding-top: 2rem;
  }
  .pc--dark {
    background: var(--color-primary-container, #0F1F3D); color: white;
    border-color: var(--color-navy-600, #1E3A5F);
  }
  .pc--dark .pc__name, .pc--dark .pc__amount { color: white; }
  .pc--dark .pc__desc { color: rgba(203,213,225,0.7); }
  .pc--dark .pc__list li { color: rgba(203,213,225,0.85); }
  .pc--dark .pc__chk { color: #4ade80; }

  .pc__badge {
    position: absolute; top: -11px; left: 50%; transform: translateX(-50%);
    background: var(--color-secondary, #0051d5); color: white;
    font-size: 10px; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; padding: 3px 14px; border-radius: 10px;
    white-space: nowrap;
  }
  .pc__name {
    font-family: var(--font-headline); font-size: 1.1rem;
    font-weight: 800; color: var(--color-primary-container);
    margin-bottom: 0.25rem;
  }
  .pc__desc {
    font-size: 12px; color: #64748b; line-height: 1.45;
    margin-bottom: 1rem; min-height: 36px;
  }
  .pc__price {
    display: flex; align-items: baseline; gap: 3px;
    margin-bottom: 1rem;
  }
  .pc__amount {
    font-size: 2rem; font-weight: 800;
    color: var(--color-primary-container); letter-spacing: -0.02em;
  }
  .pc__period { font-size: 13px; color: #64748b; }

  /* CTAs */
  .pc__cta {
    display: block; text-align: center; padding: 10px 16px;
    font-weight: 700; font-size: 13px; border-radius: 6px;
    text-decoration: none; transition: all 0.15s; margin-bottom: 1rem;
  }
  .pc__cta--ghost {
    border: 1px solid #cbd5e1; color: #475569; background: transparent;
  }
  .pc__cta--ghost:hover { background: #f1f5f9; color: #0F1F3D; }
  .pc__cta--outline {
    border: 2px solid var(--color-secondary); color: var(--color-secondary);
    background: transparent;
  }
  .pc__cta--outline:hover { background: var(--color-secondary); color: white; }
  .pc__cta--fill {
    background: var(--color-secondary); color: white;
    border: 2px solid var(--color-secondary);
  }
  .pc__cta--fill:hover { background: #003ea8; border-color: #003ea8; }
  .pc__cta--white {
    background: white; color: var(--color-primary-container);
    border: 2px solid rgba(255,255,255,0.3); font-weight: 700;
  }
  .pc__cta--white:hover { background: rgba(255,255,255,0.9); }

  /* Feature lists */
  .pc__list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 8px;
    border-top: 1px solid rgba(0,0,0,0.06); padding-top: 1rem;
  }
  .pc--dark .pc__list { border-top-color: rgba(255,255,255,0.1); }
  .pc__list li {
    display: flex; align-items: flex-start; gap: 6px;
    font-size: 12.5px; color: #475569; line-height: 1.4;
  }
  .pc__chk { flex-shrink: 0; color: #16a34a; font-weight: 700; font-size: 13px; line-height: 1.25; }
  .pc__chk--blue { color: var(--color-secondary); }

  /* ===== Trust row ===== */
  .trust-row { padding: 1.5rem 0 1rem; }
  .trust-row__badges {
    display: flex; justify-content: center; gap: 1.5rem;
    flex-wrap: wrap; margin-bottom: 1.25rem;
  }
  .trust-row__badge {
    display: flex; align-items: center; gap: 6px;
    font-size: 13px; font-weight: 600; color: var(--color-primary-container);
    background: #f8fafc; border: 1px solid #e2e8f0;
    padding: 8px 16px; border-radius: 6px;
  }
  .trust-row__badge .material-symbols-outlined {
    font-size: 18px; color: var(--color-secondary);
  }
  .trust-row__guarantee {
    display: flex; align-items: center; gap: 10px;
    background: #f0fdf4; border: 1px solid #bbf7d0;
    border-radius: 8px; padding: 12px 20px; max-width: 700px; margin: 0 auto;
  }
  .trust-row__guarantee .material-symbols-outlined {
    font-size: 24px; color: #16a34a; flex-shrink: 0;
  }
  .trust-row__guarantee strong { font-size: 13px; color: #15803d; }
  .trust-row__guarantee p { font-size: 12px; color: #45474e; line-height: 1.4; margin: 0; }

  /* ===== FAQ compact ===== */
  .faq-compact { padding: 1.5rem 0 2rem; }
  .faq-compact :global(.section) { padding: 0; }
  .faq-compact :global(.faq-section) { padding: 0; }
  .faq-compact :global(h2) { font-size: 1.4rem; margin-bottom: 1rem; }

  /* ===== Checkout banners ===== */
  :global(.checkout-banner) {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 18px; border-radius: 8px;
    font-size: 14px; font-weight: 600; margin-top: 1.25rem;
    animation: slideDown 0.3s ease;
  }
  :global(.checkout-banner--success) {
    background: rgba(22,163,74,0.15); color: #4ade80; border: 1px solid rgba(74,222,128,0.3);
  }
  :global(.checkout-banner--cancel) {
    background: rgba(234,179,8,0.15); color: #fbbf24; border: 1px solid rgba(251,191,36,0.3);
  }
  :global(.checkout-banner .material-symbols-outlined) { font-size: 20px; }
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ===== Responsive ===== */
  @media (max-width: 1024px) {
    .pc-grid { grid-template-columns: repeat(2, 1fr); }
    .pc--pop { transform: none; }
  }
  @media (max-width: 640px) {
    .pc-grid { grid-template-columns: 1fr; }
    .trust-row__badges { flex-direction: column; align-items: center; }
    .ph { padding: 5rem 0 2rem; }
  }
</style>

<script>
  // --- Billing toggle ---
  let currentPeriod: 'monthly' | 'annual' = 'monthly';
  const toggle = document.getElementById('billing-toggle');
  if (toggle) {
    const buttons = toggle.querySelectorAll('.ph__toggle-btn');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => b.classList.remove('ph__toggle-btn--active'));
        btn.classList.add('ph__toggle-btn--active');
        currentPeriod = btn.getAttribute('data-period') as 'monthly' | 'annual';
        document.querySelectorAll('.pc__amount[data-monthly]').forEach((el) => {
          const a = el as HTMLElement;
          a.textContent = a.dataset[currentPeriod] || a.textContent;
        });
        document.querySelectorAll('.pc__period[data-monthly]').forEach((el) => {
          const p = el as HTMLElement;
          p.textContent = p.dataset[currentPeriod] || p.textContent;
        });
      });
    });
  }

  // --- Stripe Checkout ---
  document.querySelectorAll('[data-plan]').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      const el = btn as HTMLElement;
      const priceKey = currentPeriod === 'monthly' ? 'data-price-monthly' : 'data-price-annual';
      const priceId = el.getAttribute(priceKey);
      if (!priceId) return;

      el.style.pointerEvents = 'none';
      el.style.opacity = '0.6';
      const origText = el.textContent;
      el.textContent = '...';

      try {
        const lang = window.location.pathname.split('/')[1] || 'en';
        const res = await fetch('/api/create-checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ priceId, mode: 'subscription', lang }),
        });
        const data = await res.json();
        if (data.url) {
          window.location.href = data.url;
        } else {
          console.error('Checkout error:', data.error);
          el.textContent = origText;
          el.style.pointerEvents = '';
          el.style.opacity = '';
        }
      } catch (err) {
        console.error('Checkout fetch error:', err);
        el.textContent = origText;
        el.style.pointerEvents = '';
        el.style.opacity = '';
      }
    });
  });

  // --- Handle success/cancel URL params ---
  const params = new URLSearchParams(window.location.search);
  if (params.get('success') === 'true') {
    const pLang = window.location.pathname.split('/')[1] || 'en';
    const banner = document.createElement('div');
    banner.className = 'checkout-banner checkout-banner--success';
    // Check if user has an auth session
    fetch('/api/auth/session', { credentials: 'include' })
      .then(r => r.json())
      .then(data => {
        if (data.user) {
          banner.innerHTML = '<span class="material-symbols-outlined">check_circle</span> Payment successful! Your subscription is now active. <a href="/' + pLang + '/dashboard/" style="color:white;text-decoration:underline;font-weight:700;margin-left:8px;">Go to Dashboard &rarr;</a>';
        } else {
          banner.innerHTML = '<span class="material-symbols-outlined">check_circle</span> Payment successful! <a href="/' + pLang + '/signup/" style="color:white;text-decoration:underline;font-weight:700;margin-left:8px;">Create your account</a> to access your Pro features.';
        }
      })
      .catch(() => {
        banner.innerHTML = '<span class="material-symbols-outlined">check_circle</span> Payment successful! <a href="/' + pLang + '/signup/" style="color:white;text-decoration:underline;font-weight:700;margin-left:8px;">Create your account</a> to access your Pro features.';
      });
    document.querySelector('.ph__inner')?.appendChild(banner);
  }
  if (params.get('canceled') === 'true') {
    const banner = document.createElement('div');
    banner.className = 'checkout-banner checkout-banner--cancel';
    banner.innerHTML = '<span class="material-symbols-outlined">info</span> Checkout canceled. No charges were made.';
    document.querySelector('.ph__inner')?.appendChild(banner);
  }
  if (params.get('manage') === 'true') {
    // Redirect to customer portal (needs customerId from session/cookie)
    const customerId = localStorage.getItem('stripe_customer_id');
    if (customerId) {
      fetch('/api/customer-portal', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ customerId, lang: window.location.pathname.split('/')[1] || 'en' }),
      }).then(r => r.json()).then(data => {
        if (data.url) window.location.href = data.url;
      });
    }
  }
</script>
