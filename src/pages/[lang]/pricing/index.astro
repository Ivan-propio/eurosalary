const c = fb(i18n, lang);

const pageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: c.h1,
    author: { '@type': 'Organization', name: 'EuroSalary.eu' },
    datePublished: '2026-04-04',
    dateModified: '2026-04-04',
    publisher: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: c.faq.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer },
    })),
  },
];
---

<BaseLayout title={c.metaTitle} description={c.metaDesc} datePublished="2026-04-04" dateModified="2026-04-04" schema={pageSchema}>
  <!-- Hero -->
  <section class="pricing-hero">
    <div class="pricing-hero__dots"></div>
    <div class="container pricing-hero__inner">
      <nav class="pricing-hero__breadcrumbs" aria-label="Breadcrumb">
        <a href={`/${lang}/`}>{c.home}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <span>{c.breadcrumb}</span>
      </nav>
      <div class="pricing-hero__badge">
        <span class="material-symbols-outlined">payments</span>
        {c.breadcrumb}
      </div>
      <h1>{c.h1}</h1>
      <p class="pricing-hero__answer">{c.introAnswer}</p>
    </div>
  </section>

  <article class="container pricing-body">
    <TLDRBox items={c.tldr} />

    <!-- Billing Toggle -->
    <section class="pricing-section">
      <div class="pricing-toggle" id="billing-toggle">
        <button class="pricing-toggle__btn pricing-toggle__btn--active" data-period="monthly">{c.monthlyLabel}</button>
        <button class="pricing-toggle__btn" data-period="annual">
          {c.annualLabel}
          <span class="pricing-toggle__save">{c.annualSave}</span>
        </button>
      </div>

      <!-- Cards -->
