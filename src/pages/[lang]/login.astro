const c = fb(i18n, lang);
---

<BaseLayout title={c.metaTitle} description={c.metaDesc}>
  <section class="auth">
    <div class="auth__card">
      <div class="auth__header">
        <a href={`/${lang}/`} class="auth__logo" aria-label="EuroSalary.eu — Home">
          Euro<span>Salary</span><small>.eu</small>
        </a>
        <h1 class="auth__title">{c.h1}</h1>
        <p class="auth__subtitle">{c.subtitle}</p>
      </div>

      <form class="auth__form" id="login-form" novalidate>
        <div class="auth__field">
          <label for="login-email">{c.emailLabel}</label>
          <div class="auth__input-wrap">
            <span class="material-symbols-outlined">mail</span>
            <input type="email" id="login-email" name="email" placeholder={c.emailPlaceholder} required autocomplete="email" />
          </div>
        </div>
        <div class="auth__field">
          <div class="auth__label-row">
            <label for="login-password">{c.passwordLabel}</label>
            <a href={`/${lang}/auth/forgot-password/`} class="auth__forgot">{c.forgotPassword}</a>
          </div>
          <div class="auth__input-wrap">
            <span class="material-symbols-outlined">lock</span>
            <input type="password" id="login-password" name="password" placeholder={c.passwordPlaceholder} required autocomplete="current-password" />
            <button type="button" class="auth__toggle-pw" aria-label="Toggle password visibility">
              <span class="material-symbols-outlined">visibility</span>
            </button>
          </div>
        </div>

        <div class="auth__error" id="login-error" role="alert" aria-live="polite"></div>

        <button type="submit" class="auth__submit" id="login-btn">
          <span class="auth__submit-text">{c.loginBtn}</span>
          <span class="auth__spinner"></span>
        </button>
      </form>

      <p class="auth__alt">
        {c.noAccount} <a href={`/${lang}/signup/`}>{c.signupLink}</a>
      </p>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ lang, errorInvalid: c.errorInvalid, errorNetwork: c.errorNetwork, errorGeneric: c.errorGeneric }}>
  const form = document.getElementById('login-form');
  const emailInput = document.getElementById('login-email');
  const passwordInput = document.getElementById('login-password');
  const errorEl = document.getElementById('login-error');
  const submitBtn = document.getElementById('login-btn');

  // Toggle password visibility
  document.querySelectorAll('.auth__toggle-pw').forEach((btn) => {
    btn.addEventListener('click', () => {
      const input = btn.parentElement.querySelector('input');
      const icon = btn.querySelector('.material-symbols-outlined');
      if (input.type === 'password') {
        input.type = 'text';
        icon.textContent = 'visibility_off';
      } else {
        input.type = 'password';
        icon.textContent = 'visibility';
      }
    });
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.textContent = '';
    errorEl.classList.remove('auth__error--show');
    submitBtn.classList.add('auth__submit--loading');
    submitBtn.disabled = true;

    const email = emailInput.value.trim();
    const password = passwordInput.value;

    try {
      const res = await fetch('/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ email, password }),
      });

      if (res.ok) {
        window.location.href = `/${lang}/dashboard/`;
      } else {
        const data = await res.json().catch(() => ({}));
        errorEl.textContent = data.error || errorInvalid;
        errorEl.classList.add('auth__error--show');
      }
    } catch (err) {
      errorEl.textContent = err.message.includes('fetch') ? errorNetwork : errorGeneric;
      errorEl.classList.add('auth__error--show');
    } finally {
      submitBtn.classList.remove('auth__submit--loading');
      submitBtn.disabled = false;
    }
  });
</script>

