    ro: 'Sănătate', cs: 'Zdravotnictví', sv: 'Sjukvård', da: 'Sundhed',
    fi: 'Terveydenhuolto', el: 'Υγεία', hu: 'Egészségügy', sk: 'Zdravotníctvo',
    bg: 'Здравеопазване', hr: 'Zdravstvo', sl: 'Zdravstvo', lt: 'Sveikatos priežiūra',
    lv: 'Veselības aprūpe', et: 'Tervishoid', mt: 'Saħħa', ga: 'Cúram Sláinte',
