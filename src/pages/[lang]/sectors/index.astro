    it: 'Risorse umane', pt: 'Recursos humanos', nl: 'Personeelszaken', pl: 'Zasoby ludzkie',
    ro: 'Resurse umane', cs: 'Lidské zdroje', sv: 'Personalavdelning', da: 'Personaleafdelingen',
    fi: 'Henkilöstöhallinto', el: 'Ανθρώπινο δυναμικό', hu: 'Emberi erőforrások', sk: 'Ľudské zdroje',
    bg: 'Човешки ресурси', hr: 'Ljudski resursi', sl: 'Človeški viri', lt: 'Žmogiškieji ištekliai',
    lv: 'Cilvēkresursi', et: 'Personalijuhtimine', mt: 'Riżorsi Umani', ga: 'Acmhainní Daonna',
