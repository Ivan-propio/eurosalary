---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TLDRBox from '../../../components/TLDRBox.astro';
import { jobNames, uiLabels } from '../../../i18n/translations';
import { languages } from '../../../i18n/ui';
import { fb, useTranslations } from '../../../i18n/utils';

// --------------- Sectors data ---------------
const sectors = [
  { id: 'technology', jobs: ['software-engineer', 'data-scientist', 'devops-engineer', 'ux-designer', 'data-analyst'], avgRange: [45000, 85000] },
  { id: 'finance', jobs: ['financial-analyst', 'accountant'], avgRange: [40000, 75000] },
  { id: 'healthcare', jobs: ['doctor', 'nurse', 'pharmacist'], avgRange: [30000, 90000] },
  { id: 'legal', jobs: ['lawyer'], avgRange: [45000, 80000] },
  { id: 'education', jobs: ['teacher', 'university-professor'], avgRange: [28000, 60000] },
  { id: 'engineering', jobs: ['mechanical-engineer', 'civil-engineer'], avgRange: [35000, 65000] },
  { id: 'management', jobs: ['product-manager', 'project-manager', 'operations-manager'], avgRange: [40000, 75000] },
  { id: 'marketing', jobs: ['marketing-manager'], avgRange: [35000, 65000] },
  { id: 'sales', jobs: ['sales-manager'], avgRange: [35000, 70000] },
  { id: 'hr', jobs: ['hr-manager'], avgRange: [35000, 60000] },
];

// --------------- Sector names ---------------
