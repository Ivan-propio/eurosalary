  }

  /* ============ Sources ============ */
  .compare-sources__intro {
    color: #45474e;
    margin-bottom: var(--space-6);
  }
  .compare-sources__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }
  .source-card {
    background: white;
    border: 1px solid #e6e8ea;
    border-left: 4px solid var(--color-secondary, #0051d5);
    padding: var(--space-6);
    border-radius: 4px;
  }
  .source-card__icon {
    font-size: 20px;
    color: var(--color-secondary, #0051d5);
    display: block;
    margin-bottom: var(--space-2);
  }
  .source-card strong {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-primary-container, #0F1F3D);
    margin-bottom: 4px;
  }
  .source-card p {
    font-size: 12px;
    color: #75777e;
    line-height: 1.5;
  }
  .compare-sources__updated {
    font-size: 12px;
    color: #75777e;
    margin-top: var(--space-4);
  }

  /* ============ Responsive ============ */
  @media (max-width: 768px) {
    .compare-hero__grid {
      grid-template-columns: 1fr;
    }
    .compare-hero__versus {
      justify-content: center;
    }
    .compare-hero__country-card {
      min-width: 120px;
      padding: var(--space-4);
    }
    .salary-diff__row {
      grid-template-columns: 100px 1fr 80px;
      gap: var(--space-2);
    }
    .verdicts-grid {
      grid-template-columns: 1fr;
    }
    .compare-links__grid {
      grid-template-columns: 1fr;
    }
    .compare-related__grid {
      grid-template-columns: 1fr;
    }
    .compare-sources__grid {
      grid-template-columns: 1fr;
    }
    .compare-table {
      font-size: 12px;
    }
  }
</style>
