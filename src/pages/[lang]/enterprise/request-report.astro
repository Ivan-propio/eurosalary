export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang }, props: { lang } }));
}

const { lang } = Astro.params;
const t = fb(i18n, lang) || i18n.en;

const pageSchema = [
  {
    '@context': 'https://schema.org', '@type': 'Article',
    headline: t.h1,
    author: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
    publisher: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
    datePublished: '2026-04-05', dateModified: '2026-04-05',
    description: t.metaDesc,
    mainEntityOfPage: `https://eurosalary.eu/${lang}/enterprise/request-report/`,
  },
  {
    '@context': 'https://schema.org', '@type': 'FAQPage',
    mainEntity: t.faq.map((item: any) => ({ '@type': 'Question', name: item.question, acceptedAnswer: { '@type': 'Answer', text: item.answer } })),
  },
];
---

<BaseLayout title={t.metaTitle} description={t.metaDesc} datePublished="2026-04-05" dateModified="2026-04-05" schema={pageSchema}>
  <section class="page-hero">
    <div class="page-hero__dots"></div>
    <div class="container page-hero__inner">
      <nav class="page-hero__breadcrumbs" aria-label="Breadcrumb">
        <a href={`/${lang}/`}>{t.home}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <a href={`/${lang}/enterprise/`}>{t.enterprise}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <span class="page-hero__breadcrumbs-current">{t.breadcrumb}</span>
      </nav>
      <h1 class="page-hero__title">{t.h1}</h1>
      <p class="page-hero__desc">{t.introAnswer}</p>
      <p class="hero-subtitle">{t.heroSubtitle}</p>
    </div>
  </section>

  <article class="container page-body">
    <TLDRBox items={t.tldr} />

    <!-- Sample Report Preview -->
    <section class="section">
      <h2 class="section-title">{t.sampleTitle}</h2>
      <p class="section-desc">{t.sampleDesc}</p>
      <div class="features-grid">
        {t.sampleFeatures.map((f) => (
          <div class="feature-card">
            <div class="feature-card__icon"><span class="material-symbols-outlined">{f.icon}</span></div>
            <h3 class="feature-card__title">{f.title}</h3>
            <p class="feature-card__desc">{f.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Pricing -->
    <section class="section">
      <h2 class="section-title">{t.pricingTitle}</h2>
      <p class="section-desc">{t.pricingDesc}</p>
      <div class="pricing-grid">
        {t.pricingTiers.map((tier, i) => (
          <div class:list={['pricing-card', { 'pricing-card--featured': i === 1 }]}>
            <h3 class="pricing-card__name">{tier.name}</h3>
            <p class="pricing-card__price">&euro;{tier.price}</p>
            <ul class="pricing-card__features">
              {tier.features.map((f) => (<li><span class="material-symbols-outlined" style="font-size:16px;color:#2563EB;vertical-align:middle;margin-right:6px;">check</span>{f}</li>))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Form -->
    <section class="section contact-section" id="contact">
      <h2 class="section-title">{t.formTitle}</h2>
      <p class="section-desc">{t.formDesc}</p>
      <form class="contact-form" id="report-form">
        <input type="hidden" name="type" value="enterprise" />
        <input type="hidden" name="source" value="request-report" />
        <div class="contact-form__row">
          <div class="contact-form__field">
            <label for="rr-name">{t.formLabels.name}</label>
            <input type="text" id="rr-name" name="name" required />
          </div>
          <div class="contact-form__field">
            <label for="rr-email">{t.formLabels.email}</label>
            <input type="email" id="rr-email" name="email" required />
          </div>
        </div>
        <div class="contact-form__field">
          <label for="rr-company">{t.formLabels.company}</label>
          <input type="text" id="rr-company" name="company" required />
        </div>
        <div class="contact-form__row">
          <div class="contact-form__field">
            <label for="rr-countries">{t.formLabels.countries}</label>
            <input type="text" id="rr-countries" name="countries" placeholder="e.g. Germany, France, Spain" />
          </div>
          <div class="contact-form__field">
            <label for="rr-type">{t.formLabels.reportType}</label>
            <select id="rr-type" name="report_type" required>
              <option value="">—</option>
              {t.reportTypeOptions.map((opt) => (<option value={opt}>{opt}</option>))}
            </select>
          </div>
        </div>
        <div class="contact-form__field">
          <label for="rr-jobs">{t.formLabels.jobCategories}</label>
          <input type="text" id="rr-jobs" name="job_categories" placeholder="e.g. Software Engineering, Finance, Marketing" />
        </div>
        <button type="submit" class="contact-form__submit">{t.formLabels.submit}</button>
        <p class="form-success" id="report-success" style="display:none;">{t.successMsg}</p>
      </form>
    </section>

    <FAQSection items={t.faq} />
  </article>
</BaseLayout>

<script>
  const form = document.getElementById('report-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form));
      try {
        await fetch('/api/contact', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
        form.style.display = 'none';
        document.getElementById('report-success')!.style.display = 'block';
      } catch (err) { console.error(err); }
    });
  }
</script>

<style>
  .page-body { padding-top: 2.5rem; padding-bottom: 4rem; }
  .hero-subtitle { margin-top: 1.5rem; font-size: var(--text-sm); color: rgba(255,255,255,0.7); max-width: 700px; line-height: var(--leading-relaxed); }
  .section-title { font-family: 'Public Sans', sans-serif; font-size: 1.75rem; font-weight: 800; letter-spacing: -0.02em; color: #0F1F3D; margin-bottom: 0.5rem; }
  .section-desc { color: #4B5563; margin-bottom: 2rem; max-width: 600px; }
  .features-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-top: 1rem; }
  .feature-card { background: #FFFFFF; border: 1px solid #E5E7EB; border-radius: 12px; padding: 2rem; transition: box-shadow 0.2s ease, border-color 0.2s ease; }
  .feature-card:hover { border-color: #2563EB; box-shadow: 0 4px 24px rgba(37, 99, 235, 0.08); }
  .feature-card__icon { width: 48px; height: 48px; border-radius: 10px; background: rgba(37, 99, 235, 0.08); display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; }
  .feature-card__icon .material-symbols-outlined { font-size: 24px; color: #2563EB; }
  .feature-card__title { font-family: 'Public Sans', sans-serif; font-size: 1.25rem; font-weight: 700; color: #0F1F3D; margin-bottom: 0.5rem; }
  .feature-card__desc { font-size: var(--text-sm); color: #4B5563; line-height: var(--leading-relaxed); }

