    socialProofItems: [{ name: 'Sarah Lindqvist', role: 'VP People, NordTech Group', quote: 'Laghdaigh EuroSalary ar thimthriall tagarmarcaiochta o 6 seachtaine go 3 la.' }, { name: 'Marco Benedetti', role: 'Managing Partner, AlpineHR', quote: 'Usaidimid tuairisci EuroSalary mar bhainleibheal do ar gcliaint chomhairleacha.' }, { name: 'Dr. Katrin Meier', role: 'CHRO, MedEuropa Healthcare', quote: 'Bhi an comhthathu API lenar n-asc SAP SuccessFactors gan uaim.' }],
    certTitle: 'Comhlionadh agus deimhniuchain',
    certItems: ['Bonneagar deimhnithe SOC 2 Cineail II', 'Proiseail comhlionach le GDPR le conaitheacht sonrai san AE (Frankfurt)', 'Measunachtai ullmhaiochta do Threoir Tredireach Paa', 'Cleachtais slandala ailinithe le ISO 27001', 'Comhaontuaithe proiseala sonrai curtha ar fail mar chaighdean'],
    formTitle: 'Iarr do thaispeaintas fiontraighe',
    formDesc: 'Lion an fhoirm agus rachaidh ar bhfoireann fiontraighe i dteagmhail leat laistigh de 24 uair.',
    formLabels: { name: 'Ainm iomlain', email: 'Riomhphost oibre', company: 'Ainm na cuideachta', companySize: 'Meid na cuideachta', countries: 'Tiorda spoise', message: 'Innis duinn faoi do riachtanais', submit: 'Iarr taispeaintas fiontraighe' },
    companySizeOptions: ['50-249 fostaithe', '250-999 fostaithe', '1,000-4,999 fostaithe', '5,000-9,999 fostaithe', '10,000+ fostaithe'],
    successMsg: 'Go raibh maith agat! Rachaidh ar bhfoireann fiontraighe i dteagmhail leat laistigh de 24 uair.',
    faq: [{ question: 'Ce fhad a mhaireann an taispeaintas fiontraighe?', answer: 'Maireann taispeaintas fiontraighe caighdeanach 30 noimeoid agus ta se oiriuunte do do thionscal agus do mheid.' }, { question: 'An bhfuil an taispeaintas saor in aisce?', answer: 'Ta an taispeaintas saor in aisce go huile agus gan aon oibleagaid.' }, { question: 'Cad ba cheart dom a ullmhu?', answer: 'Ni ga aon ullmhuchain.' }, { question: 'An feidir le nios mo baill foirne a bheith pairteach?', answer: 'Cinnte. Molaimid do cheannasaithe AD agus anailisithe cuitimh a bheith pairteach.' }, { question: 'Ce chomh tapa is feidir linn tosu tar eis an taispeaintais?', answer: 'Cuirtear onboarding fiontraighe i gcrich laistigh de 48 uair tar eis an conradh a shiniU.' }],
  },
};

// --------------- getStaticPaths ---------------
export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
    props: { lang },
  }));
}

// --------------- Page data ---------------
const { lang } = Astro.params;
const t = fb(i18n, lang) || i18n.en;

const pageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: t.h1,
    author: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
    publisher: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
    datePublished: '2026-04-05',
    dateModified: '2026-04-05',
    description: t.metaDesc,
    mainEntityOfPage: `https://eurosalary.eu/${lang}/enterprise/demo/`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: t.faq.map((item: any) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: { '@type': 'Answer', text: item.answer },
    })),
  },
];
---

<BaseLayout
  title={t.metaTitle}
  description={t.metaDesc}
  datePublished="2026-04-05"
  dateModified="2026-04-05"
  schema={pageSchema}
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="page-hero__dots"></div>
    <div class="container page-hero__inner">
      <nav class="page-hero__breadcrumbs" aria-label="Breadcrumb">
        <a href={`/${lang}/`}>{t.home}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <a href={`/${lang}/enterprise/`}>{t.enterprise}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <span class="page-hero__breadcrumbs-current">{t.breadcrumb}</span>
      </nav>
      <h1 class="page-hero__title">{t.h1}</h1>
      <p class="page-hero__desc">{t.introAnswer}</p>
      <p class="hero-subtitle">{t.heroSubtitle}</p>
    </div>
  </section>

  <article class="container page-body">
    <TLDRBox items={t.tldr} />

    <!-- Trust Signals -->
    <section class="section">
      <h2 class="section-title">{t.trustTitle}</h2>
      <div class="trust-grid">
        {t.trustCards.map((card) => (
          <div class="trust-card">
            <span class="material-symbols-outlined trust-card__icon">{card.icon}</span>
            <p class="trust-card__value">{card.value}</p>
            <p class="trust-card__label">{card.label}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Social Proof -->
    <section class="section">
      <h2 class="section-title">{t.socialProofTitle}</h2>
      <div class="testimonials-grid">
        {t.socialProofItems.map((item) => (
          <div class="testimonial-card">
            <div class="testimonial-card__quote">
              <span class="material-symbols-outlined" style="color:#2563EB;font-size:24px;">format_quote</span>
              <p>{item.quote}</p>
            </div>
            <div class="testimonial-card__author">
              <p class="testimonial-card__name">{item.name}</p>
              <p class="testimonial-card__role">{item.role}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Certifications -->
    <section class="section">
      <h2 class="section-title">{t.certTitle}</h2>
      <div class="cert-grid">
        {t.certItems.map((item) => (
          <div class="cert-item">
            <span class="material-symbols-outlined cert-item__icon">check_circle</span>
            <p>{item}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Contact Form -->
    <section class="section contact-section" id="contact">
      <h2 class="section-title">{t.formTitle}</h2>
      <p class="section-desc">{t.formDesc}</p>
      <form class="contact-form" id="demo-form">
        <input type="hidden" name="type" value="enterprise" />
        <input type="hidden" name="source" value="enterprise-demo" />
        <div class="contact-form__row">
          <div class="contact-form__field">
            <label for="demo-name">{t.formLabels.name}</label>
            <input type="text" id="demo-name" name="name" required />
          </div>
          <div class="contact-form__field">
            <label for="demo-email">{t.formLabels.email}</label>
            <input type="email" id="demo-email" name="email" required />
          </div>
        </div>
        <div class="contact-form__row">
          <div class="contact-form__field">
            <label for="demo-company">{t.formLabels.company}</label>
            <input type="text" id="demo-company" name="company" required />
          </div>
          <div class="contact-form__field">
            <label for="demo-size">{t.formLabels.companySize}</label>
            <select id="demo-size" name="company_size" required>
              <option value="">—</option>
              {t.companySizeOptions.map((opt) => (
                <option value={opt}>{opt}</option>
              ))}
            </select>
          </div>
        </div>
        <div class="contact-form__field">
          <label for="demo-countries">{t.formLabels.countries}</label>
          <input type="text" id="demo-countries" name="countries_of_interest" placeholder="e.g. Germany, France, Spain" />
        </div>
        <div class="contact-form__field">
          <label for="demo-message">{t.formLabels.message}</label>
          <textarea id="demo-message" name="message" rows="4"></textarea>
        </div>
        <button type="submit" class="contact-form__submit">{t.formLabels.submit}</button>
        <p class="form-success" id="demo-success" style="display:none;">{t.successMsg}</p>
      </form>
    </section>

    <FAQSection items={t.faq} />
  </article>
</BaseLayout>

<script>
  const form = document.getElementById('demo-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form));
      try {
        await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        form.style.display = 'none';
        document.getElementById('demo-success')!.style.display = 'block';
      } catch (err) {
        console.error(err);
      }
    });
  }
</script>

<style>
  .page-body { padding-top: 2.5rem; padding-bottom: 4rem; }
  .hero-subtitle { margin-top: 1.5rem; font-size: var(--text-sm); color: rgba(255,255,255,0.7); max-width: 700px; line-height: var(--leading-relaxed); }
  .section-title { font-family: 'Public Sans', sans-serif; font-size: 1.75rem; font-weight: 800; letter-spacing: -0.02em; color: #0F1F3D; margin-bottom: 0.5rem; }
  .section-desc { color: #4B5563; margin-bottom: 2rem; max-width: 600px; }

  /* Trust grid */
  .trust-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 1.5rem; }
  .trust-card { background: linear-gradient(135deg, #0F1F3D, #1E3A5F); border-radius: 12px; padding: 2rem; text-align: center; }
  .trust-card__icon { font-size: 32px; color: #2563EB; display: block; margin-bottom: 0.5rem; }
  .trust-card__value { font-family: 'Public Sans', sans-serif; font-size: 2.25rem; font-weight: 800; color: #FFFFFF; margin-bottom: 0.25rem; }
  .trust-card__label { font-size: var(--text-sm); color: rgba(255,255,255,0.7); }

  /* Testimonials */
  .testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 1.5rem; }
  .testimonial-card { background: #F9FAFB; border: 1px solid #E5E7EB; border-radius: 12px; padding: 2rem; display: flex; flex-direction: column; justify-content: space-between; }
  .testimonial-card__quote p { font-size: var(--text-sm); color: #374151; line-height: var(--leading-relaxed); margin-top: 0.5rem; font-style: italic; }
  .testimonial-card__author { margin-top: 1.5rem; border-top: 1px solid #E5E7EB; padding-top: 1rem; }
  .testimonial-card__name { font-weight: 700; color: #0F1F3D; font-size: var(--text-sm); }
  .testimonial-card__role { font-size: 12px; color: #6B7280; }

  /* Certifications */
  .cert-grid { display: flex; flex-direction: column; gap: 1rem; margin-top: 1.5rem; }
  .cert-item { display: flex; align-items: center; gap: 0.75rem; padding: 1rem 1.5rem; background: #F9FAFB; border: 1px solid #E5E7EB; border-radius: 8px; }
  .cert-item__icon { color: #16A34A; font-size: 20px; flex-shrink: 0; }
  .cert-item p { font-size: var(--text-sm); color: #374151; }

  /* Contact form */
  .contact-section { margin-top: 3rem; }
  .contact-form { max-width: 640px; display: flex; flex-direction: column; gap: 1.25rem; }
  .contact-form__row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .contact-form__field { display: flex; flex-direction: column; gap: 0.375rem; }
  .contact-form__field label { font-size: var(--text-sm); font-weight: 600; color: #0F1F3D; }
  .contact-form__field input,
  .contact-form__field textarea,
  .contact-form__field select { padding: 0.75rem 1rem; border: 1px solid #D1D5DB; border-radius: 8px; font-size: var(--text-sm); color: #111827; background: #FFFFFF; transition: border-color 0.2s ease; }
  .contact-form__field input:focus,
  .contact-form__field textarea:focus,
  .contact-form__field select:focus { outline: none; border-color: #2563EB; box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1); }
  .contact-form__submit { align-self: flex-start; padding: 0.875rem 2rem; background: #2563EB; color: #FFFFFF; font-weight: 700; font-size: var(--text-sm); border: none; border-radius: 8px; cursor: pointer; transition: background 0.2s ease; }
  .contact-form__submit:hover { background: #1D4ED8; }
  .form-success { color: #16A34A; font-weight: 600; margin-top: 1rem; }

  @media (max-width: 768px) {
    .trust-grid { grid-template-columns: repeat(2, 1fr); }
    .testimonials-grid { grid-template-columns: 1fr; }
    .contact-form__row { grid-template-columns: 1fr; }
  }
</style>
