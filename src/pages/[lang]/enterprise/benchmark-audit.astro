export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang }, props: { lang } }));
}

const { lang } = Astro.params;
const t = fb(i18n, lang) || i18n.en;

const pageSchema = [
  { '@context': 'https://schema.org', '@type': 'Article', headline: t.h1, author: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' }, publisher: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' }, datePublished: '2026-04-05', dateModified: '2026-04-05', description: t.metaDesc, mainEntityOfPage: `https://eurosalary.eu/${lang}/enterprise/benchmark-audit/` },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: t.faq.map((item: any) => ({ '@type': 'Question', name: item.question, acceptedAnswer: { '@type': 'Answer', text: item.answer } })) },
];
---

<BaseLayout title={t.metaTitle} description={t.metaDesc} datePublished="2026-04-05" dateModified="2026-04-05" schema={pageSchema}>
  <section class="page-hero">
    <div class="page-hero__dots"></div>
    <div class="container page-hero__inner">
      <nav class="page-hero__breadcrumbs" aria-label="Breadcrumb">
        <a href={`/${lang}/`}>{t.home}</a><span class="material-symbols-outlined">chevron_right</span>
        <a href={`/${lang}/enterprise/`}>{t.enterprise}</a><span class="material-symbols-outlined">chevron_right</span>
        <span class="page-hero__breadcrumbs-current">{t.breadcrumb}</span>
      </nav>
      <h1 class="page-hero__title">{t.h1}</h1>
      <p class="page-hero__desc">{t.introAnswer}</p>
      <p class="hero-subtitle">{t.heroSubtitle}</p>
    </div>
  </section>

  <article class="container page-body">
    <TLDRBox items={t.tldr} />

    <!-- What audit includes -->
    <section class="section">
      <h2 class="section-title">{t.auditTitle}</h2>
      <p class="section-desc">{t.auditDesc}</p>
      <div class="features-grid">
        {t.auditIncludes.map((item) => (
          <div class="feature-card">
            <div class="feature-card__icon"><span class="material-symbols-outlined">{item.icon}</span></div>
            <h3 class="feature-card__title">{item.title}</h3>
            <p class="feature-card__desc">{item.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Process Timeline -->
    <section class="section">
      <h2 class="section-title">{t.processTitle}</h2>
      <div class="process-timeline">
        {t.processSteps.map((step) => (
          <div class="process-step">
            <div class="process-step__number">{step.step}</div>
            <div class="process-step__content">
              <h3 class="process-step__title">{step.title}</h3>
              <p class="process-step__desc">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Form -->
    <section class="section contact-section" id="contact">
      <h2 class="section-title">{t.formTitle}</h2>
      <p class="section-desc">{t.formDesc}</p>
      <form class="contact-form" id="audit-form">
        <input type="hidden" name="type" value="employer" />
        <input type="hidden" name="source" value="benchmark-audit" />
        <div class="contact-form__row">
          <div class="contact-form__field"><label for="ba-name">{t.formLabels.name}</label><input type="text" id="ba-name" name="name" required /></div>
          <div class="contact-form__field"><label for="ba-email">{t.formLabels.email}</label><input type="email" id="ba-email" name="email" required /></div>
        </div>
        <div class="contact-form__row">
          <div class="contact-form__field"><label for="ba-company">{t.formLabels.company}</label><input type="text" id="ba-company" name="company" required /></div>
          <div class="contact-form__field"><label for="ba-employees">{t.formLabels.employees}</label>
            <select id="ba-employees" name="number_of_employees" required><option value="">—</option>{t.employeeOptions.map((opt) => (<option value={opt}>{opt}</option>))}</select>
          </div>
        </div>
        <div class="contact-form__field"><label for="ba-source">{t.formLabels.currentSource}</label><input type="text" id="ba-source" name="current_benchmark_source" placeholder="e.g. Mercer, Willis Towers Watson, Internal" /></div>
        <div class="contact-form__field"><label for="ba-countries">{t.formLabels.countries}</label><input type="text" id="ba-countries" name="countries" placeholder="e.g. Germany, France, Spain" /></div>
        <button type="submit" class="contact-form__submit">{t.formLabels.submit}</button>
        <p class="form-success" id="audit-success" style="display:none;">{t.successMsg}</p>
      </form>
    </section>

    <FAQSection items={t.faq} />
  </article>
</BaseLayout>

<script>
  const form = document.getElementById('audit-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form));
      try {
        await fetch('/api/contact', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
        form.style.display = 'none';
        document.getElementById('audit-success')!.style.display = 'block';
      } catch (err) { console.error(err); }
    });
  }
</script>

<style>
  .page-body { padding-top: 2.5rem; padding-bottom: 4rem; }
  .hero-subtitle { margin-top: 1.5rem; font-size: var(--text-sm); color: rgba(255,255,255,0.7); max-width: 700px; line-height: var(--leading-relaxed); }
  .section-title { font-family: 'Public Sans', sans-serif; font-size: 1.75rem; font-weight: 800; letter-spacing: -0.02em; color: #0F1F3D; margin-bottom: 0.5rem; }
  .section-desc { color: #4B5563; margin-bottom: 2rem; max-width: 600px; }
  .features-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-top: 1rem; }
  .feature-card { background: #FFFFFF; border: 1px solid #E5E7EB; border-radius: 12px; padding: 2rem; transition: box-shadow 0.2s ease, border-color 0.2s ease; }
  .feature-card:hover { border-color: #2563EB; box-shadow: 0 4px 24px rgba(37, 99, 235, 0.08); }
  .feature-card__icon { width: 48px; height: 48px; border-radius: 10px; background: rgba(37, 99, 235, 0.08); display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; }
  .feature-card__icon .material-symbols-outlined { font-size: 24px; color: #2563EB; }
  .feature-card__title { font-family: 'Public Sans', sans-serif; font-size: 1.25rem; font-weight: 700; color: #0F1F3D; margin-bottom: 0.5rem; }
  .feature-card__desc { font-size: var(--text-sm); color: #4B5563; line-height: var(--leading-relaxed); }

  /* Process timeline */
  .process-timeline { display: flex; flex-direction: column; gap: 0; margin-top: 1.5rem; }
  .process-step { display: flex; gap: 1.5rem; padding: 1.5rem 0; border-bottom: 1px solid #E5E7EB; }
  .process-step:last-child { border-bottom: none; }
  .process-step__number { font-family: 'Public Sans', sans-serif; font-size: 2rem; font-weight: 800; color: #2563EB; min-width: 56px; }
  .process-step__title { font-family: 'Public Sans', sans-serif; font-size: 1.125rem; font-weight: 700; color: #0F1F3D; margin-bottom: 0.25rem; }
  .process-step__desc { font-size: var(--text-sm); color: #4B5563; line-height: var(--leading-relaxed); }

  /* Contact form */
  .contact-section { margin-top: 3rem; }
  .contact-form { max-width: 640px; display: flex; flex-direction: column; gap: 1.25rem; }
  .contact-form__row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .contact-form__field { display: flex; flex-direction: column; gap: 0.375rem; }
  .contact-form__field label { font-size: var(--text-sm); font-weight: 600; color: #0F1F3D; }
  .contact-form__field input, .contact-form__field select { padding: 0.75rem 1rem; border: 1px solid #D1D5DB; border-radius: 8px; font-size: var(--text-sm); color: #111827; background: #FFFFFF; transition: border-color 0.2s ease; }
  .contact-form__field input:focus, .contact-form__field select:focus { outline: none; border-color: #2563EB; box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1); }
  .contact-form__submit { align-self: flex-start; padding: 0.875rem 2rem; background: #2563EB; color: #FFFFFF; font-weight: 700; font-size: var(--text-sm); border: none; border-radius: 8px; cursor: pointer; transition: background 0.2s ease; }
  .contact-form__submit:hover { background: #1D4ED8; }
  .form-success { color: #16A34A; font-weight: 600; margin-top: 1rem; }

  @media (max-width: 768px) {
    .features-grid { grid-template-columns: 1fr; }
    .contact-form__row { grid-template-columns: 1fr; }
  }
</style>
