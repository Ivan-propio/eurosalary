  metaTitle: string;
  metaDesc: string;
  home: string;
  breadcrumb: string;
  introAnswer: string;
  tldr: string[];
  heroSubtitle: string;
  featureCards: { title: string; desc: string; icon: string }[];
  caseStudies: { name: string; industry: string; result: string; icon: string }[];
  roiTitle: string;
  roiDesc: string;
  roiMetrics: { label: string; value: string }[];
  contactTitle: string;
  contactDesc: string;
