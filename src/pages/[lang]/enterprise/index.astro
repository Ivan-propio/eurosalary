      { name: 'AlpineHR Consulting', industry: 'HR Consulting (serving 120+ enterprise clients)', result: 'White-labelled EuroSalary reports as part of their advisory offering, generating an additional 340K in annual recurring revenue.', icon: 'business' },
      { name: 'MedEuropa Healthcare', industry: 'Healthcare (15,000 employees, 6 EU countries)', result: 'Integrated the custom API into their SAP SuccessFactors instance, automating pay band updates for 200+ job families across all operating countries.', icon: 'local_hospital' },
