// --------------- getStaticPaths ---------------
export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
    props: { lang },
  }));
}

// --------------- Page data ---------------
const { lang } = Astro.params;
const t = fb(i18n, lang) || i18n.en;
const ui = useTranslations(lang as any);

const pageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: t.h1,
    author: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
    publisher: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
    datePublished: '2026-04-04',
    dateModified: '2026-04-04',
    description: t.metaDesc,
    mainEntityOfPage: `https://eurosalary.eu/${lang}/enterprise/`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: t.faq.map((item: any) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  },
];
---

<BaseLayout
  title={t.metaTitle}
  description={t.metaDesc}
  datePublished="2026-04-04"
  dateModified="2026-04-04"
  schema={pageSchema}
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="page-hero__dots"></div>
    <div class="container page-hero__inner">
      <nav class="page-hero__breadcrumbs" aria-label="Breadcrumb">
        <a href={`/${lang}/`}>{t.home}</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <span class="page-hero__breadcrumbs-current">{t.breadcrumb}</span>
      </nav>
      <div class="page-hero__grid">
        <div class="page-hero__content">
          <h1 class="page-hero__title">{t.h1}</h1>
          <p class="page-hero__desc">{t.introAnswer}</p>
        </div>
        <div class="page-hero__side">
          <div class="page-hero__card">
            <span class="page-hero__card-label"><span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;margin-right:4px;">corporate_fare</span> Enterprise Solutions</span>
            <p class="page-hero__card-item">White-label & Custom API</p>
            <p class="page-hero__card-item">99.9% SLA Guarantee</p>
          </div>
        </div>
      </div>
      <p class="hero-subtitle">{t.heroSubtitle}</p>
    </div>
  </section>

  <article class="container page-body">
    <TLDRBox items={t.tldr} />

    <!-- Feature Cards -->
    <section class="section features-section">
      <div class="features-grid">
        {t.featureCards.map((card) => (
          <div class="feature-card">
            <div class="feature-card__icon">
              <span class="material-symbols-outlined">{card.icon}</span>
            </div>
            <h2 class="feature-card__title">{card.title}</h2>
            <p class="feature-card__desc">{card.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Case Studies -->
    <section class="section case-studies-section">
      <h2 class="section-title">Enterprise Case Studies</h2>
      <div class="case-studies-grid">
        {t.caseStudies.map((cs) => (
          <div class="case-study-card">
            <div class="case-study-card__logo">
              <span class="material-symbols-outlined">{cs.icon}</span>
            </div>
            <h3 class="case-study-card__name">{cs.name}</h3>
            <p class="case-study-card__industry">{cs.industry}</p>
            <p class="case-study-card__result">{cs.result}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ROI Calculator -->
    <section class="section roi-section">
      <h2 class="section-title">{t.roiTitle}</h2>
