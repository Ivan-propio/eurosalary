---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'es';
const t = useTranslations(lang);

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'EuroSalary.eu',
    url: 'https://eurosalary.eu',
    description: 'La plataforma definitiva de comparación salarial europea. Compara salarios en 27 países de la UE.',
    potentialAction: {
      '@type': 'SearchAction',
      target: 'https://eurosalary.eu/es/salary/{search_term_string}',
      'query-input': 'required name=search_term_string',
    },
  },
];

const featuredSalaries = [
  { job: 'Ingeniero de software', country: 'Alemania', salary: '€72.000', flag: '🇩🇪' },
  { job: 'Product Manager', country: 'Países Bajos', salary: '€68.000', flag: '🇳🇱' },
  { job: 'Data Scientist', country: 'Francia', salary: '€55.000', flag: '🇫🇷' },
  { job: 'Enfermero/a', country: 'Bélgica', salary: '€42.000', flag: '🇧🇪' },
  { job: 'Director de marketing', country: 'España', salary: '€38.000', flag: '🇪🇸' },
  { job: 'Analista financiero', country: 'Luxemburgo', salary: '€78.000', flag: '🇱🇺' },
];
---

<BaseLayout
  title="Salarios promedio en Europa (2026) — Compara en 27 países"
  description="Compara salarios promedio en Europa. Datos verificados de Eurostat, ofertas de empleo e informes anónimos. Actualizado mensualmente en 2026."
  schema={schema}
>
  <section class="hero">
    <div class="container">
      <h1>{t('home.title')}</h1>
      <p>{t('home.subtitle')}</p>
      <form class="hero__search" action={`/${lang}/salary/`} method="get">
        <input type="text" name="q" placeholder={t('home.searchPlaceholder')} autocomplete="off" />
        <button type="submit">{t('home.searchButton')}</button>
      </form>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="stats-bar">
        <div class="stat-item">
          <div class="stat-item__value">200+</div>
          <div class="stat-item__label">{t('stats.jobs')}</div>
        </div>
        <div class="stat-item">
          <div class="stat-item__value">27</div>
          <div class="stat-item__label">{t('stats.countries')}</div>
        </div>
        <div class="stat-item">
          <div class="stat-item__value">50K+</div>
          <div class="stat-item__label">{t('stats.dataPoints')}</div>
        </div>
        <div class="stat-item">
          <div class="stat-item__value">Mensual</div>
          <div class="stat-item__label">{t('stats.updated')}</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--light">
    <div class="container">
      <h2 style="text-align: center; margin-bottom: var(--space-8);">{t('home.featuredTitle')}</h2>
      <div class="featured-grid">
        {featuredSalaries.map((item) => (
          <div class="card">
            <div class="featured-card__flag">{item.flag}</div>
            <h3 class="featured-card__job">{item.job}</h3>
            <p class="featured-card__country">{item.country}</p>
            <p class="featured-card__salary">{item.salary}<span>/año</span></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 style="text-align: center; margin-bottom: var(--space-8);">{t('home.howItWorks')}</h2>
      <div class="how-grid">
        <div class="how-step">
          <div class="how-step__number">1</div>
          <h3>Datos oficiales</h3>
          <p>Agregamos datos salariales de Eurostat, OCDE y oficinas de estadística nacionales de los 27 estados miembros de la UE.</p>
        </div>
        <div class="how-step">
          <div class="how-step__number">2</div>
          <h3>Ofertas de empleo</h3>
          <p>Analizamos miles de ofertas verificadas de Indeed, StepStone y LinkedIn para seguir rangos salariales en tiempo real.</p>
        </div>
        <div class="how-step">
          <div class="how-step__number">3</div>
          <h3>Informes anónimos</h3>
          <p>Profesionales de toda Europa envían sus salarios de forma anónima, añadiendo datos verificados por nuestros algoritmos.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container" style="text-align: center;">
      <h2>{t('newsletter.title')}</h2>
      <p style="color: var(--color-gray-300); margin: var(--space-4) auto var(--space-6); max-width: 500px;">
        {t('newsletter.subtitle')}
      </p>
      <form class="newsletter-form" action="/api/newsletter" method="post">
        <input type="hidden" name="language" value={lang} />
        <input type="email" name="email" placeholder={t('newsletter.emailPlaceholder')} required class="form-input" />
        <button type="submit" class="btn btn--primary btn--lg">{t('newsletter.subscribe')}</button>
      </form>
      <p style="font-size: var(--text-xs); color: var(--color-gray-400); margin-top: var(--space-3);">
        {t('newsletter.privacy')}
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .featured-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  .featured-card__flag { font-size: var(--text-3xl); margin-bottom: var(--space-3); }
  .featured-card__job { font-size: var(--text-lg); font-weight: var(--weight-semibold); margin-bottom: var(--space-1); }
  .featured-card__country { font-size: var(--text-sm); color: var(--color-gray-500); margin-bottom: var(--space-3); }
  .featured-card__salary { font-size: var(--text-2xl); font-weight: var(--weight-bold); color: var(--color-blue-600); }
  .featured-card__salary span { font-size: var(--text-sm); font-weight: var(--weight-normal); color: var(--color-gray-500); }
  .how-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-8); }
  .how-step { text-align: center; }
  .how-step__number { width: 48px; height: 48px; border-radius: var(--radius-full); background: var(--color-blue-600); color: var(--color-white); font-size: var(--text-xl); font-weight: var(--weight-bold); display: flex; align-items: center; justify-content: center; margin: 0 auto var(--space-4); }
  .how-step h3 { margin-bottom: var(--space-2); }
  .how-step p { font-size: var(--text-sm); color: var(--color-gray-600); }
  .newsletter-form { display: flex; gap: var(--space-3); max-width: 480px; margin: 0 auto; }
  .newsletter-form .form-input { flex: 1; }
  @media (max-width: 768px) { .featured-grid { grid-template-columns: 1fr; } .how-grid { grid-template-columns: 1fr; gap: var(--space-6); } .newsletter-form { flex-direction: column; } }
</style>
