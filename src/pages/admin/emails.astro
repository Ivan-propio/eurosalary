  .icon-btn { background:none; border:1px solid var(--border); color:var(--text-3); width:32px; height:32px; border-radius:var(--r-sm); cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all .12s; }
  .icon-btn:hover { border-color:var(--border-h); color:var(--text); background:var(--bg-hover); }
  .icon-btn .material-symbols-outlined { font-size:16px; }

  /* Content */
  .content { flex:1; overflow-y:auto; padding:24px 28px 60px; }
