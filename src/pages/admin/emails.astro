  /* Badges — identical */
  .b { display:inline-flex; align-items:center; padding:2px 8px; border-radius:4px; font-size:.625rem; font-weight:600; text-transform:uppercase; letter-spacing:.03em; white-space:nowrap; line-height:1.5; }
