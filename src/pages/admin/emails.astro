---
// Admin Email Engine — Unified design system with main admin dashboard
// Manages: Workflows (sequences), Campaigns (newsletters), Analytics, Subscribers, Settings
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>EuroSalary — Email Engine</title>
  <link rel="icon" type="image/svg+xml" href="/favicon-admin.svg" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />
</head>
<body>

<!-- Login -->
<div id="login-screen">
  <div class="login-box">
    <div class="login-logo">
      <svg width="28" height="28" viewBox="0 0 120 120"><g stroke-linejoin="round" transform="translate(0 5)"><polygon points="40.95,59 60,70 60,92 40.95,103 21.9,92 21.9,70" fill="none" stroke="#4D8FFF" stroke-width="3.5"/><polygon points="79.05,59 98.1,70 98.1,92 79.05,103 60,92 60,70" fill="#4D8FFF"/><polygon points="60,26 79.05,37 79.05,59 60,70 40.95,59 40.95,37" fill="#FFCC00"/></g></svg>
      <span>EuroSalary</span>
    </div>
    <p class="login-sub">Email Engine</p>
    <input type="password" id="pwd-input" placeholder="Password" autofocus />
    <button id="login-btn">Sign in</button>
    <p id="login-error"></p>
  </div>
</div>

<!-- Dashboard -->
<div id="dashboard" style="display:none">
  <div class="sidebar-overlay" id="sidebar-overlay"></div>

  <!-- Sidebar — identical structure to main admin -->
  <aside class="sidebar" id="sidebar">
    <div class="sb-head">
      <img src="/favicon.svg" alt="" width="28" height="28" class="sb-icon" />
      <span class="sb-brand">Email Engine</span>
    </div>
    <nav class="sb-nav" id="sidebar-nav">
      <a href="/admin/" class="sb-item sb-back">
        <span class="material-symbols-outlined">arrow_back</span>Back to Admin
      </a>
      <div class="sb-sep"></div>
      <button class="sb-item active" data-section="workflows">
        <span class="material-symbols-outlined">account_tree</span>Workflows
        <span class="sb-count" id="nav-count-workflows"></span>
      </button>
      <button class="sb-item" data-section="campaigns">
        <span class="material-symbols-outlined">campaign</span>Campaigns
        <span class="sb-count" id="nav-count-campaigns"></span>
      </button>
      <div class="sb-sep"></div>
      <button class="sb-item" data-section="analytics">
        <span class="material-symbols-outlined">monitoring</span>Analytics
      </button>
      <button class="sb-item" data-section="subscribers">
        <span class="material-symbols-outlined">people</span>Subscribers
      </button>
      <div class="sb-sep"></div>
      <button class="sb-item" data-section="settings">
        <span class="material-symbols-outlined">tune</span>Settings
      </button>
    </nav>
    <div class="sb-foot">
      <a href="https://eurosalary.eu" target="_blank" class="sb-link">
        <span class="material-symbols-outlined">open_in_new</span>View site
      </a>
      <button class="sb-link" id="logout-btn" style="border:none;background:none;cursor:pointer;width:100%;text-align:left">
        <span class="material-symbols-outlined">logout</span>Sign out
      </button>
    </div>
  </aside>

  <!-- Main -->
  <div class="main">
    <header class="topbar">
      <div class="topbar-l">
        <button class="hamburger" id="hamburger"><span class="material-symbols-outlined">menu</span></button>
        <h2 class="topbar-title" id="topbar-title">Workflows</h2>
      </div>
      <div class="topbar-r">
        <span id="last-refresh" class="meta-text"></span>
        <button class="icon-btn" id="refresh-btn" title="Refresh"><span class="material-symbols-outlined">refresh</span></button>
      </div>
    </header>

    <div class="content">

      <!-- ═══════ WORKFLOWS ═══════ -->
      <section class="panel active" id="sec-workflows">
        <div id="wf-list-view">
          <div class="sec-head">
            <div class="sec-head-row">
              <div>
                <h1 class="sec-title">Workflows</h1>
                <p class="sec-desc">Automated email sequences triggered by user actions</p>
              </div>
              <button class="btn-primary" id="btn-new-workflow">
                <span class="material-symbols-outlined">add</span> New Workflow
              </button>
            </div>
          </div>
          <div class="card">
            <div class="tbl scroll-y-lg" id="wf-table"></div>
          </div>
        </div>

        <div id="wf-detail-view" style="display:none">
          <div class="sec-head">
            <div class="sec-head-row">
              <div>
                <button class="btn-ghost" id="btn-back-workflows">
                  <span class="material-symbols-outlined">arrow_back</span> Back
                </button>
                <h1 class="sec-title" id="wf-detail-name"></h1>
                <p class="sec-desc" id="wf-detail-meta"></p>
              </div>
              <div class="btn-group">
                <button class="btn-outline" id="btn-toggle-wf">
                  <span class="material-symbols-outlined">pause</span> <span id="btn-toggle-wf-label">Pause</span>
                </button>
                <button class="btn-outline btn-danger" id="btn-delete-wf">
                  <span class="material-symbols-outlined">delete</span> Delete
                </button>
              </div>
            </div>
          </div>
          <div class="kpi-row kpi-4" id="wf-kpis"></div>
          <div class="sec-head-row" style="margin:16px 0 10px">
            <h3 style="font-size:.8rem;font-weight:600">Steps</h3>
            <button class="btn-primary btn-sm" id="btn-add-step">
              <span class="material-symbols-outlined">add</span> Add Step
            </button>
          </div>
          <div id="wf-steps-list"></div>
        </div>
      </section>

      <!-- ═══════ CAMPAIGNS ═══════ -->
      <section class="panel" id="sec-campaigns">
        <div id="camp-list-view">
          <div class="sec-head">
            <div class="sec-head-row">
              <div>
                <h1 class="sec-title">Campaigns</h1>
                <p class="sec-desc">Newsletters, one-time blasts, recurring sends</p>
              </div>
              <button class="btn-primary" id="btn-new-campaign">
                <span class="material-symbols-outlined">add</span> New Campaign
              </button>
            </div>
          </div>
          <div class="card">
            <div class="tbl scroll-y-lg" id="camp-table"></div>
          </div>
        </div>
        <div id="camp-detail-view" style="display:none">
          <div class="sec-head">
            <div class="sec-head-row">
              <div>
                <button class="btn-ghost" id="btn-back-campaigns">
                  <span class="material-symbols-outlined">arrow_back</span> Back
                </button>
                <h1 class="sec-title" id="camp-detail-name"></h1>
              </div>
              <div class="btn-group">
                <button class="btn-outline" id="btn-toggle-camp">
                  <span class="material-symbols-outlined">pause</span> <span id="btn-toggle-camp-label">Pause</span>
                </button>
                <button class="btn-outline btn-danger" id="btn-delete-camp">
                  <span class="material-symbols-outlined">delete</span> Delete
                </button>
              </div>
            </div>
          </div>
          <div class="card" style="padding:20px" id="camp-editor"></div>
        </div>
      </section>

      <!-- ═══════ ANALYTICS ═══════ -->
      <section class="panel" id="sec-analytics">
        <div class="sec-head">
          <h1 class="sec-title">Analytics</h1>
          <p class="sec-desc">Email performance across all workflows and campaigns</p>
        </div>
        <div class="kpi-row kpi-4" id="analytics-kpis"></div>
        <div class="card">
          <div class="card-h"><h3>Recent Sends</h3></div>
          <div class="tbl scroll-y-lg" id="analytics-table"></div>
        </div>
      </section>

      <!-- ═══════ SUBSCRIBERS ═══════ -->
      <section class="panel" id="sec-subscribers">
        <div class="sec-head">
          <h1 class="sec-title">Subscribers</h1>
          <p class="sec-desc">Leads with email preferences and consent</p>
        </div>
        <div style="margin-bottom:12px">
          <div class="filter-bar" id="subs-filters">
            <button class="f-btn active" data-filter="all">All</button>
            <button class="f-btn" data-filter="subscribed">Subscribed</button>
            <button class="f-btn" data-filter="unsubscribed">Unsubscribed</button>
          </div>
        </div>
        <div class="card">
          <div class="tbl scroll-y-lg" id="subs-table"></div>
        </div>
      </section>

      <!-- ═══════ SETTINGS ═══════ -->
      <section class="panel" id="sec-settings">
        <div class="sec-head">
          <h1 class="sec-title">Settings</h1>
          <p class="sec-desc">Email engine configuration</p>
        </div>
        <div class="card" style="padding:20px">
          <h3 style="font-size:.8rem;font-weight:600;margin-bottom:12px">Brand Tokens</h3>
          <p class="sec-desc" style="margin-bottom:12px">These values are injected into every email. Edit <code>src/data/brand-tokens.json</code> and redeploy.</p>
          <div id="settings-brand"></div>
        </div>
        <div class="card" style="padding:20px;margin-top:12px">
          <h3 style="font-size:.8rem;font-weight:600;margin-bottom:12px">Supported Languages</h3>
          <div style="display:flex;gap:6px">
            <span class="b b-blue">EN</span>
            <span class="b b-blue">FR</span>
            <span class="b b-blue">DE</span>
            <span class="b b-blue">ES</span>
          </div>
          <p class="sec-desc" style="margin-top:8px">All workflows and campaigns support these 4 languages. Each lead receives emails in their preferred language.</p>
        </div>
      </section>

    </div>
  </div>
</div>

<!-- ═══════ MODALS ═══════ -->
<div class="modal-overlay" id="modal-new-wf" style="display:none">
  <div class="modal">
    <div class="modal-head"><h2>New Workflow</h2><button class="modal-x" data-close="modal-new-wf"><span class="material-symbols-outlined">close</span></button></div>
    <div class="modal-body">
      <div class="fg"><label>Name</label><input type="text" id="nwf-name" placeholder="e.g. newsletter_welcome" /></div>
      <div class="fg"><label>Description</label><input type="text" id="nwf-desc" placeholder="Welcome sequence for newsletter subscribers" /></div>
      <div class="fg"><label>Trigger Event</label>
        <select id="nwf-trigger">
          <option value="newsletter_signup">Newsletter Signup</option>
          <option value="report_download">Report Download</option>
          <option value="checkout_started">Checkout Started</option>
          <option value="subscription_created">Subscription Created</option>
          <option value="subscription_cancelled">Subscription Cancelled</option>
          <option value="api_key_created">API Key Created</option>
          <option value="manual">Manual (Outreach)</option>
        </select>
      </div>
      <div class="fg"><label>Target Type</label>
        <select id="nwf-target">
          <option value="general">General</option>
          <option value="employer">Employer</option>
          <option value="recruiter">Recruiter</option>
          <option value="enterprise">Enterprise</option>
          <option value="api_user">API User</option>
          <option value="partner">Partner</option>
        </select>
      </div>
    </div>
    <div class="modal-foot"><button class="btn-outline" data-close="modal-new-wf">Cancel</button><button class="btn-primary" id="btn-create-wf">Create Workflow</button></div>
  </div>
</div>

<div class="modal-overlay" id="modal-new-camp" style="display:none">
  <div class="modal">
    <div class="modal-head"><h2>New Campaign</h2><button class="modal-x" data-close="modal-new-camp"><span class="material-symbols-outlined">close</span></button></div>
    <div class="modal-body">
      <div class="fg"><label>Name</label><input type="text" id="ncamp-name" placeholder="e.g. Weekly Salary Digest" /></div>
      <div class="fg"><label>Description</label><input type="text" id="ncamp-desc" placeholder="Tuesday newsletter with salary trends" /></div>
      <div class="fg"><label>Type</label>
        <select id="ncamp-type">
          <option value="recurring">Recurring</option>
          <option value="one_time">One-time</option>
        </select>
      </div>
      <div class="fg" id="ncamp-cron-group"><label>Schedule</label>
        <select id="ncamp-cron">
          <option value="0 9 * * 2">Every Tuesday 9 AM UTC</option>
          <option value="0 9 * * 1">Every Monday 9 AM UTC</option>
          <option value="0 9 * * 5">Every Friday 9 AM UTC</option>
          <option value="0 9 1 * *">1st of every month 9 AM UTC</option>
        </select>
      </div>
      <div class="fg"><label>Target Segment</label>
        <select id="ncamp-segment">
          <option value="newsletter_subscribers">Newsletter Subscribers</option>
          <option value="all_leads">All Leads (with consent)</option>
          <option value="pro_users">Pro Users</option>
          <option value="churned">Churned Users</option>
        </select>
      </div>
    </div>
    <div class="modal-foot"><button class="btn-outline" data-close="modal-new-camp">Cancel</button><button class="btn-primary" id="btn-create-camp">Create Campaign</button></div>
  </div>
</div>

<!-- Step Editor Modal -->
<div class="modal-overlay" id="modal-step-editor" style="display:none">
  <div class="modal modal-wide">
    <div class="modal-head"><h2 id="step-editor-title">Edit Step</h2><button class="modal-x" data-close="modal-step-editor"><span class="material-symbols-outlined">close</span></button></div>
    <div class="modal-body">
      <div style="display:flex;gap:12px">
        <div class="fg" style="flex:1"><label>Step Order</label><input type="number" id="step-order" min="1" value="1" /></div>
        <div class="fg" style="flex:1"><label>Delay (hours)</label><input type="number" id="step-delay" min="0" value="0" placeholder="0 = immediate" /></div>
      </div>
      <div class="lang-tabs" id="step-lang-tabs">
        <button class="lang-tab active" data-lang="en">EN</button>
        <button class="lang-tab" data-lang="fr">FR</button>
        <button class="lang-tab" data-lang="de">DE</button>
        <button class="lang-tab" data-lang="es">ES</button>
      </div>
      <div id="step-lang-panes">
        <div class="lang-pane active" data-lang="en">
          <div class="fg"><label>Subject <span class="hint">(EN)</span></label><input type="text" class="step-subject" data-lang="en" placeholder="Email subject line..." /></div>
          <div class="fg">
            <div class="editor-bar"><label>Body <span class="hint">(EN)</span></label><div class="mode-toggle"><button class="mode-btn active" data-mode="text" data-lang="en">Text</button><button class="mode-btn" data-mode="html" data-lang="en">&lt;/&gt; HTML</button></div></div>
            <textarea class="step-body" data-lang="en" data-mode="text" rows="14" placeholder={"Write your email content here...\n\nUse **bold**, *italic*, [link text](url)\nVariables: {name}, {company}, {country}, {price}, {product}"}></textarea>
            <div class="editor-help"><strong>Formatting:</strong> <code>**bold**</code> <code>*italic*</code> <code>[link](url)</code> &bull; <strong>Variables:</strong> <code>&#123;name&#125;</code> <code>&#123;company&#125;</code> <code>&#123;country&#125;</code></div>
          </div>
        </div>
        <div class="lang-pane" data-lang="fr">
          <div class="fg"><label>Subject <span class="hint">(FR)</span></label><input type="text" class="step-subject" data-lang="fr" placeholder="Objet de l'email..." /></div>
          <div class="fg"><div class="editor-bar"><label>Body <span class="hint">(FR)</span></label><div class="mode-toggle"><button class="mode-btn active" data-mode="text" data-lang="fr">Text</button><button class="mode-btn" data-mode="html" data-lang="fr">&lt;/&gt; HTML</button></div></div><textarea class="step-body" data-lang="fr" data-mode="text" rows="14" placeholder="Contenu de l'email..."></textarea></div>
        </div>
        <div class="lang-pane" data-lang="de">
          <div class="fg"><label>Subject <span class="hint">(DE)</span></label><input type="text" class="step-subject" data-lang="de" placeholder="Betreff..." /></div>
          <div class="fg"><div class="editor-bar"><label>Body <span class="hint">(DE)</span></label><div class="mode-toggle"><button class="mode-btn active" data-mode="text" data-lang="de">Text</button><button class="mode-btn" data-mode="html" data-lang="de">&lt;/&gt; HTML</button></div></div><textarea class="step-body" data-lang="de" data-mode="text" rows="14" placeholder="E-Mail-Inhalt..."></textarea></div>
        </div>
        <div class="lang-pane" data-lang="es">
          <div class="fg"><label>Subject <span class="hint">(ES)</span></label><input type="text" class="step-subject" data-lang="es" placeholder="Asunto del email..." /></div>
          <div class="fg"><div class="editor-bar"><label>Body <span class="hint">(ES)</span></label><div class="mode-toggle"><button class="mode-btn active" data-mode="text" data-lang="es">Text</button><button class="mode-btn" data-mode="html" data-lang="es">&lt;/&gt; HTML</button></div></div><textarea class="step-body" data-lang="es" data-mode="text" rows="14" placeholder="Contenido del email..."></textarea></div>
        </div>
      </div>
      <details class="preview-details"><summary>Preview Email</summary><div class="preview-frame" id="step-preview"></div></details>
    </div>
    <div class="modal-foot"><button class="btn-outline" data-close="modal-step-editor">Cancel</button><button class="btn-outline" id="btn-step-preview">Preview</button><button class="btn-primary" id="btn-save-step">Save Step</button></div>
  </div>
</div>

<style is:global>
  /* ══════════ UNIFIED DESIGN SYSTEM — matches admin/index.astro exactly ══════════ */
  :root {
    --bg: #09090b; --bg-card: #111113; --bg-surface: #18181b; --bg-hover: #1f1f23;
    --border: #232328; --border-h: #333338;
    --text: #fafafa; --text-2: #a1a1aa; --text-3: #71717a; --text-4: #52525b;
    --blue: #3b82f6; --blue-d: rgba(59,130,246,.14);
    --purple: #8b5cf6; --purple-d: rgba(139,92,246,.14);
    --amber: #f59e0b; --amber-d: rgba(245,158,11,.14);
    --green: #10b981; --green-d: rgba(16,185,129,.14);
    --rose: #f43f5e; --rose-d: rgba(244,63,94,.14);
    --teal: #14b8a6; --teal-d: rgba(20,184,166,.14);
    --cyan: #06b6d4; --cyan-d: rgba(6,182,212,.14);
    --sidebar-w: 220px; --topbar-h: 52px; --r: 10px; --r-sm: 6px;
    --mono: 'JetBrains Mono', 'SF Mono', monospace;
  }
  * { margin:0; padding:0; box-sizing:border-box; scrollbar-width:thin; scrollbar-color:var(--border) transparent; }
  body { font-family:'Inter',system-ui,sans-serif; background:var(--bg); color:var(--text); min-height:100vh; overflow:hidden; font-size:13px; -webkit-font-smoothing:antialiased; }
  :focus-visible { outline:2px solid var(--blue); outline-offset:2px; }
  :focus:not(:focus-visible) { outline:none; }

  /* Login — identical to main admin */
  #login-screen { display:flex; align-items:center; justify-content:center; min-height:100vh; }
  .login-box { background:var(--bg-card); border:1px solid var(--border); border-radius:14px; padding:2.5rem 2rem; width:360px; text-align:center; box-shadow:0 20px 50px rgba(0,0,0,.5); }
  .login-logo { display:flex; align-items:center; justify-content:center; gap:8px; font-size:1.4rem; font-weight:800; letter-spacing:-.02em; }
  .login-sub { color:var(--text-4); font-size:.8rem; margin:4px 0 1.5rem; }
  .login-box input { width:100%; padding:10px 14px; border:1px solid var(--border); border-radius:var(--r-sm); background:var(--bg); color:var(--text); font-size:.85rem; margin-bottom:.75rem; outline:none; font-family:inherit; transition:border-color .15s; }
  .login-box input:focus { border-color:var(--blue); }
  .login-box button { width:100%; padding:10px; background:var(--blue); color:#fff; border:none; border-radius:var(--r-sm); font-size:.85rem; font-weight:600; cursor:pointer; font-family:inherit; }
  .login-box button:hover { background:#2563eb; }
  #login-error { color:var(--rose); font-size:.75rem; margin-top:.5rem; min-height:1em; }

  /* Sidebar — identical to main admin */
  .sidebar { position:fixed; top:0; left:0; width:var(--sidebar-w); height:100vh; background:var(--bg-card); border-right:1px solid var(--border); display:flex; flex-direction:column; z-index:100; transition:transform .2s ease; }
  .sb-head { padding:14px 16px; display:flex; align-items:center; gap:8px; border-bottom:1px solid var(--border); }
  .sb-icon { width:28px; height:28px; border-radius:6px; }
  .sb-brand { font-weight:700; font-size:.85rem; flex:1; }
  .sb-nav { flex:1; padding:8px 6px; overflow-y:auto; display:flex; flex-direction:column; gap:1px; }
  .sb-item { display:flex; align-items:center; gap:8px; padding:8px 10px; border:none; background:none; color:var(--text-3); font-size:.8rem; font-weight:500; border-radius:var(--r-sm); cursor:pointer; width:100%; text-align:left; transition:all .12s; font-family:inherit; text-decoration:none; }
  .sb-item:hover { background:var(--bg-hover); color:var(--text-2); }
  .sb-item.active { background:var(--blue-d); color:var(--blue); font-weight:600; }
  .sb-item .material-symbols-outlined { font-size:18px; }
  .sb-back { color:var(--text-4); font-weight:500; }
  .sb-back:hover { color:var(--text-2); background:var(--bg-hover); }
  .sb-count { margin-left:auto; font-size:.65rem; background:var(--border); padding:1px 6px; border-radius:8px; color:var(--text-3); }
  .sb-sep { height:1px; background:var(--border); margin:6px 10px; }
  .sb-foot { padding:10px 12px; border-top:1px solid var(--border); display:flex; flex-direction:column; gap:2px; }
  .sb-link { display:flex; align-items:center; gap:6px; color:var(--text-4); font-size:.75rem; text-decoration:none; padding:5px 4px; font-family:inherit; }
  .sb-link:hover { color:var(--text-3); }
  .sb-link .material-symbols-outlined { font-size:15px; }
  .sidebar-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.6); z-index:90; backdrop-filter:blur(2px); }

  /* Main */
  .main { margin-left:var(--sidebar-w); height:100vh; display:flex; flex-direction:column; }

  /* Topbar — identical */
  .topbar { height:var(--topbar-h); border-bottom:1px solid var(--border); padding:0 24px; display:flex; align-items:center; justify-content:space-between; background:var(--bg-card); flex-shrink:0; }
  .topbar-l { display:flex; align-items:center; gap:10px; }
  .topbar-r { display:flex; align-items:center; gap:8px; }
  .topbar-title { font-size:1rem; font-weight:600; }
  .hamburger { display:none; background:none; border:none; color:var(--text-3); cursor:pointer; }
  .hamburger .material-symbols-outlined { font-size:22px; }
