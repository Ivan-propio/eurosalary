  /* KPI Row */
  .kpi-row { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:16px; margin-bottom:20px; max-width:1400px; }
  .kpi-4 { grid-template-columns:repeat(4,1fr); }
  .kpi { background:var(--bg-card); border:1px solid var(--border); border-radius:var(--r); padding:18px 20px; transition:border-color .15s; }
