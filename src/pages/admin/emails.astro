  /* Cards */
  .card { background:var(--bg-card); border:1px solid var(--border); border-radius:var(--r); margin-bottom:16px; overflow:hidden; transition:border-color .15s; }
  .card:hover { border-color:var(--border-h); }
  .card-h { padding:14px 20px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; gap:12px; }
  .card-h h3 { font-size:.8125rem; font-weight:600; letter-spacing:-.01em; }

  /* Tables — identical */
  .tbl { overflow-x:auto; }
  .scroll-y-lg { max-height:520px; overflow-y:auto; }
  table { width:100%; border-collapse:collapse; }
  th { text-align:left; padding:10px 16px; background:var(--bg-surface); color:var(--text-3); font-size:.6875rem; font-weight:600; text-transform:uppercase; letter-spacing:.05em; border-bottom:1px solid var(--border); position:sticky; top:0; z-index:2; white-space:nowrap; box-shadow:0 1px 0 var(--border); }
  td { padding:10px 16px; border-bottom:1px solid var(--border); font-size:.78rem; color:var(--text-2); white-space:nowrap; }
  tr { transition:background .08s; }
  tbody tr:nth-child(even) { background:rgba(255,255,255,.015); }
  tr:hover { background:var(--bg-hover); }
  td:first-child { color:var(--text); font-weight:500; }
