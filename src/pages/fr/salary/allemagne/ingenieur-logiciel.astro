---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import TLDRBox from '../../../../components/TLDRBox.astro';
import SalaryTable from '../../../../components/SalaryTable.astro';
import FAQSection from '../../../../components/FAQSection.astro';
import CountryCompare from '../../../../components/CountryCompare.astro';
import JobAffiliateCTA from '../../../../components/JobAffiliateCTA.astro';
import SalaryForm from '../../../../components/SalaryForm.astro';

const lang = 'fr';
const jobName = 'Ingénieur logiciel';
const jobSlug = 'software-engineer';
const countryName = 'Allemagne';
const countrySlug = 'allemagne';
const countryCode = 'DE';

const salaryRows = [
  { level: 'junior', min: 42000, median: 48000, max: 55000, netEstimate: 30000 },
  { level: 'mid', min: 55000, median: 65000, max: 78000, netEstimate: 40000 },
  { level: 'senior', min: 75000, median: 85000, max: 100000, netEstimate: 52000 },
  { level: 'lead', min: 90000, median: 105000, max: 130000, netEstimate: 62000 },
];

const compareCountries = [
  { countryName: 'France', countrySlug: 'france', countryCode: 'FR', flag: '🇫🇷', medianSalary: 52000 },
  { countryName: 'Pays-Bas', countrySlug: 'pays-bas', countryCode: 'NL', flag: '🇳🇱', medianSalary: 62000 },
  { countryName: 'Espagne', countrySlug: 'espagne', countryCode: 'ES', flag: '🇪🇸', medianSalary: 40000 },
  { countryName: 'Irlande', countrySlug: 'irlande', countryCode: 'IE', flag: '🇮🇪', medianSalary: 68000 },
  { countryName: 'Luxembourg', countrySlug: 'luxembourg', countryCode: 'LU', flag: '🇱🇺', medianSalary: 75000 },
  { countryName: 'Autriche', countrySlug: 'autriche', countryCode: 'AT', flag: '🇦🇹', medianSalary: 58000 },
];

const faqItems = [
  {
    question: 'Quel est le salaire moyen d\'un ingénieur logiciel en Allemagne en 2026 ?',
    answer: 'Le salaire brut médian d\'un ingénieur logiciel en Allemagne est de 65 000 € par an pour un profil intermédiaire. Les juniors gagnent environ 48 000 €, tandis que les seniors peuvent atteindre 85 000 € ou plus. Ces chiffres sont basés sur les données Eurostat et les offres d\'emploi vérifiées.',
  },
  {
    question: 'Combien gagne un ingénieur logiciel après impôts en Allemagne ?',
    answer: 'Un ingénieur logiciel de niveau intermédiaire gagnant 65 000 € brut en Allemagne touche environ 40 000 € net par an. L\'Allemagne applique un impôt progressif (14-45 %), plus la surtaxe de solidarité (5,5 %) et les cotisations sociales (~20 %).',
  },
  {
    question: 'Quels facteurs influencent le salaire d\'un ingénieur logiciel en Allemagne ?',
    answer: 'Les principaux facteurs sont : la ville (Munich et Francfort paient 15-20 % au-dessus de la moyenne), la taille de l\'entreprise, les langages de programmation (Go, Rust et Scala offrent des primes), le secteur d\'activité et les années d\'expérience.',
  },
  {
    question: 'Quelles villes allemandes paient le mieux les ingénieurs logiciels ?',
    answer: 'Munich est en tête avec des salaires médians 15-20 % au-dessus de la moyenne nationale, suivie de Francfort (+12 %), Stuttgart (+10 %), Hambourg (+8 %) et Berlin (+5 %).',
  },
  {
    question: 'Comment le salaire d\'ingénieur logiciel en Allemagne se compare-t-il aux autres pays de l\'UE ?',
    answer: 'L\'Allemagne se classe dans le top 5 de l\'UE. Le Luxembourg (75 000 €) et l\'Irlande (68 000 €) paient plus, tandis que les Pays-Bas (62 000 €) sont proches. La France (52 000 €) et l\'Espagne (40 000 €) sont significativement en dessous.',
  },
];

const pageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: 'Quel est le salaire moyen d\'un ingénieur logiciel en Allemagne en 2026 ?',
    author: { '@type': 'Organization', name: 'EuroSalary.eu' },
    datePublished: '2026-01-15',
    dateModified: '2026-04-01',
    publisher: { '@type': 'Organization', name: 'EuroSalary.eu', url: 'https://eurosalary.eu' },
  },
];
---

<BaseLayout
  title="Salaire moyen Ingénieur logiciel en Allemagne (2026)"
  description="Le salaire moyen d'un ingénieur logiciel en Allemagne est de 65 000 €/an, allant de 42 000 € (junior) à 130 000 € (lead). Mis à jour avril 2026. Source : Eurostat."
  datePublished="2026-01-15"
  dateModified="2026-04-01"
  schema={pageSchema}
>
  <nav class="breadcrumbs container">
    <a href={`/${lang}/`}>Accueil</a>
    <span class="breadcrumbs__sep">/</span>
    <a href={`/${lang}/salary/`}>Salaires</a>
    <span class="breadcrumbs__sep">/</span>
    <a href={`/${lang}/country/${countrySlug}/`}>{countryName}</a>
    <span class="breadcrumbs__sep">/</span>
    <span>{jobName}</span>
  </nav>

  <article class="salary-page container">
    <h1>Quel est le salaire moyen d'un ingénieur logiciel en Allemagne en 2026 ?</h1>

    <p class="salary-page__answer">
      Le salaire brut moyen d'un ingénieur logiciel en Allemagne est de <strong>65 000 € par an</strong> (niveau intermédiaire).
      Les juniors débutent à 48 000 €, les seniors gagnent 85 000 € et les leads atteignent 105 000 €.
      Après impôts et cotisations sociales, le salaire net est d'environ 40 000 € pour un poste intermédiaire.
    </p>

    <TLDRBox items={[
      'Salaire médian : 65 000 €/an brut (40 000 € net) niveau intermédiaire',
      'Fourchette : 42 000 € (junior) à 130 000 € (lead)',
      'L\'Allemagne se classe 4e dans l\'UE pour les salaires en ingénierie logicielle',
    ]} />

    <section>
      <h2>Grille salariale ingénieur logiciel par niveau d'expérience</h2>
      <SalaryTable rows={salaryRows} />
    </section>

    <CountryCompare job={jobName} jobSlug={jobSlug} items={compareCountries} />

    <JobAffiliateCTA jobName={jobName} countryName={countryName} countryCode={countryCode} />

    <SalaryForm />

    <FAQSection items={faqItems} />
  </article>
</BaseLayout>

<style>
  .salary-page { padding-bottom: var(--space-16); }
  .salary-page h1 { margin-top: var(--space-6); margin-bottom: var(--space-4); }
  .salary-page__answer { font-size: var(--text-lg); line-height: var(--leading-relaxed); color: var(--color-gray-700); margin-bottom: var(--space-6); max-width: 720px; }
</style>
